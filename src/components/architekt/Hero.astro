---
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
---

<section class="av-hero" data-av-hero>
  <!-- Blueprint Grid Background -->
  <div class="av-hero__bp" aria-hidden="true"></div>

  <!-- Top spec bar -->
  <div class="av-hero__spec av-container">
    <span class="av-hero__spec-cell">
      <span class="av-hero__spec-k">FILE</span>
      <span class="av-hero__spec-v">AV-2026.HOME.IDX</span>
    </span>
    <span class="av-hero__spec-cell">
      <span class="av-hero__spec-k">SCALE</span>
      <span class="av-hero__spec-v">1 : 1</span>
    </span>
    <span class="av-hero__spec-cell">
      <span class="av-hero__spec-k">DATE</span>
      <span class="av-hero__spec-v">05.2026</span>
    </span>
    <span class="av-hero__spec-cell">
      <span class="av-hero__spec-k">REV</span>
      <span class="av-hero__spec-v">07</span>
    </span>
    <span class="av-hero__spec-cell av-hero__spec-cell--push">
      <span class="av-hero__spec-dot" aria-hidden="true"></span>
      <span class="av-hero__spec-v">ATELIER OPEN · MO–FR</span>
    </span>
  </div>

  <div class="av-hero__inner av-container">
    <div class="av-hero__copy">
      <div class="av-hero__index">
        <span class="av-hero__index-n">N°</span>
        <span class="av-hero__index-v">01</span>
        <span class="av-hero__index-line" aria-hidden="true"></span>
        <span class="av-hero__index-k">INDEX / HERO</span>
      </div>

      <h1 class="av-hero__headline">
        <span class="av-hero__line">
          <SplitText by="chars" delay={0.1} stagger={0.018} onScroll={false}>RÄUME</SplitText>
        </span>
        <span class="av-hero__line av-hero__line--small">
          <SplitText by="chars" delay={0.3} stagger={0.018} onScroll={false}>mit</SplitText>
        </span>
        <span class="av-hero__line">
          <SplitText by="chars" delay={0.45} stagger={0.018} onScroll={false}>HALTUNG.</SplitText>
        </span>
      </h1>

      <div class="av-hero__caption">
        <span class="av-hero__caption-tag" aria-hidden="true"></span>
        <p>
          ARCHITEKTURBÜRO MIT SITZ IN LÜDENSCHEID — NEUBAU, SANIERUNG UND
          INNENARCHITEKTUR IM SAUERLAND UND BERGISCHEN LAND, SEIT 1998.
        </p>
      </div>

      <div class="av-hero__actions">
        <MagneticButton href="/demos/architekt/kontakt/" strength={0.35} variant="primary" class="av-hero__cta">
          <span>ERSTGESPRÄCH ANFRAGEN</span>
          <span aria-hidden="true">→</span>
        </MagneticButton>
        <a href="/demos/architekt/projekte/" class="av-hero__link">
          <span>Projektarchiv</span>
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
        </a>
      </div>

      <table class="av-hero__data">
        <tbody>
          <tr>
            <th>PROJEKTE</th>
            <td>184</td>
            <td class="av-hero__data-unit">REALISIERT</td>
          </tr>
          <tr>
            <th>JAHRE</th>
            <td>27</td>
            <td class="av-hero__data-unit">SEIT GRÜNDUNG</td>
          </tr>
          <tr>
            <th>TEAM</th>
            <td>07</td>
            <td class="av-hero__data-unit">ARCHITEKT:INNEN</td>
          </tr>
          <tr>
            <th>RADIUS</th>
            <td>100</td>
            <td class="av-hero__data-unit">KM AB LÜDENSCHEID</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Plansatz-Visual -->
    <figure class="av-hero__plan" data-av-hero-plan>
      <div class="av-hero__plan-rule" data-rule="top">
        <span>N°142 — WOHNHAUS HAGEN-HOHENLIMBURG</span>
      </div>

      <svg class="av-hero__svg" viewBox="0 0 540 700" role="img" aria-label="Architektonischer Schnitt eines Neubaus mit Maßlinien">
        <!-- Maßlinien oben -->
        <g stroke="currentColor" stroke-width="0.6" opacity="0.6" fill="none">
          <line x1="80" y1="80" x2="460" y2="80" />
          <line x1="80" y1="74" x2="80" y2="86" />
          <line x1="270" y1="74" x2="270" y2="86" />
          <line x1="460" y1="74" x2="460" y2="86" />
        </g>
        <text x="175" y="68" font-family="JetBrains Mono, monospace" font-size="9" font-weight="500" fill="currentColor" text-anchor="middle" letter-spacing="0.5">9840</text>
        <text x="365" y="68" font-family="JetBrains Mono, monospace" font-size="9" font-weight="500" fill="currentColor" text-anchor="middle" letter-spacing="0.5">9840</text>

        <!-- Boden mit Schraffur -->
        <line x1="40" y1="590" x2="500" y2="590" stroke="currentColor" stroke-width="1.4" />
        <g stroke="currentColor" stroke-width="0.4" opacity="0.5">
          <line x1="40" y1="590" x2="30" y2="610" />
          <line x1="70" y1="590" x2="60" y2="610" />
          <line x1="100" y1="590" x2="90" y2="610" />
          <line x1="130" y1="590" x2="120" y2="610" />
          <line x1="160" y1="590" x2="150" y2="610" />
          <line x1="190" y1="590" x2="180" y2="610" />
          <line x1="220" y1="590" x2="210" y2="610" />
          <line x1="250" y1="590" x2="240" y2="610" />
          <line x1="280" y1="590" x2="270" y2="610" />
          <line x1="310" y1="590" x2="300" y2="610" />
          <line x1="340" y1="590" x2="330" y2="610" />
          <line x1="370" y1="590" x2="360" y2="610" />
          <line x1="400" y1="590" x2="390" y2="610" />
          <line x1="430" y1="590" x2="420" y2="610" />
          <line x1="460" y1="590" x2="450" y2="610" />
          <line x1="490" y1="590" x2="480" y2="610" />
        </g>

        <!-- Haus-Hüllkurve -->
        <path
          d="M 100 590 L 100 320 L 270 130 L 440 320 L 440 590 Z"
          fill="color-mix(in srgb, var(--color-accent) 8%, transparent)"
          stroke="currentColor"
          stroke-width="1.6"
        />

        <!-- Geschoss-Decke -->
        <line x1="100" y1="450" x2="440" y2="450" stroke="currentColor" stroke-width="1" opacity="0.7" />

        <!-- Großes Fenster EG -->
        <rect x="130" y="475" width="110" height="115" fill="color-mix(in srgb, var(--color-accent) 18%, transparent)" stroke="currentColor" stroke-width="1.2" />
        <line x1="185" y1="475" x2="185" y2="590" stroke="currentColor" stroke-width="0.7" />
        <line x1="130" y1="532" x2="240" y2="532" stroke="currentColor" stroke-width="0.7" />

        <!-- Tür -->
        <rect x="270" y="485" width="55" height="105" fill="none" stroke="currentColor" stroke-width="1.2" />
        <circle cx="318" cy="538" r="2" fill="currentColor" />

        <!-- Fenster OG -->
        <rect x="140" y="370" width="60" height="65" fill="color-mix(in srgb, var(--color-accent) 14%, transparent)" stroke="currentColor" stroke-width="1.1" />
        <line x1="170" y1="370" x2="170" y2="435" stroke="currentColor" stroke-width="0.5" />
        <rect x="245" y="370" width="60" height="65" fill="color-mix(in srgb, var(--color-accent) 14%, transparent)" stroke="currentColor" stroke-width="1.1" />
        <line x1="275" y1="370" x2="275" y2="435" stroke="currentColor" stroke-width="0.5" />
        <rect x="350" y="370" width="60" height="65" fill="color-mix(in srgb, var(--color-accent) 14%, transparent)" stroke="currentColor" stroke-width="1.1" />
        <line x1="380" y1="370" x2="380" y2="435" stroke="currentColor" stroke-width="0.5" />

        <!-- Mittelachse -->
        <line x1="270" y1="130" x2="270" y2="590" stroke="currentColor" stroke-width="0.4" stroke-dasharray="6 4" opacity="0.45" />
        <circle cx="270" cy="130" r="2" fill="currentColor" opacity="0.6"/>
        <circle cx="270" cy="590" r="2" fill="currentColor" opacity="0.6"/>

        <!-- Personen-Silhouette zur Skala -->
        <g fill="currentColor" opacity="0.5">
          <circle cx="350" cy="555" r="4" />
          <rect x="346" y="560" width="8" height="30" />
        </g>
        <text x="362" y="580" font-family="JetBrains Mono, monospace" font-size="8" fill="currentColor" opacity="0.5">1.80m</text>

        <!-- Maßlinie rechts -->
        <g stroke="currentColor" stroke-width="0.6" opacity="0.6" fill="none">
          <line x1="480" y1="130" x2="480" y2="590" />
          <line x1="474" y1="130" x2="486" y2="130" />
          <line x1="474" y1="590" x2="486" y2="590" />
        </g>
        <text x="492" y="365" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" letter-spacing="0.5" transform="rotate(90 492 365)">7920</text>

        <!-- Sonnen-Vektor -->
        <g stroke="var(--color-accent)" stroke-width="1.5" fill="none">
          <circle cx="430" cy="160" r="14" fill="none" />
          <line x1="430" y1="160" x2="385" y2="205" />
          <polygon points="385,205 393,199 391,211" fill="var(--color-accent)" stroke="none" />
        </g>
        <text x="430" y="135" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="var(--color-accent)" text-anchor="middle" letter-spacing="0.5">SW</text>
      </svg>

      <div class="av-hero__plan-rule" data-rule="bottom">
        <span>SCHNITT A-A · M 1 : 100</span>
        <span class="av-hero__plan-rule-id">142.S.01</span>
      </div>
    </figure>
  </div>

  <!-- Sliding strip -->
  <div class="av-hero__strip" aria-hidden="true">
    <div class="av-hero__strip-track">
      <span>HOAI 1–9</span><span>+</span>
      <span>NEUBAU</span><span>+</span>
      <span>SANIERUNG</span><span>+</span>
      <span>INNENARCHITEKTUR</span><span>+</span>
      <span>DENKMAL</span><span>+</span>
      <span>KFW-FÖRDERUNG</span><span>+</span>
      <span>LÜDENSCHEID NRW</span><span>+</span>
      <span>HOAI 1–9</span><span>+</span>
      <span>NEUBAU</span><span>+</span>
      <span>SANIERUNG</span><span>+</span>
      <span>INNENARCHITEKTUR</span><span>+</span>
      <span>DENKMAL</span><span>+</span>
      <span>KFW-FÖRDERUNG</span><span>+</span>
      <span>LÜDENSCHEID NRW</span><span>+</span>
    </div>
  </div>
</section>

<style>
  .av-hero {
    position: relative;
    min-height: 100svh;
    padding-block: 0 0;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-bg);
  }

  /* Blueprint grid */
  .av-hero__bp {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--av-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--av-grid-line) 1px, transparent 1px);
    background-size: clamp(40px, 6vw, 72px) clamp(40px, 6vw, 72px);
    background-position: 50% 0%;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 30%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 30%, transparent 90%);
    z-index: 0;
    pointer-events: none;
  }

  /* Spec bar */
  .av-hero__spec {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2rem;
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--color-rule);
    position: relative;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .av-hero__spec-cell {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .av-hero__spec-cell--push { margin-left: auto; }

  .av-hero__spec-k {
    color: var(--color-muted);
    font-weight: 500;
  }

  .av-hero__spec-v {
    color: var(--color-text);
    font-weight: 700;
  }

  .av-hero__spec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
    animation: av-pulse 2.4s ease-in-out infinite;
  }

  @keyframes av-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.8); opacity: 0.6; }
  }

  /* Inner grid */
  .av-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(3rem, 6vw, 5rem);
  }

  @media (min-width: 720px) {
    .av-hero__inner {
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.7fr);
      gap: clamp(1.5rem, 3vw, 3rem);
    }
  }

  /* Copy */
  .av-hero__copy {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .av-hero__index {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .av-hero__index-n {
    color: var(--color-muted);
  }

  .av-hero__index-v {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
  }

  .av-hero__index-line {
    width: clamp(28px, 5vw, 56px);
    height: 1px;
    background: var(--color-rule-strong);
  }

  .av-hero__index-k {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Headline */
  .av-hero__headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 12vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin: 0;
    color: var(--color-text);
    text-transform: uppercase;
    word-break: break-word;
    overflow-wrap: anywhere;
    hyphens: none;
  }

  /* eigene Zeile, mit Reveal-Mask — Padding rechts gibt der Glyph-Schulter Platz */
  .av-hero__line {
    display: block;
    overflow: hidden;
    padding-right: 0.06em;
  }

  .av-hero__line--small {
    font-size: 0.42em;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: var(--color-muted);
    padding-left: 0.5em;
    margin-block: 0.3em;
    line-height: 1;
  }

  /* Caption */
  .av-hero__caption {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 1rem;
    max-width: 56ch;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .av-hero__caption-tag {
    width: 10px;
    height: 10px;
    margin-top: 6px;
    border: 1.5px solid var(--color-accent);
    background:
      linear-gradient(45deg, transparent 47%, var(--color-accent) 47%, var(--color-accent) 53%, transparent 53%);
  }

  .av-hero__caption p {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin: 0;
    font-weight: 500;
  }

  /* Actions */
  .av-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 2rem;
  }

  .av-hero__cta {
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 1.1rem 1.75rem;
  }

  .av-hero__cta:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .av-hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    transition: color 0.3s, gap 0.3s var(--ease-out-expo);
  }

  .av-hero__link svg {
    width: 14px;
    height: 14px;
  }

  .av-hero__link:hover {
    color: var(--color-accent);
    gap: 0.85rem;
  }

  /* Data Table */
  .av-hero__data {
    margin: 0;
    border-collapse: collapse;
    width: 100%;
    max-width: 520px;
    font-family: var(--font-mono);
    border-top: 1px solid var(--color-rule);
  }

  .av-hero__data tr {
    border-bottom: 1px solid var(--color-rule);
  }

  .av-hero__data th,
  .av-hero__data td {
    padding: 0.7rem 0.5rem;
    text-align: left;
    vertical-align: baseline;
  }

  .av-hero__data th {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    width: 7rem;
  }

  .av-hero__data td {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .av-hero__data-unit {
    font-size: 0.68rem !important;
    font-weight: 500 !important;
    letter-spacing: 0.12em !important;
    color: var(--color-muted) !important;
    text-align: right !important;
  }

  /* Plan */
  .av-hero__plan {
    margin: 0;
    position: relative;
    background: color-mix(in srgb, var(--color-bg) 60%, white);
    border: 1px solid var(--color-rule-strong);
    color: var(--color-text);
    will-change: transform;
  }

  .av-hero__plan::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--av-blueprint-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--av-blueprint-grid) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    opacity: 0.6;
  }

  .av-hero__plan-rule {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    font-weight: 700;
    background: var(--color-text);
    color: var(--color-bg);
  }

  .av-hero__plan-rule[data-rule="bottom"] {
    background: var(--color-bg);
    color: var(--color-text);
    border-top: 1px solid var(--color-rule-strong);
  }

  .av-hero__plan-rule-id {
    color: var(--color-accent);
  }

  .av-hero__svg {
    display: block;
    width: 100%;
    height: auto;
    position: relative;
    z-index: 1;
  }

  /* Strip */
  .av-hero__strip {
    position: relative;
    z-index: 2;
    background: var(--color-text);
    color: var(--color-bg);
    border-top: 1px solid var(--color-rule);
    overflow: hidden;
    padding-block: 0.85rem;
  }

  .av-hero__strip-track {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: max-content;
    animation: av-strip 32s linear infinite;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .av-hero__strip-track span:nth-child(even) {
    color: var(--color-accent);
  }

  @keyframes av-strip {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .av-hero__strip-track { animation: none; }
    .av-hero__spec-dot { animation: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function init() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const hero = document.querySelector<HTMLElement>('[data-av-hero]');
    const plan = document.querySelector<HTMLElement>('[data-av-hero-plan]');
    if (!hero || !plan) return;

    gsap.to(plan, {
      yPercent: -8,
      ease: 'none',
      scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.6 },
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
