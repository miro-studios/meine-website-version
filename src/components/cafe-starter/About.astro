---
/**
 * Café Nordlicht — Section 2: Über uns / Was wir tun
 *
 * Editorial 2-Spalten-Layout:
 *  - links:  Eyebrow + Mega-Headline (Split-Text, scroll-getriggert)
 *  - rechts: Fließtext + 3 Stat-Counter (Jahre · Gäste/Woche · Bohnensorten)
 *
 * Pflicht-Effekte:
 *  - Reveal-on-Scroll mit Stagger
 *  - NumberCounter beim In-View-Eintritt
 *  - Pin-Section: linke Headline bleibt sichtbar, während rechts gescrollt wird
 *    (3. unterschiedliche Scroll-Trigger-Animation neben Hero-Parallax und
 *    Section-3-Reveals)
 */
import SplitText from '@components/shared/SplitText.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
---

<section class="cs-about" id="ueber-uns" data-cs-about>
  <div class="cs-about__inner">
    <aside class="cs-about__col-left" data-cs-about-pin>
      <p class="cs-about__eyebrow">
        <span aria-hidden="true">02 ·</span> Über uns
      </p>
      <h2 class="cs-about__headline">
        <SplitText as="span" by="words" stagger={0.06}>
          Klein, aber mit Haltung.
        </SplitText>
      </h2>
      <p class="cs-about__lead">
        Ein Tisch. Eine Espressomaschine. Ein Ofen, der nie ganz auskühlt.
      </p>
    </aside>

    <div class="cs-about__col-right">
      <RevealOnScroll y={36} duration={0.9} stagger={0.12}>
        <p class="cs-about__body">
          Vor sieben Jahren haben wir den alten Tante-Emma-Laden am Knapper Weg
          übernommen, das Holzregal stehen lassen und einen italienischen
          La&nbsp;Marzocco hineingestellt. Seitdem rösten wir unsere Bohnen
          selbst — kleine Chargen, jede Woche frisch — und backen unser
          Sauerteigbrot ab vier Uhr morgens, damit es um halb sieben auf dem
          Tresen liegt.
        </p>

        <p class="cs-about__body">
          Wir glauben an langsames Handwerk und kurze Wege. Mehl aus der
          Wassermühle in Plettenberg, Milch von der Genossenschaft im
          Volmetal, Eier vom Hof Schniedenharn. Was bei uns auf den Tisch
          kommt, hat einen Namen, ein Gesicht und meistens auch eine
          Geschichte.
        </p>

        <p class="cs-about__signature">
          <span class="cs-about__signature-label">— Mira & Jonas</span>
          <span class="cs-about__signature-role">Inhaber & Röster</span>
        </p>
      </RevealOnScroll>

      <ul class="cs-about__stats" role="list">
        <li class="cs-about__stat">
          <span class="cs-about__stat-num">
            <NumberCounter to={7} suffix="" duration={1.6} />
          </span>
          <span class="cs-about__stat-label">Jahre am Knapper Weg</span>
        </li>
        <li class="cs-about__stat">
          <span class="cs-about__stat-num">
            <NumberCounter to={420} duration={2.2} />
          </span>
          <span class="cs-about__stat-label">Gäste pro Woche</span>
        </li>
        <li class="cs-about__stat">
          <span class="cs-about__stat-num">
            <NumberCounter to={11} duration={1.8} />
          </span>
          <span class="cs-about__stat-label">Bohnensorten gerade auf der Karte</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .cs-about {
    background: var(--color-bg);
    color: var(--color-text);
    padding-block: clamp(5rem, 10vw, 9rem);
    padding-inline: var(--cs-gutter);
    border-top: 1px solid var(--color-rule);
    position: relative;
  }

  .cs-about__inner {
    max-width: var(--cs-container);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
  }

  @media (min-width: 900px) {
    .cs-about__inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      align-items: start;
    }
  }

  /* ── Linke Spalte ──────────────────────────────────────────────────────── */
  .cs-about__col-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 900px) {
    .cs-about__col-left {
      position: sticky;
      top: clamp(3rem, 8vh, 6rem);
    }
  }

  .cs-about__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }

  .cs-about__headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text);
    max-width: 12ch;
    overflow: hidden;
  }

  .cs-about__lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    color: var(--color-muted);
    max-width: 26ch;
    line-height: 1.45;
  }

  /* ── Rechte Spalte ─────────────────────────────────────────────────────── */
  .cs-about__col-right {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .cs-about__body {
    font-size: clamp(1.05rem, 1.2vw, 1.18rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
    max-width: 56ch;
  }

  .cs-about__body + .cs-about__body {
    margin-top: 1.25rem;
  }

  .cs-about__signature {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-style: italic;
  }

  .cs-about__signature-label {
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  .cs-about__signature-role {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  /* ── Stats ─────────────────────────────────────────────────────────────── */
  .cs-about__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-rule);
    list-style: none;
  }

  @media (min-width: 600px) {
    .cs-about__stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .cs-about__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cs-about__stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1;
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
  }

  .cs-about__stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    line-height: 1.5;
    max-width: 22ch;
  }
</style>
