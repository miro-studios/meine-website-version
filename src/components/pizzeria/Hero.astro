---
/**
 * Bella Notte — Hero
 *
 * Editorial Magazine Aesthetic.
 *  - oben:    Mini-Bar (Brand-Mark + Adresse + Telefon-CTA)
 *  - links:   Mega-Display "La Vera Pizza" — Wort-für-Wort-Reveal,
 *             zweite Zeile in Italic-Burgund
 *  - rechts:  Pizza-SVG mit langsamer Parallax-Rotation beim Scroll
 *  - unten:   Doppel-CTA (Magnetic + Telefon) + Trust-Indikatoren
 *  - bottom:  Scroll-Indikator
 *
 * Pflicht-Effekte aus Paket-02:
 *  - Split-Text-Reveal beim Pageload (chars)
 *  - Clip-Path-Reveal auf das Hero-Visual
 *  - Parallax-Rotation der Pizza beim Scroll (eigene Komposition #1)
 *  - Magnetic CTA
 *  - Trust-Element direkt sichtbar
 */
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
---

<section class="bn-hero" data-bn-hero>
  <!-- ── Top-Bar ─────────────────────────────────────────────────────── -->
  <header class="bn-hero__bar">
    <a href="/demos/pizzeria/" class="bn-hero__brand" aria-label="Bella Notte — Startseite">
      <span class="bn-hero__brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="12" r="10" />
          <circle cx="8" cy="9" r="1.4" fill="currentColor" stroke="none" />
          <circle cx="15" cy="10" r="1" fill="currentColor" stroke="none" />
          <circle cx="11" cy="14" r="1.2" fill="currentColor" stroke="none" />
          <circle cx="16" cy="15" r="0.8" fill="currentColor" stroke="none" />
        </svg>
      </span>
      <span class="bn-hero__brand-name">
        <span class="bn-hero__brand-name-it">Bella</span> Notte
      </span>
    </a>

    <p class="bn-hero__bar-meta" aria-label="Standort">
      <span>Knapper Weg 47</span>
      <span aria-hidden="true" class="bn-hero__bar-dot"></span>
      <span>58507 Lüdenscheid</span>
      <span aria-hidden="true" class="bn-hero__bar-dot"></span>
      <a href="tel:+4923519876543" class="bn-hero__bar-tel">02351 / 98 76 543</a>
    </p>
  </header>

  <!-- ── Inner ──────────────────────────────────────────────────────── -->
  <div class="bn-hero__inner">
    <div class="bn-hero__copy">
      <p class="bn-hero__eyebrow">
        <span class="bn-hero__dot" aria-hidden="true"></span>
        Trattoria · Lüdenscheid · Familie Caruso seit 1972
      </p>

      <h1 class="bn-hero__headline" aria-label="La Vera Pizza">
        <span class="bn-hero__headline-line">
          <SplitText by="chars" delay={0.1} stagger={0.03} onScroll={false}>La Vera</SplitText>
        </span>
        <span class="bn-hero__headline-line bn-hero__headline-line--alt">
          <SplitText by="chars" delay={0.45} stagger={0.03} onScroll={false}>Pizza.</SplitText>
        </span>
      </h1>

      <p class="bn-hero__sub">
        Holzofen aus Neapel. Mehl aus Caputo-Mühle. Tomaten aus den
        Bergen vom Vesuv. Wir kochen wie die Nonna —
        <em>nur etwas pünktlicher</em>.
      </p>

      <div class="bn-hero__actions">
        <MagneticButton href="#reservieren" strength={0.35} variant="primary" class="bn-hero__cta">
          <span>Tisch reservieren</span>
          <span class="bn-hero__cta-arrow" aria-hidden="true">→</span>
        </MagneticButton>

        <a href="#speisekarte" class="bn-hero__secondary">
          <span class="bn-hero__secondary-label">oder erst</span>
          <span class="bn-hero__secondary-line">
            <span class="bn-hero__secondary-text">die Karte ansehen</span>
            <span class="bn-hero__secondary-arrow" aria-hidden="true">↓</span>
          </span>
        </a>
      </div>

      <!-- Trust-Indikatoren: direkt im Hero sichtbar -->
      <ul class="bn-hero__trust" role="list">
        <li class="bn-hero__trust-item">
          <span class="bn-hero__trust-stars" aria-label="4,9 von 5 Sternen">
            <svg viewBox="0 0 60 12" width="60" height="12" aria-hidden="true">
              {[0, 12, 24, 36, 48].map((x) => (
                <path
                  d={`M${x + 6} 0.8 L${x + 7.6} 4.4 L${x + 11.4} 4.8 L${x + 8.6} 7.4 L${x + 9.4} 11.2 L${x + 6} 9.2 L${x + 2.6} 11.2 L${x + 3.4} 7.4 L${x + 0.6} 4.8 L${x + 4.4} 4.4 Z`}
                  fill="currentColor"
                />
              ))}
            </svg>
          </span>
          <span class="bn-hero__trust-text">
            <strong>4,9</strong>
            <span>· 312 Google-Bewertungen</span>
          </span>
        </li>
        <li class="bn-hero__trust-item bn-hero__trust-item--press">
          <span class="bn-hero__trust-quote">
            „Die beste Pizza im Sauerland."
          </span>
          <span class="bn-hero__trust-source">— Gault & Millau, 2024</span>
        </li>
      </ul>
    </div>

    <!-- ── Hero-Visual: Pizza, langsam parallax-rotiert ──────────────── -->
    <figure class="bn-hero__visual" data-bn-hero-visual>
      <div class="bn-hero__visual-paper" aria-hidden="true"></div>

      <!-- Goldgelb-Akzent-Stempel hinter der Pizza -->
      <div class="bn-hero__stamp" aria-hidden="true">
        <svg viewBox="0 0 200 200" width="100%" height="100%">
          <defs>
            <path id="bn-stamp-arc" d="M 100,100 m -84,0 a 84,84 0 1,1 168,0 a 84,84 0 1,1 -168,0" />
          </defs>
          <text font-family="Fraunces, serif" font-size="13" font-style="italic" letter-spacing="0.3em" fill="currentColor">
            <textPath href="#bn-stamp-arc" startOffset="0">
              · NAPOLI · TRADITIONE · LÜDENSCHEID · DAL 1972 · NAPOLI · TRADITIONE ·
            </textPath>
          </text>
        </svg>
      </div>

      <svg
        class="bn-hero__pizza"
        viewBox="0 0 480 480"
        role="img"
        aria-label="Illustrierte Pizza mit Tomate, Mozzarella und Basilikum"
        data-bn-hero-pizza
      >
        <!-- Holzbrett-Schatten -->
        <ellipse cx="240" cy="430" rx="180" ry="22" fill="#1F1410" opacity="0.18" />

        <!-- Pizza-Teig-Rand -->
        <circle cx="240" cy="240" r="200" fill="#E4B97A" />
        <circle cx="240" cy="240" r="200" fill="none" stroke="#8A5A2B" stroke-width="2.5" opacity="0.4" />

        <!-- Char-Spots am Rand (gebackene Bläschen) -->
        <g fill="#3D2410" opacity="0.55">
          <circle cx="92" cy="178" r="3.5" />
          <circle cx="78" cy="230" r="4" />
          <circle cx="108" cy="320" r="3" />
          <circle cx="190" cy="420" r="3.8" />
          <circle cx="320" cy="418" r="3.2" />
          <circle cx="392" cy="320" r="4.2" />
          <circle cx="404" cy="240" r="3" />
          <circle cx="378" cy="148" r="3.5" />
          <circle cx="280" cy="68" r="3.2" />
          <circle cx="180" cy="72" r="4" />
        </g>

        <!-- Tomatensauce -->
        <circle cx="240" cy="240" r="168" fill="#A8261B" />
        <circle cx="240" cy="240" r="168" fill="#6B1A12" opacity="0.18" />

        <!-- Mozzarella-Klumpen (organische Flecken) -->
        <g fill="#FBF6EC">
          <path d="M 170 180 Q 200 165 215 190 Q 222 215 195 220 Q 165 220 158 200 Q 155 184 170 180 Z" />
          <path d="M 270 165 Q 305 158 312 188 Q 308 215 285 218 Q 258 215 255 192 Q 254 170 270 165 Z" />
          <path d="M 320 245 Q 355 240 358 270 Q 352 295 325 296 Q 300 290 300 268 Q 302 248 320 245 Z" />
          <path d="M 175 285 Q 210 280 215 308 Q 212 332 188 335 Q 162 330 158 308 Q 158 290 175 285 Z" />
          <path d="M 260 310 Q 290 305 295 332 Q 290 355 265 358 Q 240 352 238 332 Q 238 314 260 310 Z" />
          <path d="M 218 230 Q 245 226 250 250 Q 246 268 226 270 Q 208 266 208 250 Q 208 234 218 230 Z" />
        </g>

        <!-- Mozzarella-Glanz (helle Highlights) -->
        <g fill="#FFFFFF" opacity="0.6">
          <ellipse cx="185" cy="195" rx="12" ry="4" />
          <ellipse cx="285" cy="180" rx="14" ry="5" />
          <ellipse cx="335" cy="262" rx="13" ry="4" />
          <ellipse cx="190" cy="300" rx="14" ry="5" />
          <ellipse cx="275" cy="325" rx="12" ry="4" />
        </g>

        <!-- Basilikum-Blätter (Olivgrün) -->
        <g fill="#3F5026">
          <path d="M 225 200 Q 215 188 222 178 Q 235 175 240 188 Q 238 200 230 204 Q 225 204 225 200 Z" />
          <path d="M 230 188 L 228 200" stroke="#2A3819" stroke-width="0.7" />
          <path d="M 310 215 Q 322 208 328 220 Q 324 232 314 232 Q 305 228 305 222 Q 305 218 310 215 Z" />
          <path d="M 315 218 L 318 230" stroke="#2A3819" stroke-width="0.7" />
          <path d="M 175 250 Q 188 244 192 256 Q 188 268 178 268 Q 168 264 168 258 Q 168 252 175 250 Z" />
          <path d="M 180 252 L 184 264" stroke="#2A3819" stroke-width="0.7" />
          <path d="M 248 282 Q 258 274 264 286 Q 260 296 252 298 Q 244 294 244 288 Q 244 284 248 282 Z" />
          <path d="M 254 280 L 256 294" stroke="#2A3819" stroke-width="0.7" />
          <path d="M 290 340 Q 302 332 306 344 Q 302 354 294 354 Q 286 350 286 346 Q 286 342 290 340 Z" />
          <path d="M 295 338 L 298 352" stroke="#2A3819" stroke-width="0.7" />
        </g>

        <!-- Schnittlinien (8 Stücke, dezent) -->
        <g stroke="#1F1410" stroke-width="0.6" opacity="0.18">
          <line x1="240" y1="72" x2="240" y2="408" />
          <line x1="72" y1="240" x2="408" y2="240" />
          <line x1="121" y1="121" x2="359" y2="359" />
          <line x1="359" y1="121" x2="121" y2="359" />
        </g>

        <!-- Goldgelber Olivenöl-Glanz (Akzent) -->
        <g fill="#E8B547" opacity="0.45">
          <ellipse cx="220" cy="220" rx="3" ry="2" />
          <ellipse cx="300" cy="270" rx="2.5" ry="1.8" />
          <ellipse cx="195" cy="270" rx="2" ry="1.5" />
          <ellipse cx="265" cy="200" rx="2.5" ry="1.8" />
        </g>
      </svg>

      <figcaption class="bn-hero__visual-caption">
        <span aria-hidden="true">⌖</span>
        <span>Margherita D.O.P.</span>
        <span aria-hidden="true">·</span>
        <span>Holzofen 480°C</span>
      </figcaption>
    </figure>
  </div>

  <!-- ── Scroll-Indikator unten ──────────────────────────────────────── -->
  <div class="bn-hero__scroll" aria-hidden="true">
    <span class="bn-hero__scroll-label">Scrollen</span>
    <span class="bn-hero__scroll-line"></span>
  </div>

  <!-- ── Mega-Wortmarke driftet beim Verlassen ein (Pflicht-Effekt) ──── -->
  <div class="bn-hero__wordmark" aria-hidden="true" data-bn-wordmark>
    <span>Bella</span>
  </div>
</section>

<style>
  /* ── Container ─────────────────────────────────────────────────────── */
  .bn-hero {
    position: relative;
    min-height: 100svh;
    padding-inline: var(--bn-gutter);
    padding-block: clamp(1.25rem, 2.5vw, 2rem) clamp(4rem, 8vw, 7rem);
    background:
      radial-gradient(ellipse 70% 40% at 85% 10%, color-mix(in srgb, var(--color-accent) 18%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 50% at 10% 90%, color-mix(in srgb, var(--color-primary) 8%, transparent), transparent 60%),
      var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    isolation: isolate;
  }

  /* dezente Papier-Textur über der ganzen Hero */
  .bn-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bn-grain);
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  .bn-hero > * {
    position: relative;
    z-index: 1;
  }

  /* ── Top-Bar ───────────────────────────────────────────────────────── */
  .bn-hero__bar {
    max-width: var(--bn-container);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--color-rule);
    flex-wrap: wrap;
  }

  .bn-hero__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1;
  }

  .bn-hero__brand-mark {
    display: inline-flex;
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .bn-hero__brand-name {
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .bn-hero__brand-name-it {
    font-style: italic;
    color: var(--color-primary);
  }

  .bn-hero__bar-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }

  .bn-hero__bar-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.5;
  }

  .bn-hero__bar-tel {
    color: var(--color-primary);
    border-bottom: 1px solid transparent;
    padding-block: 0.5rem;
    margin-block: -0.5rem;
    transition: border-color 0.3s ease;
    font-variant-numeric: tabular-nums;
  }

  .bn-hero__bar-tel:hover {
    border-bottom-color: currentColor;
  }

  /* ── Inner Grid ────────────────────────────────────────────────────── */
  .bn-hero__inner {
    max-width: var(--bn-container);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  @media (min-width: 900px) {
    .bn-hero__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    }
  }

  /* ── Copy ─────────────────────────────────────────────────────────── */
  .bn-hero__copy {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 2.8vw, 2.25rem);
  }

  .bn-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    max-width: 100%;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .bn-hero__dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 22%, transparent);
    animation: bn-pulse 2.4s var(--ease-in-out-quart) infinite;
  }

  @keyframes bn-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(0.85); opacity: 0.7; }
  }

  .bn-hero__headline {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 13vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin-block: 0.25rem;
  }

  .bn-hero__headline-line {
    display: block;
    overflow: hidden;
  }

  .bn-hero__headline-line--alt {
    color: var(--color-primary);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
    padding-left: clamp(1.5rem, 8vw, 6rem);
    margin-top: -0.05em;
  }

  .bn-hero__sub {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.5vw, 1.4rem);
    line-height: 1.45;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    max-width: 36ch;
  }

  .bn-hero__sub em {
    color: var(--color-primary);
    font-style: italic;
  }

  /* ── Actions ──────────────────────────────────────────────────────── */
  .bn-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2.25rem;
    margin-top: 0.5rem;
  }

  .bn-hero__cta {
    --pad-x: 2.1rem;
    --pad-y: 1.1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    letter-spacing: 0.01em;
    background-color: var(--color-primary);
    color: var(--color-cream);
  }

  .bn-hero__cta:hover {
    background-color: var(--color-deep);
    color: var(--color-cream);
  }

  .bn-hero__cta-arrow {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .bn-hero__cta:hover .bn-hero__cta-arrow {
    transform: translateX(5px);
  }

  .bn-hero__secondary {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .bn-hero__secondary:hover {
    color: var(--color-primary);
  }

  .bn-hero__secondary-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .bn-hero__secondary-line {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .bn-hero__secondary-arrow {
    font-style: normal;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .bn-hero__secondary:hover .bn-hero__secondary-arrow {
    transform: translateY(3px);
  }

  /* ── Trust ────────────────────────────────────────────────────────── */
  .bn-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
    list-style: none;
    padding-top: 1.25rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .bn-hero__trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .bn-hero__trust-stars {
    color: var(--color-accent);
    display: inline-flex;
  }

  .bn-hero__trust-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-muted);
  }

  .bn-hero__trust-text strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-text);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .bn-hero__trust-item--press {
    border-left: 1px solid var(--color-rule);
    padding-left: 1.25rem;
  }

  @media (max-width: 520px) {
    .bn-hero__trust-item--press {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--color-rule);
      padding-top: 0.85rem;
    }
  }

  .bn-hero__trust-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--color-text);
    max-width: 22ch;
    line-height: 1.3;
  }

  .bn-hero__trust-source {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }

  /* ── Visual ───────────────────────────────────────────────────────── */
  .bn-hero__visual {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
    isolation: isolate;
    /* Clip-Path-Reveal: startet als Punkt, wird vom Script aufgemacht */
    clip-path: inset(0 0 0 0 round 50%);
  }

  @media (min-width: 900px) {
    .bn-hero__visual {
      max-width: none;
      transform: translateY(-1rem);
    }
  }

  .bn-hero__visual-paper {
    position: absolute;
    inset: -8%;
    background:
      radial-gradient(circle at 30% 30%, color-mix(in srgb, var(--color-accent) 28%, transparent), transparent 60%),
      radial-gradient(circle at 70% 70%, color-mix(in srgb, var(--color-primary) 12%, transparent), transparent 55%);
    border-radius: 50%;
    z-index: -2;
    filter: blur(6px);
  }

  /* Goldgelb-Stempel (Kreis-Text), rotiert langsam */
  .bn-hero__stamp {
    position: absolute;
    inset: -10%;
    color: var(--color-accent);
    z-index: -1;
    opacity: 0.85;
    animation: bn-stamp-spin 28s linear infinite;
    will-change: transform;
  }

  @keyframes bn-stamp-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .bn-hero__pizza {
    width: 100%;
    height: 100%;
    will-change: transform;
    filter: drop-shadow(0 24px 32px color-mix(in srgb, var(--color-deep) 30%, transparent));
  }

  .bn-hero__visual-caption {
    position: absolute;
    bottom: -2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* ── Scroll-Indikator ─────────────────────────────────────────────── */
  .bn-hero__scroll {
    position: absolute;
    left: var(--bn-gutter);
    bottom: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    pointer-events: none;
  }

  .bn-hero__scroll-line {
    display: block;
    width: 60px;
    height: 1px;
    background: currentColor;
    overflow: hidden;
    position: relative;
  }

  .bn-hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-primary);
    transform: translateX(-100%);
    animation: bn-scroll-line 2.8s var(--ease-in-out-quart) infinite;
  }

  @keyframes bn-scroll-line {
    0%   { transform: translateX(-100%); }
    60%  { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  /* ── Mega-Wortmarke (driftet beim Scroll-Out rein) ────────────────── */
  .bn-hero__wordmark {
    position: absolute;
    left: 50%;
    bottom: -0.15em;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(8rem, 24vw, 22rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: color-mix(in srgb, var(--color-primary) 14%, transparent);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
    will-change: transform, opacity;
    opacity: 0;
  }

  /* ── Reduced-Motion ───────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bn-hero__dot,
    .bn-hero__stamp,
    .bn-hero__scroll-line::after {
      animation: none !important;
    }
    .bn-hero__visual {
      clip-path: none;
    }
    .bn-hero__wordmark {
      opacity: 1;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function init() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const hero = document.querySelector<HTMLElement>('[data-bn-hero]');
    const visual = document.querySelector<HTMLElement>('[data-bn-hero-visual]');
    const pizza = document.querySelector<HTMLElement>('[data-bn-hero-pizza]');
    const wordmark = document.querySelector<HTMLElement>('[data-bn-wordmark]');
    if (!hero) return;

    // 1) Clip-Path-Reveal des Hero-Visuals beim Laden (Custom-Animation #1, Teil A)
    if (visual && !reduce) {
      gsap.fromTo(
        visual,
        { clipPath: 'inset(50% 50% 50% 50% round 50%)' },
        {
          clipPath: 'inset(0% 0% 0% 0% round 50%)',
          duration: 1.6,
          ease: 'expo.out',
          delay: 0.4,
        }
      );
    }

    // 2) Pizza dreht sich beim Scroll langsam (Custom-Animation #1, Teil B)
    if (pizza && !reduce) {
      gsap.to(pizza, {
        rotation: 38,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: 0.8,
        },
      });

      // zusätzlicher Y-Parallax
      gsap.to(pizza, {
        yPercent: -10,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: 0.6,
        },
      });
    }

    // 3) Mega-Wortmarke "Bella" driftet von unten rein beim Scroll-Out
    if (wordmark && !reduce) {
      gsap.fromTo(
        wordmark,
        { yPercent: 70, opacity: 0 },
        {
          yPercent: 0,
          opacity: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: hero,
            start: 'top top',
            end: 'bottom top',
            scrub: 0.8,
          },
        }
      );
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
