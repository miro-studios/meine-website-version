</style>

<script>
  type FieldName = 'name' | 'email' | 'message' | 'consent';

  const ERR: Record<FieldName, { required: string; invalid: string }> = {
    name:    { required: 'Bitte deinen Namen.',         invalid: 'Mindestens zwei Zeichen.' },
    email:   { required: 'Bitte deine E-Mail-Adresse.', invalid: 'Das sieht nicht nach einer E-Mail aus.' },
    message: { required: 'Was sollen wir wissen?',      invalid: 'Mindestens fünf Zeichen.' },
    consent: { required: 'Bitte bestätige die Datenschutzerklärung.', invalid: '' },
  };

  function validateField(input: HTMLInputElement | HTMLTextAreaElement, name: FieldName): string {
    if (name === 'consent') {
      return (input as HTMLInputElement).checked ? '' : ERR.consent.required;
    }
    const v = input.value.trim();
    if (!v) return ERR[name].required;
    if (name === 'email') {
      const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
      if (!ok) return ERR.email.invalid;
    } else {
      const min = (input as HTMLInputElement).minLength;
      if (min > 0 && v.length < min) return ERR[name].invalid;
    }
    return '';
  }

  function setError(form: HTMLFormElement, name: FieldName, msg: string) {
    const errEl = form.querySelector<HTMLElement>(`[data-error-for="${name}"]`);
    const inputEl = form.querySelector<HTMLElement>(`[name="${name}"]`);
    const field = inputEl?.closest('.bn-form__field, .bn-form__consent');
    if (errEl) errEl.textContent = msg;
    if (field) field.classList.toggle('is-error', !!msg);
  }

  function init() {
    const form = document.querySelector<HTMLFormElement>('[data-bn-form]');
    if (!form) return;

    const fieldNames: FieldName[] = ['name', 'email', 'message', 'consent'];

    fieldNames.forEach((name) => {
      const input = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${name}"]`);
      if (!input) return;
      const event = name === 'consent' ? 'change' : 'blur';
      input.addEventListener(event, () => setError(form, name, validateField(input, name)));
      input.addEventListener('input', () => {
        const field = input.closest('.bn-form__field, .bn-form__consent');
        if (field?.classList.contains('is-error')) {
          setError(form, name, validateField(input, name));
        }
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot — schweigend abbrechen
      const hp = (form.elements.namedItem('website') as HTMLInputElement | null)?.value;
      if (hp) return;

      // Validate alle Pflichtfelder
      let hasError = false;
      fieldNames.forEach((name) => {
        const input = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${name}"]`);
        if (!input) return;
        const msg = validateField(input, name);
        setError(form, name, msg);
        if (msg) hasError = true;
      });

      if (hasError) {
        const firstError = form.querySelector<HTMLElement>('.is-error input, .is-error textarea');
        firstError?.focus();
        return;
      }

      const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submit) {
        submit.disabled = true;
        const label = submit.querySelector('.bn-form__submit-label');
        if (label) label.textContent = 'Wird gesendet…';
      }

      // Demo-Submit: simuliert Netzwerk-Roundtrip.
      // In Produktion: fetch zu Formspree / Cloudflare Worker + Turnstile-Token mitsenden.
      const data = Object.fromEntries(new FormData(form).entries());
      // eslint-disable-next-line no-console
      console.info('[Bella Notte — Reservierungsanfrage]', data);

      await new Promise((r) => setTimeout(r, 800));
      form.classList.add('is-success');
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
