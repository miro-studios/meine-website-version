---
/**
 * Bella Notte — Section 5: Standort / Anfahrt
 *
 * 2-Spalten-Editorial-Layout:
 *  - links:  Headline, Adresse, Öffnungszeiten, Tel/E-Mail als Action-Blocks
 *  - rechts: Click-to-Load Map (Privacy-freundlich, OpenStreetMap)
 *
 * Pflicht-Effekte:
 *  - Map lädt erst NACH explizitem Klick (DSGVO, kein Auto-Embed)
 *  - Reveal-on-Scroll auf Info-Blocks
 *  - Telefon + E-Mail als prominente CTAs
 */
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import SplitText from '@components/shared/SplitText.astro';

// Lüdenscheid-Koordinaten — wir nehmen einen plausiblen Punkt am Knapper Weg
const lat = 51.21978;
const lng = 7.62576;
// OpenStreetMap Embed-URL (kein Cookie, kein Tracking)
const osmEmbed = `https://www.openstreetmap.org/export/embed.html?bbox=${lng - 0.008},${lat - 0.004},${lng + 0.008},${lat + 0.004}&layer=mapnik&marker=${lat},${lng}`;
const osmLink = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=17/${lat}/${lng}`;
---

<section class="bn-loc" id="standort" data-bn-loc>
  <div class="bn-loc__inner">
    <!-- ── Links: Headline + Info-Stack ──────────────────────────────── -->
    <div class="bn-loc__col-left">
      <p class="bn-loc__eyebrow"><span aria-hidden="true">05 ·</span> Wo wir sind</p>

      <h2 class="bn-loc__headline">
        <span class="bn-loc__headline-line">
          <SplitText by="words" stagger={0.06}>Komm vorbei.</SplitText>
        </span>
        <span class="bn-loc__headline-line bn-loc__headline-line--alt">
          <SplitText by="words" stagger={0.06} delay={0.2}>Bring Hunger mit.</SplitText>
        </span>
      </h2>

      <p class="bn-loc__lead">
        Mitten in Lüdenscheid. Parkhaus am Stern (3&nbsp;Minuten zu Fuß),
        Bushaltestelle direkt vor der Tür.
      </p>

      <RevealOnScroll y={28} duration={0.85} stagger={0.1} class="bn-loc__info">
        <a
          href={osmLink}
          class="bn-loc__info-block"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="bn-loc__info-label">Adresse</span>
          <span class="bn-loc__info-value">
            Knapper Weg 47<br />
            58507 Lüdenscheid
          </span>
          <span class="bn-loc__info-link">Route planen ↗</span>
        </a>

        <a href="tel:+4923519876543" class="bn-loc__info-block">
          <span class="bn-loc__info-label">Reservieren</span>
          <span class="bn-loc__info-value">02351 / 98 76 543</span>
          <span class="bn-loc__info-link">Jetzt anrufen ↗</span>
        </a>

        <a href="mailto:ciao@bella-notte-luedenscheid.de" class="bn-loc__info-block">
          <span class="bn-loc__info-label">Schreiben</span>
          <span class="bn-loc__info-value">ciao@bella-notte-luedenscheid.de</span>
          <span class="bn-loc__info-link">Mail senden ↗</span>
        </a>

        <div class="bn-loc__info-block bn-loc__info-block--static">
          <span class="bn-loc__info-label">Öffnungszeiten</span>
          <ul class="bn-loc__hours" role="list">
            <li><span>Di – Do</span><span>17:30 – 22:30</span></li>
            <li><span>Fr – Sa</span><span>17:30 – 23:30</span></li>
            <li><span>So</span><span>12:00 – 22:00</span></li>
            <li class="bn-loc__hours-closed"><span>Mo</span><span>Riposo</span></li>
          </ul>
        </div>
      </RevealOnScroll>
    </div>

    <!-- ── Rechts: Click-to-Load Map ─────────────────────────────────── -->
    <div class="bn-loc__col-right">
      <div class="bn-loc__map" data-bn-map>
        <!-- Placeholder mit hand-gezeichneter Mini-Map als Vorschau -->
        <div class="bn-loc__map-placeholder" data-bn-map-placeholder>
          <svg
            class="bn-loc__map-sketch"
            viewBox="0 0 400 300"
            aria-hidden="true"
            focusable="false"
          >
            <!-- Untergrund (Stadt-Cream) -->
            <rect width="400" height="300" fill="#F0E8D8" />

            <!-- Stadtblöcke (abstrakt) -->
            <g fill="#E0D4BD">
              <rect x="20" y="40" width="80" height="60" />
              <rect x="120" y="30" width="100" height="50" />
              <rect x="240" y="50" width="70" height="70" />
              <rect x="20" y="130" width="90" height="55" />
              <rect x="130" y="120" width="80" height="55" />
              <rect x="230" y="140" width="100" height="50" />
              <rect x="20" y="210" width="110" height="65" />
              <rect x="150" y="200" width="90" height="70" />
              <rect x="260" y="220" width="120" height="55" />
            </g>

            <!-- Straßen (helles Weiß) -->
            <g stroke="#FBF6EC" stroke-width="6" fill="none">
              <line x1="0" y1="110" x2="400" y2="110" />
              <line x1="0" y1="195" x2="400" y2="195" />
              <line x1="115" y1="0" x2="115" y2="300" />
              <line x1="225" y1="0" x2="225" y2="300" />
            </g>

            <!-- Hauptstraße (Knapper Weg) -->
            <line
              x1="0"
              y1="155"
              x2="400"
              y2="155"
              stroke="#FBF6EC"
              stroke-width="10"
            />
            <line
              x1="0"
              y1="155"
              x2="400"
              y2="155"
              stroke="#E8B547"
              stroke-width="2"
              stroke-dasharray="8 6"
              opacity="0.7"
            />

            <!-- Marker (Bella Notte Standort) -->
            <g transform="translate(200 145)">
              <circle
                r="20"
                fill="#A8261B"
                opacity="0.18"
                class="bn-loc__map-marker-pulse"
              />
              <circle
                r="12"
                fill="#A8261B"
                opacity="0.3"
                class="bn-loc__map-marker-pulse"
                style="animation-delay: -0.7s;"
              />
              <path
                d="M 0 -16 C -8 -16 -14 -10 -14 -2 C -14 8 0 22 0 22 C 0 22 14 8 14 -2 C 14 -10 8 -16 0 -16 Z"
                fill="#A8261B"
              />
              <circle cx="0" cy="-2" r="4" fill="#FBF6EC" />
            </g>

            <!-- Label am Marker -->
            <g transform="translate(200 200)" text-anchor="middle">
              <rect x="-44" y="-2" width="88" height="22" rx="11" fill="#1F1410" />
              <text
                x="0"
                y="13"
                fill="#FBF6EC"
                font-family="Fraunces, serif"
                font-style="italic"
                font-size="13"
              >
                Bella Notte
              </text>
            </g>

            <!-- N-Indikator -->
            <g transform="translate(360 30)">
              <circle r="14" fill="none" stroke="#1F1410" stroke-width="1" opacity="0.4" />
              <text
                x="0"
                y="5"
                text-anchor="middle"
                fill="#1F1410"
                font-family="Fraunces, serif"
                font-size="14"
                opacity="0.7"
              >N</text>
              <path d="M 0 -10 L -3 -4 L 0 -6 L 3 -4 Z" fill="#A8261B" />
            </g>
          </svg>

          <div class="bn-loc__map-overlay">
            <p class="bn-loc__map-title">Karte anzeigen</p>
            <p class="bn-loc__map-text">
              Beim Klick auf "Karte laden" wird ein Kartenausschnitt von
              <strong>OpenStreetMap</strong> geladen. Es werden keine Cookies
              gesetzt, kein Tracking findet statt.
            </p>
            <button
              type="button"
              class="bn-loc__map-btn"
              data-bn-map-load
              data-magnetic
              data-magnetic-strength="0.25"
            >
              <span>Karte laden</span>
              <span aria-hidden="true">→</span>
            </button>
            <a
              href={osmLink}
              target="_blank"
              rel="noopener noreferrer"
              class="bn-loc__map-skip"
            >
              oder bei OpenStreetMap öffnen ↗
            </a>
          </div>
        </div>

        <!-- Echter Map-Iframe (wird per JS aktiviert) -->
        <iframe
          class="bn-loc__map-frame"
          data-bn-map-frame
          data-src={osmEmbed}
          title="Karte: Bella Notte, Knapper Weg 47, Lüdenscheid"
          width="100%"
          height="100%"
          loading="lazy"
          referrerpolicy="no-referrer"
        ></iframe>
      </div>

      <p class="bn-loc__caption">
        <span class="bn-loc__caption-line" aria-hidden="true"></span>
        Karte über OpenStreetMap · DSGVO-konform
      </p>
    </div>
  </div>
</section>

<style>
  .bn-loc {
    background: var(--color-bg);
    color: var(--color-text);
    padding-block: clamp(5rem, 10vw, 9rem);
    padding-inline: var(--bn-gutter);
    border-top: 1px solid var(--color-rule);
    position: relative;
  }

  .bn-loc__inner {
    max-width: var(--bn-container);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 5vw, 4.5rem);
  }

  @media (min-width: 960px) {
    .bn-loc__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: start;
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  /* ── Left ─────────────────────────────────────────────────────── */
  .bn-loc__col-left {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .bn-loc__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }

  .bn-loc__headline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6.5vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    max-width: 14ch;
  }

  .bn-loc__headline-line {
    display: block;
    overflow: hidden;
  }

  .bn-loc__headline-line--alt {
    color: var(--color-primary);
    font-style: italic;
    padding-left: clamp(0.5rem, 3vw, 2.5rem);
  }

  .bn-loc__lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    color: var(--color-muted);
    max-width: 40ch;
    line-height: 1.5;
  }

  .bn-loc__info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 520px) {
    .bn-loc__info {
      grid-template-columns: 1fr;
    }
  }

  .bn-loc__info-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-cream);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    color: var(--color-text);
    transition:
      border-color 0.3s ease,
      transform 0.4s var(--ease-out-expo),
      background-color 0.3s ease;
  }

  .bn-loc__info-block:not(.bn-loc__info-block--static):hover {
    border-color: var(--color-primary);
    transform: translateY(-3px);
  }

  .bn-loc__info-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .bn-loc__info-value {
    font-family: var(--font-display);
    font-size: 1.02rem;
    line-height: 1.4;
    color: var(--color-text);
    word-break: break-word;
  }

  .bn-loc__info-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    margin-top: 0.2rem;
  }

  .bn-loc__hours {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .bn-loc__hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .bn-loc__hours-closed {
    color: var(--color-muted);
    font-style: italic;
  }

  /* ── Right: Map ───────────────────────────────────────────────── */
  .bn-loc__col-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bn-loc__map {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: var(--color-surface);
    isolation: isolate;
  }

  .bn-loc__map-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr;
    transition: opacity 0.5s ease, visibility 0.5s;
  }

  .bn-loc__map.is-loaded .bn-loc__map-placeholder {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .bn-loc__map-sketch {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bn-loc__map-marker-pulse {
    transform-origin: center;
    animation: bn-loc-pulse 2.4s var(--ease-in-out-quart) infinite;
  }

  @keyframes bn-loc-pulse {
    0%, 100% { transform: scale(1); opacity: 0.18; }
    50%      { transform: scale(1.5); opacity: 0; }
  }

  .bn-loc__map-overlay {
    position: relative;
    z-index: 2;
    margin: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    text-align: center;
    background: color-mix(in srgb, var(--color-cream) 92%, transparent);
    backdrop-filter: blur(6px);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    max-width: 320px;
    box-shadow: 0 20px 50px -20px color-mix(in srgb, var(--color-deep) 30%, transparent);
  }

  .bn-loc__map-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .bn-loc__map-text {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .bn-loc__map-text strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .bn-loc__map-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 0.4rem;
    padding: 0.85rem 1.5rem;
    background: var(--color-primary);
    color: var(--color-cream);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease, box-shadow 0.4s ease;
    will-change: transform;
  }

  .bn-loc__map-btn:hover {
    background-color: var(--color-deep);
    box-shadow: 0 16px 32px -8px color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .bn-loc__map-skip {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    border-bottom: 1px solid transparent;
    transition: color 0.3s ease, border-color 0.3s ease;
    align-self: center;
    padding-block: 0.3rem;
  }

  .bn-loc__map-skip:hover {
    color: var(--color-primary);
    border-bottom-color: currentColor;
  }

  .bn-loc__map-frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .bn-loc__caption {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }

  .bn-loc__caption-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  /* ── Reduced-Motion ───────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bn-loc__map-marker-pulse {
      animation: none;
    }
  }
</style>

<script>
  function init() {
    const root = document.querySelector<HTMLElement>('[data-bn-map]');
    if (!root) return;

    const button = root.querySelector<HTMLButtonElement>('[data-bn-map-load]');
    const frame = root.querySelector<HTMLIFrameElement>('[data-bn-map-frame]');
    if (!button || !frame) return;

    const src = frame.dataset.src;
    if (!src) return;

    const load = () => {
      // Click-to-Load: setze src nur nach explizitem Consent
      frame.src = src;
      // Sobald iframe fertig ist, blende Placeholder aus
      const reveal = () => root.classList.add('is-loaded');
      frame.addEventListener('load', reveal, { once: true });
      // Fallback falls load-Event nicht feuert
      setTimeout(reveal, 1200);
    };

    button.addEventListener('click', load, { once: true });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
