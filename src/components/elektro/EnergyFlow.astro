---
/**
 * EnergyFlow — Premium Wow-Section.
 *
 * Isometrisches Energie-Flow-Diagramm:
 * Sonne → PV-Module → Wechselrichter → Verteilung → Wärmepumpe / Wallbox / Verbraucher.
 * Animierte Strompfade (stroke-dasharray-Animation) zeigen Energiefluss.
 *
 * Komplette Section inkl. Spec-Bar, Live-KPIs rechts und Hover-Highlights
 * auf den Hauptkomponenten. Funktioniert auch ohne JS (Pfad-Animationen
 * via CSS).
 */
---

<section class="hk-flow hk-section" data-hk-section data-hk-name="Energiefluss" data-hk-flow>
  <div class="hk-container">
    <div class="hk-bar">
      <span class="hk-bar-n">N° 03</span>
      <span class="hk-bar-line" aria-hidden="true"></span>
      <span class="hk-bar-k">ENERGIEFLUSS / EIN HAUS · LIVE</span>
    </div>

    <div class="hk-flow__head">
      <h2 class="hk-flow__h">
        EINE&nbsp;ANLAGE.<br />
        <span class="hk-flow__h-alt">FÜNF&nbsp;GEWERKE.</span><br />
        EIN&nbsp;FLUSS.
      </h2>
      <p class="hk-flow__lead">
        So sieht eine moderne Holtkamp-Installation aus: Sonne lädt den
        Speicher, der Speicher trägt nachts die Wärmepumpe und die Wallbox.
        Über das KNX-System sieht der Eigentümer jede Kilowattstunde.
      </p>
    </div>

    <div class="hk-flow__stage">
      <!-- Spec-Top-Bar -->
      <div class="hk-flow__spec" aria-hidden="true">
        <span class="hk-flow__spec-k">REF</span>
        <span class="hk-flow__spec-v">HK-FLOW-026</span>
        <span class="hk-flow__spec-dot"></span>
        <span class="hk-flow__spec-v">SAMPLE · 12,4 kWp</span>
        <span class="hk-flow__spec-line"></span>
        <span class="hk-flow__spec-k">LIVE</span>
        <span class="hk-flow__spec-pulse"></span>
        <span class="hk-flow__spec-v">FLUSS AKTIV</span>
      </div>

      <!-- Diagramm + KPI-Seitenleiste -->
      <div class="hk-flow__grid">
        <div class="hk-flow__diagram">
          <svg viewBox="0 0 640 440" class="hk-flow__svg" role="img" aria-label="Energieflussdiagramm: Sonne, PV, Speicher, Verteilung, Wärmepumpe, Wallbox, Verbraucher">
            <defs>
              <pattern id="hk-flow-grid" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M20 0H0V20" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
              </pattern>
              <linearGradient id="hk-flow-fade" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0"/>
                <stop offset="50%" stop-color="var(--color-accent)" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/>
              </linearGradient>
              <filter id="hk-flow-glow">
                <feGaussianBlur stdDeviation="2.4"/>
                <feComposite in2="SourceGraphic" operator="over"/>
              </filter>
            </defs>

            <!-- Hintergrund-Grid -->
            <rect width="640" height="440" fill="url(#hk-flow-grid)" opacity="0.5"/>

            <!-- Boden-Linie -->
            <line x1="20" y1="370" x2="620" y2="370" stroke="currentColor" stroke-width="1" opacity="0.4"/>

            <!-- ── SONNE oben links ──────────────────────────────────── -->
            <g class="hk-flow__node" data-hk-flow-node="sun">
              <circle cx="100" cy="80" r="22" fill="none" stroke="var(--color-accent)" stroke-width="1.6"/>
              <g stroke="var(--color-accent)" stroke-width="1.2" fill="none">
                <line x1="100" y1="48" x2="100" y2="55"/>
                <line x1="100" y1="105" x2="100" y2="112"/>
                <line x1="68" y1="80" x2="75" y2="80"/>
                <line x1="125" y1="80" x2="132" y2="80"/>
                <line x1="80" y1="60" x2="84" y2="64"/>
                <line x1="116" y1="96" x2="120" y2="100"/>
                <line x1="84" y1="96" x2="80" y2="100"/>
                <line x1="120" y1="60" x2="116" y2="64"/>
              </g>
              <text x="100" y="135" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-accent)" letter-spacing="1.5" font-weight="700">SONNE</text>
            </g>

            <!-- ── HAUS (zentral) ──────────────────────────────────────── -->
            <g class="hk-flow__node" data-hk-flow-node="house">
              <!-- Hauswände -->
              <path d="M 200 370 L 200 250 L 320 180 L 440 250 L 440 370 Z"
                    fill="color-mix(in srgb, var(--color-text) 5%, transparent)"
                    stroke="currentColor" stroke-width="1.6"/>
              <!-- Dach mit PV-Modulen -->
              <g class="hk-flow__pv">
                <polygon points="218,256 245,239 255,243 228,261" fill="var(--color-accent)" opacity="0.85"/>
                <polygon points="240,242 267,225 277,229 250,247" fill="var(--color-accent)" opacity="0.85"/>
                <polygon points="262,228 289,211 299,215 272,233" fill="var(--color-accent)" opacity="0.85"/>
                <polygon points="320,200 347,217 337,221 310,204" fill="var(--color-accent)" opacity="0.85"/>
                <polygon points="342,214 369,231 359,235 332,218" fill="var(--color-accent)" opacity="0.85"/>
                <polygon points="364,228 391,245 381,249 354,232" fill="var(--color-accent)" opacity="0.85"/>
              </g>
              <!-- Modul-Rasterlinien -->
              <g stroke="currentColor" stroke-width="0.4" opacity="0.4" fill="none">
                <line x1="218" y1="256" x2="290" y2="212"/>
                <line x1="248" y1="270" x2="320" y2="226"/>
                <line x1="320" y1="180" x2="395" y2="226"/>
                <line x1="320" y1="226" x2="395" y2="270"/>
              </g>
              <!-- Fenster + Tür -->
              <rect x="225" y="305" width="32" height="38" fill="color-mix(in srgb, var(--color-accent) 22%, transparent)" stroke="currentColor" stroke-width="1"/>
              <rect x="305" y="290" width="30" height="80" fill="none" stroke="currentColor" stroke-width="1"/>
              <rect x="385" y="305" width="32" height="38" fill="color-mix(in srgb, var(--color-accent) 22%, transparent)" stroke="currentColor" stroke-width="1"/>
              <!-- Verteilerbox -->
              <rect x="350" y="200" width="22" height="30" fill="var(--color-bg)" stroke="var(--color-accent)" stroke-width="1.2"/>
              <line x1="354" y1="207" x2="368" y2="207" stroke="var(--color-accent)" stroke-width="0.6"/>
              <line x1="354" y1="213" x2="368" y2="213" stroke="var(--color-accent)" stroke-width="0.6"/>
              <line x1="354" y1="219" x2="368" y2="219" stroke="var(--color-accent)" stroke-width="0.6"/>
              <text x="320" y="388" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-accent)" letter-spacing="1.5" font-weight="700">HAUS · 12,4 kWp</text>
            </g>

            <!-- ── SPEICHER (links unten am Haus) ─────────────────────── -->
            <g class="hk-flow__node" data-hk-flow-node="battery">
              <rect x="125" y="290" width="55" height="78" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
              <rect x="132" y="335" width="40" height="6" fill="var(--color-accent)" opacity="0.95"/>
              <rect x="132" y="325" width="40" height="6" fill="var(--color-accent)" opacity="0.85"/>
              <rect x="132" y="315" width="40" height="6" fill="var(--color-accent)" opacity="0.55"/>
              <rect x="132" y="305" width="40" height="6" fill="var(--color-accent)" opacity="0.25"/>
              <line x1="135" y1="298" x2="170" y2="298" stroke="currentColor" stroke-width="0.6" opacity="0.7"/>
              <text x="152" y="383" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="currentColor" opacity="0.85" letter-spacing="1" font-weight="700">10 kWh</text>
            </g>

            <!-- ── WÄRMEPUMPE (links unten am Boden) ─────────────────── -->
            <g class="hk-flow__node" data-hk-flow-node="hp">
              <rect x="40" y="310" width="62" height="58" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
              <rect x="40" y="310" width="62" height="12" fill="none" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="71" cy="345" r="14" fill="none" stroke="currentColor" stroke-width="1.2"/>
              <g stroke="currentColor" stroke-width="1" fill="none" transform="translate(71 345)">
                <path d="M0 -10 A 5 5 0 0 1 5 0"/>
                <path d="M0 10 A 5 5 0 0 1 -5 0"/>
                <path d="M-10 0 A 5 5 0 0 1 0 -5"/>
                <path d="M10 0 A 5 5 0 0 1 0 5"/>
              </g>
              <circle cx="71" cy="345" r="2" fill="currentColor"/>
              <!-- Wärme-Wellen -->
              <g stroke="var(--color-accent)" stroke-width="1.2" fill="none" opacity="0.85" class="hk-flow__heat">
                <path d="M108 330 q-4 -6 0 -12"/>
                <path d="M115 335 q-4 -6 0 -12"/>
                <path d="M108 345 q-4 -6 0 -12"/>
                <path d="M115 350 q-4 -6 0 -12"/>
              </g>
              <text x="71" y="385" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="currentColor" opacity="0.85" letter-spacing="1" font-weight="700">WP · 9 kW</text>
            </g>

            <!-- ── WALLBOX + AUTO (rechts unten) ──────────────────────── -->
            <g class="hk-flow__node" data-hk-flow-node="ev">
              <!-- Wallbox -->
              <rect x="462" y="300" width="26" height="48" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
              <line x1="462" y1="312" x2="488" y2="312" stroke="currentColor" stroke-width="0.6"/>
              <path d="M478 320 L 470 332 L 475 332 L 473 340 L 481 328 L 476 328 Z" fill="var(--color-accent)"/>
              <circle cx="486" cy="307" r="1.5" fill="var(--color-accent)"/>
              <!-- Ladekabel zum Auto -->
              <path d="M 488 340 Q 510 340 520 350 Q 530 360 545 358"
                    stroke="currentColor" stroke-width="1.4" fill="none"/>
              <!-- Auto-Andeutung -->
              <path d="M 520 370 Q 520 350 540 348 L 590 348 Q 605 348 612 360 L 612 370 Z"
                    fill="color-mix(in srgb, var(--color-text) 6%, transparent)"
                    stroke="currentColor" stroke-width="1.4"/>
              <circle cx="540" cy="370" r="7" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
              <circle cx="540" cy="370" r="3" fill="currentColor"/>
              <circle cx="600" cy="370" r="7" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
              <circle cx="600" cy="370" r="3" fill="currentColor"/>
              <!-- Fenster -->
              <path d="M 530 350 L 545 340 L 580 340 L 595 350 Z"
                    fill="color-mix(in srgb, var(--color-accent) 18%, transparent)"
                    stroke="currentColor" stroke-width="0.8"/>
              <text x="568" y="395" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="currentColor" opacity="0.85" letter-spacing="1" font-weight="700">EV · 11 kW</text>
            </g>

            <!-- ── FLOW-PFADE (animierte Stromlinien) ─────────────────── -->
            <g class="hk-flow__paths" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <!-- Sonne → Dach -->
              <path class="hk-flow__path hk-flow__path--solar" d="M 118 95 Q 160 130 220 175 Q 260 195 305 200" stroke="var(--color-accent)" stroke-width="2"/>
              <!-- Verteilung → Speicher -->
              <path class="hk-flow__path hk-flow__path--store" d="M 350 215 Q 310 220 245 240 Q 200 260 175 290" stroke="var(--color-accent)" stroke-width="2"/>
              <!-- Verteilung → Wärmepumpe -->
              <path class="hk-flow__path hk-flow__path--hp" d="M 350 220 Q 280 240 200 280 Q 150 300 108 330" stroke="var(--color-accent)" stroke-width="2"/>
              <!-- Verteilung → Wallbox -->
              <path class="hk-flow__path hk-flow__path--ev" d="M 372 220 Q 410 245 440 280 Q 460 295 475 305" stroke="var(--color-accent)" stroke-width="2"/>
              <!-- Verteilung → Verbraucher (Fenster) -->
              <path class="hk-flow__path hk-flow__path--use" d="M 360 230 Q 350 270 320 305" stroke="var(--color-accent)" stroke-width="1.6"/>
            </g>

            <!-- Sammelpunkt-Indikator am Verteiler -->
            <circle cx="361" cy="215" r="3.5" fill="var(--color-accent)" class="hk-flow__pulse-dot"/>

            <!-- Mess-Bar rechts -->
            <g class="hk-flow__measure" aria-hidden="true">
              <line x1="620" y1="80" x2="620" y2="370" stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
              <line x1="615" y1="80" x2="625" y2="80" stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
              <line x1="615" y1="370" x2="625" y2="370" stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
              <text x="630" y="225" font-family="JetBrains Mono, monospace" font-size="8" fill="currentColor" opacity="0.7" letter-spacing="0.5" transform="rotate(90 630 225)">7,2 m</text>
            </g>
          </svg>
        </div>

        <!-- KPI-Seitenleiste rechts -->
        <aside class="hk-flow__kpi" aria-label="Live-Kennzahlen">
          <header>
            <span class="hk-flow__kpi-dot" aria-hidden="true"></span>
            <span>BILANZ · HEUTE</span>
            <span class="hk-flow__kpi-id">12:42</span>
          </header>

          <dl>
            <div>
              <dt>PV-ERTRAG</dt>
              <dd><span data-hk-flow-pv>0,0</span><span>kWh</span></dd>
              <span class="hk-flow__kpi-bar" style="--w: 78%"></span>
              <span class="hk-flow__kpi-foot">+18% gegenüber Vorjahr</span>
            </div>
            <div>
              <dt>SPEICHER</dt>
              <dd><span data-hk-flow-soc>0</span><span>%</span></dd>
              <span class="hk-flow__kpi-bar" style="--w: 64%"></span>
              <span class="hk-flow__kpi-foot">6,4 / 10 kWh</span>
            </div>
            <div>
              <dt>WP-VERBRAUCH</dt>
              <dd><span data-hk-flow-hp>0,0</span><span>kWh</span></dd>
              <span class="hk-flow__kpi-bar hk-flow__kpi-bar--soft" style="--w: 42%"></span>
              <span class="hk-flow__kpi-foot">COP 4,3 · ⌀</span>
            </div>
            <div>
              <dt>WALLBOX</dt>
              <dd class="hk-flow__kpi-charging">
                <span class="hk-flow__kpi-charging-dot" aria-hidden="true"></span>
                LÄDT · 7,4 kW
              </dd>
              <span class="hk-flow__kpi-bar" style="--w: 67%"></span>
              <span class="hk-flow__kpi-foot">noch ~ 38 min</span>
            </div>
          </dl>

          <footer>
            <span class="hk-flow__kpi-foot-k">AUTARKIE</span>
            <span class="hk-flow__kpi-foot-v"><span data-hk-flow-aut>74</span>%</span>
          </footer>
        </aside>
      </div>

      <!-- Bottom-Spec-Bar -->
      <div class="hk-flow__bottom" aria-hidden="true">
        <span class="hk-flow__bottom-k">FLOW · 01</span>
        <span class="hk-flow__bottom-v">Sonne → PV-Module → Wechselrichter</span>
        <span class="hk-flow__bottom-sep">→</span>
        <span class="hk-flow__bottom-v">Verteilung</span>
        <span class="hk-flow__bottom-sep">→</span>
        <span class="hk-flow__bottom-v">Speicher / Wärmepumpe / Wallbox</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hk-flow {
    border-top: 1px solid var(--color-rule);
    background: var(--color-bg);
    position: relative;
  }

  .hk-flow__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 900px) {
    .hk-flow__head {
      grid-template-columns: 1.4fr 1fr;
      align-items: end;
    }
  }

  .hk-flow__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 5.6rem);
    line-height: 0.88;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
  }
  .hk-flow__h-alt { color: var(--color-accent); }

  .hk-flow__lead {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    max-width: 40ch;
    margin: 0;
  }

  /* Stage */
  .hk-flow__stage {
    border: 1px solid var(--color-rule-strong);
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  /* Spec-Top-Bar */
  .hk-flow__spec {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: var(--color-bg);
  }
  .hk-flow__spec-k { color: var(--color-muted); font-weight: 700; }
  .hk-flow__spec-v { color: var(--color-text); font-weight: 600; }
  .hk-flow__spec-dot {
    width: 4px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 50%;
  }
  .hk-flow__spec-line {
    flex: 1;
    height: 1px;
    background: var(--color-rule-strong);
    min-width: 1rem;
  }
  .hk-flow__spec-pulse {
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 22%, transparent),
                0 0 8px var(--color-accent);
    animation: hk-pulse 1.8s ease-in-out infinite;
  }

  /* Grid: Diagramm | KPI */
  .hk-flow__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 900px) {
    .hk-flow__grid {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 0.9fr);
    }
  }

  .hk-flow__diagram {
    padding: clamp(1rem, 2vw, 1.75rem);
    background:
      radial-gradient(ellipse 80% 50% at 50% 90%,
        color-mix(in srgb, var(--color-accent) 8%, transparent),
        transparent 70%),
      var(--color-bg);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 900px) {
    .hk-flow__diagram { border-bottom: none; border-right: 1px solid var(--color-rule); }
  }

  .hk-flow__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Animated Energy Paths */
  .hk-flow__path {
    stroke-dasharray: 6 14;
    animation: hk-flow-dash 1.6s linear infinite;
    opacity: 0.95;
    filter: drop-shadow(0 0 3px color-mix(in srgb, var(--color-accent) 60%, transparent));
  }
  .hk-flow__path--solar { animation-duration: 2.4s; }
  .hk-flow__path--store { animation-duration: 1.4s; }
  .hk-flow__path--hp    { animation-duration: 2s; }
  .hk-flow__path--ev    { animation-duration: 1.2s; }
  .hk-flow__path--use   { animation-duration: 2.6s; opacity: 0.55; }
  @keyframes hk-flow-dash {
    from { stroke-dashoffset: 20; }
    to   { stroke-dashoffset: 0; }
  }

  .hk-flow__pulse-dot {
    transform-origin: 361px 215px;
    animation: hk-flow-pulse 2s ease-in-out infinite;
    filter: drop-shadow(0 0 5px var(--color-accent));
  }
  @keyframes hk-flow-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.6); opacity: 0.5; }
  }

  .hk-flow__heat path {
    animation: hk-flow-heat 2.4s ease-in-out infinite;
  }
  .hk-flow__heat path:nth-child(2) { animation-delay: 0.4s; }
  .hk-flow__heat path:nth-child(3) { animation-delay: 0.8s; }
  .hk-flow__heat path:nth-child(4) { animation-delay: 1.2s; }
  @keyframes hk-flow-heat {
    0%, 100% { opacity: 0.4; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-2px); }
  }

  /* Node-Hover-Highlight */
  .hk-flow__node {
    transition: filter 0.4s var(--ease-out-expo);
    cursor: pointer;
  }
  .hk-flow__node:hover {
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--color-accent) 70%, transparent));
  }

  /* KPI-Seitenleiste */
  .hk-flow__kpi {
    background: var(--color-bg);
    color: var(--color-text);
    display: flex;
    flex-direction: column;
  }

  .hk-flow__kpi header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.95rem;
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--color-text);
    font-weight: 700;
  }
  .hk-flow__kpi header > span:nth-child(2) { flex: 1; }
  .hk-flow__kpi-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 25%, transparent),
                0 0 6px var(--color-accent);
    animation: hk-pulse 2.4s ease-in-out infinite;
  }
  .hk-flow__kpi-id {
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .hk-flow__kpi dl {
    margin: 0;
    padding: 0;
    flex: 1;
    display: grid;
  }
  .hk-flow__kpi dl > div {
    padding: 0.9rem 0.95rem;
    border-bottom: 1px solid var(--color-rule);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    column-gap: 0.5rem;
    row-gap: 0.25rem;
    position: relative;
  }
  .hk-flow__kpi dl > div:last-child { border-bottom: none; }

  .hk-flow__kpi dt {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    font-weight: 700;
  }
  .hk-flow__kpi dd {
    grid-column: 2;
    grid-row: 1;
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
    color: var(--color-text);
    font-weight: 400;
    letter-spacing: 0.005em;
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    font-variant-numeric: tabular-nums;
  }
  .hk-flow__kpi dd > span:last-child {
    font-size: 0.5em;
    color: var(--color-muted);
    letter-spacing: 0.14em;
  }

  .hk-flow__kpi-bar {
    grid-column: 1 / -1;
    grid-row: 2;
    height: 2px;
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    margin-top: 0.25rem;
    overflow: hidden;
    position: relative;
  }
  .hk-flow__kpi-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--color-accent);
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-accent) 50%, transparent);
    transform-origin: left;
    animation: hk-flow-bar 1.4s var(--ease-out-expo) 0.4s both;
  }
  .hk-flow__kpi-bar--soft::after {
    background: linear-gradient(90deg,
      var(--color-accent),
      color-mix(in srgb, var(--color-accent) 30%, var(--color-text)));
  }
  @keyframes hk-flow-bar {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .hk-flow__kpi-foot {
    grid-column: 1 / -1;
    grid-row: 3;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }

  .hk-flow__kpi-charging {
    color: var(--color-accent) !important;
    font-family: var(--font-mono) !important;
    font-size: 0.86rem !important;
    letter-spacing: 0.14em;
    font-weight: 700;
  }
  .hk-flow__kpi-charging-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    margin-right: 0.4em;
    animation: hk-pulse 1.2s ease-in-out infinite;
  }

  .hk-flow__kpi footer {
    padding: 1.05rem 0.95rem;
    background: var(--color-accent);
    color: var(--color-bg);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .hk-flow__kpi-foot-k {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    font-weight: 700;
  }
  .hk-flow__kpi-foot-v {
    font-family: var(--font-display);
    font-size: 2.2rem;
    line-height: 1;
    letter-spacing: 0.005em;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
  }
  .hk-flow__kpi-foot-v span { font-variant-numeric: tabular-nums; }

  /* Bottom-Spec */
  .hk-flow__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--color-rule);
    background: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hk-flow__bottom-k { color: var(--color-accent); font-weight: 700; }
  .hk-flow__bottom-v { color: var(--color-text); font-weight: 500; }
  .hk-flow__bottom-sep { color: var(--color-muted); }

  @media (prefers-reduced-motion: reduce) {
    .hk-flow__path,
    .hk-flow__heat path,
    .hk-flow__pulse-dot,
    .hk-flow__spec-pulse,
    .hk-flow__kpi-charging-dot,
    .hk-flow__kpi-dot,
    .hk-flow__kpi-bar::after {
      animation: none !important;
    }
    .hk-flow__path { stroke-dasharray: 0; }
  }
</style>

<script>
  function easeOutCubic(t: number) {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateValue(
    el: HTMLElement,
    from: number,
    to: number,
    duration: number,
    formatter: (v: number) => string,
  ) {
    const start = performance.now();
    function tick(now: number) {
      const t = Math.min(1, (now - start) / duration);
      const v = from + (to - from) * easeOutCubic(t);
      el.textContent = formatter(v);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function initFlow() {
    const root = document.querySelector<HTMLElement>('[data-hk-flow]');
    if (!root || root.dataset.flowInit === 'true') return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const pv = root.querySelector<HTMLElement>('[data-hk-flow-pv]');
    const soc = root.querySelector<HTMLElement>('[data-hk-flow-soc]');
    const hp = root.querySelector<HTMLElement>('[data-hk-flow-hp]');
    const aut = root.querySelector<HTMLElement>('[data-hk-flow-aut]');

    // Werte beim Scroll-Eintritt einmal hochzählen
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          root.dataset.flowInit = 'true';
          if (pv) animateValue(pv, 0, 28.4, reduce ? 0 : 1600, (v) => v.toFixed(1).replace('.', ','));
          if (soc) animateValue(soc, 0, 64, reduce ? 0 : 1400, (v) => String(Math.round(v)));
          if (hp) animateValue(hp, 0, 9.2, reduce ? 0 : 1600, (v) => v.toFixed(1).replace('.', ','));
          if (aut) animateValue(aut, 0, 74, reduce ? 0 : 2000, (v) => String(Math.round(v)));
          io.disconnect();
        });
      },
      { threshold: 0.25 },
    );
    io.observe(root);
  }

  initFlow();
  document.addEventListener('astro:page-load', initFlow);
</script>
