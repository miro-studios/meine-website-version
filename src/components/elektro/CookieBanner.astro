---
/**
 * Cookie-Banner mit Consent-Mode-Pattern (UI-only Demo).
 *
 * Erscheint einmal pro Session unten am Bildschirmrand, wird per
 * sessionStorage gemerkt. Drei Optionen: Alle akzeptieren · Auswahl
 * speichern · Nur notwendig. Optional-Toggles für Analyse + Marketing.
 *
 * Im echten Kundenprojekt würden die Toggles GA4/Plausible/etc. via
 * Consent-Mode v2 steuern. Hier rein visuelles Premium-Detail.
 */
---

<aside class="hk-consent" data-hk-consent role="dialog" aria-label="Cookie-Einstellungen" aria-hidden="true">
  <div class="hk-consent__inner">
    <div class="hk-consent__head">
      <span class="hk-consent__head-tag">
        <span class="hk-consent__head-dot" aria-hidden="true"></span>
        DSGVO / CONSENT
      </span>
      <h2 class="hk-consent__h">Eine Frage, dann läuft alles.</h2>
      <p class="hk-consent__p">
        Wir benutzen <strong>technisch erforderliche Cookies</strong>, damit
        die Website überhaupt läuft. Optional: <strong>Analyse-Cookies</strong>
        (anonymisierte Zugriffszahlen über Plausible) — kein Tracking, keine
        US-Daten­weitergabe.
      </p>
    </div>

    <fieldset class="hk-consent__opts">
      <legend class="hk-consent__legend">Was Sie erlauben</legend>

      <label class="hk-consent__opt is-forced">
        <span class="hk-consent__opt-mark" aria-hidden="true">●</span>
        <span class="hk-consent__opt-body">
          <span class="hk-consent__opt-k">NOTWENDIG</span>
          <span class="hk-consent__opt-v">Form-State, Theme, Spam-Schutz · immer aktiv</span>
        </span>
        <input type="checkbox" checked disabled />
      </label>

      <label class="hk-consent__opt">
        <span class="hk-consent__opt-mark" aria-hidden="true">○</span>
        <span class="hk-consent__opt-body">
          <span class="hk-consent__opt-k">STATISTIK</span>
          <span class="hk-consent__opt-v">Plausible · keine Cookies, EU-Hosting, anonymisierte Zähler</span>
        </span>
        <input type="checkbox" data-hk-consent-stat />
      </label>

      <label class="hk-consent__opt">
        <span class="hk-consent__opt-mark" aria-hidden="true">○</span>
        <span class="hk-consent__opt-body">
          <span class="hk-consent__opt-k">MARKETING</span>
          <span class="hk-consent__opt-v">Verzichten wir bewusst — keine Re-Targeting-Pixel</span>
        </span>
        <input type="checkbox" disabled />
      </label>
    </fieldset>

    <div class="hk-consent__actions">
      <button class="hk-consent__btn hk-consent__btn--ghost" data-hk-consent-min type="button" data-cursor-hover>
        <span>NUR NOTWENDIG</span>
      </button>
      <button class="hk-consent__btn hk-consent__btn--mid" data-hk-consent-save type="button" data-cursor-hover>
        <span>AUSWAHL SPEICHERN</span>
      </button>
      <button class="hk-consent__btn hk-consent__btn--primary" data-hk-consent-all type="button" data-cursor-hover>
        <span>ALLES AKZEPTIEREN</span>
        <span aria-hidden="true">→</span>
      </button>
    </div>

    <div class="hk-consent__foot">
      Details in der <a href="/demos/elektro/datenschutz/" data-cursor-hover>Datenschutzerklärung</a>.
      Jederzeit über den Cookie-Status-Indikator im Footer änderbar.
    </div>
  </div>
</aside>

<style>
  .hk-consent {
    position: fixed;
    left: 50%;
    bottom: clamp(1rem, 2vw, 1.5rem);
    transform: translate(-50%, 0);
    z-index: 9000;
    width: min(640px, calc(100% - 2rem));
    background: linear-gradient(180deg,
      var(--color-surface) 0%,
      var(--color-surface-2) 100%);
    border: 1px solid var(--color-rule-strong);
    color: var(--color-text);
    box-shadow:
      0 30px 70px -20px rgba(0, 0, 0, 0.55),
      0 0 0 1px color-mix(in srgb, var(--color-accent) 8%, transparent),
      0 0 60px -20px color-mix(in srgb, var(--color-accent) 25%, transparent);
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 30px);
    transition: opacity 0.6s var(--ease-out-expo),
                transform 0.7s var(--ease-out-expo),
                visibility 0.6s linear;
  }

  /* Corner-Brackets (Premium-Signal) */
  .hk-consent::before,
  .hk-consent::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--color-accent);
    border-style: solid;
    pointer-events: none;
  }
  .hk-consent::before {
    top: -1px; left: -1px;
    border-width: 1.5px 0 0 1.5px;
  }
  .hk-consent::after {
    bottom: -1px; right: -1px;
    border-width: 0 1.5px 1.5px 0;
  }

  .hk-consent.is-open {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .hk-consent.is-leaving {
    opacity: 0;
    transform: translate(-50%, 30px);
  }

  .hk-consent__inner {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hk-consent__head { display: flex; flex-direction: column; gap: 0.6rem; }

  .hk-consent__head-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    font-weight: 700;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .hk-consent__head-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 30%, transparent);
    animation: hk-pulse 2.4s ease-in-out infinite;
  }

  .hk-consent__h {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
  }

  .hk-consent__p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    margin: 0;
  }
  .hk-consent__p strong { color: var(--color-text); font-weight: 600; }

  .hk-consent__opts {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-rule);
  }
  .hk-consent__legend { display: none; }

  .hk-consent__opt {
    display: grid;
    grid-template-columns: 1.5rem 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-rule);
    cursor: pointer;
    transition: background-color 0.3s var(--ease-out-expo);
  }
  .hk-consent__opt:last-child { border-bottom: none; }
  .hk-consent__opt:hover:not(.is-forced) { background: color-mix(in srgb, var(--color-accent) 5%, transparent); }
  .hk-consent__opt.is-forced { cursor: default; }
  .hk-consent__opt input[disabled] + .hk-consent__opt-body { opacity: 0.7; }

  .hk-consent__opt-mark {
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-align: center;
    font-size: 0.9rem;
  }
  .hk-consent__opt input:checked ~ .hk-consent__opt-mark,
  .hk-consent__opt.is-forced .hk-consent__opt-mark {
    color: var(--color-accent);
  }

  .hk-consent__opt-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .hk-consent__opt-k {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--color-text);
    font-weight: 700;
  }
  .hk-consent__opt-v {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  .hk-consent__opt input {
    appearance: none;
    width: 36px;
    height: 18px;
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    position: relative;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
  }
  .hk-consent__opt input::before {
    content: '';
    position: absolute;
    top: 1px;
    left: 1px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-text);
    transition: left 0.3s var(--ease-out-expo), background 0.3s;
  }
  .hk-consent__opt input:checked {
    background: color-mix(in srgb, var(--color-accent) 35%, var(--color-bg));
    border-color: var(--color-accent);
  }
  .hk-consent__opt input:checked::before {
    left: calc(100% - 15px);
    background: var(--color-accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }
  .hk-consent__opt input[disabled] { cursor: not-allowed; opacity: 0.6; }
  .hk-consent__opt.is-forced input { background: color-mix(in srgb, var(--color-accent) 35%, var(--color-bg)); border-color: var(--color-accent); }
  .hk-consent__opt.is-forced input::before { left: calc(100% - 15px); background: var(--color-accent); }

  .hk-consent__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  @media (min-width: 600px) {
    .hk-consent__actions { grid-template-columns: auto auto 1fr; }
  }

  .hk-consent__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s, color 0.3s, transform 0.3s var(--ease-out-expo);
  }
  .hk-consent__btn:hover { transform: translateY(-1px); }

  .hk-consent__btn--ghost {
    background: transparent;
    color: var(--color-muted);
    border: 1px solid var(--color-rule-strong);
  }
  .hk-consent__btn--ghost:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .hk-consent__btn--mid {
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }
  .hk-consent__btn--mid:hover {
    background: color-mix(in srgb, var(--color-text) 80%, var(--color-accent));
  }

  .hk-consent__btn--primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }
  .hk-consent__btn--primary:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, white);
    box-shadow: 0 12px 28px -8px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .hk-consent__foot {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.55;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }
  .hk-consent__foot a { color: var(--color-accent); text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .hk-consent,
    .hk-consent__head-dot,
    .hk-consent__btn { animation: none; transition: opacity 0.2s linear, visibility 0.2s; }
  }
</style>

<script>
  function init() {
    const banner = document.querySelector<HTMLElement>('[data-hk-consent]');
    if (!banner) return;

    // Idempotency-Guard
    if (banner.dataset.hkConsentInit === '1') return;
    banner.dataset.hkConsentInit = '1';

    // Bereits beantwortet?
    if (sessionStorage.getItem('hk-consent') !== null) {
      banner.remove();
      return;
    }

    // Wartet kurz, damit Preloader Vorrang hat
    setTimeout(() => {
      banner.classList.add('is-open');
      banner.setAttribute('aria-hidden', 'false');
    }, 1800);

    const bannerEl = banner;
    function close(choice: string) {
      sessionStorage.setItem('hk-consent', choice);
      bannerEl.classList.remove('is-open');
      bannerEl.classList.add('is-leaving');
      setTimeout(() => bannerEl.remove(), 700);
    }

    bannerEl.querySelector('[data-hk-consent-min]')?.addEventListener('click', () => close('necessary'));
    bannerEl.querySelector('[data-hk-consent-all]')?.addEventListener('click', () => close('all'));
    bannerEl.querySelector('[data-hk-consent-save]')?.addEventListener('click', () => {
      const stat = (bannerEl.querySelector('[data-hk-consent-stat]') as HTMLInputElement | null)?.checked;
      close(stat ? 'necessary+stats' : 'necessary');
    });
  }

  init();

  // Bei Astro View Transitions wird das Banner-Markup pro Sub-Seite neu
  // eingefügt. Wenn die Einwilligung schon erteilt wurde, entfernen wir
  // den Banner aus dem eingehenden DOM (sonst flackert er kurz auf).
  document.addEventListener('astro:before-swap', (e: Event) => {
    if (sessionStorage.getItem('hk-consent') === null) return;
    const newDoc = (e as Event & { newDocument?: Document }).newDocument;
    newDoc?.querySelector('[data-hk-consent]')?.remove();
  });

  document.addEventListener('astro:page-load', init);
</script>
