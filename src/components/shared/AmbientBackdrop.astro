---
/**
 * <AmbientBackdrop />
 *
 * Filmischer fixed-position Background-Layer mit Aurora-Orbs, Stars und
 * subtilem Wireframe-Ikosaeder. Aktiviert sich automatisch wenn das
 * Trigger-Element (per `triggerSelector`) in den Viewport scrollt.
 *
 * Verwendung in der Page:
 *   <AmbientBackdrop triggerSelector="[data-scroll-story]" />
 *
 * Die Komponente legt sich position:fixed über das gesamte Viewport,
 * pointer-events:none, z-index:0 — alle echten Inhalte müssen z-index ≥ 1
 * haben um drüberzuliegen.
 */

interface Props {
  /** CSS-Selector für das Trigger-Element, das die Aktivierung steuert. */
  triggerSelector?: string;
  /** Intensity 0..1. Default 0.55 desktop, 0.4 mobile. */
  intensity?: number;
}

const { triggerSelector = '[data-scroll-story]', intensity } = Astro.props;
---

<div
  class="ambient"
  data-ambient
  data-trigger-selector={triggerSelector}
  data-intensity={intensity ?? ''}
  aria-hidden="true"
>
  <canvas class="ambient__canvas" data-ambient-canvas></canvas>
  <div class="ambient__grid" data-ambient-grid></div>
  <div class="ambient__vignette"></div>
</div>

<style is:global>
  /*
   * Backdrop liegt fixed über dem ganzen Viewport, hinter dem Content.
   * Alle Sections die DRÜBER liegen sollen brauchen position:relative
   * und z-index ≥ 1 — die meisten haben das ohnehin.
   */
  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ambient.is-active {
    opacity: 1;
  }

  .ambient__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Subtiles Dot-Grid das mit Scroll driftet */
  .ambient__grid {
    position: absolute;
    inset: -10%;
    background-image:
      radial-gradient(circle, color-mix(in srgb, var(--color-text) 7%, transparent) 1px, transparent 1.5px);
    background-size: 42px 42px;
    background-position: 0 var(--grid-shift, 0px);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 75%);
    opacity: 0.55;
    will-change: background-position;
  }

  /* Vertikale Vignette — schwarz an Header/Footer, klar in der Mitte */
  .ambient__vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--color-bg) 0%,
      transparent 18%,
      transparent 78%,
      var(--color-bg) 100%
    );
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ambient {
      transition: opacity 0.3s linear;
    }
  }
</style>

<script>
  import { initAmbientBackdrop } from '@lib/ambient-backdrop';

  let cleanup: (() => void) | null = null;

  const start = () => {
    cleanup?.();
    const root = document.querySelector<HTMLElement>('[data-ambient]');
    if (!root) return;
    const sel = root.dataset.triggerSelector || '[data-scroll-story]';
    const trigger = document.querySelector<HTMLElement>(sel);
    const intensityAttr = root.dataset.intensity;
    const intensity = intensityAttr ? parseFloat(intensityAttr) : undefined;
    cleanup = initAmbientBackdrop(root, trigger, { intensity });
  };

  start();
  document.addEventListener('astro:page-load', () => {
    cleanup?.();
    cleanup = null;
    start();
  });
  document.addEventListener('astro:before-swap', () => {
    cleanup?.();
    cleanup = null;
  });
</script>
