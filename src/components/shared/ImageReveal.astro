---
interface Props {
  src: string;
  alt: string;
  /** Reveal-Richtung — von wo der Clip-Path kommt */
  direction?: 'top' | 'bottom' | 'left' | 'right';
  /** Bildbreite (für intrinsische Größe) */
  width?: number;
  /** Bildhöhe */
  height?: number;
  /** ScrollTrigger-Start */
  start?: string;
  /** Loading-Strategie */
  loading?: 'lazy' | 'eager';
  /** Object-Fit */
  fit?: 'cover' | 'contain' | 'fill' | 'none' | 'scale-down';
  /** Object-Position */
  position?: string;
  /** Wrapper-Klassen */
  class?: string;
  /** Wrapper-Aspect-Ratio (z.B. "16/9", "4/5") */
  aspectRatio?: string;
}

const {
  src,
  alt,
  direction = 'bottom',
  width,
  height,
  start = 'top 75%',
  loading = 'lazy',
  fit = 'cover',
  position = 'center',
  class: className = '',
  aspectRatio,
} = Astro.props;
---

<div
  class:list={['image-reveal', className]}
  data-image-reveal
  data-direction={direction}
  data-start={start}
  style={aspectRatio ? `aspect-ratio: ${aspectRatio};` : undefined}
>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    style={`object-fit: ${fit}; object-position: ${position};`}
  />
</div>

<style>
  .image-reveal {
    overflow: hidden;
    position: relative;
    will-change: clip-path;
  }

  .image-reveal img {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  import { imageReveal } from '@lib/animations';
  import type { ImageRevealDirection } from '@lib/animations';

  const cleanups = new Map<HTMLElement, () => void>();

  const start = () => {
    document.querySelectorAll<HTMLElement>('[data-image-reveal]').forEach((el) => {
      const direction = (el.dataset.direction as ImageRevealDirection) ?? 'bottom';
      const triggerStart = el.dataset.start ?? 'top 75%';
      const cleanup = imageReveal(el, direction, triggerStart);
      cleanups.set(el, cleanup);
    });
  };

  const stop = () => {
    cleanups.forEach((fn) => fn());
    cleanups.clear();
  };

  start();
  document.addEventListener('astro:page-load', start);
  document.addEventListener('astro:before-swap', stop);
</script>
