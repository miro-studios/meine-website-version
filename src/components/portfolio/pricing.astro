  }

  .plan__demo-chip-headline {
    font-family: var(--font-display);
    font-size: clamp(0.75rem, 1.1vw, 1rem);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 500;
    z-index: 1;
