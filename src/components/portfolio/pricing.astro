    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-accent) 8%, transparent) 0%,
        color-mix(in srgb, var(--color-accent) 2%, transparent) 100%
      ),
