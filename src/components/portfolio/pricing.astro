  .plan__preview-link:hover { gap: 0.55rem; }

  /* Theme-Farben fuer Demo-Chips */
  .plan__demo-chip--pizzeria .plan__demo-chip-bg {
    background-color: #F8F2E8;
    color: #A8261B;
  }
  .plan__demo-chip--pizzeria .plan__demo-chip-headline { font-style: italic; }
  .plan__demo-chip--pizzeria .plan__demo-chip-overlay {
