    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .plan__demo-chip-cat {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .plan__preview-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
