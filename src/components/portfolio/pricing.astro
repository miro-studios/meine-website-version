  .plan__cta :global(.magnetic-btn) { width: 100%; }

  /* ===== Support-Inklusiv-Banner ========================================= */
  .support-banner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    align-items: center;
