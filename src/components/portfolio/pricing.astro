---
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';

type Plan = {
  index: string;
  name: string;
  tagline: string;
  description: string;
  price: string;
  delivery: string;
  features: readonly string[];
  cta: string;
  variant: 'starter' | 'featured' | 'premium';
  badge?: string;
};

const onePagerPlans: readonly Plan[] = [
  {
    index: '01',
    name: 'Starter',
    tagline: 'Online praesent. Schnell.',
    description:
      'Fuer Selbststaendige und kleine Geschaefte, die endlich sichtbar werden muessen. Eine fokussierte Seite, die Vertrauen aufbaut und zur Anfrage fuehrt.',
    price: '&euro; 599',
    delivery: '5&ndash;7 Werktage',
    features: [
      'Onepager bis 4 Sections',
      'Individuelles Design auf Ihre Marke',
      'Mobile-optimiert &middot; Lighthouse 90+',
      'Basis-SEO (Meta, Sitemap, Schema)',
      'Kontakt- oder Anfrageformular',
      'Ladezeit unter 2 Sekunden',
    ],
    cta: 'Starter starten',
    variant: 'starter',
  },
  {
    index: '02',
    name: 'Growth',
    tagline: 'Mehr Anfragen. Klar messbar.',
    description:
      'Fuer lokale Unternehmen, die nicht nur eine Website wollen &mdash; sondern eine, die verkauft. Editorial-Niveau mit Conversion im Kern.',
    price: '&euro; 1.299',
    delivery: '7&ndash;12 Werktage',
    features: [
      'Onepager bis 6 Sections',
      'Editorial-Design + Custom-Animationen',
      'Premium-SEO (technisch + lokal)',
      'Google-Maps &amp; Bewertungs-Integration',
      'Anfrageformular mit Validierung',
      'Lighthouse 95+ Performance',
      '2 Korrekturschleifen inklusive',
    ],
    cta: 'Growth waehlen',
    variant: 'featured',
    badge: 'Beliebteste Wahl',
  },
  {
    index: '03',
    name: 'Premium',
    tagline: 'Verkaufsstark. Animiert. Einzigartig.',
    description:
      'Wenn Ihr Auftritt auf Awwwards-Niveau spielen soll. Aufwendiges Storytelling, hoechste Conversion &mdash; eine Seite, die nicht vergessen wird.',
    price: '&euro; 2.299',
    delivery: '10&ndash;16 Werktage',
    features: [
      'Voll animierter Onepager (GSAP, Lenis, Custom-Cursor)',
      'Bildrecherche &amp; Auswahl passend zur Marke',
      'Optimierte CTA-Strecken &amp; Conversion-Layout',
      'Erweiterte SEO + Google Business Einrichtung',
      'GA4 + Conversion-Tracking',
      'Unbegrenzte Korrekturschleifen',
    ],
    cta: 'Premium anfragen',
    variant: 'premium',
  },
];

const multiPagePlans: readonly Plan[] = [
  {
    index: '01',
    name: 'Basic',
    tagline: 'Ihr Unternehmen, klar strukturiert.',
    description:
      'Die mehrseitige Basis fuer etablierte Selbststaendige, die mehr Tiefe brauchen &mdash; Vertrauen durch Struktur, ohne Schnickschnack.',
    price: '&euro; 1.499',
    delivery: '14&ndash;21 Werktage',
    features: [
      '4&ndash;5 Seiten (Start, &Uuml;ber, Leistungen, Kontakt + 1)',
      'Editorial-Design, voll responsiv',
      'Basis-CMS fuer eigenstaendige Pflege',
      'SEO-Grundlagen + lokale Optimierung',
      'Ladezeit unter 2 Sekunden',
      'SSL &amp; Sicherheits-Setup',
    ],
    cta: 'Basic anfragen',
    variant: 'starter',
  },
  {
    index: '02',
    name: 'Business',
    tagline: 'Skalieren. Vertrauen aufbauen. Wachsen.',
    description:
      'Fuer wachsende Unternehmen, die ihre Website als Wachstumsmotor nutzen. Tiefe, Story und Lead-Funnel in einem konsistenten Auftritt.',
    price: '&euro; 2.799',
    delivery: '4&ndash;6 Wochen',
    features: [
      '6&ndash;10 Seiten inkl. Blog oder Case-Studies',
      'Erweitertes CMS mit eigenen Modulen',
      'SEO-Strategie + Content-Architektur',
      'Custom-Animationen &amp; Story-Sections',
      'DE/EN-Mehrsprachigkeit auf Wunsch',
      'Lead-Funnel- / Newsletter-Anbindung',
      'GA4 + Conversion-Tracking',
      '3 Korrekturschleifen inklusive',
    ],
    cta: 'Business buchen',
    variant: 'featured',
    badge: 'Beliebteste Wahl',
  },
  {
    index: '03',
    name: 'Pro',
    tagline: 'Der digitale Auftritt, der gewinnt.',
    description:
      'Fuer etablierte Marken, die maximale Tiefe und Wirkung brauchen. Konzipiert, gestaltet und gebaut wie ein Studio-Flagship.',
    price: '&euro; 4.499',
    delivery: '6&ndash;8 Wochen',
    features: [
      'Unbegrenzte Seiten + Custom-Module',
      'Headless-CMS auf Wunsch (Sanity, Storyblok)',
      'Premium-SEO + Content-Strategie',
      'Bildrecherche &amp; Stock-Foto Direktion',
      'Komplexe Animationen &amp; Interaktionen',
      'Performance-Garantie Lighthouse 95+',
      'E-Commerce-Anbindung moeglich',
      'Kickoff-Gespraech &amp; Anforderungsanalyse',
    ],
    cta: 'Pro anfragen',
    variant: 'premium',
  },
];

const supportInclusions = [
  'Domain (.de oder .com) inklusive',
  'Cloudflare Hosting inklusive',
  'SSL-Zertifikat automatisch',
  'Inhalts-Aenderungen (Texte, Bilder)',
  'Bug-Fixes &amp; technischer Support',
] as const;
---

<section class="pricing" aria-labelledby="pricing-title">
  <div class="pricing__inner">
    <header class="pricing__header">
      <span class="pricing__eyebrow">
        <span class="dash" aria-hidden="true"></span>
        Pakete / 03
      </span>

      <SplitText
        as="h2"
        by="words"
        stagger={0.05}
        class="pricing__title"
        id="pricing-title"
      >
        Klare Pakete.
      </SplitText>

      <p class="pricing__intro">
        Drei Stufen pro Format &mdash; vom fokussierten Einstieg bis zum Premium-Auftritt.
        Domain, Hosting und Support in jedem Paket inklusive. Keine
        Vertragsfalle, keine versteckten Aufschl&auml;ge.
      </p>
    </header>

    <!-- ============== Master Toggle ========================================= -->
    <div class="pricing__sync" data-sync data-active="one-pager">
      <div
        class="demo-toggle pricing__master-toggle"
        role="tablist"
        aria-label="Format w&auml;hlen"
        data-toggle
      >
        <span class="demo-toggle__rail" aria-hidden="true"></span>
        <span class="demo-toggle__halo" aria-hidden="true"></span>
        <span class="demo-toggle__thumb" aria-hidden="true">
          <span class="demo-toggle__thumb-shine" aria-hidden="true"></span>
        </span>
        <button
          type="button"
          class="demo-toggle__option is-active"
          role="tab"
          aria-selected="true"
          data-target="one-pager"
          data-cursor-hover
        >
          <span class="demo-toggle__option-dot" aria-hidden="true"></span>
          <span class="demo-toggle__option-stack">
            <span class="demo-toggle__option-label">One-Pager</span>
            <span class="demo-toggle__option-price">599 &ndash; 2.299 &euro;</span>
          </span>
          <span class="demo-toggle__option-arrow" aria-hidden="true">&rarr;</span>
        </button>
        <button
          type="button"
          class="demo-toggle__option"
          role="tab"
          aria-selected="false"
          data-target="multi-page"
          data-cursor-hover
        >
          <span class="demo-toggle__option-dot" aria-hidden="true"></span>
          <span class="demo-toggle__option-stack">
            <span class="demo-toggle__option-label">Multi-Page</span>
            <span class="demo-toggle__option-price">1.499 &ndash; 4.499 &euro;</span>
          </span>
          <span class="demo-toggle__option-arrow" aria-hidden="true">&rarr;</span>
        </button>
      </div>

      <!-- ============== Plan-Panels ========================================== -->
      <div class="plans-panels">

        <!-- One-Pager -->
        <div class="plans-panel is-active" role="tabpanel" data-panel="one-pager" aria-label="One-Pager Pakete">
          <div class="pricing__grid">
            <RevealOnScroll class="pricing__grid-inner" stagger={0.1} y={50}>
              {onePagerPlans.map((plan) => (
                <article class:list={['plan', `plan--${plan.variant}`]} data-cursor-hover>
                  {plan.badge && <span class="plan__badge mono-label">{plan.badge}</span>}

                  <header class="plan__head">
                    <span class="plan__index mono-label">{plan.index} / One-Pager</span>
                    <h3 class="plan__name" set:html={plan.name} />
                    <p class="plan__tagline" set:html={plan.tagline} />
                  </header>

                  <div class="plan__price">
                    <span class="plan__price-amount" set:html={plan.price} />
                    <span class="plan__price-suffix">einmalig</span>
                  </div>

                  <p class="plan__delivery mono-label">
                    <span class="dash" aria-hidden="true" />
                    Lieferzeit <span set:html={plan.delivery} />
                  </p>

                  <p class="plan__description" set:html={plan.description} />

                  <ul class="plan__features">
                    {plan.features.map((f) => (
                      <li>
                        <span class="plan__check" aria-hidden="true">+</span>
                        <span set:html={f} />
                      </li>
                    ))}
                    <li class="plan__feature--included">
                      <span class="plan__check" aria-hidden="true">&#9733;</span>
                      Domain, Hosting &amp; Support inklusive
                    </li>
                  </ul>

                  <div class="plan__cta">
                    <MagneticButton
                      href="/kontakt"
                      variant={plan.variant === 'featured' ? 'primary' : 'ghost'}
                      strength={0.25}
                      class="plan__btn"
                    >
                      <span set:html={plan.cta} />
                      <span aria-hidden="true">&rarr;</span>
                    </MagneticButton>
                  </div>
                </article>
              ))}
            </RevealOnScroll>
          </div>
        </div>

        <!-- Multi-Page -->
        <div class="plans-panel" role="tabpanel" data-panel="multi-page" aria-label="Multi-Page Pakete" hidden>
          <div class="pricing__grid">
            <RevealOnScroll class="pricing__grid-inner" stagger={0.1} y={50}>
              {multiPagePlans.map((plan) => (
                <article class:list={['plan', `plan--${plan.variant}`]} data-cursor-hover>
                  {plan.badge && <span class="plan__badge mono-label">{plan.badge}</span>}

                  <header class="plan__head">
                    <span class="plan__index mono-label">{plan.index} / Multi-Page</span>
                    <h3 class="plan__name" set:html={plan.name} />
                    <p class="plan__tagline" set:html={plan.tagline} />
                  </header>

                  <div class="plan__price">
                    <span class="plan__price-amount" set:html={plan.price} />
                    <span class="plan__price-suffix">einmalig</span>
                  </div>

                  <p class="plan__delivery mono-label">
                    <span class="dash" aria-hidden="true" />
                    Lieferzeit <span set:html={plan.delivery} />
                  </p>

                  <p class="plan__description" set:html={plan.description} />

                  <ul class="plan__features">
                    {plan.features.map((f) => (
                      <li>
                        <span class="plan__check" aria-hidden="true">+</span>
                        <span set:html={f} />
                      </li>
                    ))}
                    <li class="plan__feature--included">
                      <span class="plan__check" aria-hidden="true">&#9733;</span>
                      Domain, Hosting &amp; Support inklusive
                    </li>
                  </ul>

                  <div class="plan__cta">
                    <MagneticButton
                      href="/kontakt"
                      variant={plan.variant === 'featured' ? 'primary' : 'ghost'}
                      strength={0.25}
                      class="plan__btn"
                    >
                      <span set:html={plan.cta} />
                      <span aria-hidden="true">&rarr;</span>
                    </MagneticButton>
                  </div>
                </article>
              ))}
            </RevealOnScroll>
          </div>
        </div>

      </div>
    </div>

    <!-- ============== Support-Inklusiv-Banner ============================== -->
    <aside class="support-banner" aria-label="Im Preis enthaltener Support">
      <div class="support-banner__head">
        <span class="support-banner__icon" aria-hidden="true">&#9733;</span>
        <div>
          <h4 class="support-banner__title">
            Domain, Hosting &amp; Support &mdash; alles inklusive
          </h4>
          <p class="support-banner__sub">
            <strong>&euro; 34,99 / Monat</strong> &mdash; kein Aufpreis, kein Add-On.
            Jederzeit monatlich k&uuml;ndbar.
          </p>
        </div>
      </div>
      <ul class="support-banner__list">
        {supportInclusions.map((f) => (
          <li>
            <span class="support-banner__check" aria-hidden="true">+</span>
            <span set:html={f} />
          </li>
        ))}
      </ul>
    </aside>

    <footer class="pricing__footer">
      <p class="pricing__note">
        Alle Preise zzgl. 19&nbsp;% USt. Monatliche K&uuml;ndigung jederzeit m&ouml;glich.
        Domain-Registrierung im ersten Monat enthalten &mdash; keine versteckten Aufschl&auml;ge.
      </p>
    </footer>
  </div>
</section>

<style>
  .pricing {
    position: relative;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad);
    background-color: color-mix(in srgb, var(--color-text) 4%, var(--color-bg));
  }

  .pricing__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .pricing__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 60rem;
  }

  .pricing__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .pricing__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
  }

  .pricing__intro {
    font-size: var(--text-lg);
    line-height: 1.5;
    max-width: 52ch;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
  }

  /* ===== Master Toggle =================================================== */
  .pricing__sync {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .pricing__master-toggle {
    width: 100%;
    max-width: clamp(42rem, 78vw, 64rem);
    margin-inline: auto;
  }

  /* ===== Plan-Panels Crossfade ========================================== */
  .plans-panels { position: relative; }

  .plans-panel {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.45s cubic-bezier(0.32, 0.72, 0, 1);
    pointer-events: none;
  }
  .plans-panel.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .plans-panel[hidden] { display: none; }

  /* ===== 3-Column Plan Grid ============================================== */
  .pricing__grid :global(.pricing__grid-inner) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
    align-items: stretch;
  }

  @media (max-width: 1100px) {
    .pricing__grid :global(.pricing__grid-inner) {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* ===== Plan card ======================================================== */
  .plan {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 2.2vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg);
    cursor: none;
    transition: transform 0.5s var(--ease-out-expo),
      border-color 0.4s var(--ease-out-expo);
    isolation: isolate;
    height: 100%;
  }

  .plan:hover { transform: translateY(-4px); }

  .plan--featured {
    border-color: var(--color-accent);
    box-shadow:
      0 1px 0 0 color-mix(in srgb, var(--color-accent) 25%, transparent),
      0 20px 40px -20px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .plan--featured::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--color-accent) 0%, transparent 60%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: -1;
  }

  @media (min-width: 1101px) {
    .plan--featured { transform: translateY(-12px); }
    .plan--featured:hover { transform: translateY(-16px); }
  }

  .plan--premium {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-text) 3%, var(--color-bg)) 0%,
      var(--color-bg) 100%
    );
  }

  .plan__badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: color-mix(in srgb, var(--color-text) 88%, transparent);
    color: var(--color-bg);
    padding: 0.45rem 0.9rem;
    border-radius: 9999px;
    line-height: 1;
    white-space: nowrap;
  }
  .plan--featured .plan__badge {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .plan__head { display: flex; flex-direction: column; gap: 0.4rem; }
  .plan__index { color: var(--color-muted); }

  .plan__name {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 2.6vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 500;
    margin: 0;
  }

  .plan__tagline {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-style: italic;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    margin: 0;
  }

  .plan__price {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    padding-block: 0.6rem 0.4rem;
  }

  .plan__price-suffix {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .plan__price-amount {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 3.5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--color-text);
  }

  .plan--featured .plan__price-amount { color: var(--color-accent); }

  .plan__delivery {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    margin: 0;
  }
  .plan__delivery .dash { width: 1.5rem; }

  .plan__description {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
  }

  .plan__features {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .plan__features li {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    font-size: var(--text-sm);
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-text) 88%, transparent);
  }

  .plan__check {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    line-height: 1;
    flex-shrink: 0;
  }

  .plan__feature--included {
    margin-top: 0.35rem;
    padding-top: 0.55rem;
    border-top: 1px dashed color-mix(in srgb, var(--color-text) 14%, transparent);
    color: var(--color-text) !important;
    font-weight: 500;
  }
  .plan__feature--included .plan__check { color: var(--color-accent); }

  /* ===== Demo-Vorschau im Plan ============================================ */
  .plan__preview {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    margin-top: 0.25rem;
  }

  .plan__preview-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  .plan__preview-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }
  .plan__preview-row--two {
    grid-template-columns: 1fr 1fr;
  }

  .plan__demo-chip {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-decoration: none;
    color: inherit;
    cursor: none;
    transition: transform 0.4s var(--ease-out-expo);
  }

  a.plan__demo-chip:hover { transform: translateY(-2px); }

  .plan__demo-chip-bg {
    position: relative;
    display: flex;
    align-items: flex-end;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    padding: 0.5rem 0.65rem;
    isolation: isolate;
    transition: transform 0.5s var(--ease-out-expo);
  }

  a.plan__demo-chip:hover .plan__demo-chip-bg { transform: scale(1.02); }

  .plan__demo-chip--soon .plan__demo-chip-bg {
    border: 1px dashed color-mix(in srgb, var(--color-text) 20%, transparent);
  }

  .plan__demo-chip-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.85;
    pointer-events: none;
  }

  .plan__demo-chip-hatch {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      135deg,
      transparent 0,
      transparent 10px,
      color-mix(in srgb, currentColor 12%, transparent) 10px,
      color-mix(in srgb, currentColor 12%, transparent) 11px
    );
    opacity: 0.4;
  }

  .plan__demo-chip-soon-label {
    position: absolute;
    top: 0.4rem;
    left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.45rem;
