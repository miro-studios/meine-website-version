<script>
  const init = () => {
    const syncRoot = document.querySelector<HTMLElement>('[data-sync]');
    if (!syncRoot) return;

    const toggle = syncRoot.querySelector<HTMLElement>('[data-toggle]');
    if (!toggle) return;

    const options = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.demo-toggle__option'));
    const panels = Array.from(syncRoot.querySelectorAll<HTMLElement>('[data-panel]'));

    const setActive = (target: string) => {
      if (syncRoot.dataset.active === target) return;
      syncRoot.dataset.active = target;
      toggle.dataset.active = target;

      options.forEach((opt) => {
        const isActive = opt.dataset.target === target;
        opt.classList.toggle('is-active', isActive);
        opt.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      const outgoing = panels.find((p) => p.classList.contains('is-active'));
      const incoming = panels.find((p) => p.dataset.panel === target);
      if (!incoming) return;

      if (outgoing && outgoing !== incoming) {
        outgoing.classList.remove('is-active');
        window.setTimeout(() => outgoing.setAttribute('hidden', ''), 200);
      }

      incoming.removeAttribute('hidden');
      void incoming.offsetWidth;
      window.setTimeout(
        () => incoming.classList.add('is-active'),
        outgoing && outgoing !== incoming ? 200 : 0
      );
    };

    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        if (opt.dataset.target) setActive(opt.dataset.target);
      });
    });

    toggle.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      e.preventDefault();
      const idx = options.findIndex((o) => o.classList.contains('is-active'));
      const next =
        e.key === 'ArrowRight'
          ? options[(idx + 1) % options.length]
          : options[(idx - 1 + options.length) % options.length];
      next.focus();
      if (next.dataset.target) setActive(next.dataset.target);
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
