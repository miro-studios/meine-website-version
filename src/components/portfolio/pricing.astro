  /* ===== Toggle =========================================================== */
  .demo-toggle {
    --toggle-pad: 8px;
    --toggle-spring: cubic-bezier(0.5, 1.6, 0.4, 1);
    --toggle-glide: cubic-bezier(0.32, 0.72, 0, 1);
    position: relative;
    display: flex;
    width: 100%;
    padding: var(--toggle-pad);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-text) 4%, transparent) 0%,
        color-mix(in srgb, var(--color-text) 12%, transparent) 100%
      );
    border: 1px solid color-mix(in srgb, var(--color-text) 14%, transparent);
    border-radius: 9999px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-text) 8%, transparent),
      inset 0 -1px 0 color-mix(in srgb, var(--color-bg) 30%, transparent),
      0 1px 0 color-mix(in srgb, var(--color-bg) 40%, transparent);
    transition:
      border-color 0.5s var(--toggle-glide),
      box-shadow 0.5s var(--toggle-glide);
  }

  .demo-toggle:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-text) 8%, transparent),
      inset 0 -1px 0 color-mix(in srgb, var(--color-bg) 30%, transparent),
      0 0 0 4px color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  /* Subtler inner rail with vertical separators */
  .demo-toggle__rail {
    position: absolute;
    inset: var(--toggle-pad);
    border-radius: 9999px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .demo-toggle__rail::before,
  .demo-toggle__rail::after {
    content: '';
    position: absolute;
    top: 22%;
    bottom: 22%;
    width: 1px;
    background: color-mix(in srgb, var(--color-text) 14%, transparent);
    opacity: 0;
    transition: opacity 0.4s var(--toggle-glide);
  }
  .demo-toggle__rail::before { left: 50%; }
  .demo-toggle__rail::after { left: 50%; transform: translateX(-1px); }
  .demo-toggle:hover .demo-toggle__rail::before { opacity: 0.6; }

  /* Pulsing halo behind thumb */
  .demo-toggle__halo {
    position: absolute;
    top: var(--toggle-pad);
    left: var(--toggle-pad);
    height: calc(100% - var(--toggle-pad) * 2);
    width: calc(50% - var(--toggle-pad));
    border-radius: 9999px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-accent) 35%, transparent) 0%,
      transparent 70%
    );
    filter: blur(20px);
    transform: translateX(0) scale(1);
    transition: transform 0.7s var(--toggle-spring);
    will-change: transform;
    opacity: 0.85;
    animation: toggle-halo-pulse 3.5s ease-in-out infinite;
  }
  .demo-toggle[data-active='multi-page'] .demo-toggle__halo {
    transform: translateX(100%) scale(1);
  }

  @keyframes toggle-halo-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }

  /* Thumb with gradient + spring animation + squash */
  .demo-toggle__thumb {
    position: absolute;
    top: var(--toggle-pad);
    left: var(--toggle-pad);
    height: calc(100% - var(--toggle-pad) * 2);
    width: calc(50% - var(--toggle-pad));
    border-radius: 9999px;
    background:
      linear-gradient(
        135deg,
        var(--color-accent) 0%,
        color-mix(in srgb, var(--color-accent) 75%, var(--color-text)) 100%
      );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, #fff 30%, transparent),
      inset 0 -1px 0 color-mix(in srgb, #000 25%, transparent),
      0 2px 6px color-mix(in srgb, var(--color-accent) 35%, transparent),
      0 12px 32px -6px color-mix(in srgb, var(--color-accent) 55%, transparent);
    transition:
      transform 0.7s var(--toggle-spring),
      box-shadow 0.5s var(--toggle-glide);
    z-index: 1;
    will-change: transform;
    overflow: hidden;
    isolation: isolate;
  }

  .demo-toggle[data-active='multi-page'] .demo-toggle__thumb {
    transform: translateX(100%);
  }

  /* Squash effect during transition */
  .demo-toggle[data-animating='true'] .demo-toggle__thumb {
    animation: toggle-thumb-squash 0.7s var(--toggle-spring);
  }

  @keyframes toggle-thumb-squash {
    0% { scale: 1 1; }
    35% { scale: 1.08 0.86; }
    70% { scale: 0.96 1.04; }
    100% { scale: 1 1; }
  }

  /* Shine sweep across thumb */
  .demo-toggle__thumb-shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      110deg,
      transparent 30%,
      color-mix(in srgb, #fff 45%, transparent) 50%,
      transparent 70%
    );
    transform: translateX(-110%);
    pointer-events: none;
  }
  .demo-toggle[data-animating='true'] .demo-toggle__thumb-shine {
    animation: toggle-shine 0.8s ease-out;
  }
  @keyframes toggle-shine {
    0%   { transform: translateX(-110%); }
    100% { transform: translateX(110%); }
  }

  /* Hover-lean: thumb leans toward the inactive option being hovered */
  .demo-toggle:has(.demo-toggle__option:not(.is-active):hover) .demo-toggle__thumb {
    transform: translateX(2%);
  }
  .demo-toggle[data-active='multi-page']:has(.demo-toggle__option:not(.is-active):hover) .demo-toggle__thumb {
    transform: translateX(98%);
  }

  /* Options */
  .demo-toggle__option {
    position: relative;
    z-index: 2;
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: clamp(0.85rem, 1.4vw, 1.1rem) clamp(1rem, 2vw, 1.6rem);
    background: none;
    border: none;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-text) 60%, transparent);
    cursor: none;
    border-radius: 9999px;
    transition:
      color 0.4s var(--toggle-glide),
      transform 0.5s var(--toggle-spring);
    -webkit-tap-highlight-color: transparent;
    text-align: center;
    line-height: 1.2;
    overflow: hidden;
  }

  .demo-toggle__option:hover { color: var(--color-text); }
  .demo-toggle__option.is-active { color: var(--color-bg); }

  /* Inactive hovered option scales up subtly */
  .demo-toggle__option:not(.is-active):hover {
    transform: scale(1.03);
  }

  .demo-toggle__option:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  /* Indicator dot */
  .demo-toggle__option-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    opacity: 0.35;
    transform: scale(0.7);
    transition:
      opacity 0.45s var(--toggle-glide),
      transform 0.55s var(--toggle-spring),
      box-shadow 0.45s var(--toggle-glide);
  }

  .demo-toggle__option.is-active .demo-toggle__option-dot {
    opacity: 1;
    transform: scale(1);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--color-bg) 25%, transparent),
      0 0 12px color-mix(in srgb, #fff 60%, transparent);
    animation: toggle-dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes toggle-dot-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--color-bg) 25%, transparent),
        0 0 8px color-mix(in srgb, #fff 50%, transparent);
    }
    50% {
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--color-bg) 35%, transparent),
        0 0 18px color-mix(in srgb, #fff 80%, transparent);
    }
  }

  /* Option text stack */
  .demo-toggle__option-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    line-height: 1;
    text-align: left;
  }

  .demo-toggle__option-label {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: none;
    transition:
      letter-spacing 0.6s var(--toggle-glide),
      transform 0.5s var(--toggle-spring);
  }

  .demo-toggle__option-price {
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 0.75vw, 0.75rem);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    opacity: 0.7;
    transition:
      opacity 0.45s var(--toggle-glide),
      letter-spacing 0.6s var(--toggle-glide);
  }

  .demo-toggle__option.is-active .demo-toggle__option-label {
    letter-spacing: 0;
  }
  .demo-toggle__option.is-active .demo-toggle__option-price {
    opacity: 0.9;
    letter-spacing: 0.2em;
  }

  /* Arrow appears on active */
  .demo-toggle__option-arrow {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 1.15rem;
    line-height: 1;
    opacity: 0;
    transform: translateX(-8px);
    transition:
      opacity 0.45s var(--toggle-glide),
      transform 0.55s var(--toggle-spring);
  }

  .demo-toggle__option.is-active .demo-toggle__option-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .demo-toggle__option:not(.is-active):hover .demo-toggle__option-arrow {
    opacity: 0.5;
    transform: translateX(-4px);
  }

  @media (max-width: 640px) {
    .demo-toggle__option { gap: 0.4rem; }
    .demo-toggle__option-arrow { display: none; }
    .demo-toggle__option-price { font-size: 0.6rem; letter-spacing: 0.12em; }
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-toggle__thumb,
    .demo-toggle__halo,
    .plans-panel,
    .demo-toggle__option,
    .demo-toggle__option-dot,
    .demo-toggle__option-label,
    .demo-toggle__option-price,
    .demo-toggle__option-arrow {
      transition: none;
      animation: none !important;
    }
    .demo-toggle__thumb-shine { display: none; }
  }
</style>

<script>
  const init = () => {
    const syncRoot = document.querySelector<HTMLElement>('[data-sync]');
    if (!syncRoot) return;

    const toggle = syncRoot.querySelector<HTMLElement>('[data-toggle]');
    if (!toggle) return;

    const options = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.demo-toggle__option'));
    const panels = Array.from(syncRoot.querySelectorAll<HTMLElement>('[data-panel]'));

    let animTimer: number | undefined;

    const setActive = (target: string) => {
      if (syncRoot.dataset.active === target) return;
      syncRoot.dataset.active = target;
      toggle.dataset.active = target;

      // Trigger one-shot squash + shine animations on thumb
      toggle.dataset.animating = 'true';
      window.clearTimeout(animTimer);
      animTimer = window.setTimeout(() => {
        delete toggle.dataset.animating;
      }, 800);

      options.forEach((opt) => {
        const isActive = opt.dataset.target === target;
        opt.classList.toggle('is-active', isActive);
        opt.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      const outgoing = panels.find((p) => p.classList.contains('is-active'));
      const incoming = panels.find((p) => p.dataset.panel === target);
      if (!incoming) return;

      if (outgoing && outgoing !== incoming) {
        outgoing.classList.remove('is-active');
        window.setTimeout(() => outgoing.setAttribute('hidden', ''), 200);
      }

      incoming.removeAttribute('hidden');
      void incoming.offsetWidth;
      window.setTimeout(
        () => incoming.classList.add('is-active'),
        outgoing && outgoing !== incoming ? 200 : 0
      );
    };

    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        if (opt.dataset.target) setActive(opt.dataset.target);
      });
    });

    toggle.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      e.preventDefault();
      const idx = options.findIndex((o) => o.classList.contains('is-active'));
      const next =
        e.key === 'ArrowRight'
          ? options[(idx + 1) % options.length]
          : options[(idx - 1 + options.length) % options.length];
      next.focus();
      if (next.dataset.target) setActive(next.dataset.target);
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
