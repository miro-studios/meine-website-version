---
/**
 * miro-studios — Hero (Editorial Studio Showcase v2)
 *
 * Aufwändig & elegant: animierter Aurora-Background, asymmetrische
 * Mega-Display-Typo mit Branchen-Rotator, drei Floating Glass-Cards mit
 * Mausparallax, subtiles Knotenpunkt-Netzwerk im Hintergrund, kinetischer
 * Marquee am Boden. 3D-Tilt auf die Headline bei Mausbewegung.
 *
 * Alle Inhalte real — keine fiktiven Stats/Reviews. Reduced-Motion-safe.
 */
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
import HeroNetwork from './HeroNetwork.astro';
---

<section class="hero" aria-labelledby="hero-headline" data-hero>
  <!-- Layer 1: Aurora-Mesh-Gradient ──────────────────────────────────── -->
  <div class="hero__aurora" aria-hidden="true">
    <div class="hero__aurora-blob hero__aurora-blob--1"></div>
    <div class="hero__aurora-blob hero__aurora-blob--2"></div>
    <div class="hero__aurora-blob hero__aurora-blob--3"></div>
  </div>

  <!-- Layer 2: Filmgrain-Noise ───────────────────────────────────────── -->
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Layer 3: Knotenpunkt-Netzwerk (subtle, hinten) ──────────────────── -->
  <div class="hero__network" aria-hidden="true">
    <HeroNetwork nodes={24} maxDist={140} speed={14} />
  </div>

  <!-- Layer 4: Top-Bar ────────────────────────────────────────────────── -->
  <header class="hero__top">
    <span class="hero__brand">
      <span class="hero__brand-mark" aria-hidden="true">◇</span>
      <span class="hero__brand-text">miro-studios</span>
      <span class="hero__brand-sep" aria-hidden="true">·</span>
      <span class="hero__brand-loc">Kierspe · NRW</span>
    </span>

    <span class="hero__avail">
      <span class="hero__avail-dot" aria-hidden="true"></span>
      <span class="hero__avail-label">Verfügbar für</span>
      <span class="hero__avail-period">Q2 / Q3 2026</span>
    </span>
  </header>

  <!-- Layer 5: Main Content ───────────────────────────────────────────── -->
  <div class="hero__main">
    <!-- Editorial-Spalte links -->
    <div class="hero__editorial">
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-line" aria-hidden="true"></span>
        <span>Webdesign &amp; Entwicklung &mdash; aus dem Sauerland</span>
      </p>

      <h1 id="hero-headline" class="hero__headline" data-hero-headline>
        <SplitText as="span" by="words" stagger={0.06} class="hero__line hero__line--1">
          Websites,
        </SplitText>
        <SplitText
          as="span"
          by="words"
          stagger={0.06}
          delay={0.2}
          class="hero__line hero__line--italic hero__line--2"
        >
          die verkaufen.
        </SplitText>
        <span class="hero__line hero__line--rotator hero__line--3">
          <span class="hero__rotator-prefix">für</span>
          <span class="hero__rotator" aria-live="polite">
            <span class="hero__rotator-word is-active">deine Pizzeria</span>
            <span class="hero__rotator-word">deinen Friseur</span>
            <span class="hero__rotator-word">dein Café</span>
            <span class="hero__rotator-word">dein Handwerk</span>
          </span>
        </span>
      </h1>

      <p class="hero__tagline">
        Ein junges Studio aus Kierspe baut Websites für lokale Geschäfte —
        klare Gestaltung, ehrliche Preise, ein Ansprechpartner.
      </p>

      <div class="hero__actions">
        <MagneticButton href="/arbeiten" variant="primary" strength={0.3} class="hero__cta">
          <span>Demos ansehen</span>
          <span class="hero__cta-arrow" aria-hidden="true">→</span>
        </MagneticButton>

        <a href="/kontakt" class="hero__secondary">
          <span class="hero__secondary-label">oder direkt</span>
          <span class="hero__secondary-line">
            <span>Anfrage starten</span>
            <span class="hero__secondary-arrow" aria-hidden="true">↗</span>
          </span>
        </a>
      </div>
    </div>

    <!-- Floating Glass-Cards (Mausparallax) -->
    <aside class="hero__cards" aria-hidden="true">
      <div
        class="hero-card hero-card--available"
        data-parallax="0.45"
        style="--delay: 0.4s;"
      >
        <span class="hero-card__icon" aria-hidden="true">
          <span class="hero-card__pulse"></span>
          <span class="hero-card__dot"></span>
        </span>
        <div class="hero-card__body">
          <span class="hero-card__label">Status</span>
          <span class="hero-card__value">Verfügbar Q2 / Q3 2026</span>
        </div>
      </div>

      <div
        class="hero-card hero-card--delivery"
        data-parallax="0.28"
        style="--delay: 0.55s;"
      >
        <span class="hero-card__icon hero-card__icon--time" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" stroke-linecap="round" />
          </svg>
        </span>
        <div class="hero-card__body">
          <span class="hero-card__label">Lieferzeit ab</span>
          <span class="hero-card__value hero-card__value--accent">
            5 <span class="hero-card__unit">Tagen</span>
          </span>
        </div>
      </div>

      <div
        class="hero-card hero-card--code"
        data-parallax="0.18"
        style="--delay: 0.7s;"
      >
        <span class="hero-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="m8 6-6 6 6 6M16 6l6 6-6 6M14 4l-4 16" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <div class="hero-card__body">
          <span class="hero-card__label">Code</span>
          <span class="hero-card__value">100 % selbst geschrieben</span>
        </div>
      </div>
    </aside>
  </div>

  <!-- Layer 6: Bottom-Marquee (kinetisch) ─────────────────────────────── -->
  <div class="hero__bottom" aria-hidden="true">
    <div class="hero__marquee" data-hero-marquee>
      <span class="hero__marquee-track">
        {Array.from({ length: 3 }).map(() => (
          <span class="hero__marquee-group">
            <span>Editorial Webdesign</span>
            <span class="hero__marquee-dot">◇</span>
            <span>Aus Kierspe</span>
            <span class="hero__marquee-dot">◇</span>
            <span>Für lokale Geschäfte</span>
            <span class="hero__marquee-dot">◇</span>
            <span>Selbst geschriebener Code</span>
            <span class="hero__marquee-dot">◇</span>
            <span>Ab 599 €</span>
            <span class="hero__marquee-dot">◇</span>
          </span>
        ))}
      </span>
    </div>
  </div>

  <!-- Scroll-Hinweis -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-label">scrollen</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  /* ── Container ──────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    padding-inline: var(--container-pad);
    padding-block: clamp(5rem, 9vw, 8rem) 0;
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    gap: clamp(1.5rem, 4vw, 3rem);
    overflow: hidden;
    isolation: isolate;
    background-color: var(--color-bg);
  }

  /* ══════════════════════════════════════════════════════════════════════
     Layer 1: Aurora-Mesh-Gradient
     ══════════════════════════════════════════════════════════════════════ */
  .hero__aurora {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero__aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
    will-change: transform;
  }

  .hero__aurora-blob--1 {
    width: clamp(400px, 50vw, 800px);
    aspect-ratio: 1;
    top: -15%;
    right: -10%;
    background: radial-gradient(
      circle at 30% 30%,
      color-mix(in srgb, var(--color-accent) 55%, transparent) 0%,
      transparent 70%
    );
    animation: aurora-drift-1 24s ease-in-out infinite;
  }

  .hero__aurora-blob--2 {
    width: clamp(350px, 45vw, 700px);
    aspect-ratio: 1;
    bottom: -20%;
    left: -10%;
    background: radial-gradient(
      circle at 60% 60%,
      color-mix(in srgb, #E8B547 35%, transparent) 0%,
      transparent 70%
    );
    animation: aurora-drift-2 30s ease-in-out infinite;
  }

  .hero__aurora-blob--3 {
    width: clamp(300px, 40vw, 600px);
    aspect-ratio: 1;
    top: 40%;
    left: 35%;
    background: radial-gradient(
      circle at 50% 50%,
      color-mix(in srgb, var(--color-accent-deep, #7A2B1F) 22%, transparent) 0%,
      transparent 70%
    );
    animation: aurora-drift-3 26s ease-in-out infinite;
  }

  @keyframes aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-40px, 30px) scale(1.08); }
    66%      { transform: translate(20px, -20px) scale(0.95); }
  }

  @keyframes aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(50px, -40px) scale(1.1); }
  }

  @keyframes aurora-drift-3 {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50%      { transform: translate(calc(-50% + 30px), calc(-50% - 40px)) scale(0.9); }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Layer 2: Filmgrain-Noise
     ══════════════════════════════════════════════════════════════════════ */
  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.07;
    mix-blend-mode: multiply;
  }

  /* ══════════════════════════════════════════════════════════════════════
     Layer 3: Network (subtle, hinter Content)
     ══════════════════════════════════════════════════════════════════════ */
  .hero > .hero__network {
    position: absolute;
    top: 50%;
    right: clamp(-3rem, -2vw, -2rem);
    transform: translateY(-50%);
    width: clamp(320px, 38vw, 560px);
    aspect-ratio: 1;
    opacity: 0.55;
    z-index: 2;
    pointer-events: auto;
  }

  @media (max-width: 1100px) {
    .hero > .hero__network {
      top: auto;
      bottom: 5rem;
      right: -4rem;
      width: 320px;
      transform: none;
      opacity: 0.4;
    }
  }

  /* Mobile/Touch: Netzwerk komplett ausblenden — auf kleiner Fläche wirkt
     das Knoten-Gewusel chaotisch, und `pointer-events: auto` würde Touch-
     Scroll blockieren. */
  @media (max-width: 768px), (hover: none), (pointer: coarse) {
    .hero > .hero__network {
      display: none;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Top-Bar
     ══════════════════════════════════════════════════════════════════════ */
  .hero__top {
    position: relative;
    z-index: 5;
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    flex-wrap: wrap;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .hero__brand-mark {
    color: var(--color-accent);
    font-size: 1rem;
    transform: translateY(-1px);
  }

  .hero__brand-text {
    color: var(--color-text);
  }

  .hero__brand-sep {
    opacity: 0.4;
  }

  /* Neon-Grün-Tokens (lokal im Hero) */
  .hero__avail {
    --neon: #15E266;
    --neon-bright: #39FF7C;

    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--neon);
    text-shadow:
      0 0 8px color-mix(in srgb, var(--neon-bright) 50%, transparent),
      0 0 16px color-mix(in srgb, var(--neon-bright) 25%, transparent);
    padding: 0.5rem 0.85rem;
    border-radius: 100px;
    background-color: color-mix(in srgb, var(--color-text) 4%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--neon) 35%, transparent);
    backdrop-filter: blur(8px);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--neon) 15%, transparent),
      0 4px 20px -4px color-mix(in srgb, var(--neon-bright) 30%, transparent);
  }

  .hero__avail-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--neon-bright);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--neon) 28%, transparent),
      0 0 12px var(--neon-bright),
      0 0 22px color-mix(in srgb, var(--neon-bright) 60%, transparent);
    animation: hero-avail-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-avail-pulse {
    0%, 100% {
      transform: scale(1);
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--neon) 28%, transparent),
        0 0 12px var(--neon-bright),
        0 0 22px color-mix(in srgb, var(--neon-bright) 60%, transparent);
    }
    50% {
      transform: scale(0.78);
      box-shadow:
        0 0 0 6px color-mix(in srgb, var(--neon) 18%, transparent),
        0 0 18px var(--neon-bright),
        0 0 32px color-mix(in srgb, var(--neon-bright) 70%, transparent);
    }
  }

  .hero__avail-label {
    color: color-mix(in srgb, var(--neon) 75%, transparent);
  }

  /* ══════════════════════════════════════════════════════════════════════
     Main Content (Editorial Asymmetric Layout)
     ══════════════════════════════════════════════════════════════════════ */
  .hero__main {
    position: relative;
    z-index: 4;
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    align-self: center;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .hero__editorial {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 1.85rem);
    max-width: 64rem;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin: 0;
  }

  .hero__eyebrow-line {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--color-accent);
  }

  /* ── Mega-Display-Headline ──────────────────────────────────────────── */
  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 11vw, 10rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 0;
    color: var(--color-text);
    text-wrap: balance;
    transform-style: preserve-3d;
    transform: perspective(1200px)
               rotateX(var(--tilt-x, 0deg))
               rotateY(var(--tilt-y, 0deg));
    transition: transform 0.5s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }

  :global(.hero__line) {
    display: block;
  }

  :global(.hero__line--italic) {
    font-style: italic;
    color: var(--color-accent);
    padding-left: clamp(1rem, 5vw, 4rem);
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }

  /* Rotator-Zeile: kleiner + heller */
  .hero__line--rotator {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw + 0.4rem, 1.85rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
    padding-left: clamp(0.4rem, 2vw, 2rem);
    letter-spacing: -0.01em;
    margin-top: 0.5rem;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
  }

  .hero__rotator-prefix {
    color: var(--color-muted);
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.65em;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  /* Rotator: alle Wörter übereinander gestackt (kein Layout-Shift) */
  .hero__rotator {
    display: inline-grid;
    grid-template-areas: "stack";
    vertical-align: baseline;
  }

  .hero__rotator-word {
    grid-area: stack;
    white-space: nowrap;
    color: var(--color-text);
    opacity: 0;
    transform: translateY(0.3em);
    filter: blur(8px);
    transition:
      opacity 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      transform 0.5s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      filter 0.4s ease;
  }

  .hero__rotator-word.is-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
    transition:
      opacity 0.55s 0.15s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      transform 0.65s 0.15s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      filter 0.55s 0.15s ease;
  }

  /* ── Tagline ────────────────────────────────────────────────────────── */
  .hero__tagline {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.2vw + 0.5rem, 1.35rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 44ch;
  }

  /* ── Actions ────────────────────────────────────────────────────────── */
  .hero__actions {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 2rem;
  }

  .hero__cta {
    --pad-x: 2.1rem;
    --pad-y: 1.1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    letter-spacing: 0.01em;
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .hero__cta:hover {
    background-color: var(--color-accent);
    color: #FFF;
  }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(5px);
  }

  .hero__secondary {
    display: inline-flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--color-text);
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .hero__secondary:hover {
    color: var(--color-accent);
  }

  .hero__secondary-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .hero__secondary-line {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .hero__secondary-arrow {
    font-style: normal;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero__secondary:hover .hero__secondary-arrow {
    transform: translate(3px, -3px);
  }

  /* ══════════════════════════════════════════════════════════════════════
     Floating Glass-Cards
     ══════════════════════════════════════════════════════════════════════ */
  .hero__cards {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .hero-card {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1.15rem;
    background: color-mix(in srgb, var(--color-surface) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    border-radius: 14px;
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    box-shadow:
      0 12px 40px -12px color-mix(in srgb, var(--color-text) 25%, transparent),
      0 2px 8px -4px color-mix(in srgb, var(--color-text) 10%, transparent);
    pointer-events: auto;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-card-in 0.9s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) forwards;
    animation-delay: var(--delay, 0.4s);
    transition: transform 0.5s var(--ease-out-expo);
    will-change: transform;
  }

  @keyframes hero-card-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-card__icon {
    flex-shrink: 0;
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
    position: relative;
  }

  .hero-card__pulse {
    position: absolute;
    inset: 8px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    opacity: 0;
    animation: hero-card-pulse 2s ease-out infinite;
  }

  @keyframes hero-card-pulse {
    0%   { transform: scale(0.6); opacity: 0.8; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  .hero-card__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .hero-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.2;
  }

  .hero-card__label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }

  .hero-card__value {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    white-space: nowrap;
  }

  .hero-card__value--accent {
    color: var(--color-accent);
    font-size: 1.45rem;
    line-height: 1;
  }

  .hero-card__unit {
    font-size: 0.7em;
    color: var(--color-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-left: 0.15em;
  }

  /* Positionierung der 3 Cards — überlappen das Network, schwebend rechts */
  .hero-card--available {
    top: clamp(7rem, 16vh, 11rem);
    right: clamp(2rem, 6vw, 5rem);
  }

  .hero-card--delivery {
    top: 48%;
    right: clamp(-1rem, 0vw, 1rem);
  }

  .hero-card--code {
    top: 70%;
    right: clamp(4rem, 10vw, 8rem);
  }

  /* Mobile: Cards verstecken (zu eng) */
  @media (max-width: 900px) {
    .hero__cards {
      display: none;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Bottom-Marquee (kinetisch)
     ══════════════════════════════════════════════════════════════════════ */
  .hero__bottom {
    position: relative;
    z-index: 4;
    margin-inline: calc(-1 * var(--container-pad));
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    background-color: color-mix(in srgb, var(--color-text) 3%, var(--color-bg));
    overflow: hidden;
  }

  .hero__marquee {
    overflow: hidden;
    padding-block: 0.85rem;
  }

  .hero__marquee-track {
    display: inline-flex;
    gap: 2rem;
    white-space: nowrap;
    will-change: transform;
    animation: hero-marquee-scroll 30s linear infinite;
  }

  @keyframes hero-marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-100% / 3)); }
  }

  .hero__marquee-group {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(0.95rem, 1vw + 0.5rem, 1.15rem);
    color: var(--color-text);
    flex-shrink: 0;
  }

  .hero__marquee-dot {
    color: var(--color-accent);
    font-style: normal;
    font-size: 0.85em;
  }

  /* ══════════════════════════════════════════════════════════════════════
     Scroll-Hinweis
     ══════════════════════════════════════════════════════════════════════ */
  .hero__scroll {
    position: absolute;
    bottom: 5rem;
    left: var(--container-pad);
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    pointer-events: none;
  }

  .hero__scroll-line {
    display: block;
    width: 50px;
    height: 1px;
    background: color-mix(in srgb, var(--color-text) 15%, transparent);
    overflow: hidden;
    position: relative;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: translateX(-100%);
    animation: hero-scroll-line 2.8s var(--ease-in-out-quart) infinite;
  }

  @keyframes hero-scroll-line {
    0%   { transform: translateX(-100%); }
    60%  { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  @media (max-width: 640px) {
    .hero__scroll { display: none; }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Responsive
     ══════════════════════════════════════════════════════════════════════ */
  @media (max-width: 520px) {
    .hero__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }
    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .hero__actions :global(.magnetic-btn) {
      width: 100%;
      max-width: 22rem;
      justify-content: center;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Reduced-Motion
     ══════════════════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .hero__aurora-blob,
    .hero__avail-dot,
    .hero__rotator-word,
    .hero-card,
    .hero-card__pulse,
    .hero__marquee-track,
    .hero__scroll-line::after,
    .hero__headline {
      animation: none !important;
      transition: none !important;
    }
    .hero-card {
      opacity: 1;
      transform: none;
    }
    .hero__rotator-word { opacity: 0; }
    .hero__rotator-word.is-active { opacity: 1; transform: none; filter: none; }
  }
</style>

<!-- ══════════════════════════════════════════════════════════════════════
     Scripts
     ══════════════════════════════════════════════════════════════════════ -->
<script>
  // ── Word-Rotator: tauscht alle 3.2s das aktive Wort ──────────────────
  function initRotator() {
    const rotator = document.querySelector<HTMLElement>('.hero__rotator');
    if (!rotator) return;
    const words = Array.from(rotator.querySelectorAll<HTMLElement>('.hero__rotator-word'));
    if (words.length <= 1) return;
    let active = 0;
    const tick = () => {
      words[active].classList.remove('is-active');
      active = (active + 1) % words.length;
      words[active].classList.add('is-active');
    };
    const interval = window.setInterval(tick, 3200);
    document.addEventListener('astro:before-swap', () => window.clearInterval(interval), { once: true });
  }

  // ── Mausparallax auf Floating Cards + Headline 3D-Tilt ──────────────
  function initParallax() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none), (pointer: coarse)').matches) return;

    const hero = document.querySelector<HTMLElement>('[data-hero]');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
    const headline = document.querySelector<HTMLElement>('[data-hero-headline]');
    if (!hero) return;

    let raf = 0;
    let tx = 0, ty = 0;
    let cx = 0, cy = 0;

    const onMove = (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      tx = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      ty = ((e.clientY - rect.top) / rect.height) * 2 - 1;
    };

    const onLeave = () => {
      tx = 0; ty = 0;
    };

    const tick = () => {
      // Lerp Richtung target für sanfte Bewegung
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      // Cards
      for (const card of cards) {
        const strength = parseFloat(card.dataset.parallax || '0.3');
        card.style.transform = `translate(${-cx * 30 * strength}px, ${-cy * 30 * strength}px)`;
      }

      // Headline 3D-Tilt
      if (headline) {
        headline.style.setProperty('--tilt-y', `${cx * 3}deg`);
        headline.style.setProperty('--tilt-x', `${-cy * 2}deg`);
      }

      raf = requestAnimationFrame(tick);
    };

    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('mouseleave', onLeave);
    tick();

    document.addEventListener('astro:before-swap', () => {
      hero.removeEventListener('mousemove', onMove);
      hero.removeEventListener('mouseleave', onLeave);
      cancelAnimationFrame(raf);
    }, { once: true });
  }

  // ── Init ─────────────────────────────────────────────────────────────
  function initAll() {
    initRotator();
    initParallax();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
  document.addEventListener('astro:page-load', initAll);
</script>
