---
/**
 * miro-studios — Hero (Editorial)
 *
 * Ruhig, klar, lesbar. Kein 3D, kein Particle-Overload, kein Logo-Zerfall.
 * Eine große editoriale Headline, eine ehrliche Tagline, zwei klare CTAs.
 *
 * Detail-Layer: dezente Meta-Labels in Mono an den Rändern (Standort,
 * Verfügbarkeit) und ein subtil rotierendes Stempel-SVG als ruhiger
 * grafischer Akzent — wie auf einem Lookbook-Cover.
 */
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
---

<section class="hero" aria-labelledby="hero-headline">
  <!-- Oben: Standort + Verfügbarkeit ------------------------------------ -->
  <header class="hero__top">
    <span class="hero__meta">
      <span class="hero__meta-mark" aria-hidden="true">◇</span>
      <span>miro-studios</span>
      <span class="hero__meta-sep" aria-hidden="true">·</span>
      <span>Kierspe · NRW</span>
    </span>

    <span class="hero__avail">
      <span class="hero__avail-dot" aria-hidden="true"></span>
      Verfügbar für Q2 / Q3 2026
    </span>
  </header>

  <!-- Mitte: Editorial-Headline ----------------------------------------- -->
  <div class="hero__center">
    <p class="hero__eyebrow">
      <span class="hero__eyebrow-line" aria-hidden="true"></span>
      <span>Webdesign &amp; Entwicklung aus dem Sauerland</span>
    </p>

    <h1 id="hero-headline" class="hero__headline">
      <SplitText as="span" by="words" stagger={0.06} class="hero__line">
        Websites,
      </SplitText>
      <SplitText
        as="span"
        by="words"
        stagger={0.06}
        delay={0.18}
        class="hero__line hero__line--italic"
      >
        die verkaufen.
      </SplitText>
    </h1>

    <p class="hero__tagline">
      Ein junges Studio aus Kierspe baut Websites für lokale Geschäfte —
      Pizzerien, Friseure, Handwerker, Cafés. Klare Gestaltung,
      ehrliche Preise, ein Ansprechpartner.
    </p>

    <div class="hero__actions">
      <MagneticButton href="/arbeiten" variant="primary" strength={0.25} class="hero__cta">
        <span>Demos ansehen</span>
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </MagneticButton>

      <a href="/kontakt" class="hero__secondary">
        <span class="hero__secondary-label">oder direkt</span>
        <span class="hero__secondary-line">
          <span>Anfrage starten</span>
          <span class="hero__secondary-arrow" aria-hidden="true">↗</span>
        </span>
      </a>
    </div>
  </div>

  <!-- Stempel-Akzent rechts (langsamer Spin) ---------------------------- -->
  <div class="hero__stamp" aria-hidden="true">
    <svg viewBox="0 0 220 220" width="100%" height="100%">
      <defs>
        <path id="hero-stamp-arc" d="M 110,110 m -88,0 a 88,88 0 1,1 176,0 a 88,88 0 1,1 -176,0" />
      </defs>
      <circle cx="110" cy="110" r="92" fill="none" stroke="currentColor" stroke-width="1" opacity="0.35" />
      <circle cx="110" cy="110" r="78" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" />
      <text font-family="Fraunces, serif" font-size="11" font-style="italic" letter-spacing="0.32em" fill="currentColor">
        <textPath href="#hero-stamp-arc" startOffset="0">
          · MIRO · STUDIOS · KIERSPE · NRW · DESIGN · CODE · MIRO · STUDIOS ·
        </textPath>
      </text>
      <text x="110" y="116" text-anchor="middle" font-family="Fraunces, serif" font-size="14" font-style="italic" fill="currentColor" opacity="0.55">est. 2026</text>
    </svg>
  </div>

  <!-- Unten: Scroll-Hinweis --------------------------------------------- -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-label">scrollen</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  /* ── Container ──────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    padding-inline: var(--container-pad);
    padding-block: clamp(5rem, 9vw, 8rem) clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(
        ellipse 70% 50% at 80% 20%,
        color-mix(in srgb, var(--color-accent) 8%, transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse 60% 40% at 10% 90%,
        color-mix(in srgb, var(--color-accent) 5%, transparent),
        transparent 60%
      ),
      var(--color-bg);
  }

  /* dezente Papier-Textur über der ganzen Hero */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 0;
  }

  .hero > * { position: relative; z-index: 1; }

  /* ── Top-Bar: Brand-Mark + Verfügbarkeit ────────────────────────────── */
  .hero__top {
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-rule);
    flex-wrap: wrap;
  }

  .hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  .hero__meta-mark {
    color: var(--color-accent);
    font-size: 1rem;
    transform: translateY(-1px);
  }

  .hero__meta-sep {
    opacity: 0.5;
  }

  .hero__avail {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text);
  }

  .hero__avail-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4a9956;
    box-shadow: 0 0 0 4px color-mix(in srgb, #4a9956 22%, transparent);
    animation: hero-avail-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-avail-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(0.78); opacity: 0.6; }
  }

  /* ── Center: Headline + CTA ─────────────────────────────────────────── */
  .hero__center {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .hero__center > * {
    max-width: 56rem;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin: 0;
  }

  .hero__eyebrow-line {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--color-accent);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 11vw, 9.5rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 0;
    color: var(--color-text);
    text-wrap: balance;
  }

  :global(.hero__line) {
    display: block;
  }

  :global(.hero__line--italic) {
    font-style: italic;
    color: var(--color-accent);
    padding-left: clamp(1.5rem, 6vw, 5rem);
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }

  .hero__tagline {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.3vw + 0.5rem, 1.4rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    max-width: 48ch;
  }

  /* ── Actions ────────────────────────────────────────────────────────── */
  .hero__actions {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2.25rem;
  }

  .hero__cta {
    --pad-x: 2.1rem;
    --pad-y: 1.05rem;
    font-family: var(--font-body);
    font-size: 1rem;
    letter-spacing: 0.01em;
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .hero__cta:hover {
    background-color: var(--color-accent);
    color: #FFF;
  }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(5px);
  }

  .hero__secondary {
    display: inline-flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--color-text);
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .hero__secondary:hover {
    color: var(--color-accent);
  }

  .hero__secondary-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .hero__secondary-line {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .hero__secondary-arrow {
    font-style: normal;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero__secondary:hover .hero__secondary-arrow {
    transform: translate(3px, -3px);
  }

  /* ── Stempel (Akzent rechts oben) ────────────────────────────────────── */
  .hero__stamp {
    position: absolute;
    top: clamp(6rem, 14vh, 10rem);
    right: clamp(-3rem, -2vw, -2rem);
    width: clamp(180px, 22vw, 320px);
    aspect-ratio: 1;
    color: var(--color-accent);
    opacity: 0.55;
    animation: hero-stamp-spin 40s linear infinite;
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  @keyframes hero-stamp-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .hero__stamp {
      top: auto;
      bottom: 6rem;
      right: -4rem;
      width: 200px;
      opacity: 0.35;
    }
  }

  /* ── Scroll-Hinweis unten links ─────────────────────────────────────── */
  .hero__scroll {
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted);
  }

  .hero__scroll-line {
    display: block;
    width: 60px;
    height: 1px;
    background: var(--color-rule);
    overflow: hidden;
    position: relative;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: translateX(-100%);
    animation: hero-scroll-line 2.8s var(--ease-in-out-quart) infinite;
  }

  @keyframes hero-scroll-line {
    0%   { transform: translateX(-100%); }
    60%  { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 520px) {
    .hero__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
    .hero__actions :global(.magnetic-btn) {
      width: 100%;
      max-width: 22rem;
      justify-content: center;
    }
  }

  /* ── Reduced-Motion ─────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__avail-dot,
    .hero__stamp,
    .hero__scroll-line::after {
      animation: none !important;
    }
  }
</style>
