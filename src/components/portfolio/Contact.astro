---
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';

const projectTypes = [
  { value: '', label: 'Bitte wählen' },
  { value: 'starter-onepager', label: 'One-Pager · Starter (599 €)' },
  { value: 'growth-onepager', label: 'One-Pager · Growth (1.299 €)' },
  { value: 'premium-onepager', label: 'One-Pager · Premium (2.299 €)' },
  { value: 'basic-multipage', label: 'Multi-Page · Basic (1.499 €)' },
  { value: 'business-multipage', label: 'Multi-Page · Business (2.799 €)' },
  { value: 'pro-multipage', label: 'Multi-Page · Pro (4.499 €)' },
  { value: 'unsicher', label: 'Bin mir noch unsicher' },
  { value: 'sonstiges', label: 'Etwas anderes' },
];

const budgetRanges = [
  { value: '', label: 'Bitte wählen' },
  { value: 'starter', label: 'unter 1.000 €' },
  { value: 'small', label: '1.000 € – 2.000 €' },
  { value: 'medium', label: '2.000 € – 3.500 €' },
  { value: 'large', label: '3.500 € – 5.000 €' },
  { value: 'xlarge', label: '5.000 € und mehr' },
  { value: 'open', label: 'Offen / muss sich ergeben' },
];
---

<section id="kontakt" class="contact" aria-labelledby="contact-title">
  <div class="contact__inner">
    <div class="contact__intro">
      <span class="contact__eyebrow">
        <span class="dash" aria-hidden="true"></span>
        Kontakt
      </span>

      <SplitText
        as="h2"
        by="words"
        stagger={0.05}
        class="contact__title"
        id="contact-title"
      >
        Lass uns reden.
      </SplitText>

      <p class="contact__copy">
        Erstes Gespräch ist immer kostenlos. Egal ob du schon ein konkretes
        Projekt hast oder nur eine Idee — schreib uns. Wir melden uns
        innerhalb von 48 Stunden.
      </p>

      <ul class="contact__direct">
        <li class="contact__direct-item">
          <span class="contact__direct-label">Mail</span>
          <a href="mailto:info@miro-studios.de" class="contact__direct-value">
            info@miro-studios.de
          </a>
        </li>
        <li class="contact__direct-item">
          <span class="contact__direct-label">Telefon</span>
          <a href="tel:+49235112345678" class="contact__direct-value">
            +49 (0) 2351 / 123 45 678
          </a>
        </li>
        <li class="contact__direct-item">
          <span class="contact__direct-label">Studio</span>
          <span class="contact__direct-value">
            Lüdenscheid · NRW · Termine nach Absprache
          </span>
        </li>
      </ul>
    </div>

    <form class="contact-form" data-contact-form novalidate>
      <!-- Web3Forms hidden inputs -->
      <input type="hidden" name="access_key" value="38ad6adc-4cc0-4d48-8f11-646853352085" />
      <input type="hidden" name="subject" value="Neue Anfrage über miro-studios.de" />
      <input type="hidden" name="from_name" value="miro-studios Anfrage-Formular" />
      <!-- Honeypot Spam-Schutz: Bots fuellen das aus, Menschen sehen es nicht -->
      <input type="checkbox" name="botcheck" class="contact-form__honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="contact-form__row">
        <label class="field" for="contact-name">
          <span class="field__label">
            <span class="field__num">01</span>
            Wie heißt du?
            <span class="field__required" aria-hidden="true">*</span>
          </span>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="field__input"
            placeholder="Vor- und Nachname"
            required
            autocomplete="name"
          />
        </label>

        <label class="field" for="contact-email">
          <span class="field__label">
            <span class="field__num">02</span>
            E-Mail
            <span class="field__required" aria-hidden="true">*</span>
          </span>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="field__input"
            placeholder="du@adresse.de"
            required
            autocomplete="email"
          />
        </label>
      </div>

      <div class="contact-form__row">
        <label class="field" for="contact-type">
          <span class="field__label">
            <span class="field__num">03</span>
            Projekt-Typ
          </span>
          <select id="contact-type" name="projectType" class="field__input">
            {projectTypes.map((opt) => <option value={opt.value}>{opt.label}</option>)}
          </select>
        </label>

        <label class="field" for="contact-budget">
          <span class="field__label">
            <span class="field__num">04</span>
            Grobes Budget
          </span>
          <select id="contact-budget" name="budget" class="field__input">
            {budgetRanges.map((opt) => <option value={opt.value}>{opt.label}</option>)}
          </select>
        </label>
      </div>

      <label class="field" for="contact-message">
        <span class="field__label">
          <span class="field__num">05</span>
          Worum geht's?
          <span class="field__required" aria-hidden="true">*</span>
        </span>
        <textarea
          id="contact-message"
          name="message"
          class="field__input field__input--textarea"
          rows="5"
          placeholder="Erzähl uns kurz vom Projekt — was, für wen, wann."
          required
        ></textarea>
      </label>

      <div class="contact-form__footer">
        <p class="contact-form__legal">
          Mit dem Absenden willigst du ein, dass wir deine Daten zur
          Bearbeitung deiner Anfrage verarbeiten. Mehr in der
          <a href="/datenschutz">Datenschutzerklärung</a>.
        </p>

        <MagneticButton type="submit" strength={0.3} class="contact-form__submit">
          Anfrage senden
          <span aria-hidden="true">→</span>
        </MagneticButton>
      </div>

      <output class="contact-form__success" data-contact-success aria-live="polite">
        <!-- Animated Glow-Halo hinter der Karte -->
        <span class="success-glow" aria-hidden="true"></span>

        <!-- Animierter SVG Checkmark der sich selbst zeichnet -->
        <span class="success-mark" aria-hidden="true">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="36" class="success-mark__circle" />
            <path d="M24 41.5 L36 53 L57 30" class="success-mark__check" />
          </svg>
        </span>

        <span class="success-eyebrow mono-label">
          <span class="success-dot" aria-hidden="true"></span>
          Anfrage angekommen
        </span>

        <h3 class="success-title">
          <span class="success-title__line">Danke<span class="success-name" data-success-name></span>.</span>
          <span class="success-title__line success-title__line--accent">
            Wir sind dran.
          </span>
        </h3>

        <p class="success-copy">
          Du bekommst gleich eine Bestätigung an deine E-Mail.
          Wir melden uns persönlich innerhalb von <strong>48 Stunden</strong>
          — meistens schneller.
        </p>

        <div class="success-meta">
          <span class="success-meta__item">
            <span class="success-meta__label">Status</span>
            <span class="success-meta__value">
              <span class="success-meta__pulse" aria-hidden="true"></span>
              In Bearbeitung
            </span>
          </span>
          <span class="success-meta__item">
            <span class="success-meta__label">Antwort innerhalb</span>
            <span class="success-meta__value">48 h</span>
          </span>
        </div>

        <button type="button" class="success-reset" data-contact-reset>
          <span>Weitere Anfrage senden</span>
          <span aria-hidden="true">↻</span>
        </button>
      </output>

      <output
        class="contact-form__error"
        data-contact-error
        aria-live="polite"
        role="status"
      >
        <span class="error-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" class="error-mark__circle" />
            <path d="M12 7v5" class="error-mark__line" />
            <circle cx="12" cy="16" r="1" class="error-mark__dot" />
          </svg>
        </span>
        <span class="error-text" data-contact-error-text>
          Etwas ist schiefgelaufen.
        </span>
      </output>
    </form>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad);
  }

  .contact__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }

  /* Linke Spalte: Intro */
  .contact__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: sticky;
    top: 6rem;
  }

  @media (max-width: 1024px) {
    .contact__intro {
      position: static;
    }
  }

  .contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
  }

  .contact__copy {
    font-size: var(--text-lg);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 44ch;
  }

  .contact__direct {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    padding-top: var(--space-3);
  }

  .contact__direct-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact__direct-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .contact__direct-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s var(--ease-out-expo);
  }

  a.contact__direct-value:hover {
    color: var(--color-accent);
  }

  /* Rechte Spalte: Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    border-radius: var(--radius-lg);
    background-color: color-mix(in srgb, var(--color-text) 2%, transparent);
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .field__num {
    color: color-mix(in srgb, var(--color-accent) 80%, transparent);
  }

  .field__required {
    color: var(--color-accent);
  }

  .field__input {
    width: 100%;
    padding: 0.875rem 1rem;
    background-color: var(--color-bg);
    border: 1px solid color-mix(in srgb, var(--color-text) 14%, transparent);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo);
  }

  .field__input:focus {
    outline: none;
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 4%, var(--color-bg));
  }

  .field__input--textarea {
    resize: vertical;
    min-height: 8rem;
    font-family: var(--font-body);
  }

  .field__input::placeholder {
    color: color-mix(in srgb, var(--color-text) 35%, transparent);
  }

  /* Custom Select-Arrow */
  select.field__input {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23999' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .field--invalid .field__input {
    border-color: #f87171;
  }

  .contact-form__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .contact-form__legal {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 36ch;
  }

  .contact-form__legal a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-text) 30%, transparent);
    text-underline-offset: 2px;
  }

  /* ============== Honeypot (Spam-Schutz) ============== */
  .contact-form__honeypot {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  /* ============== Submit-Button Loading-State =========== */
  .contact-form__submit[data-loading='true'] {
    pointer-events: none;
    opacity: 0.85;
  }
  .contact-form__submit[data-loading='true']::after {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    margin-left: 0.5rem;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ============== Success-State ========================= */
  .contact-form__success {
    display: none;
    position: relative;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.25rem, 3vw, 2.5rem);
    min-height: 22rem;
    overflow: hidden;
    isolation: isolate;
  }

  .contact-form[data-state='success'] .contact-form__success {
    display: flex;
    animation: success-card-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes success-card-in {
    0% { opacity: 0; transform: translateY(16px) scale(0.98); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  .contact-form[data-state='success'] :where(.contact-form__row, .field, .contact-form__footer) {
    display: none;
  }

  /* Glow-Halo hinter der Karte */
  .success-glow {
    position: absolute;
    inset: -20%;
    z-index: -1;
    background:
      radial-gradient(ellipse at 50% 30%,
        color-mix(in srgb, var(--color-accent) 22%, transparent) 0%,
        transparent 55%
      );
    filter: blur(40px);
    opacity: 0;
    animation: success-glow-in 1.4s 0.2s ease-out forwards;
  }
  @keyframes success-glow-in {
    to { opacity: 1; }
  }

  /* SVG Checkmark - zeichnet sich selbst */
  .success-mark {
    display: inline-block;
    width: clamp(64px, 8vw, 88px);
    height: clamp(64px, 8vw, 88px);
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }
  .success-mark svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .success-mark__circle,
  .success-mark__check {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .success-mark__circle {
    stroke: var(--color-accent);
    stroke-width: 2.5;
    stroke-dasharray: 226;
    stroke-dashoffset: 226;
    animation: success-circle-draw 0.75s 0.15s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--color-accent) 60%, transparent));
  }
  .success-mark__check {
    stroke: var(--color-accent);
    stroke-width: 4;
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: success-check-draw 0.45s 0.75s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  @keyframes success-circle-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes success-check-draw {
    to { stroke-dashoffset: 0; }
  }

  /* Eyebrow mit Live-Dot */
  .success-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
    color: var(--color-accent);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    opacity: 0;
    animation: success-eyebrow-in 0.5s 1.05s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes success-eyebrow-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .success-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
    animation: success-dot-pulse 1.6s ease-in-out infinite;
  }
  @keyframes success-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent); }
    50% { box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-accent) 12%, transparent); }
  }

  /* Headline */
  .success-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .success-title__line {
    display: block;
    opacity: 0;
    transform: translateY(14px);
    animation: success-line-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .success-title__line:nth-child(1) { animation-delay: 1.15s; }
  .success-title__line:nth-child(2) { animation-delay: 1.3s; }

  .success-title__line--accent {
    font-style: italic;
    color: var(--color-accent);
    background-image: linear-gradient(
      105deg,
      var(--color-accent) 0%,
      var(--color-accent) 35%,
      #ffd4a0 50%,
      var(--color-accent) 65%,
      var(--color-accent) 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation:
      success-line-in 0.7s 1.3s cubic-bezier(0.16, 1, 0.3, 1) forwards,
      success-shimmer 3s 2s ease-in-out infinite;
  }
  @keyframes success-line-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes success-shimmer {
    0%, 100% { background-position: 100% center; }
    50% { background-position: 0% center; }
  }

  .success-name {
    font-family: var(--font-display);
    font-style: italic;
  }
  .success-name:not(:empty)::before {
    content: ', ';
  }

  .success-copy {
    max-width: 38ch;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    font-size: var(--text-base);
    line-height: 1.55;
    margin: 0 0 clamp(1.5rem, 3vw, 2.25rem);
    opacity: 0;
    animation: success-line-in 0.6s 1.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .success-copy strong {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Meta-Info Cards */
  .success-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
    opacity: 0;
    animation: success-line-in 0.6s 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .success-meta__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    padding: 0.65rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    border-radius: var(--radius-md);
    background-color: color-mix(in srgb, var(--color-text) 3%, transparent);
    text-align: left;
  }
  .success-meta__label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }
  .success-meta__value {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1;
  }
  .success-meta__pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #4ade80;
    box-shadow: 0 0 0 0 color-mix(in srgb, #4ade80 50%, transparent);
    animation: meta-pulse 1.5s ease-out infinite;
  }
  @keyframes meta-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, #4ade80 50%, transparent); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* Reset-Button */
  .success-reset {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.2rem;
    background: none;
    border: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    border-radius: 9999px;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      color 0.3s var(--ease-out-expo),
      border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo);
    opacity: 0;
    animation: success-line-in 0.6s 1.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .success-reset:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .success-reset > span:last-child {
    display: inline-block;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .success-reset:hover > span:last-child {
    transform: rotate(180deg);
  }

  /* ============== Error-State =========================== */
  .contact-form__error {
    display: none;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    background-color: color-mix(in srgb, #f87171 10%, transparent);
    border: 1px solid color-mix(in srgb, #f87171 35%, transparent);
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .contact-form[data-state='error'] .contact-form__error {
    display: flex;
    animation: error-shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97);
  }
  @keyframes error-shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    40% { transform: translateX(5px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(3px); }
  }

  .error-mark {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: #f87171;
  }
  .error-mark svg { width: 100%; height: 100%; display: block; }
  .error-mark__circle,
  .error-mark__line,
  .error-mark__dot {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
  }
  .error-mark__circle { stroke-width: 2; }
  .error-mark__line { stroke-width: 2; }
  .error-mark__dot { fill: currentColor; stroke: none; }

  @media (prefers-reduced-motion: reduce) {
    .contact-form__success,
    .success-glow,
    .success-mark__circle,
    .success-mark__check,
    .success-eyebrow,
    .success-dot,
    .success-title__line,
    .success-title__line--accent,
    .success-copy,
    .success-meta,
    .success-meta__pulse,
    .success-reset,
    .contact-form__error {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .success-mark__circle,
    .success-mark__check {
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<script>
  // Web3Forms-Endpoint — kostenlos, unbegrenzt
  const ENDPOINT = 'https://api.web3forms.com/submit';

  const init = () => {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form) return;

    const errorOut = form.querySelector<HTMLElement>('[data-contact-error]');
    const errorTextOut = form.querySelector<HTMLElement>('[data-contact-error-text]');
    const successNameEl = form.querySelector<HTMLElement>('[data-success-name]');
    const submitBtn = form.querySelector<HTMLElement>('.contact-form__submit');
    const resetBtn = form.querySelector<HTMLButtonElement>('[data-contact-reset]');

    const setError = (msg: string) => {
      form.dataset.state = 'error';
      if (errorTextOut) errorTextOut.textContent = msg;
    };

    const setLoading = (loading: boolean) => {
      if (submitBtn) submitBtn.dataset.loading = loading ? 'true' : 'false';
      submitBtn?.querySelectorAll('button, a').forEach((b) => {
        if (loading) b.setAttribute('aria-busy', 'true');
        else b.removeAttribute('aria-busy');
      });
    };

    const resetForm = () => {
      form.reset();
      form.dataset.state = '';
      if (successNameEl) successNameEl.textContent = '';
      // Re-set the hidden inputs that form.reset() doesn't touch
      const ak = form.querySelector<HTMLInputElement>('[name="access_key"]');
      if (ak) ak.value = '38ad6adc-4cc0-4d48-8f11-646853352085';
    };

    const handleSubmit = async (event: SubmitEvent) => {
      event.preventDefault();

      if (errorTextOut) errorTextOut.textContent = '';
      form.dataset.state = '';

      // Validierung
      const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        '[required]',
      );
      let invalid = false;
      requiredFields.forEach((field) => {
        const fieldEl = field.closest('.field');
        if (!field.value.trim()) {
          fieldEl?.classList.add('field--invalid');
          invalid = true;
        } else {
          fieldEl?.classList.remove('field--invalid');
        }
      });
      const emailField = form.querySelector<HTMLInputElement>('input[type="email"]');
      if (emailField && emailField.value && !emailField.checkValidity()) {
        emailField.closest('.field')?.classList.add('field--invalid');
        invalid = true;
      }
      if (invalid) {
        setError('Bitte pruefe die markierten Felder.');
        return;
      }

      // Vornamen extrahieren fuer personalisierte Erfolgs-Anzeige
      const nameField = form.querySelector<HTMLInputElement>('input[name="name"]');
      const fullName = nameField?.value.trim() ?? '';
      const firstName = fullName.split(/\s+/)[0] || '';

      // FormData zusammenbauen + replyto setzen damit man direkt antworten kann
      const formData = new FormData(form);
      if (emailField?.value) {
        formData.set('replyto', emailField.value);
      }

      setLoading(true);

      try {
        const response = await fetch(ENDPOINT, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok && (data.success === true || data.success === undefined)) {
          // Vornamen ins Success-State setzen
          if (successNameEl && firstName) {
            successNameEl.textContent = firstName;
          }
          form.dataset.state = 'success';
          form.reset();
          setLoading(false);
        } else {
          setLoading(false);
          setError(
            data?.message ||
              'Etwas ist schiefgelaufen. Versuch es nochmal oder schreib direkt an info@miro-studios.de.',
          );
        }
      } catch (err) {
        setLoading(false);
        setError(
          'Verbindung fehlgeschlagen. Versuch es nochmal oder schreib direkt an info@miro-studios.de.',
        );
      }
    };

    form.addEventListener('submit', handleSubmit);
    resetBtn?.addEventListener('click', resetForm);

    document.addEventListener(
      'astro:before-swap',
      () => {
        form.removeEventListener('submit', handleSubmit);
        resetBtn?.removeEventListener('click', resetForm);
      },
      { once: true },
    );
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
