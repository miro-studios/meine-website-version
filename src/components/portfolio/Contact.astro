---
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';

const projectTypes = [
  { value: '', label: 'Bitte wählen' },
  { value: 'one-pager', label: 'One-Pager (~1.890 €+)' },
  { value: 'multi-page', label: 'Multi-Page (~4.290 €+)' },
  { value: 'premium', label: 'Premium (~8.900 €+)' },
  { value: 'unsicher', label: 'Bin mir noch unsicher' },
  { value: 'sonstiges', label: 'Etwas anderes' },
];

const budgetRanges = [
  { value: '', label: 'Bitte wählen' },
  { value: 'small', label: 'unter 3.000 €' },
  { value: 'medium', label: '3.000 € – 6.000 €' },
  { value: 'large', label: '6.000 € – 12.000 €' },
  { value: 'xlarge', label: '12.000 € und mehr' },
  { value: 'open', label: 'Offen / muss sich ergeben' },
];
---

<section id="kontakt" class="contact" aria-labelledby="contact-title">
  <div class="contact__inner">
    <div class="contact__intro">
      <span class="contact__eyebrow">
        <span class="dash" aria-hidden="true"></span>
        Kontakt
      </span>

      <SplitText
        as="h2"
        by="words"
        stagger={0.05}
        class="contact__title"
        id="contact-title"
      >
        Lass uns reden.
      </SplitText>

      <p class="contact__copy">
        Erstes Gespräch ist immer kostenlos. Egal ob du schon ein konkretes
        Projekt hast oder nur eine Idee — schreib uns. Wir melden uns
        innerhalb von 48 Stunden.
      </p>

      <ul class="contact__direct">
        <li class="contact__direct-item">
          <span class="contact__direct-label">Mail</span>
          <a href="mailto:hallo@studio.de" class="contact__direct-value">
            hallo@studio.de
          </a>
        </li>
        <li class="contact__direct-item">
          <span class="contact__direct-label">Telefon</span>
          <a href="tel:+49235112345678" class="contact__direct-value">
            +49 (0) 2351 / 123 45 678
          </a>
        </li>
        <li class="contact__direct-item">
          <span class="contact__direct-label">Studio</span>
          <span class="contact__direct-value">
            Lüdenscheid · NRW · Termine nach Absprache
          </span>
        </li>
      </ul>
    </div>

    <form class="contact-form" data-contact-form novalidate>
      <div class="contact-form__row">
        <label class="field" for="contact-name">
          <span class="field__label">
            <span class="field__num">01</span>
            Wie heißt du?
            <span class="field__required" aria-hidden="true">*</span>
          </span>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="field__input"
            placeholder="Vor- und Nachname"
            required
            autocomplete="name"
          />
        </label>

        <label class="field" for="contact-email">
          <span class="field__label">
            <span class="field__num">02</span>
            E-Mail
            <span class="field__required" aria-hidden="true">*</span>
          </span>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="field__input"
            placeholder="du@adresse.de"
            required
            autocomplete="email"
          />
        </label>
      </div>

      <div class="contact-form__row">
        <label class="field" for="contact-type">
          <span class="field__label">
            <span class="field__num">03</span>
            Projekt-Typ
          </span>
          <select id="contact-type" name="projectType" class="field__input">
            {projectTypes.map((opt) => <option value={opt.value}>{opt.label}</option>)}
          </select>
        </label>

        <label class="field" for="contact-budget">
          <span class="field__label">
            <span class="field__num">04</span>
            Grobes Budget
          </span>
          <select id="contact-budget" name="budget" class="field__input">
            {budgetRanges.map((opt) => <option value={opt.value}>{opt.label}</option>)}
          </select>
        </label>
      </div>

      <label class="field" for="contact-message">
        <span class="field__label">
          <span class="field__num">05</span>
          Worum geht's?
          <span class="field__required" aria-hidden="true">*</span>
        </span>
        <textarea
          id="contact-message"
          name="message"
          class="field__input field__input--textarea"
          rows="5"
          placeholder="Erzähl uns kurz vom Projekt — was, für wen, wann."
          required
        ></textarea>
      </label>

      <div class="contact-form__footer">
        <p class="contact-form__legal">
          Mit dem Absenden willigst du ein, dass wir deine Daten zur
          Bearbeitung deiner Anfrage verarbeiten. Mehr in der
          <a href="/datenschutz">Datenschutzerklärung</a>.
        </p>

        <MagneticButton type="submit" strength={0.3} class="contact-form__submit">
          Anfrage senden
          <span aria-hidden="true">→</span>
        </MagneticButton>
      </div>

      <output class="contact-form__success" data-contact-success aria-live="polite">
        <span class="success-icon" aria-hidden="true">✓</span>
        <strong>Danke!</strong> Deine Nachricht ist angekommen — wir melden uns
        innerhalb von 48 Stunden.
      </output>

      <output
        class="contact-form__error"
        data-contact-error
        aria-live="polite"
        role="status"
      ></output>
    </form>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad);
  }

  .contact__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }

  /* Linke Spalte: Intro */
  .contact__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: sticky;
    top: 6rem;
  }

  @media (max-width: 1024px) {
    .contact__intro {
      position: static;
    }
  }

  .contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
  }

  .contact__copy {
    font-size: var(--text-lg);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 44ch;
  }

  .contact__direct {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    padding-top: var(--space-3);
  }

  .contact__direct-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact__direct-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .contact__direct-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s var(--ease-out-expo);
  }

  a.contact__direct-value:hover {
    color: var(--color-accent);
  }

  /* Rechte Spalte: Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    border-radius: var(--radius-lg);
    background-color: color-mix(in srgb, var(--color-text) 2%, transparent);
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .field__num {
    color: color-mix(in srgb, var(--color-accent) 80%, transparent);
  }

  .field__required {
    color: var(--color-accent);
  }

  .field__input {
    width: 100%;
    padding: 0.875rem 1rem;
    background-color: var(--color-bg);
    border: 1px solid color-mix(in srgb, var(--color-text) 14%, transparent);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo);
  }

  .field__input:focus {
    outline: none;
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 4%, var(--color-bg));
  }

  .field__input--textarea {
    resize: vertical;
    min-height: 8rem;
    font-family: var(--font-body);
  }

  .field__input::placeholder {
    color: color-mix(in srgb, var(--color-text) 35%, transparent);
  }

  /* Custom Select-Arrow */
  select.field__input {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23999' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .field--invalid .field__input {
    border-color: #f87171;
  }

  .contact-form__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .contact-form__legal {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 36ch;
  }

  .contact-form__legal a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-text) 30%, transparent);
    text-underline-offset: 2px;
  }

  /* Success / Error */
  .contact-form__success,
  .contact-form__error {
    display: none;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .contact-form__success {
    background-color: color-mix(in srgb, #4ade80 12%, transparent);
    color: var(--color-text);
    border: 1px solid color-mix(in srgb, #4ade80 35%, transparent);
  }

  .contact-form__error {
    background-color: color-mix(in srgb, #f87171 12%, transparent);
    color: var(--color-text);
    border: 1px solid color-mix(in srgb, #f87171 35%, transparent);
  }

  .contact-form[data-state='success'] .contact-form__success {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .contact-form[data-state='error'] .contact-form__error {
    display: block;
  }

  .contact-form[data-state='success'] :where(.contact-form__row, .field, .contact-form__footer) {
    display: none;
  }

  .success-icon {
    color: #4ade80;
    font-size: var(--text-xl);
    line-height: 1;
  }
</style>

<script>
  // TODO: Endpoint via Formspree o.ä. konfigurieren — Phase 2.5
  const ENDPOINT: string | null = null;

  const init = () => {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form) return;

    const errorOut = form.querySelector<HTMLElement>('[data-contact-error]');

    const handleSubmit = async (event: SubmitEvent) => {
      event.preventDefault();

      // Reset error
      if (errorOut) errorOut.textContent = '';
      form.dataset.state = '';

      // Manual validation
      const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        '[required]',
      );
      let invalid = false;
      requiredFields.forEach((field) => {
        const fieldEl = field.closest('.field');
        if (!field.value.trim()) {
          fieldEl?.classList.add('field--invalid');
          invalid = true;
        } else {
          fieldEl?.classList.remove('field--invalid');
        }
      });
      const emailField = form.querySelector<HTMLInputElement>('input[type="email"]');
      if (emailField && emailField.value && !emailField.checkValidity()) {
        emailField.closest('.field')?.classList.add('field--invalid');
        invalid = true;
      }
      if (invalid) {
        form.dataset.state = 'error';
        if (errorOut) errorOut.textContent = 'Bitte prüfe die markierten Felder.';
        return;
      }

      const formData = new FormData(form);

      // Mock-Submit wenn kein Endpoint konfiguriert ist
      if (!ENDPOINT) {
        // eslint-disable-next-line no-console
        console.info('[contact-form] Mock-Submit (kein Endpoint konfiguriert):', Object.fromEntries(formData));
        form.dataset.state = 'success';
        return;
      }

      try {
        const response = await fetch(ENDPOINT, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          form.reset();
          form.dataset.state = 'success';
        } else {
          form.dataset.state = 'error';
          if (errorOut) errorOut.textContent = 'Etwas ist schiefgelaufen. Versuch es nochmal oder schreib direkt an hallo@studio.de.';
        }
      } catch (err) {
        form.dataset.state = 'error';
        if (errorOut) errorOut.textContent = 'Verbindung fehlgeschlagen. Versuch es nochmal oder schreib direkt an hallo@studio.de.';
      }
    };

    form.addEventListener('submit', handleSubmit);

    // Cleanup
    document.addEventListener(
      'astro:before-swap',
      () => form.removeEventListener('submit', handleSubmit),
      { once: true },
    );
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
