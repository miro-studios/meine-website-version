---
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import SplitText from '@components/shared/SplitText.astro';

const capabilities = [
  {
    index: '01',
    title: 'Individuelles Design',
    description:
      'Jede Seite ist ein Unikat. Kein Page-Builder, kein Template-Kauf, kein Drag & Drop. Layout, Typografie und Farben werden speziell für deine Marke entwickelt — in Figma, bevor die erste Codezeile entsteht.',
    tools: ['Eigenes Layout', 'Typografie', 'Figma', 'Mobile-First'],
  },
  {
    index: '02',
    title: 'Selbst geschriebener Code',
    description:
      'Astro statt WordPress. Weniger Plugins, weniger Angriffsfläche, deutlich schneller. Lighthouse mindestens 90 auf Mobile — getestet auf 3G-Drosselung, von 320 px bis 4K.',
    tools: ['Astro', 'TypeScript', 'Cloudflare Pages'],
  },
  {
    index: '03',
    title: 'DSGVO sauber von Anfang an',
    description:
      'Schriften über Bunny Fonts (EU-CDN, kein Tracking), kein Google Analytics, Hosting auf Cloudflare-Rechenzentren in der EU. Datenschutzerklärung und Impressum bauen wir mit ein.',
    tools: ['Bunny Fonts', 'EU-Hosting', 'DSGVO-Setup'],
  },
  {
    index: '04',
    title: 'Bei Google gefunden werden',
    description:
      'Technisches SEO (Ladezeit, Meta-Tags, strukturiertes HTML, Sitemap) ist immer dabei. Für lokale Suchen wie „Friseur Kierspe" oder „Elektriker Sauerland" richten wir auf Wunsch dein Google-Unternehmensprofil ein.',
    tools: ['Lokales SEO', 'Google Business', 'Strukturierte Daten'],
  },
  {
    index: '05',
    title: 'Landingpages für Werbung',
    description:
      'Conversion-optimierte Seiten für Google Ads oder Meta Ads. Ein Fokus, ein Ziel, keine Ablenkung — damit jeder Klick aus deinem Werbe-Budget eine Chance auf eine Anfrage bekommt.',
    tools: ['Google Ads', 'Meta Ads', 'Conversion-Setup'],
  },
  {
    index: '06',
    title: 'Hosting & laufende Pflege',
    description:
      'Optionales Paket für 34,99 € pro Monat: Domain (.de oder .com), Cloudflare-Hosting mit DDoS-Schutz, SSL automatisch erneuert, Inhalts-Änderungen, Bug-Fixes und technischer Support. Monatlich kündbar — keine Vertragsfalle.',
    tools: ['Domain inklusive', 'Cloudflare', 'Monatlich kündbar'],
  },
] as const;
---

<section class="capabilities" aria-labelledby="capabilities-title">
  <header class="capabilities__header">
    <span class="capabilities__eyebrow">
      <span class="dash" aria-hidden="true"></span>
      Disziplinen / 06
    </span>

    <SplitText
      as="h2"
      by="words"
      stagger={0.05}
      class="capabilities__title"
      id="capabilities-title"
    >
      Was wir für dich machen.
    </SplitText>

    <p class="capabilities__lede">
      Sechs Bereiche, die wir komplett selbst abdecken — kein Outsourcing,
      kein „das geht auch noch". Was hier steht, machen wir wirklich.
    </p>
  </header>

  <RevealOnScroll class="capabilities__list" stagger={0.06} y={30}>
    {
      capabilities.map((cap) => (
        <article class="cap-row" data-cursor-hover>
          <span class="cap-row__index">{cap.index}</span>
          <div class="cap-row__heading">
            <h3 class="cap-row__title">{cap.title}</h3>
            <ul class="cap-row__tools">
              {cap.tools.map((tool) => (
                <li>{tool}</li>
              ))}
            </ul>
          </div>
          <p class="cap-row__description">{cap.description}</p>
          <span class="cap-row__arrow" aria-hidden="true">→</span>
        </article>
      ))
    }
  </RevealOnScroll>
</section>

<style>
  .capabilities {
    position: relative;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad);
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .capabilities__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .capabilities__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .capabilities :global(.capabilities__title) {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 400;
  }

  .capabilities__lede {
    margin: 0.5rem 0 0;
    font-size: clamp(1rem, 1.1vw + 0.5rem, 1.25rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 52ch;
  }

  .capabilities__list {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
  }

  .cap-row {
    position: relative;
    display: grid;
    grid-template-columns: 4rem 1fr 1.5fr 2rem;
    gap: clamp(1rem, 3vw, 3rem);
    padding-block: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    align-items: start;
    cursor: pointer;
    transition: padding 0.4s var(--ease-out-expo),
      background-color 0.4s var(--ease-out-expo);
  }

  /* Akzent-Strich links beim Hover */
  .cap-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    height: 1px;
    width: 0;
    background-color: var(--color-accent);
    transform: translateY(-50%);
    transition: width 0.5s var(--ease-out-expo);
  }

  .cap-row:hover::before {
    width: 2rem;
  }

  .cap-row:hover {
    padding-left: 2.5rem;
  }

  .cap-row:hover .cap-row__title {
    color: var(--color-accent);
  }

  .cap-row__index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.1em;
    padding-top: 0.5rem;
  }

  .cap-row__heading {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cap-row__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 500;
    transition: color 0.4s var(--ease-out-expo);
  }

  .cap-row__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cap-row__tools li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
  }

  .cap-row__description {
    font-size: var(--text-base);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 50ch;
  }

  .cap-row__arrow {
    font-size: var(--text-xl);
    color: var(--color-muted);
    transition: transform 0.4s var(--ease-out-expo),
      color 0.4s var(--ease-out-expo);
    padding-top: 0.25rem;
  }

  .cap-row:hover .cap-row__arrow {
    color: var(--color-accent);
    transform: translate(8px, -4px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .cap-row {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
      gap: 1rem;
    }
    .cap-row__description {
      grid-column: 1 / -1;
    }
    .cap-row__arrow {
      display: none;
    }
    .cap-row:hover {
      padding-left: 1rem;
    }
  }
</style>
