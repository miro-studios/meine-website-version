---
interface Props {
  /** Reihenfolge-Nummer (01, 02, ...) */
  index: string;
  /** Name des Demo-Brands */
  name: string;
  /** Branche / Tagline */
  category: string;
  /** Slug-URL zum Demo-Ordner */
  href: string;
  /** Theme-Slug für die Vorschau-Ästhetik */
  theme: 'pizzeria' | 'elektro' | 'friseur' | 'handwerker';
  /** Display-Headline in der Vorschau */
  previewHeadline: string;
  /** Optional: kleiner Untertitel für die Vorschau */
  previewSubline?: string;
  /** Farb-Swatches (3 Hex-Werte) für Meta-Bereich */
  palette: readonly [string, string, string];
  /** Tags / Keywords */
  tags: readonly string[];
  /** Wenn true: nimmt mehr Spalten ein (asymmetrisches Grid) */
  large?: boolean;
  /** Wenn true: kompakte Darstellung (kleinere Card, ohne Tags/Palette) */
  compact?: boolean;
}

const {
  index,
  name,
  category,
  href,
  theme,
  previewHeadline,
  previewSubline,
  palette,
  tags,
  large = false,
  compact = false,
}: Props = Astro.props;
---

<a
  href={href}
  class:list={['demo-card', `demo-card--${theme}`, { 'demo-card--large': large, 'demo-card--compact': compact }]}
  data-cursor-hover
  aria-label={`Demo-Site ${name} (${category}) ansehen`}
>
  <!-- Vorschau-Bereich (themed) -->
  <div
    class="demo-card__preview"
    data-theme={theme}
    data-depth-hover
    data-depth-strength="6"
  >
    <span class="demo-card__index">{index}</span>

    <div class="demo-card__preview-inner">
      <span class="demo-card__preview-eyebrow">{name}</span>
      <span class="demo-card__preview-headline">{previewHeadline}</span>
      {previewSubline && (
        <span class="demo-card__preview-subline">{previewSubline}</span>
      )}
    </div>

    <span class="demo-card__cta" aria-hidden="true">
      <span>Demo öffnen</span>
      <span class="demo-card__cta-arrow">→</span>
    </span>

    <!-- Subtle pattern-overlay je nach Theme -->
    <div class="demo-card__overlay" aria-hidden="true"></div>
  </div>

  <!-- Meta-Bereich (Name, Category, Palette, Tags) -->
  <div class="demo-card__meta">
    <div class="demo-card__heading">
      <h3 class="demo-card__name">{name}</h3>
      <span class="demo-card__category">{category}</span>
    </div>

    {!compact && (
      <ul class="demo-card__palette" aria-label="Farbpalette">
        {
          palette.map((color) => (
            <li
              class="demo-card__swatch"
              style={`background-color: ${color};`}
              aria-label={color}
            />
          ))
        }
      </ul>
    )}

    {!compact && (
      <ul class="demo-card__tags">
        {tags.map((t) => <li>{t}</li>)}
      </ul>
    )}

    {compact && (
      <ul class="demo-card__palette demo-card__palette--compact" aria-label="Farbpalette">
        {
          palette.map((color) => (
            <li
              class="demo-card__swatch"
              style={`background-color: ${color};`}
              aria-label={color}
            />
          ))
        }
      </ul>
    )}
  </div>
</a>

<style>
  .demo-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: inherit;
    text-decoration: none;
    cursor: none;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .demo-card:hover {
    transform: translateY(-4px);
  }

  /* -- Preview-Container ---------------------------------------------------- */
  .demo-card__preview {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    isolation: isolate;
    transition: transform 0.6s var(--ease-out-expo);
    will-change: transform;
  }

  .demo-card--large .demo-card__preview {
    aspect-ratio: 16 / 11;
  }

  .demo-card--compact {
    gap: 0.75rem;
  }

  .demo-card--compact .demo-card__preview {
    aspect-ratio: 5 / 4;
    padding: clamp(0.875rem, 1.6vw, 1.25rem);
    border-radius: var(--radius-md);
  }

  .demo-card--compact .demo-card__preview-headline {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
  }

  .demo-card--compact .demo-card__cta {
    font-size: 10px;
    padding: 0.3rem 0.55rem;
    gap: 0.35rem;
  }

  .demo-card--compact .demo-card__index {
    font-size: 10px;
  }

  .demo-card--compact .demo-card__name {
    font-size: var(--text-base);
  }

  .demo-card--compact .demo-card__category {
    font-size: 10px;
  }

  .demo-card--compact .demo-card__meta {
    grid-template-columns: 1fr auto;
  }

  .demo-card__palette--compact {
    grid-column: auto;
  }

  .demo-card--compact .demo-card__swatch {
    width: 10px;
    height: 10px;
  }

  /* Tilt via GSAP-driven depth-hover (data-depth-hover). Kein CSS-scale,
     sonst kämpft es mit dem GSAP-transform. */

  .demo-card__index {
    position: absolute;
    top: clamp(1rem, 2.5vw, 1.5rem);
    right: clamp(1rem, 2.5vw, 1.5rem);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .demo-card__preview-inner {
    position: absolute;
    inset: clamp(1.25rem, 3vw, 2.5rem);
    top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .demo-card__preview-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.65;
  }

  .demo-card__preview-headline {
    font-family: var(--demo-display, var(--font-display));
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 500;
  }

  .demo-card__preview-subline {
    font-family: var(--demo-body, var(--font-body));
    font-size: var(--text-base);
    opacity: 0.75;
    margin-top: 0.5rem;
  }

  .demo-card__cta {
    position: absolute;
    top: clamp(1rem, 2.5vw, 1.5rem);
    left: clamp(1rem, 2.5vw, 1.5rem);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.5rem 0.85rem;
    border-radius: 9999px;
    background-color: color-mix(in srgb, currentColor 8%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
    transition: background-color 0.4s var(--ease-out-expo);
  }

  .demo-card:hover .demo-card__cta {
    background-color: color-mix(in srgb, currentColor 18%, transparent);
  }

  .demo-card__cta-arrow {
    transition: transform 0.4s var(--ease-out-expo);
  }

  .demo-card:hover .demo-card__cta-arrow {
    transform: translate(4px, -4px);
  }

  .demo-card__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.85;
  }

  /* ============== Theme-spezifische Vorschau-Designs ====================== */

  /* Pizzeria: warmes Terracotta + creme, organische Textur */
  .demo-card__preview[data-theme='pizzeria'] {
    background-color: #F8F2E8;
    color: #1A0F0A;
    --demo-display: 'Recoleta', 'Fraunces', ui-serif, Georgia, serif;
  }

  .demo-card__preview[data-theme='pizzeria'] .demo-card__overlay {
    background:
      radial-gradient(circle at 20% 80%, #C44536 0%, transparent 45%),
      radial-gradient(circle at 90% 20%, #E8B547 0%, transparent 35%),
      linear-gradient(180deg, transparent 60%, #A8261B 110%);
    opacity: 0.18;
  }

  .demo-card__preview[data-theme='pizzeria'] .demo-card__preview-headline {
    font-style: italic;
    color: #A8261B;
  }

  /* Elektro: tiefschwarz + electric yellow */
  .demo-card__preview[data-theme='elektro'] {
    background-color: #0E0E0C;
    color: #F0EDE4;
  }

  .demo-card__preview[data-theme='elektro'] .demo-card__overlay {
    background:
      linear-gradient(180deg, transparent 50%, #FFD60A 200%),
      repeating-linear-gradient(
        90deg,
        transparent 0,
        transparent 49px,
        color-mix(in srgb, #FFD60A 8%, transparent) 49px,
        color-mix(in srgb, #FFD60A 8%, transparent) 50px
      );
    opacity: 0.5;
  }

  .demo-card__preview[data-theme='elektro'] .demo-card__preview-headline {
    text-transform: uppercase;
    font-family: 'Anton', 'Bebas Neue', 'Arial Narrow Bold', sans-serif;
    letter-spacing: 0.02em;
    color: #FFD60A;
  }

  /* Friseur: bone + plum, editorial Italic */
  .demo-card__preview[data-theme='friseur'] {
    background-color: #F8F4ED;
    color: #1A1716;
  }

  .demo-card__preview[data-theme='friseur'] .demo-card__overlay {
    background:
      radial-gradient(circle at 80% 70%, #F4C5B5 0%, transparent 40%),
      radial-gradient(circle at 10% 30%, #B5C4A8 0%, transparent 35%);
    opacity: 0.4;
  }

  .demo-card__preview[data-theme='friseur'] .demo-card__preview-headline {
    font-style: italic;
    color: #3A2438;
    font-family: 'PP Editorial New', 'Boska', 'Tobias', ui-serif, Georgia, serif;
  }

  /* Handwerker: warmweiß + Erdtöne */
  .demo-card__preview[data-theme='handwerker'] {
    background-color: #EFEAE0;
    color: #26221E;
  }

  .demo-card__preview[data-theme='handwerker'] .demo-card__overlay {
    background:
      linear-gradient(135deg, transparent 30%, #C75D2F 130%),
      linear-gradient(45deg, transparent 60%, #5A6E4F 200%);
    opacity: 0.18;
  }

  .demo-card__preview[data-theme='handwerker'] .demo-card__preview-headline {
    color: #3A2C1F;
    font-weight: 600;
  }

  /* -- Meta-Bereich --------------------------------------------------------- */
  .demo-card__meta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 1rem;
  }

  .demo-card__heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .demo-card__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .demo-card__category {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .demo-card__palette {
    display: inline-flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .demo-card__swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
  }

  .demo-card__tags {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .demo-card__tags li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }
</style>
