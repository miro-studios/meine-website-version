---
/**
 * Manifest — narratives Statement zur Studio-Haltung.
 *
 * Nicht "wir sind toll", sondern eine ehrliche Position: was glauben wir,
 * für wen bauen wir, warum lohnt sich das. Word-für-Word-Reveal als
 * Editorial-Akzent (Pflicht-Effekt laut Paket-06, Phase 6).
 *
 * Keine Statistiken, keine Buzzwords — nur drei klare Sätze.
 */
import SplitText from '@components/shared/SplitText.astro';
---

<section class="manifest" aria-labelledby="manifest-title">
  <div class="manifest__inner">
    <header class="manifest__head">
      <span class="manifest__eyebrow">
        <span class="manifest__eyebrow-line" aria-hidden="true"></span>
        Manifest
      </span>
    </header>

    <SplitText
      as="h2"
      by="words"
      stagger={0.04}
      class="manifest__statement"
      id="manifest-title"
    >
      Kleine Geschäfte verdienen Websites, die ihre Arbeit ernst nehmen.
    </SplitText>

    <div class="manifest__body">
      <p class="manifest__para">
        Die meisten lokalen Sites sehen aus wie Templates — weil es Templates sind.
        Eine Pizzeria, ein Friseur und ein Steuerberater haben am Ende den
        gleichen WordPress-Auftritt, nur mit ausgetauschten Bildern. Das ist
        kein Webdesign, das ist Befüllung.
      </p>

      <p class="manifest__para">
        Wir machen es anders. Jede Site wird einzeln entworfen, mit der Hand
        gezeichnet, von einem Menschen gebaut. Keine Plugin-Suppe, keine
        12-monatige Abo-Falle, keine Standards die nirgendwo Standard sind.
      </p>

      <p class="manifest__para manifest__para--accent">
        Du bekommst eine Website, die zu dir passt — und einen Ansprechpartner,
        der weiß, was darin steckt.
      </p>
    </div>
  </div>
</section>

<style>
  .manifest {
    position: relative;
    padding-block: clamp(4rem, 9vw, 8rem);
    padding-inline: var(--container-pad);
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-rule);
    overflow: hidden;
    isolation: isolate;
  }

  /* sehr großes, sehr dezentes Wasserzeichen-Wort im Hintergrund */
  .manifest::before {
    content: '"';
    position: absolute;
    top: -2rem;
    right: -1rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20rem, 50vw, 40rem);
    line-height: 0.7;
    color: color-mix(in srgb, var(--color-accent) 8%, transparent);
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }

  .manifest__inner {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.75rem, 4vw, 3rem);
  }

  @media (min-width: 900px) {
    .manifest__inner {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1.4fr);
      column-gap: clamp(3rem, 6vw, 6rem);
    }

    .manifest__head {
      grid-column: 1 / -1;
    }
  }

  .manifest__head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .manifest__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .manifest__eyebrow-line {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--color-accent);
  }

  :global(.manifest__statement) {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
    text-wrap: balance;
  }

  .manifest__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 44ch;
  }

  @media (min-width: 900px) {
    .manifest__body {
      align-self: end;
      padding-top: 1rem;
    }
  }

  .manifest__para {
    margin: 0;
    font-size: clamp(0.98rem, 0.9vw + 0.6rem, 1.1rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
  }

  .manifest__para--accent {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.2vw + 0.6rem, 1.4rem);
    font-style: italic;
    line-height: 1.5;
    padding-top: 0.25rem;
    border-top: 1px solid var(--color-rule);
    margin-top: 0.5rem;
  }
</style>
