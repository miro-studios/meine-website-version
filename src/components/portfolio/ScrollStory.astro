---
/**
 * ScrollStory — Sticky-Sphere + statische Step-Liste.
 *
 * Kein Pin, kein erzwungenes Step-Swap. Sphere bleibt per `position: sticky`
 * neben den Step-Karten und reagiert auf Hover/Viewport-Mitte des aktiven
 * Steps via `story:progress`-Event.
 */

const steps = [
  {
    index: '01',
    title: 'Wir verstehen dein Geschäft',
    body: 'Vor jeder Codezeile kommen Gespräche. Was unterscheidet dich vom Wettbewerber zwei Straßen weiter? Welche Kunden willst du gewinnen?',
    meta: 'Briefing · Recherche',
  },
  {
    index: '02',
    title: 'Wir entwerfen, nicht klicken',
    body: 'Keine Drag-and-Drop-Templates, keine generischen Themes. Jedes Layout wird in Figma als eigene Idee entwickelt — Typografie, Bildsprache, Energie.',
    meta: 'Konzept · Design',
  },
  {
    index: '03',
    title: 'Wir bauen mit echtem Code',
    body: 'Astro, GSAP, Three.js — moderne Frontend-Technologie für 60-fps Performance auf Handy und Desktop. Lighthouse 90+, sonst stoppen wir die Auslieferung.',
    meta: 'Build · QA',
  },
  {
    index: '04',
    title: 'Wir hosten und pflegen',
    body: 'Strato-Hosting durch uns. Updates, Backups, kleine Änderungen — du bekommst eine Kontaktperson, keinen Ticket-Roboter.',
    meta: 'Launch · Support',
  },
];
---

<section
  class="scroll-story"
  data-scroll-story
  aria-labelledby="story-title"
>
  <div class="scroll-story__inner">
    <header class="scroll-story__header">
      <span class="scroll-story__eyebrow">
        <span class="dash" aria-hidden="true"></span>
        Wie wir arbeiten
      </span>
      <h2 id="story-title" class="scroll-story__title">
        Vier Schritte. Kein Bullshit.
      </h2>
      <p class="scroll-story__lede">
        Vom ersten Gespräch bis zum Live-Gang — vier klare Phasen. Klick oder
        hover die Karten, um zu sehen wie sich die Bühne dreht.
      </p>
    </header>

    <div class="scroll-story__layout">
      <!-- Linke Spalte: Sticky Editorial-Stage -->
      <aside class="scroll-story__stage-wrap">
        <div class="scroll-story__stage" data-story-stage aria-hidden="true">
          <!-- Top-Meta: Phase x / total -->
          <div class="scroll-story__meta">
            <span class="scroll-story__meta-label">Phase</span>
            <span class="scroll-story__meta-count">
              <span data-story-current>01</span>
              <span class="scroll-story__meta-sep">/</span>
              <span>0{steps.length}</span>
            </span>
          </div>

          <!-- Mega-Number mit Morph -->
          <div class="scroll-story__num-wrap">
            <div class="scroll-story__num-stack" data-story-num-stack>
              {steps.map((step, i) => (
                <span
                  class:list={['scroll-story__num', { 'is-active': i === 0 }]}
                  data-num-index={i}
                >{step.index}</span>
              ))}
            </div>

            <!-- Dezenter Akzent-Bogen rechts neben der Zahl -->
            <svg
              class="scroll-story__arc"
              viewBox="0 0 100 100"
              fill="none"
              aria-hidden="true"
            >
              <circle
                cx="50" cy="50" r="46"
                stroke="currentColor"
                stroke-width="0.4"
                stroke-dasharray="2 4"
                opacity="0.35"
              />
              <circle
                class="scroll-story__arc-progress"
                cx="50" cy="50" r="46"
                stroke="currentColor"
                stroke-width="0.9"
                stroke-linecap="round"
                pathLength="100"
                data-story-arc
              />
            </svg>
          </div>

          <!-- Progress-Bar + Label -->
          <div class="scroll-story__progress">
            <div class="scroll-story__bar" aria-hidden="true">
              <div class="scroll-story__bar-fill" data-story-bar></div>
            </div>
            <span
              class="scroll-story__phase-label"
              data-story-current-label
            >Briefing · Recherche</span>
          </div>
        </div>
      </aside>

      <!-- Rechte Spalte: alle Steps gleichzeitig sichtbar -->
      <ol class="scroll-story__steps" data-story-steps role="list">
        {steps.map((step, i) => (
          <li>
            <button
              type="button"
              class:list={['story-step', { 'is-active': i === 0 }]}
              data-story-step
              data-step-index={i}
              data-step-meta={step.meta}
              data-cursor-hover
              aria-label={`Schritt ${step.index}: ${step.title}`}
              aria-current={i === 0 ? 'step' : 'false'}
            >
              <span class="story-step__rail" aria-hidden="true"></span>

              <header class="story-step__head">
                <span class="story-step__index">{step.index}</span>
                <span class="story-step__meta">{step.meta}</span>
              </header>

              <h3 class="story-step__title">{step.title}</h3>
              <p class="story-step__body">{step.body}</p>
            </button>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .scroll-story {
    position: relative;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad);
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--color-accent) 4%, transparent) 50%,
      transparent 100%
    );
    overflow: clip;
  }

  .scroll-story__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .scroll-story__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 56rem;
  }

  .scroll-story__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .scroll-story__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 500;
    margin: 0;
  }

  .scroll-story__lede {
    margin: 0.5rem 0 0;
    font-size: var(--text-base);
    line-height: 1.55;
    max-width: 50ch;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  /* ===== Layout: 2 columns, sticky sphere left, steps right ============== */
  .scroll-story__layout {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  @media (max-width: 900px) {
    .scroll-story__layout {
      grid-template-columns: 1fr;
    }
  }

  .scroll-story__stage-wrap {
    position: sticky;
    top: clamp(5rem, 10vh, 8rem);
    align-self: start;
  }

  @media (max-width: 900px) {
    .scroll-story__stage-wrap {
      position: relative;
      top: 0;
      max-width: 22rem;
      margin-inline: auto;
    }
  }

  .scroll-story__stage {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-lg);
    background:
      radial-gradient(
        circle at 30% 25%,
        color-mix(in srgb, var(--color-accent) 6%, transparent) 0%,
        transparent 55%
      ),
      var(--color-surface, color-mix(in srgb, var(--color-text) 3%, var(--color-bg)));
    border: 1px solid color-mix(in srgb, var(--color-text) 8%, transparent);
    padding: clamp(1.25rem, 2.4vw, 2rem);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    overflow: hidden;
  }

  /* ── Top-Meta: PHASE 01 / 04 ──────────────────────────────────────── */
  .scroll-story__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }

  .scroll-story__meta-label {
    color: color-mix(in srgb, var(--color-text) 45%, transparent);
  }

  .scroll-story__meta-count {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .scroll-story__meta-sep {
    color: var(--color-muted);
    opacity: 0.5;
  }

  /* ── Mega-Number Stack mit Morph ──────────────────────────────────── */
  .scroll-story__num-wrap {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 0;
  }

  .scroll-story__num-stack {
    position: relative;
    display: grid;
    grid-template-areas: "stack";
    line-height: 1;
  }

  .scroll-story__num {
    grid-area: stack;
    font-family: var(--font-display);
    font-size: clamp(7rem, 18vw, 14rem);
    line-height: 0.85;
    letter-spacing: -0.06em;
    font-weight: 400;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    opacity: 0;
    transform: translateY(0.25em);
    filter: blur(10px);
    transition:
      opacity 0.5s var(--ease-out-expo),
      transform 0.7s var(--ease-out-expo),
      filter 0.5s ease;
    pointer-events: none;
    user-select: none;
  }

  .scroll-story__num.is-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
    transition:
      opacity 0.6s 0.05s var(--ease-out-expo),
      transform 0.8s 0.05s var(--ease-out-expo),
      filter 0.6s 0.05s ease;
  }

  /* Akzent-Bogen umgibt die Zahl */
  .scroll-story__arc {
    position: absolute;
    inset: -6%;
    width: 112%;
    height: 112%;
    color: var(--color-accent);
    pointer-events: none;
    transform: rotate(-90deg);
  }

  .scroll-story__arc-progress {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 0.8s var(--ease-out-expo);
  }

  /* ── Progress-Bar + Phase-Label ───────────────────────────────────── */
  .scroll-story__progress {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .scroll-story__bar {
    position: relative;
    height: 2px;
    width: 100%;
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
    overflow: hidden;
    border-radius: 2px;
  }

  .scroll-story__bar-fill {
    position: absolute;
    inset: 0;
    width: 25%;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      color-mix(in srgb, var(--color-accent) 60%, var(--color-text))
    );
    transform-origin: left center;
    transition: width 0.7s var(--ease-out-expo);
    box-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 45%, transparent);
  }

  .scroll-story__phase-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    transition: opacity 0.3s var(--ease-out-expo);
  }

  @media (max-width: 900px) {
    .scroll-story__stage {
      aspect-ratio: auto;
      min-height: 18rem;
    }
    .scroll-story__num {
      font-size: clamp(6rem, 28vw, 11rem);
    }
  }

  /* ===== Step-Liste ===================================================== */
  .scroll-story__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .scroll-story__steps li {
    display: block;
  }

  .story-step {
    --rail-w: 2px;
    position: relative;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: clamp(1.25rem, 2.5vw, 2rem) 0 clamp(1.25rem, 2.5vw, 2rem)
      clamp(1.25rem, 2.5vw, 2rem);
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: padding 0.4s var(--ease-out-expo);
    -webkit-tap-highlight-color: transparent;
  }

  .scroll-story__steps li:last-child .story-step {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  /* Akzent-Schiene links — wächst bei Aktiv */
  .story-step__rail {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: var(--rail-w);
    background-color: color-mix(in srgb, var(--color-text) 18%, transparent);
    transition: background-color 0.4s var(--ease-out-expo),
      width 0.4s var(--ease-out-expo);
  }

  .story-step.is-active .story-step__rail {
    width: 4px;
    background-color: var(--color-accent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  .story-step:hover {
    padding-left: clamp(1.5rem, 3vw, 2.5rem);
  }

  .story-step:focus-visible {
    outline: none;
  }

  .story-step:focus-visible .story-step__rail {
    background-color: var(--color-accent);
    width: 4px;
  }

  .story-step__head {
    display: inline-flex;
    align-items: baseline;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .story-step__index {
    color: var(--color-accent);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
  }

  .story-step__meta {
    color: var(--color-muted);
  }

  .story-step__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    transition: color 0.4s var(--ease-out-expo);
  }

  .story-step:hover .story-step__title,
  .story-step.is-active .story-step__title {
    color: var(--color-text);
  }

  .story-step__body {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 60%, transparent);
    max-width: 52ch;
    transition: color 0.4s var(--ease-out-expo);
  }

  .story-step.is-active .story-step__body {
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .story-step,
    .story-step__rail,
    .story-step__title,
    .story-step__body,
    .scroll-story__phase-label {
      transition: none;
    }
  }
</style>

<script>
  import { initScrollStories } from '@lib/scroll-story';

  type Cleanup = () => void;

  function initStoryStageTypo(): Cleanup {
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>('[data-scroll-story]'),
    );
    const teardowns: Cleanup[] = [];

    for (const section of sections) {
      const stack = section.querySelector<HTMLElement>('[data-story-num-stack]');
      const bar = section.querySelector<HTMLElement>('[data-story-bar]');
      const arc = section.querySelector<SVGElement>('[data-story-arc]');
      if (!stack && !bar && !arc) continue;

      const nums = stack
        ? Array.from(stack.querySelectorAll<HTMLElement>('.scroll-story__num'))
        : [];
      const stepCount = section.querySelectorAll('[data-story-step]').length || 1;

      const onProgress = (e: Event) => {
        const detail = (e as CustomEvent<{ progress: number }>).detail;
        if (!detail) return;
        const p = detail.progress;
        const idx = Math.min(stepCount - 1, Math.round(p * (stepCount - 1)));

        // Number-Stack: aktive Klasse setzen
        nums.forEach((el, i) => {
          el.classList.toggle('is-active', i === idx);
        });

        // Progress-Bar: width 0..100% (mind. 1/n damit der erste Step sichtbar ist)
        if (bar) {
          const pct = ((idx + 1) / stepCount) * 100;
          bar.style.width = `${pct}%`;
        }

        // Akzent-Bogen: stroke-dashoffset 100..0
        if (arc) {
          const offset = 100 - ((idx + 1) / stepCount) * 100;
          (arc as SVGElement).style.strokeDashoffset = String(offset);
        }
      };

      section.addEventListener('story:progress', onProgress);
      teardowns.push(() => section.removeEventListener('story:progress', onProgress));
    }

    return () => teardowns.forEach((fn) => fn());
  }

  let cleanupStory: Cleanup | null = null;
  let cleanupStage: Cleanup | null = null;

  const start = () => {
    cleanupStory?.();
    cleanupStage?.();
    cleanupStory = initScrollStories();
    cleanupStage = initStoryStageTypo();
  };
  const stop = () => {
    cleanupStory?.();
    cleanupStage?.();
    cleanupStory = null;
    cleanupStage = null;
  };

  start();
  document.addEventListener('astro:page-load', start);
  document.addEventListener('astro:before-swap', stop);
</script>
