---
const navLinks = [
  { label: 'Arbeiten', href: '/#arbeiten' },
  { label: 'Studio', href: '/about' },
  { label: 'Kontakt', href: '/kontakt' },
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
];

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/mirostudio.official', handle: '@mirostudio.official' },
  { label: 'Behance', href: 'https://behance.net', handle: '/webdev-studio' },
  { label: 'GitHub', href: 'https://github.com', handle: '/webdev-studio' },
  { label: 'Are.na', href: 'https://are.na', handle: '/webdev-studio' },
];

const wordmark = 'STUDIO';
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <!-- Top: Meta + Links -->
    <div class="site-footer__top">
      <div class="site-footer__col site-footer__col--studio">
        <p class="site-footer__heading mono-label">Webdev Studio</p>
        <p class="site-footer__copy">
          Webdesign &amp; Development<br />
          aus Lüdenscheid für lokale<br />
          Geschäfte in NRW.
        </p>
        <a href="mailto:info@miro-studios.de" class="site-footer__email">
          info@miro-studios.de
          <span class="email-arrow" aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="site-footer__col">
        <p class="site-footer__heading mono-label">Sitemap</p>
        <ul class="site-footer__links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  <span class="footer-link__label">{link.label}</span>
                  <span class="footer-link__hover" aria-hidden="true">{link.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="site-footer__col">
        <p class="site-footer__heading mono-label">Sozial</p>
        <ul class="site-footer__links">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="footer-link footer-link--social"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="footer-link__label">{link.label}</span>
                  <span class="footer-link__handle">{link.handle}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="site-footer__col site-footer__col--meta">
        <p class="site-footer__heading mono-label">Studio</p>
        <ul class="site-footer__meta">
          <li>
            <span class="meta-label">Standort</span>
            <span class="meta-value">Lüdenscheid · NRW</span>
          </li>
          <li>
            <span class="meta-label">Status</span>
            <span class="meta-value">
              <span class="status-dot" aria-hidden="true"></span>
              Verfügbar Q2/Q3 2026
            </span>
          </li>
          <li>
            <span class="meta-label">Hours</span>
            <span class="meta-value">Mo – Fr · 09:00 – 18:00</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Mega Wordmark -->
    <div class="site-footer__wordmark" aria-hidden="true">
      <span class="wordmark" data-wordmark>
        {wordmark.split('').map((letter) => (
          <span class="wordmark__char">{letter}</span>
        ))}
      </span>
    </div>

    <!-- Bottom: Copyright + Tech-Credit -->
    <div class="site-footer__bottom">
      <p class="site-footer__copyright mono-label">
        © {year} Webdev Studio · Alle Rechte vorbehalten
      </p>
      <p class="site-footer__credit mono-label">
        Built with Astro, GSAP &amp; care · v0.1.0
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background-color: var(--color-bg);
    color: var(--color-text);
    border-top: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    overflow: hidden;
  }

  .site-footer__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    padding-block: var(--space-6) 0;
  }

  /* -- Top Grid ------------------------------------------------------------ */
  .site-footer__top {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  @media (max-width: 900px) {
    .site-footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 540px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .site-footer__heading {
    color: var(--color-muted);
  }

  .site-footer__copy {
    font-size: var(--text-base);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  .site-footer__email {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    /* Tap-Target ≥ 44px für Touch-Geräte (negative margin hält Layout stabil) */
    padding-block: 0.5rem;
    margin-block: -0.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--color-text);
    transition: color 0.3s var(--ease-out-expo);
  }

  .site-footer__email:hover {
    color: var(--color-accent);
  }

  .email-arrow {
    transition: transform 0.4s var(--ease-out-expo);
  }

  .site-footer__email:hover .email-arrow {
    transform: translate(3px, -3px);
  }

  .mono-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* -- Footer-Links (mit Slide-Hover) -------------------------------------- */
  .site-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    /* Etwas mehr Abstand auf Touch, damit Tap-Areas sich nicht überlappen */
    gap: 0.5rem;
  }

  .footer-link {
    position: relative;
    display: inline-block;
    overflow: hidden;
    line-height: 1.3;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    /* Tap-Target ≥ 44px für Touch-Bedienung */
    padding-block: 0.5rem;
  }

  .footer-link__label,
  .footer-link__hover {
    display: block;
    transition: transform 0.45s var(--ease-out-expo);
  }

  .footer-link__hover {
    position: absolute;
    inset: 0;
    transform: translateY(110%);
    color: var(--color-accent);
  }

  .footer-link:hover .footer-link__label {
    transform: translateY(-110%);
  }

  .footer-link:hover .footer-link__hover {
    transform: translateY(0);
  }

  .footer-link--social {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    overflow: visible;
  }

  .footer-link--social .footer-link__label {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    transition: color 0.3s var(--ease-out-expo);
  }

  .footer-link--social:hover .footer-link__label {
    transform: none;
    color: var(--color-accent);
  }

  .footer-link__handle {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  /* -- Studio Meta --------------------------------------------------------- */
  .site-footer__meta {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .site-footer__meta li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .meta-value {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .status-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #4ade80;
    box-shadow: 0 0 0 3px color-mix(in srgb, #4ade80 20%, transparent);
  }

  /* -- Mega Wordmark ------------------------------------------------------- */
  .site-footer__wordmark {
    padding-block: clamp(2rem, 6vw, 5rem);
    overflow: hidden;
  }

  .wordmark {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    width: 100%;
    font-family: var(--font-display);
    font-size: clamp(5rem, 22vw, 22rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    font-weight: 500;
    cursor: none;
    user-select: none;
  }

  .wordmark__char {
    display: inline-block;
    will-change: transform;
    transition: transform 0.5s var(--ease-out-expo),
      color 0.5s var(--ease-out-expo);
  }

  .wordmark:hover .wordmark__char {
    color: color-mix(in srgb, var(--color-text) 50%, transparent);
  }

  .wordmark__char:hover {
    color: var(--color-accent) !important;
    transform: translateY(-8%) rotate(-3deg);
  }

  /* -- Bottom -------------------------------------------------------------- */
  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: var(--space-3);
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .site-footer__copyright,
  .site-footer__credit {
    color: var(--color-muted);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { prefersReducedMotion } from '@lib/utils';

  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    if (prefersReducedMotion()) return;

    const wordmark = document.querySelector<HTMLElement>('[data-wordmark]');
    if (!wordmark) return;

    const chars = wordmark.querySelectorAll<HTMLElement>('.wordmark__char');
    if (chars.length === 0) return;

    // Wordmark erscheint mit Stagger beim ersten Sichtbarwerden
    const tween = gsap.fromTo(
      chars,
      { yPercent: 100, opacity: 0 },
      {
        yPercent: 0,
        opacity: 1,
        stagger: 0.06,
        duration: 1.2,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: wordmark,
          start: 'top 90%',
          toggleActions: 'play none none none',
          once: true,
        },
      },
    );

    document.addEventListener(
      'astro:before-swap',
      () => {
        tween.scrollTrigger?.kill();
        tween.kill();
      },
      { once: true },
    );
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
