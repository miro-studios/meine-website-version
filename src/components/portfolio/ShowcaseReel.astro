---
import DemoCard from './DemoCard.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import SplitText from '@components/shared/SplitText.astro';

const demos = [
  {
    index: '01',
    name: 'Bella Notte',
    category: 'Pizzeria',
    href: '/demos/pizzeria/index.html',
    theme: 'pizzeria',
    previewHeadline: 'La Vera Pizza',
    palette: ['#A8261B', '#E8B547', '#F5EFE6'],
    tags: ['Editorial', 'Reservierung'],
    compact: true,
  },
  {
    index: '02',
    name: 'Holtkamp',
    category: 'Elektrotechnik',
    href: '/demos/elektro/index.html',
    theme: 'elektro',
    previewHeadline: 'Strom. Wärme.',
    palette: ['#0E0E0C', '#FFD60A', '#F0EDE4'],
    tags: ['Industrial', 'Notdienst'],
    compact: true,
  },
  {
    index: '03',
    name: 'Studio Sept',
    category: 'Friseur',
    href: '/demos/friseur/index.html',
    theme: 'friseur',
    previewHeadline: 'À la coupe',
    palette: ['#3A2438', '#F4C5B5', '#F8F4ED'],
    tags: ['Editorial', 'Buchung'],
    compact: true,
  },
  {
    index: '04',
    name: 'Kruse Bau',
    category: 'Handwerk',
    href: '/demos/handwerker/index.html',
    theme: 'handwerker',
    previewHeadline: 'Bauen mit Verstand.',
    palette: ['#3A2C1F', '#C75D2F', '#5A6E4F'],
    tags: ['Vorher/Nachher', 'Projekte'],
    compact: true,
  },
] as const;
---

<section id="showcase" class="showcase" aria-labelledby="showcase-title">
  <header class="showcase__header">
    <span class="showcase__eyebrow">
      <span class="dash" aria-hidden="true"></span>
      Arbeiten / Showcase
    </span>

    <SplitText
      as="h2"
      by="words"
      stagger={0.05}
      class="showcase__title"
      id="showcase-title"
    >
      Vier Welten.
    </SplitText>

    <p class="showcase__intro">
      Vier Branchen, vier eigenständige Setzungen — andere Schrift, andere
      Energie, andere Geschichte. Kein Theme-Klon.
    </p>

    <div class="showcase__meta">
      <span class="mono-label">04 Demos</span>
      <span class="dot" aria-hidden="true">·</span>
      <span class="mono-label">Live ansehen</span>
    </div>
  </header>

  <div class="showcase__grid">
    <RevealOnScroll class="showcase__reveal" stagger={0.12} y={60}>
      {demos.map((demo) => <DemoCard {...demo} />)}
    </RevealOnScroll>
  </div>
</section>

<style>
  .showcase {
    position: relative;
    padding-block: var(--space-6) var(--space-8);
    padding-inline: var(--container-pad);
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .showcase__header {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    max-width: 60rem;
  }

  .showcase__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: currentColor;
  }

  .showcase__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 500;
  }

  .showcase__intro {
    font-size: var(--text-lg);
    max-width: 50ch;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    line-height: 1.5;
  }

  .showcase__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
  }

  .dot {
    opacity: 0.5;
  }

  .showcase__grid :global(.showcase__reveal) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
  }

  @media (max-width: 1100px) {
    .showcase__grid :global(.showcase__reveal) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .showcase__grid :global(.showcase__reveal) {
      grid-template-columns: 1fr;
    }
  }
</style>
