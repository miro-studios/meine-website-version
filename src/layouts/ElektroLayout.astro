---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/elektro/Header.astro';
import Footer from '@components/elektro/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  theme="elektro"
  bodyClass="hk-page"
>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  body.hk-page {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  body.hk-page ::selection {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  body.hk-page :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  body.hk-page h1,
  body.hk-page h2,
  body.hk-page h3,
  body.hk-page h4 {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.005em;
    text-transform: uppercase;
  }

  /* Shared helpers */
  .hk-container {
    max-width: var(--hk-container);
    margin-inline: auto;
    padding-inline: var(--hk-gutter);
  }

  .hk-section {
    padding-block: clamp(4rem, 8vw, 8rem);
  }

  .hk-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .hk-eyebrow::before {
    content: '';
    width: clamp(20px, 4vw, 48px);
    height: 1px;
    background: currentColor;
  }

  /* Section-Header-Pattern (technisches Spec-Bar) */
  .hk-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .hk-bar-n { color: var(--color-accent); font-weight: 700; }
  .hk-bar-line { flex: 1; height: 1px; background: var(--color-rule-strong); }
  .hk-bar-k { color: var(--color-muted); font-weight: 500; }

  /* Pulse-Dot fürs Live-Indicator-Pattern */
  @keyframes hk-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.7); opacity: 0.55; }
  }
</style>
