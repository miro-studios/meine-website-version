---
import BaseLayout from '@layouts/BaseLayout.astro';
import CustomCursor from '@components/shared/CustomCursor.astro';
import ScrollProgress from '@components/shared/ScrollProgress.astro';
import Header from '@components/elektro/Header.astro';
import Footer from '@components/elektro/Footer.astro';
import Preloader from '@components/elektro/Preloader.astro';
import CookieBanner from '@components/elektro/CookieBanner.astro';
import SectionNav from '@components/elektro/SectionNav.astro';
import StatusDeck from '@components/elektro/StatusDeck.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  theme="elektro"
  bodyClass="hk-page"
>
  <!-- Brand-Preloader (nur 1× pro Session) -->
  <Preloader />

  <!-- Custom Cursor (Premium-Signal — yellow ring on interactive elements) -->
  <CustomCursor dotSize={5} ringSize={32} blendMode="difference" hoverScale={2.4} />

  <!-- Scroll-Progress oben (1px yellow line) -->
  <ScrollProgress color="var(--color-accent)" />

  <!-- Pixel-Grain Overlay über der gesamten Seite — Premium-Tactile -->
  <div class="hk-grain" aria-hidden="true"></div>

  <!-- Subtile gradiente Vignette + ambient yellow glow von unten -->
  <div class="hk-ambient" aria-hidden="true"></div>

  <Header />

  <!-- Section-Nav (sticky rechts, Awwwards-Style) — site-weit -->
  <SectionNav />

  <!-- Status-Deck (sticky links unten) — Live-Telemetrie-Ribbon -->
  <StatusDeck />

  <main>
    <slot />
  </main>
  <Footer />

  <!-- DSGVO-Consent-Banner (1× pro Session) -->
  <CookieBanner />
</BaseLayout>

<script is:inline>
  // Custom-Cursor aktivieren — Premium-Signal
  document.documentElement.dataset.cursorActive = '';
  if (document.body) document.body.dataset.cursorActive = '';
  document.addEventListener('astro:page-load', () => {
    if (document.body) document.body.dataset.cursorActive = '';
  });
</script>

<style is:global>
  body.hk-page {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    cursor: none;
  }

  @media (hover: none), (pointer: coarse) {
    body.hk-page { cursor: auto; }
  }

  /* ── Pixel-Grain (SVG-Noise) — high-end texture overlay ──────────── */
  body.hk-page .hk-grain {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='320' height='320'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.94 0 0 0 0 0.93 0 0 0 0 0.89 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.045;
    mix-blend-mode: overlay;
  }

  /* ── Ambient: subtile yellow glow von unten + Vignette ──────────── */
  body.hk-page .hk-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 40% at 50% 110%,
        color-mix(in srgb, var(--color-accent) 14%, transparent) 0%,
        transparent 70%),
      radial-gradient(ellipse 100% 80% at 50% 50%,
        transparent 60%,
        color-mix(in srgb, #000 60%, transparent) 100%);
  }

  /* ── Astro View Transitions: Yellow-Sweep zwischen Routen ──────── */
  /* Schnell (≤ 550ms gesamt) — old fadet runter, sheet fliegt durch,
     new sliced rein. Maximaler Premium-Eindruck bei minimaler Wartezeit. */
  body.hk-page::view-transition-old(root),
  body.hk-page::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }
  body.hk-page::view-transition-old(root) {
    animation: hk-view-out 0.3s var(--ease-in-out-quart) forwards;
  }
  body.hk-page::view-transition-new(root) {
    animation: hk-view-in 0.35s var(--ease-out-expo) 0.18s forwards;
  }

  @keyframes hk-view-out {
    0%   { clip-path: inset(0 0 0 0); }
    100% { clip-path: inset(0 0 100% 0); }
  }
  @keyframes hk-view-in {
    0%   { clip-path: inset(100% 0 0 0); }
    100% { clip-path: inset(0 0 0 0); }
  }

  /* Yellow-Sheet das während der Transition kurz aufblitzt */
  body.hk-page::view-transition-image-pair(root)::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    z-index: 1;
    animation: hk-view-sheet 0.55s var(--ease-in-out-quart) forwards;
    pointer-events: none;
  }
  @keyframes hk-view-sheet {
    0%, 100% { transform: translateY(105%); }
    30%, 55% { transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    body.hk-page::view-transition-old(root),
    body.hk-page::view-transition-new(root),
    body.hk-page::view-transition-image-pair(root)::before {
      animation: none !important;
    }
  }

  body.hk-page ::selection {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  body.hk-page :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  body.hk-page h1,
  body.hk-page h2,
  body.hk-page h3,
  body.hk-page h4 {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.005em;
    text-transform: uppercase;
  }

  /* Shared helpers */
  .hk-container {
    max-width: var(--hk-container);
    margin-inline: auto;
    padding-inline: var(--hk-gutter);
  }

  .hk-section {
    padding-block: clamp(4rem, 8vw, 8rem);
  }

  .hk-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .hk-eyebrow::before {
    content: '';
    width: clamp(20px, 4vw, 48px);
    height: 1px;
    background: currentColor;
  }

  /* Section-Header-Pattern (technisches Spec-Bar) */
  .hk-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .hk-bar-n { color: var(--color-accent); font-weight: 700; }
  .hk-bar-line { flex: 1; height: 1px; background: var(--color-rule-strong); }
  .hk-bar-k { color: var(--color-muted); font-weight: 500; }

  /* Pulse-Dot fürs Live-Indicator-Pattern */
  @keyframes hk-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.7); opacity: 0.55; }
  }

  /* ── Section-Divider-Tag-System ────────────────────────────────── */
  /* Kleiner "Stempel" der zwischen zwei Sections sitzt — Awwwards-Pattern */
  .hk-tag {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 0;
    z-index: 5;
  }
  .hk-tag__inner {
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-rule-strong);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .hk-tag__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }
  .hk-tag__k { color: var(--color-accent); }
  .hk-tag__v { color: var(--color-text); }
</style>
