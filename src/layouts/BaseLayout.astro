---
import { ViewTransitions } from 'astro:transitions';
import BaseHead from '@components/shared/BaseHead.astro';
import SmoothScroll from '@components/shared/SmoothScroll.astro';

import '@styles/global.css';
import '@styles/themes/portfolio.css';
import '@styles/themes/cafe-starter.css';
import '@styles/themes/pizzeria.css';
import '@styles/themes/architekt.css';
import '@styles/themes/elektro.css';

// Café Nordlicht (Starter), Bella Notte (Growth), Atelier Vossen
// (Basic Multi-Page) und Holtkamp Elektrotechnik (Business Multi-Page)
// sind echte Astro-Demos und benötigen das Theme hier.
export type Theme = 'portfolio' | 'cafe-starter' | 'pizzeria' | 'architekt' | 'elektro';

interface Props {
  title: string;
  description?: string;
  theme?: Theme;
  /** Wenn `true`, wird Lenis (Smooth Scroll) initialisiert. */
  smoothScroll?: boolean;
  /** Body-Klassen die zusätzlich gesetzt werden. */
  bodyClass?: string;
  /** Custom canonical URL */
  canonical?: string;
  /** OG-Bild-Pfad */
  image?: string;
  /** Wenn `true` (nur auf der Startseite), wird das Organization-JSON-LD ausgegeben */
  includeOrganizationSchema?: boolean;
}

const {
  title,
  description,
  theme = 'portfolio',
  smoothScroll = true,
  bodyClass = '',
  canonical,
  image,
  includeOrganizationSchema = false,
} = Astro.props;
---

<!doctype html>
<html lang="de" data-theme={theme}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      includeOrganizationSchema={includeOrganizationSchema}
    />
    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    {smoothScroll && <SmoothScroll />}
    <slot />
  </body>
</html>

<style is:global>
  /* Body-Hintergrund + Text-Farbe kommen aus dem Theme */
  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    transition: background-color 0.4s var(--ease-out-expo);
  }
</style>
