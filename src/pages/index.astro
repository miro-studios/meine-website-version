---
import PortfolioLayout from '@layouts/PortfolioLayout.astro';
import Hero from '@components/portfolio/Hero.astro';
import Manifest from '@components/portfolio/Manifest.astro';
import Works from '@components/portfolio/Works.astro';
import Capabilities from '@components/portfolio/Capabilities.astro';
import ScrollStory from '@components/portfolio/ScrollStory.astro';
import Stats from '@components/portfolio/Stats.astro';
import Pricing from '@components/portfolio/Pricing.astro';
import FaqTeaser from '@components/portfolio/FaqTeaser.astro';
import Footer from '@components/portfolio/Footer.astro';
import Marquee from '@components/shared/Marquee.astro';
---

<PortfolioLayout
  title="miro-studios — Websites für lokale Geschäfte aus Kierspe, NRW"
  description="Junges Webdesign-Studio aus Kierspe. Wir bauen Websites für Pizzerien, Friseure, Cafés und Handwerker in NRW — klare Gestaltung, ehrliche Preise, ein Ansprechpartner."
  active="index"
>
  <!-- 1. Hero — ruhig, klar, editorial -->
  <Hero />

  <!-- 2. Manifest — ehrliche Haltung, kein Werbeblabla -->
  <Manifest />

  <!-- 3. Laufband — dezenter Übergang -->
  <Marquee
    items={[
      'Webdesign aus Kierspe',
      'Für lokale Geschäfte',
      'Klare Preise',
      'Domain & Hosting inklusive',
      'Ein Ansprechpartner',
      'Selbst geschriebener Code',
      'Ab 599 €',
    ]}
    speed={55}
  />

  <!-- 4. Echte Live-Demos — das stärkste Verkaufsargument -->
  <Works />

  <!-- 5. Was wir machen — Disziplinen in einfacher Sprache -->
  <Capabilities />

  <!-- 6. Wie wir arbeiten — vier klare Schritte -->
  <ScrollStory />

  <!-- 7. Stats — ehrliche Zahlen, kein Marketing-Theater -->
  <Stats />

  <!-- 8. Preise -->
  <Pricing />

  <!-- 9. FAQ-Teaser — die 3 wichtigsten Erstfragen + Link zur Vollversion -->
  <FaqTeaser />

  <!-- 10. Studio-Teaser -->
  <section class="studio-teaser" data-studio-teaser>
    <div class="studio-teaser__inner">
      <p class="studio-teaser__label">Das Studio</p>
      <h2 class="studio-teaser__heading">Ein Kopf.<br/>Ein Studio.</h2>
      <p class="studio-teaser__sub">
        Du sprichst direkt mit dem Designer und Entwickler, der deine Website
        auch baut. Aus Kierspe, für ganz NRW.
      </p>
      <a href="/about" class="studio-teaser__btn">
        <span>Studio kennenlernen</span>
        <span class="studio-teaser__btn-icon" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- 11. CTA-Banner -->
  <section class="cta-banner" data-cta-banner>
    <div class="cta-banner__inner">
      <p class="cta-banner__label">Bereit loszulegen?</p>
      <h2 class="cta-banner__heading">
        Lass uns über deine Website sprechen.
      </h2>
      <p class="cta-banner__sub">
        Schreib mir eine kurze Nachricht — ich melde mich innerhalb von 24 Stunden
        zurück. Erstgespräch und Angebot sind kostenlos.
      </p>
      <a href="/kontakt" class="cta-banner__btn" data-magnetic>
        <span>Anfrage starten</span>
        <span class="cta-banner__btn-icon" aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <Footer />
</PortfolioLayout>

<style>
  /* ── Studio Teaser ────────────────────────────────────────────────── */
  .studio-teaser {
    position: relative;
    padding-block: clamp(4rem, 8vw, 7rem);
    padding-inline: var(--container-pad);
    border-top: 1px solid var(--color-rule);
    background-color: var(--color-bg);
  }

  .studio-teaser__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }

  @media (max-width: 720px) {
    .studio-teaser__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .studio-teaser__label {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s var(--ease-out-expo),
                transform 0.6s var(--ease-out-expo);
  }

  .studio-teaser__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin: 0;
    color: var(--color-text);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s 0.08s var(--ease-out-expo),
                transform 0.7s 0.08s var(--ease-out-expo);
  }

  .studio-teaser__sub {
    font-size: clamp(1rem, 1.1vw + 0.5rem, 1.15rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 38ch;
    margin: 0 0 1rem;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s 0.15s var(--ease-out-expo),
                transform 0.7s 0.15s var(--ease-out-expo);
  }

  .studio-teaser__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.75rem;
    border: 1px solid var(--color-text);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    width: max-content;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s 0.22s var(--ease-out-expo),
                transform 0.7s 0.22s var(--ease-out-expo),
                background-color 0.3s ease,
                color 0.3s ease;
  }

  .studio-teaser__btn:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .studio-teaser__btn-icon {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .studio-teaser__btn:hover .studio-teaser__btn-icon {
    transform: translateX(4px);
  }

  .studio-teaser.is-visible .studio-teaser__label,
  .studio-teaser.is-visible .studio-teaser__heading,
  .studio-teaser.is-visible .studio-teaser__sub,
  .studio-teaser.is-visible .studio-teaser__btn {
    opacity: 1;
    transform: none;
  }

  /* ── CTA Banner ──────────────────────────────────────────────────── */
  .cta-banner {
    position: relative;
    padding-block: clamp(4rem, 9vw, 8rem);
    padding-inline: var(--container-pad);
    text-align: center;
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 100%,
        color-mix(in srgb, var(--color-accent) 12%, transparent),
        transparent 70%
      ),
      var(--color-bg);
    border-top: 1px solid var(--color-rule);
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
    max-width: 640px;
    margin-inline: auto;
  }

  .cta-banner__label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s var(--ease-out-expo),
                transform 0.7s var(--ease-out-expo);
  }

  .cta-banner__heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 400;
    color: var(--color-text);
    text-wrap: balance;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s 0.1s var(--ease-out-expo),
                transform 0.8s 0.1s var(--ease-out-expo);
  }

  .cta-banner__sub {
    margin: 0;
    font-size: clamp(1rem, 1vw + 0.5rem, 1.15rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
    max-width: 44ch;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s 0.18s var(--ease-out-expo),
                transform 0.8s 0.18s var(--ease-out-expo);
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 1.05rem 2.4rem;
    background-color: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-radius: 100px;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px) scale(0.98);
    transition: opacity 0.7s 0.26s var(--ease-out-expo),
                transform 0.7s 0.26s var(--ease-out-expo),
                background-color 0.3s ease,
                box-shadow 0.3s ease;
  }

  .cta-banner__btn:hover {
    background-color: var(--color-accent);
    box-shadow: 0 12px 32px -8px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .cta-banner__btn-icon {
    display: inline-block;
    font-size: 1.05em;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .cta-banner__btn:hover .cta-banner__btn-icon {
    transform: translate(3px, -3px);
  }

  .cta-banner.is-visible .cta-banner__label,
  .cta-banner.is-visible .cta-banner__heading,
  .cta-banner.is-visible .cta-banner__sub,
  .cta-banner.is-visible .cta-banner__btn {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .studio-teaser__label,
    .studio-teaser__heading,
    .studio-teaser__sub,
    .studio-teaser__btn,
    .cta-banner__label,
    .cta-banner__heading,
    .cta-banner__sub,
    .cta-banner__btn {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initReveal(selector: string) {
    const el = document.querySelector<HTMLElement>(selector);
    if (!el) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.classList.add('is-visible');
      return;
    }
    ScrollTrigger.create({
      trigger: el,
      start: 'top 78%',
      once: true,
      onEnter: () => el.classList.add('is-visible'),
    });
  }

  function initAll() {
    initReveal('[data-studio-teaser]');
    initReveal('[data-cta-banner]');
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>
