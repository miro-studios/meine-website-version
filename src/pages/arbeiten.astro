<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function init() {
    const toggle = document.querySelector<HTMLElement>('.works-toggle[data-toggle]');
    const options = toggle
      ? Array.from(toggle.querySelectorAll<HTMLButtonElement>('.works-toggle__option'))
      : [];
    const cards = document.querySelectorAll<HTMLElement>('.work-card');
    if (!toggle || !options.length || !cards.length) return;

    let animTimer: number | undefined;

    const apply = (filter: string) => {
      if (toggle.dataset.active === filter) return;
      toggle.dataset.active = filter;

      // One-shot Squash + Shine
      toggle.dataset.animating = 'true';
      window.clearTimeout(animTimer);
      animTimer = window.setTimeout(() => {
        delete toggle.dataset.animating;
      }, 800);

      // Aktiver Tab + ARIA
      options.forEach((opt) => {
        const isActive = opt.dataset.filter === filter;
        opt.classList.toggle('is-active', isActive);
        opt.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      // Karten ein-/ausblenden
      cards.forEach((card) => {
        const matches = filter === 'all' || card.dataset.format === filter;
        card.classList.toggle('is-hidden', !matches);
      });

      // Reveal-on-Scroll-Trigger sind an die *ursprüngliche* Karten-Position
      // gekoppelt. Nach dem Filter rutschen die sichtbaren Karten nach oben —
      // ohne refresh blieben sie unsichtbar bis man bis zur Ur-Position scrollt.
      // 1) Jetzt-sichtbare Karten sofort auf "revealed" setzen, damit nichts hängt.
      // 2) ScrollTrigger neu vermessen, damit der Toggle-Back beim Re-Filter wieder greift.
      gsap.set(
        Array.from(cards).filter((c) => !c.classList.contains('is-hidden')),
        { opacity: 1, y: 0, clearProps: 'transform' },
      );
      ScrollTrigger.refresh();
    };

    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        if (opt.dataset.filter) apply(opt.dataset.filter);
      });
    });

    // Tastatur-Navigation
    toggle.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      e.preventDefault();
      const idx = options.findIndex((o) => o.classList.contains('is-active'));
      const next =
        e.key === 'ArrowRight'
          ? options[(idx + 1) % options.length]
          : options[(idx - 1 + options.length) % options.length];
      next.focus();
      if (next.dataset.filter) apply(next.dataset.filter);
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
