---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impressum — Bella Notte"
  description="Impressum und Anbieterkennzeichnung der Trattoria Bella Notte in Lüdenscheid."
  theme="pizzeria"
  bodyClass="bn-page bn-legal"
>
  <main class="bn-legal__page">
    <a href="/demos/pizzeria/" class="bn-legal__back">← Zurück zur Startseite</a>

    <h1 class="bn-legal__title">Impressum</h1>

    <section class="bn-legal__block">
      <h2>Angaben gemäß § 5 TMG</h2>
      <p>
        Bella Notte GbR<br />
        Inhaber: Marco Caruso & Lisa Caruso-Berghaus<br />
        Knapper Weg 47<br />
        58507 Lüdenscheid
      </p>
    </section>

    <section class="bn-legal__block">
      <h2>Kontakt</h2>
      <p>
        Telefon: 02351 / 98 76 543<br />
        E-Mail:
        <a href="mailto:ciao@bella-notte-luedenscheid.de">ciao@bella-notte-luedenscheid.de</a>
      </p>
    </section>

    <section class="bn-legal__block">
      <h2>Umsatzsteuer-ID</h2>
      <p>
        Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
        DE 287 654 321
      </p>
    </section>

    <section class="bn-legal__block">
      <h2>Verantwortlich für den Inhalt</h2>
      <p>
        Marco Caruso<br />
        Knapper Weg 47, 58507 Lüdenscheid
      </p>
    </section>

    <section class="bn-legal__block">
      <h2>Hinweis</h2>
      <p>
        Diese Demo-Seite dient ausschließlich der Veranschaulichung des
        miro-studios "Growth"-Pakets. Bella Notte ist ein fiktives
        Beispielunternehmen — alle Angaben sind frei erfunden.
      </p>
    </section>

    <section class="bn-legal__block">
      <h2>Streitschlichtung</h2>
      <p>
        Die Europäische Kommission stellt eine Plattform zur
        Online-Streitbeilegung (OS) bereit:
        <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">
          https://ec.europa.eu/consumers/odr
        </a>.
        Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren
        vor einer Verbraucherschlichtungsstelle teilzunehmen.
      </p>
    </section>
  </main>
</BaseLayout>

<style is:global>
  body.bn-legal {
    background-color: var(--color-bg);
    color: var(--color-text);
  }
</style>

<style>
  .bn-legal__page {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: var(--bn-gutter);
    padding-block: clamp(3rem, 8vw, 6rem);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .bn-legal__back {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-primary);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
    align-self: flex-start;
    padding-block: 0.5rem;
    margin-block: -0.5rem;
  }

  .bn-legal__back:hover {
    border-bottom-color: currentColor;
  }

  .bn-legal__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .bn-legal__block h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
    font-style: italic;
  }

  .bn-legal__block p {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
  }

  .bn-legal__block a {
    color: var(--color-primary);
    border-bottom: 1px solid currentColor;
  }
</style>
