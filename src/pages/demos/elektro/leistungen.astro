---
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';

type SvcIcon = 'panel' | 'pump' | 'pv' | 'knx' | 'wallbox' | 'siren';

interface Service {
  n: string;
  title: string;
  sub: string;
  text: string;
  items: string[];
  note: string;
  price: string;
  icon: SvcIcon;
  stats: Array<{ k: string; v: string; u?: string }>;
}

const services: Service[] = [
  {
    n: '01',
    title: 'ELEKTRO­INSTALLATION',
    sub: 'Privat · Gewerbe · Industrie',
    text: 'Vom kompletten Neubau über die Sanierung im Bestand bis zur einzelnen Steckdose. Wir planen Verteilungen, ziehen Leitungen, dokumentieren VDE-konform und übergeben mit Messprotokoll.',
    items: ['Neuanlagen & Erweiterungen', 'Sanierung Bestand', 'Industrieinstallationen bis 1 MW', 'Datennetze (Cat6, Cat7, Glasfaser)', 'Brandmelde- & Einbruch-Anlagen', 'E-Check mit Protokoll'],
    note: 'VDE 0100 · 0105 · 0701',
    price: 'AB 65 € / STUNDE',
    icon: 'panel',
    stats: [
      { k: 'AB', v: '65', u: '€/h' },
      { k: 'NORM', v: 'VDE' },
      { k: 'DOK', v: '100', u: '%' },
    ],
  },
  {
    n: '02',
    title: 'HEIZUNG & WÄRME',
    sub: 'Wärmepumpe · Hybrid · Solar',
    text: 'Heizungsbau ist heute zu 80% Elektrotechnik. Deshalb bauen wir beides aus einer Hand — Wärmepumpe, Pufferspeicher, Heizstab, Steuerung. Mit Heizlast­berechnung, hydraulischem Abgleich und Förderantrag.',
    items: ['Luft-Wasser-Wärmepumpen', 'Sole-Wasser-Wärmepumpen', 'Hybrid mit Gas/Öl-Bestand', 'Pufferspeicher & Warmwasser', 'Heizlast & hydraulischer Abgleich', 'BAFA-/KfW-Förderung inkl.'],
    note: 'GEG-KONFORM · BAFA-LISTE',
    price: 'AB 18.000 €',
    icon: 'pump',
    stats: [
      { k: 'COP', v: '4,3' },
      { k: 'BAFA', v: 'JA' },
      { k: 'AB', v: '18', u: 'T€' },
    ],
  },
  {
    n: '03',
    title: 'PHOTOVOLTAIK',
    sub: 'Komplett-Anlagen mit Speicher',
    text: 'Wir liefern wirtschaftliche PV-Anlagen — keine 22-kWp-Aufrüstung weil "geht halt drauf", sondern eine Auslegung, die zu Verbrauch, Dach und Budget passt. Komplettpaket: Planung, Montage, Anmeldung, Inbetriebnahme.',
    items: ['Dachanalyse & Verschattung', 'Module (BYD, Q.Cells, Meyer Burger)', 'Wechselrichter & Notstrom', 'Speicher 5–20 kWh', 'Netzanmeldung & Marktstammdaten', 'Wallbox-Anbindung'],
    note: 'MEISTERANLAGE · 10 J. GARANTIE',
    price: 'AB 8.900 €',
    icon: 'pv',
    stats: [
      { k: 'KWP', v: '6–22' },
      { k: 'SPEICHER', v: '20', u: 'kWh' },
      { k: 'GARANTIE', v: '10', u: 'J' },
    ],
  },
  {
    n: '04',
    title: 'SMART HOME',
    sub: 'KNX · Loxone · Matter',
    text: 'Eine zentrale Anlage, die schaltet, dimmt, regelt und meldet — vom 80-m²-Apartment bis zur 800-m²-Villa. Wir planen herstellerunabhängig und übergeben mit Wartungsvertrag, damit Sie nicht alleine an der ETS sitzen.',
    items: ['KNX (klassische Bus-Lösung)', 'Loxone (kompakte All-in-One)', 'Matter / Thread (modernes Mesh)', 'Visualisierung & App-Steuerung', 'Sicherheitssensorik', 'Wartung im Abo'],
    note: 'ZERTIFIZIERTE PARTNER',
    price: 'AB 95 € / STUNDE',
    icon: 'knx',
    stats: [
      { k: 'BUS', v: 'KNX' },
      { k: 'GERÄTE', v: '∞' },
      { k: 'WARTUNG', v: 'ABO' },
    ],
  },
  {
    n: '05',
    title: 'E-MOBILITÄT',
    sub: 'Wallbox · Lastmanagement · Abrechnung',
    text: 'Vom einfachen 11-kW-Heimanschluss bis zur Firmenladelösung mit dynamischem Lastmanagement und Abrechnungs-Backend. Wir installieren KEBA, ABL, Mennekes und Compleo — keine Apple-Watch-Spielzeuge.',
    items: ['Heim-Wallbox 11/22 kW', 'PV-Überschussladung', 'Firmenladeparks (4–40 Punkte)', 'Lastmanagement (statisch/dynamisch)', 'Abrechnung & RFID', 'Förderung KfW (sofern verfügbar)'],
    note: 'EICHRECHTSKONFORM · AC + DC',
    price: 'AB 1.890 €',
    icon: 'wallbox',
    stats: [
      { k: 'KW', v: '11–22' },
      { k: 'PUNKTE', v: '4–40' },
      { k: 'RFID', v: 'JA' },
    ],
  },
  {
    n: '06',
    title: '24H NOTDIENST',
    sub: 'Strom & Wärme · MK-Gebiet',
    text: 'Wenn die Sicherung knallt, die Heizung ausfällt oder die Wallbox raucht: 0 23 51 / 60 80 21. Wir sind in der Regel innerhalb von 90 Minuten bei Ihnen — Tag, Nacht, Wochenende, Feiertag.',
    items: ['Strom-Ausfall Privat', 'Heizungsausfall', 'Industrie-Notdienst', 'PV-Defekt', 'Brand- und Wasserschaden Folgearbeiten', 'Wartungsverträge mit SLA'],
    note: 'REAKTION ⌀ 90 MIN · MK',
    price: 'AB 95 € / EINSATZ',
    icon: 'siren',
    stats: [
      { k: 'MIN', v: '90' },
      { k: '24H', v: '✓' },
      { k: 'SLA', v: 'JA' },
    ],
  },
];

const faq = [
  { q: 'Was kostet ein Erstgespräch?', a: 'Für Privatkunden im MK-Gebiet ist das Erstgespräch kostenfrei — wir kommen vorbei, hören zu, geben eine erste Einschätzung. Bei Gewerbe-Aufträgen ab 50.000 € klären wir den Aufwand vorher kurz telefonisch.' },
  { q: 'Wie schnell könnt ihr starten?', a: 'Standard-Aufträge (E-Check, kleinere Installationen) in 2–4 Wochen. Größere Projekte (PV, Wärmepumpe, Sanierung) je nach Saison 6–14 Wochen. Im Sommer-Q1 buchen wir oft schon für Winter-Q4.' },
  { q: 'Macht ihr auch Anlagen, die ihr nicht selbst geplant habt?', a: 'Ja — wir übernehmen Wartungen und Erweiterungen an Fremd-Anlagen, sofern sie technisch sauber dokumentiert sind. Wenn nicht, klären wir das vorher und machen ggf. eine Bestandsaufnahme.' },
  { q: 'Welche Hersteller verbaut ihr?', a: 'Wir sind unabhängig — verbauen aber bevorzugt deutsche und europäische Komponenten mit nachweisbarer Garantie: Hager, ABB, Stiebel Eltron, Vaillant, Viessmann, KEBA, Q.Cells, BYD. Nicht aus Patriotismus, sondern weil die Ersatzteilverfügbarkeit besser ist.' },
  { q: 'Gibt es einen Servicevertrag?', a: 'Ja, für PV-Anlagen, Wärmepumpen und Smart-Home-Anlagen empfehlen wir einen Wartungsvertrag (ca. 180–340 € / Jahr). Dafür bekommen Sie 1× pro Jahr eine vollständige Wartung und priorisierten Notdienst.' },
  { q: 'Arbeitet ihr auch außerhalb des Märkischen Kreises?', a: 'Standard-Einzugsgebiet ist ein Umkreis von 50 km um Lüdenscheid. Für größere Projekte (Industrie, mehrteilige PV-Anlagen) kommen wir auch nach Köln, Bochum oder Dortmund — Anreisen werden dann separat berechnet.' },
];
---

<ElektroLayout
  title="Holtkamp Elektrotechnik — Leistungen · Was wir bauen"
  description="Elektroinstallation, Heizung, Photovoltaik, Smart Home, E-Mobilität und 24-Stunden-Notdienst. Sechs Gewerke unter einem Dach im Märkischen Kreis."
>
  <!-- ── Page Hero (mit Index-Diagramm & Spec-Bar) ────────────────── -->
  <section class="hk-pg-hero" data-hk-section data-hk-name="Übersicht">
    <div class="hk-pg-hero__spec" aria-hidden="true">
      <span class="hk-pg-hero__spec-k">PAGE</span>
      <span class="hk-pg-hero__spec-v">02 / LEISTUNGEN</span>
      <span class="hk-pg-hero__spec-dot"></span>
      <span class="hk-pg-hero__spec-k">REV</span>
      <span class="hk-pg-hero__spec-v">2026.Q2</span>
      <span class="hk-pg-hero__spec-line"></span>
      <span class="hk-pg-hero__spec-k">KAT</span>
      <span class="hk-pg-hero__spec-v">06</span>
      <span class="hk-pg-hero__spec-k">·</span>
      <span class="hk-pg-hero__spec-v">EL · HEIZ · PV · KNX · EV · NOT</span>
    </div>

    <div class="hk-container hk-pg-hero__grid">
      <div class="hk-pg-hero__copy">
        <div class="hk-bar">
          <span class="hk-bar-n">N° 02</span>
          <span class="hk-bar-line" aria-hidden="true"></span>
          <span class="hk-bar-k">PAGE / LEISTUNGEN</span>
        </div>

        <h1 class="hk-pg-hero__h">
          <span class="hk-pg-hero__line"><SplitText by="words" stagger={0.05}>SECHS</SplitText></span>
          <span class="hk-pg-hero__line hk-pg-hero__line--alt"><SplitText by="words" stagger={0.05} delay={0.15}>GEWERKE.</SplitText></span>
          <span class="hk-pg-hero__line"><SplitText by="words" stagger={0.05} delay={0.3}>EIN BETRIEB.</SplitText></span>
        </h1>

        <p class="hk-pg-hero__lead">
          Elektro und Wärme gehören zusammen geplant. Deshalb haben wir
          beide Gewerke unter einem Dach — plus PV, Smart Home, E-Mobilität
          und ein 24-Stunden-Notdienst im MK-Gebiet.
        </p>

        <!-- Quick-Nav zu den 6 Gewerken -->
        <ul class="hk-pg-hero__nav">
          {services.map((s) => (
            <li>
              <a href={`#svc-${s.n}`} class="hk-pg-hero__nav-link">
                <span class="hk-pg-hero__nav-n">{s.n}</span>
                <span class="hk-pg-hero__nav-l" set:html={s.title} />
                <span class="hk-pg-hero__nav-arrow" aria-hidden="true">↓</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Index-Karte rechts: kompakter Schaltkasten -->
      <aside class="hk-pg-hero__plate" aria-hidden="true">
        <span class="hk-pg-hero__plate-bracket hk-pg-hero__plate-bracket--tl"></span>
        <span class="hk-pg-hero__plate-bracket hk-pg-hero__plate-bracket--tr"></span>
        <span class="hk-pg-hero__plate-bracket hk-pg-hero__plate-bracket--bl"></span>
        <span class="hk-pg-hero__plate-bracket hk-pg-hero__plate-bracket--br"></span>

        <header>
          <span class="hk-pg-hero__plate-dot"></span>
          <span>INDEX · GEWERKE</span>
          <span class="hk-pg-hero__plate-rev">N° 06</span>
        </header>

        <svg viewBox="0 0 280 320" class="hk-pg-hero__plate-svg">
          <defs>
            <pattern id="hk-pg-grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M20 0H0V20" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
            </pattern>
          </defs>
          <rect width="280" height="320" fill="url(#hk-pg-grid)" opacity="0.6"/>

          <!-- Sechs Schaltsymbole im 3x2-Grid -->
          <!-- 01 ELEKTRO -->
          <g transform="translate(50 60)">
            <rect x="-20" y="-20" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <g stroke="currentColor" stroke-width="0.8" fill="none">
              <rect x="-12" y="-12" width="6" height="8"/>
              <rect x="-2" y="-12" width="6" height="8"/>
              <rect x="8" y="-12" width="6" height="8"/>
              <rect x="-12" y="0" width="6" height="8"/>
              <rect x="-2" y="0" width="6" height="8"/>
              <rect x="8" y="0" width="6" height="8"/>
            </g>
            <text x="0" y="35" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">01 EL</text>
          </g>
          <!-- 02 WP -->
          <g transform="translate(140 60)">
            <rect x="-20" y="-18" width="40" height="36" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="0" cy="0" r="10" fill="none" stroke="currentColor" stroke-width="1"/>
            <g stroke="currentColor" stroke-width="0.8" fill="none">
              <line x1="0" y1="-7" x2="0" y2="-3"/>
              <line x1="0" y1="3" x2="0" y2="7"/>
              <line x1="-7" y1="0" x2="-3" y2="0"/>
              <line x1="3" y1="0" x2="7" y2="0"/>
            </g>
            <text x="0" y="35" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">02 WP</text>
          </g>
          <!-- 03 PV -->
          <g transform="translate(230 60)">
            <polygon points="-18,12 0,-16 18,12" fill="color-mix(in srgb, var(--color-accent) 20%, transparent)" stroke="currentColor" stroke-width="1.2"/>
            <g stroke="currentColor" stroke-width="0.4" opacity="0.5">
              <line x1="-12" y1="4" x2="12" y2="4"/>
              <line x1="-6" y1="-4" x2="6" y2="-4"/>
              <line x1="-3" y1="-12" x2="3" y2="-12"/>
            </g>
            <text x="0" y="35" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">03 PV</text>
          </g>
          <!-- 04 KNX -->
          <g transform="translate(50 180)">
            <rect x="-12" y="-8" width="24" height="16" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="0" cy="0" r="2" fill="var(--color-accent)">
              <animate attributeName="opacity" values="0.4;1;0.4" dur="2s" repeatCount="indefinite"/>
            </circle>
            <g stroke="currentColor" stroke-width="0.8" fill="none">
              <line x1="-12" y1="-4" x2="-20" y2="-4"/>
              <line x1="-12" y1="4" x2="-20" y2="4"/>
              <line x1="12" y1="-4" x2="20" y2="-4"/>
              <line x1="12" y1="4" x2="20" y2="4"/>
            </g>
            <text x="0" y="25" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">04 KNX</text>
          </g>
          <!-- 05 EV -->
          <g transform="translate(140 180)">
            <rect x="-14" y="-16" width="14" height="28" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <path d="M-6 -8 L -10 0 L -7 0 L -8 6 L -3 -2 L -6 -2 Z" fill="var(--color-accent)"/>
            <path d="M0 8 Q 6 8 8 12" stroke="currentColor" stroke-width="1" fill="none"/>
            <circle cx="10" cy="12" r="2" fill="var(--color-accent)"/>
            <text x="0" y="25" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">05 EV</text>
          </g>
          <!-- 06 NOT -->
          <g transform="translate(230 180)">
            <g transform="translate(0 0)">
              <circle r="14" fill="none" stroke="var(--color-accent)" stroke-width="0.8" opacity="0.5">
                <animate attributeName="r" values="8;16" dur="2s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.6;0" dur="2s" repeatCount="indefinite"/>
              </circle>
              <g transform="rotate(-30)">
                <rect x="-3" y="-7" width="6" height="14" rx="1" fill="var(--color-accent)"/>
              </g>
            </g>
            <text x="0" y="25" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--color-accent)" letter-spacing="0.5" font-weight="700">06 24H</text>
          </g>

          <!-- Mess-Linien -->
          <g stroke="currentColor" stroke-width="0.4" opacity="0.4">
            <line x1="20" y1="280" x2="260" y2="280"/>
          </g>
          <text x="140" y="305" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="var(--color-accent)" letter-spacing="1" font-weight="700">SCHALT-MATRIX · BEISPIEL</text>
        </svg>

        <footer>
          <span>BLATT 01 · MAI 2026</span>
          <span class="hk-pg-hero__plate-foot-id">HK-PG-LST.026</span>
        </footer>
      </aside>
    </div>
  </section>

  <!-- ── Services Detail ──────────────────────────────────────────── -->
  <section class="hk-svc-list" data-hk-section data-hk-name="Gewerke im Detail">
    <div class="hk-container">
      {services.map((s, idx) => (
        <article class="hk-svc-list__row" id={`svc-${s.n}`} data-hk-svc-row>
          <div class="hk-svc-list__meta">
            <span class="hk-svc-list__n">N° {s.n}</span>
            <h2 class="hk-svc-list__h" set:html={s.title} />
            <p class="hk-svc-list__sub">{s.sub}</p>

            <!-- Mini-Stats -->
            <dl class="hk-svc-list__stats">
              {s.stats.map((st) => (
                <div>
                  <dt>{st.k}</dt>
                  <dd>{st.v}{st.u && <span class="hk-svc-list__stats-u">{st.u}</span>}</dd>
                </div>
              ))}
            </dl>

            <span class="hk-svc-list__note">{s.note}</span>
            <span class="hk-svc-list__price">{s.price}</span>
          </div>

          <div class="hk-svc-list__body">
            <!-- Großes Visual pro Gewerk -->
            <div class="hk-svc-list__visual" aria-hidden="true">
              <span class="hk-svc-list__visual-corner hk-svc-list__visual-corner--tl"></span>
              <span class="hk-svc-list__visual-corner hk-svc-list__visual-corner--tr"></span>
              <span class="hk-svc-list__visual-corner hk-svc-list__visual-corner--bl"></span>
              <span class="hk-svc-list__visual-corner hk-svc-list__visual-corner--br"></span>
              <span class="hk-svc-list__visual-label">FIG. {s.n} · {s.title.replace(/­/g, '')}</span>

              {s.icon === 'panel' && (
                <svg viewBox="0 0 640 280" class="hk-svc-list__visual-svg">
                  <defs>
                    <pattern id="grid-pa" width="22" height="22" patternUnits="userSpaceOnUse">
                      <path d="M22 0H0V22" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                    </pattern>
                  </defs>
                  <rect width="640" height="280" fill="url(#grid-pa)"/>
                  <!-- Schaltschrank -->
                  <rect x="40" y="40" width="200" height="200" fill="none" stroke="currentColor" stroke-width="1.6"/>
                  <line x1="40" y1="74" x2="240" y2="74" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
                  <line x1="40" y1="115" x2="240" y2="115" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
                  <line x1="40" y1="156" x2="240" y2="156" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
                  <line x1="40" y1="197" x2="240" y2="197" stroke="currentColor" stroke-width="0.8" opacity="0.5"/>
                  <!-- Sicherungen Reihen -->
                  <g stroke="currentColor" stroke-width="0.9" fill="none">
                    {Array.from({ length: 8 }).map((_, i) => (
                      <g transform={`translate(${50 + i * 23} 50)`}>
                        <rect width="14" height="16"/>
                        <line x1="7" y1="3" x2="7" y2="13"/>
                      </g>
                    ))}
                    {Array.from({ length: 8 }).map((_, i) => (
                      <g transform={`translate(${50 + i * 23} 91)`}>
                        <rect width="14" height="16"/>
                        <line x1="7" y1={i % 2 === 0 ? "3" : "8"} x2="7" y2="13"/>
                      </g>
                    ))}
                    {Array.from({ length: 8 }).map((_, i) => (
                      <g transform={`translate(${50 + i * 23} 132)`}>
                        <rect width="14" height="16"/>
                        <line x1="7" y1={i % 3 === 0 ? "3" : "9"} x2="7" y2="13"/>
                      </g>
                    ))}
                    {Array.from({ length: 8 }).map((_, i) => (
                      <g transform={`translate(${50 + i * 23} 173)`}>
                        <rect width="14" height="16"/>
                        <line x1="7" y1={i === 4 ? "3" : "13"} x2="7" y2="13"/>
                      </g>
                    ))}
                  </g>
                  <!-- Live-Indikator -->
                  <circle cx="220" cy="58" r="3" fill="var(--color-accent)">
                    <animate attributeName="opacity" values="1;0.3;1" dur="1.8s" repeatCount="indefinite"/>
                  </circle>
                  <text x="40" y="260" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-accent)" letter-spacing="1" font-weight="700">HAUPT-VERTEILUNG · 63 A · 5-POL</text>

                  <!-- Datenkabel Beispiele -->
                  <g stroke="var(--color-accent)" stroke-width="1.2" fill="none" stroke-dasharray="6 8">
                    <path d="M240 80 L 360 80 L 360 130 L 480 130">
                      <animate attributeName="stroke-dashoffset" values="0;-28" dur="1.6s" repeatCount="indefinite"/>
                    </path>
                    <path d="M240 140 L 320 140 L 320 200 L 480 200">
                      <animate attributeName="stroke-dashoffset" values="0;-28" dur="2.2s" repeatCount="indefinite"/>
                    </path>
                  </g>
                  <!-- Verbraucher -->
                  <g stroke="currentColor" stroke-width="1.2" fill="none">
                    <rect x="480" y="80" width="100" height="60"/>
                    <text x="530" y="115" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" letter-spacing="1" font-weight="700">UV.OG</text>
                    <rect x="480" y="170" width="100" height="60"/>
                    <text x="530" y="205" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" letter-spacing="1" font-weight="700">UV.KG</text>
                  </g>
                </svg>
              )}

              {s.icon === 'pump' && (
                <svg viewBox="0 0 640 280" class="hk-svc-list__visual-svg">
                  <defs>
                    <pattern id="grid-wp" width="22" height="22" patternUnits="userSpaceOnUse">
                      <path d="M22 0H0V22" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                    </pattern>
                  </defs>
                  <rect width="640" height="280" fill="url(#grid-wp)"/>
                  <!-- Boden -->
                  <line x1="40" y1="220" x2="600" y2="220" stroke="currentColor" stroke-width="1"/>
                  <!-- Außeneinheit -->
                  <rect x="60" y="100" width="160" height="120" fill="none" stroke="currentColor" stroke-width="1.6"/>
                  <rect x="60" y="100" width="160" height="22" fill="none" stroke="currentColor" stroke-width="0.8"/>
                  <circle cx="140" cy="170" r="36" fill="none" stroke="currentColor" stroke-width="1.2"/>
                  <g stroke="currentColor" stroke-width="1.4" fill="none" transform="translate(140 170)">
                    <path d="M0 -24 A 12 12 0 0 1 12 0">
