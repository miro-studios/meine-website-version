<style>
  /* ── Page Hero ────────────────────────────────────────────────── */
  .hk-pg-hero {
    border-top: 1px solid var(--color-rule);
    padding-block: clamp(2rem, 4vw, 3.5rem) clamp(3rem, 6vw, 5rem);
    background:
      radial-gradient(ellipse 60% 60% at 80% 0%,
        color-mix(in srgb, var(--color-accent) 6%, transparent),
        transparent 70%),
      var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .hk-pg-hero__spec {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    padding: 0.7rem var(--hk-gutter);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hk-pg-hero__spec-k { color: var(--color-muted); font-weight: 700; }
  .hk-pg-hero__spec-v { color: var(--color-text); font-weight: 600; }
  .hk-pg-hero__spec-dot { width: 4px; height: 4px; background: var(--color-accent); border-radius: 50%; }
  .hk-pg-hero__spec-line { flex: 1; height: 1px; background: var(--color-rule-strong); min-width: 1rem; }

  .hk-pg-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  @media (min-width: 1000px) {
    .hk-pg-hero__grid { grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.9fr); }
  }

  .hk-pg-hero__copy {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .hk-pg-hero__h {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 9.5vw, 9rem);
    line-height: 0.85;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0;
  }
  .hk-pg-hero__line { display: block; overflow: hidden; }
  .hk-pg-hero__line--alt { color: var(--color-accent); }

  .hk-pg-hero__lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    max-width: 55ch;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    margin: 0;
  }

  /* Quick-Nav */
  .hk-pg-hero__nav {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-rule-strong);
  }
  @media (min-width: 720px) {
    .hk-pg-hero__nav { grid-template-columns: repeat(2, 1fr); }
  }
  .hk-pg-hero__nav-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    border-right: 1px solid var(--color-rule);
    transition: background 0.3s var(--ease-out-expo), color 0.3s, padding-left 0.4s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }
  .hk-pg-hero__nav-link::before {
    content: '';
    position: absolute;
    left: 0;
