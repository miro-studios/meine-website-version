---
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';

const services = [
  {
    n: '01',
    title: 'ELEKTRO­INSTALLATION',
    sub: 'Privat · Gewerbe · Industrie',
    text: 'Vom kompletten Neubau über die Sanierung im Bestand bis zur einzelnen Steckdose. Wir planen Verteilungen, ziehen Leitungen, dokumentieren VDE-konform und übergeben mit Messprotokoll.',
    items: ['Neuanlagen & Erweiterungen', 'Sanierung Bestand', 'Industrieinstallationen bis 1 MW', 'Datennetze (Cat6, Cat7, Glasfaser)', 'Brandmelde- & Einbruch-Anlagen', 'E-Check mit Protokoll'],
    note: 'VDE 0100 · 0105 · 0701',
    price: 'AB 65 € / STUNDE',
  },
  {
    n: '02',
    title: 'HEIZUNG & WÄRME',
    sub: 'Wärmepumpe · Hybrid · Solar',
    text: 'Heizungsbau ist heute zu 80% Elektrotechnik. Deshalb bauen wir beides aus einer Hand — Wärmepumpe, Pufferspeicher, Heizstab, Steuerung. Mit Heizlast­berechnung, hydraulischem Abgleich und Förderantrag.',
    items: ['Luft-Wasser-Wärmepumpen', 'Sole-Wasser-Wärmepumpen', 'Hybrid mit Gas/Öl-Bestand', 'Pufferspeicher & Warmwasser', 'Heizlast & hydraulischer Abgleich', 'BAFA-/KfW-Förderung inkl.'],
    note: 'GEG-KONFORM · BAFA-LISTE',
    price: 'AB 18.000 €',
  },
  {
    n: '03',
    title: 'PHOTOVOLTAIK',
    sub: 'Komplett-Anlagen mit Speicher',
    text: 'Wir liefern wirtschaftliche PV-Anlagen — keine 22-kWp-Aufrüstung weil "geht halt drauf", sondern eine Auslegung, die zu Verbrauch, Dach und Budget passt. Komplettpaket: Planung, Montage, Anmeldung, Inbetriebnahme.',
    items: ['Dachanalyse & Verschattung', 'Module (BYD, Q.Cells, Meyer Burger)', 'Wechselrichter & Notstrom', 'Speicher 5–20 kWh', 'Netzanmeldung & Marktstammdaten', 'Wallbox-Anbindung'],
    note: 'MEISTERANLAGE · 10 J. GARANTIE',
    price: 'AB 8.900 €',
  },
  {
    n: '04',
    title: 'SMART HOME',
    sub: 'KNX · Loxone · Matter',
    text: 'Eine zentrale Anlage, die schaltet, dimmt, regelt und meldet — vom 80-m²-Apartment bis zur 800-m²-Villa. Wir planen herstellerunabhängig und übergeben mit Wartungsvertrag, damit Sie nicht alleine an der ETS sitzen.',
    items: ['KNX (klassische Bus-Lösung)', 'Loxone (kompakte All-in-One)', 'Matter / Thread (modernes Mesh)', 'Visualisierung & App-Steuerung', 'Sicherheitssensorik', 'Wartung im Abo'],
    note: 'ZERTIFIZIERTE PARTNER',
    price: 'AB 95 € / STUNDE',
  },
  {
    n: '05',
    title: 'E-MOBILITÄT',
    sub: 'Wallbox · Lastmanagement · Abrechnung',
    text: 'Vom einfachen 11-kW-Heimanschluss bis zur Firmenladelösung mit dynamischem Lastmanagement und Abrechnungs-Backend. Wir installieren KEBA, ABL, Mennekes und Compleo — keine Apple-Watch-Spielzeuge.',
    items: ['Heim-Wallbox 11/22 kW', 'PV-Überschussladung', 'Firmenladeparks (4–40 Punkte)', 'Lastmanagement (statisch/dynamisch)', 'Abrechnung & RFID', 'Förderung KfW (sofern verfügbar)'],
    note: 'EICHRECHTSKONFORM · AC + DC',
    price: 'AB 1.890 €',
  },
  {
    n: '06',
    title: '24H NOTDIENST',
    sub: 'Strom & Wärme · MK-Gebiet',
    text: 'Wenn die Sicherung knallt, die Heizung ausfällt oder die Wallbox raucht: 0 23 51 / 60 80 21. Wir sind in der Regel innerhalb von 90 Minuten bei Ihnen — Tag, Nacht, Wochenende, Feiertag.',
    items: ['Strom-Ausfall Privat', 'Heizungsausfall', 'Industrie-Notdienst', 'PV-Defekt', 'Brand- und Wasserschaden Folgearbeiten', 'Wartungsverträge mit SLA'],
    note: 'REAKTION ⌀ 90 MIN · MK',
    price: 'AB 95 € / EINSATZ',
  },
];

const faq = [
  { q: 'Was kostet ein Erstgespräch?', a: 'Für Privatkunden im MK-Gebiet ist das Erstgespräch kostenfrei — wir kommen vorbei, hören zu, geben eine erste Einschätzung. Bei Gewerbe-Aufträgen ab 50.000 € klären wir den Aufwand vorher kurz telefonisch.' },
  { q: 'Wie schnell könnt ihr starten?', a: 'Standard-Aufträge (E-Check, kleinere Installationen) in 2–4 Wochen. Größere Projekte (PV, Wärmepumpe, Sanierung) je nach Saison 6–14 Wochen. Im Sommer-Q1 buchen wir oft schon für Winter-Q4.' },
  { q: 'Macht ihr auch Anlagen, die ihr nicht selbst geplant habt?', a: 'Ja — wir übernehmen Wartungen und Erweiterungen an Fremd-Anlagen, sofern sie technisch sauber dokumentiert sind. Wenn nicht, klären wir das vorher und machen ggf. eine Bestandsaufnahme.' },
  { q: 'Welche Hersteller verbaut ihr?', a: 'Wir sind unabhängig — verbauen aber bevorzugt deutsche und europäische Komponenten mit nachweisbarer Garantie: Hager, ABB, Stiebel Eltron, Vaillant, Viessmann, KEBA, Q.Cells, BYD. Nicht aus Patriotismus, sondern weil die Ersatzteilverfügbarkeit besser ist.' },
  { q: 'Gibt es einen Servicevertrag?', a: 'Ja, für PV-Anlagen, Wärmepumpen und Smart-Home-Anlagen empfehlen wir einen Wartungsvertrag (ca. 180–340 € / Jahr). Dafür bekommen Sie 1× pro Jahr eine vollständige Wartung und priorisierten Notdienst.' },
  { q: 'Arbeitet ihr auch außerhalb des Märkischen Kreises?', a: 'Standard-Einzugsgebiet ist ein Umkreis von 50 km um Lüdenscheid. Für größere Projekte (Industrie, mehrteilige PV-Anlagen) kommen wir auch nach Köln, Bochum oder Dortmund — Anreisen werden dann separat berechnet.' },
];
---

<ElektroLayout
  title="Holtkamp Elektrotechnik — Leistungen · Was wir bauen"
  description="Elektroinstallation, Heizung, Photovoltaik, Smart Home, E-Mobilität und 24-Stunden-Notdienst. Sechs Gewerke unter einem Dach im Märkischen Kreis."
>
  <!-- ── Page Hero ────────────────────────────────────────────────── -->
  <section class="hk-pg-hero hk-section">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 02</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">PAGE / LEISTUNGEN</span>
      </div>

      <h1 class="hk-pg-hero__h">
        <span class="hk-pg-hero__line"><SplitText by="words" stagger={0.05}>SECHS</SplitText></span>
        <span class="hk-pg-hero__line hk-pg-hero__line--alt"><SplitText by="words" stagger={0.05} delay={0.15}>GEWERKE.</SplitText></span>
        <span class="hk-pg-hero__line"><SplitText by="words" stagger={0.05} delay={0.3}>EIN BETRIEB.</SplitText></span>
      </h1>

      <p class="hk-pg-hero__lead">
        Elektro und Wärme gehören zusammen geplant. Deshalb haben wir
        beide Gewerke unter einem Dach — plus PV, Smart Home, E-Mobilität
        und ein 24-Stunden-Notdienst im MK-Gebiet.
      </p>
    </div>
  </section>

  <!-- ── Services Detail ──────────────────────────────────────────── -->
  <section class="hk-svc-list">
    <div class="hk-container">
      {services.map(s => (
        <article class="hk-svc-list__row" id={`svc-${s.n}`}>
          <div class="hk-svc-list__meta">
            <span class="hk-svc-list__n">N° {s.n}</span>
            <h2 class="hk-svc-list__h">{s.title}</h2>
            <p class="hk-svc-list__sub">{s.sub}</p>
            <span class="hk-svc-list__note">{s.note}</span>
            <span class="hk-svc-list__price">{s.price}</span>
          </div>
          <div class="hk-svc-list__body">
            <RevealOnScroll>
              <p class="hk-svc-list__text">{s.text}</p>
              <ul class="hk-svc-list__items">
                {s.items.map(it => (
                  <li>
                    <span class="hk-svc-list__check" aria-hidden="true">+</span>
                    <span>{it}</span>
                  </li>
                ))}
              </ul>
              <a href={`/demos/elektro/kontakt/?leistung=${encodeURIComponent(s.title)}`} class="hk-svc-list__cta">
                <span>{s.title} ANFRAGEN</span>
                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
              </a>
            </RevealOnScroll>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── FAQ ─────────────────────────────────────────────────────── -->
  <section class="hk-faq hk-section">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 03</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">FAQ / BEVOR SIE ANRUFEN</span>
      </div>

      <RevealOnScroll>
        <h2 class="hk-faq__h">HÄUFIGE FRAGEN.</h2>
      </RevealOnScroll>

      <div class="hk-faq__list">
        {faq.map((item, i) => (
          <details class="hk-faq__item" open={i === 0}>
            <summary>
              <span class="hk-faq__q-n">[{String(i + 1).padStart(2, '0')}]</span>
              <span class="hk-faq__q">{item.q}</span>
              <span class="hk-faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"/></svg>
              </span>
            </summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────────────── -->
  <section class="hk-pg-cta hk-section">
    <div class="hk-container">
      <RevealOnScroll>
        <h2 class="hk-pg-cta__h">
          KLINGT NACH<br />
          <span class="hk-pg-cta__h-alt">EINEM AUFTRAG?</span>
        </h2>
        <p class="hk-pg-cta__lead">Erstgespräch kostenfrei — eine Stunde, vor Ort oder telefonisch.</p>
        <MagneticButton href="/demos/elektro/kontakt/" strength={0.4} variant="primary" class="hk-pg-cta__btn">
          <span>ANFRAGE STARTEN</span>
          <span aria-hidden="true">→</span>
        </MagneticButton>
      </RevealOnScroll>
    </div>
  </section>
</ElektroLayout>

<style>
  /* ── Page Hero ────────────────────────────────────────────────── */
  .hk-pg-hero { padding-block: clamp(3rem, 6vw, 5rem) clamp(3rem, 6vw, 5rem); }

  .hk-pg-hero__h {
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 10rem);
    line-height: 0.88;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 2rem;
  }
  .hk-pg-hero__line { display: block; overflow: hidden; }
  .hk-pg-hero__line--alt { color: var(--color-accent); }

  .hk-pg-hero__lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    max-width: 55ch;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    margin: 0;
  }

  /* ── Services Detail ─────────────────────────────────────────── */
  .hk-svc-list { border-top: 1px solid var(--color-rule); }

  .hk-svc-list__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(2.5rem, 5vw, 4.5rem) 0;
    border-bottom: 1px solid var(--color-rule-strong);
    scroll-margin-top: 6rem;
  }
  .hk-svc-list__row:last-child { border-bottom: none; }

  @media (min-width: 900px) {
    .hk-svc-list__row {
      grid-template-columns: minmax(240px, 0.85fr) minmax(0, 1.4fr);
      gap: clamp(3rem, 6vw, 6rem);
    }
  }

  .hk-svc-list__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: sticky;
    top: 5rem;
    align-self: start;
  }

  .hk-svc-list__n {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }

  .hk-svc-list__h {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    margin: 0.5rem 0;
    text-transform: uppercase;
    font-weight: 400;
  }

  .hk-svc-list__sub {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-muted);
    margin: 0;
  }

  .hk-svc-list__note {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--color-text);
    padding: 0.45rem 0.7rem;
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    border: 1px solid var(--color-rule-strong);
    width: max-content;
    max-width: 100%;
    font-weight: 700;
  }

  .hk-svc-list__price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-accent);
    letter-spacing: 0.01em;
    margin-top: 0.6rem;
    font-weight: 400;
  }

  .hk-svc-list__text {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: var(--color-text);
    max-width: 56ch;
    margin: 0 0 2rem;
  }

  .hk-svc-list__items {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    gap: 0;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 600px) {
    .hk-svc-list__items { grid-template-columns: repeat(2, 1fr); }
  }

  .hk-svc-list__items li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.65rem;
    align-items: baseline;
    padding: 0.95rem 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.45;
    border-bottom: 1px solid var(--color-rule);
  }
  .hk-svc-list__items li:last-child { border-bottom: none; }
  @media (min-width: 600px) {
    .hk-svc-list__items li:nth-last-child(-n+2) { border-bottom: none; }
  }

  .hk-svc-list__check {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .hk-svc-list__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-text);
    transition: background-color 0.3s, color 0.3s, gap 0.3s var(--ease-out-expo);
  }
  .hk-svc-list__cta:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
    gap: 0.9rem;
  }
  .hk-svc-list__cta svg { width: 14px; height: 14px; }

  /* ── FAQ ─────────────────────────────────────────────────────── */
  .hk-faq { border-top: 1px solid var(--color-rule); background: var(--color-surface); }

  .hk-faq__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
  }

  .hk-faq__list { border-top: 1px solid var(--color-rule-strong); }
  .hk-faq__item { border-bottom: 1px solid var(--color-rule-strong); }
  .hk-faq__item summary {
    list-style: none;
    cursor: pointer;
    padding: 1.5rem 0;
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: 1.5rem;
    transition: padding-left 0.4s var(--ease-out-expo), color 0.3s;
  }
  .hk-faq__item summary::-webkit-details-marker { display: none; }
  .hk-faq__item summary::marker { display: none; }
  .hk-faq__item summary:hover {
    padding-left: 1rem;
    color: var(--color-accent);
  }
  .hk-faq__q-n {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .hk-faq__q {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    line-height: 1.25;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-weight: 400;
  }
  .hk-faq__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    color: var(--color-accent);
    transition: transform 0.4s var(--ease-out-expo);
  }
  .hk-faq__item[open] .hk-faq__icon { transform: rotate(180deg); }
  .hk-faq__item p {
    padding: 0 0 1.75rem 4.5rem;
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    max-width: 65ch;
  }

  /* ── CTA ──────────────────────────────────────────────────────── */
  .hk-pg-cta {
    border-top: 1px solid var(--color-rule);
    text-align: center;
    background: var(--color-text);
    color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }
  .hk-pg-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--color-bg) 7%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-bg) 7%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
  }
  .hk-pg-cta .hk-container { position: relative; z-index: 1; }

  .hk-pg-cta__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 5rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    margin: 0 0 1.25rem;
    font-weight: 400;
    color: var(--color-bg);
  }
  .hk-pg-cta__h-alt { color: var(--color-accent); }
  .hk-pg-cta__lead {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: color-mix(in srgb, var(--color-bg) 75%, transparent);
    margin: 0 0 2rem;
  }
  .hk-pg-cta__btn {
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 1.2rem 2rem;
  }
  .hk-pg-cta__btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
