---
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';
---

<ElektroLayout
  title="Danke — Ihre Anfrage ist eingegangen · Holtkamp Elektrotechnik"
  description="Danke. Wir melden uns innerhalb von 24 Stunden zurück."
>
  <section class="hk-danke">
    <div class="hk-container hk-danke__inner">
      <!-- Animated success-mark links -->
      <div class="hk-danke__visual" aria-hidden="true">
        <svg viewBox="0 0 320 320" preserveAspectRatio="xMidYMid meet">
          <defs>
            <pattern id="hkd-grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M20 0H0V20" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
            </pattern>
          </defs>
          <rect width="320" height="320" fill="url(#hkd-grid)" />

          <!-- Pulsing rings -->
          <g transform="translate(160 160)">
            <circle cx="0" cy="0" r="60" fill="none" stroke="var(--color-accent)" stroke-width="1.2" opacity="0">
              <animate attributeName="r" values="50;120" dur="2.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0" dur="2.4s" repeatCount="indefinite"/>
            </circle>
            <circle cx="0" cy="0" r="50" fill="none" stroke="var(--color-accent)" stroke-width="1.2" opacity="0">
              <animate attributeName="r" values="45;100" dur="2.4s" begin="0.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.6;0" dur="2.4s" begin="0.8s" repeatCount="indefinite"/>
            </circle>
          </g>

          <!-- Center disc -->
          <circle cx="160" cy="160" r="56" fill="var(--color-accent)"/>
          <!-- Yellow corner brackets around it -->
          <g stroke="var(--color-accent)" stroke-width="1.4" fill="none">
            <path d="M 76 76 L 76 96 M 76 76 L 96 76"/>
            <path d="M 244 76 L 244 96 M 244 76 L 224 76"/>
            <path d="M 76 244 L 76 224 M 76 244 L 96 244"/>
            <path d="M 244 244 L 244 224 M 244 244 L 224 244"/>
          </g>

          <!-- Checkmark, draws in -->
          <path
            d="M 130 162 L 152 184 L 196 138"
            stroke="var(--color-bg)"
            stroke-width="6"
            fill="none"
            stroke-linecap="square"
            stroke-linejoin="miter"
            stroke-dasharray="110"
            stroke-dashoffset="110"
          >
            <animate attributeName="stroke-dashoffset" from="110" to="0" dur="0.9s" begin="0.3s" fill="freeze"/>
          </path>

          <!-- Diagnose-Label unten -->
          <g transform="translate(80 290)">
            <rect x="0" y="0" width="160" height="22" fill="var(--color-text)"/>
            <text x="80" y="15" font-family="JetBrains Mono, monospace" font-size="10" font-weight="700" fill="var(--color-bg)" text-anchor="middle" letter-spacing="1.5">SIGNAL · EMPFANGEN</text>
          </g>
        </svg>
      </div>

      <!-- Copy rechts -->
      <div class="hk-danke__copy">
        <div class="hk-bar">
          <span class="hk-bar-n">200 · OK</span>
          <span class="hk-bar-line" aria-hidden="true"></span>
          <span class="hk-bar-k">ANFRAGE / EINGEGANGEN</span>
        </div>

        <h1 class="hk-danke__h">
          <span class="hk-danke__h-line"><SplitText by="words" stagger={0.05}>DANKE.</SplitText></span>
          <span class="hk-danke__h-line hk-danke__h-line--alt"><SplitText by="words" stagger={0.05} delay={0.2}>WIR HABEN'S.</SplitText></span>
        </h1>

        <p class="hk-danke__lead">
          Ihre Anfrage liegt bei uns auf dem Tisch. Daniel oder Karla schauen
          sie sich an, prüfen Machbarkeit und Förderung — und melden sich
          innerhalb von <strong>24 Stunden</strong> bei Ihnen zurück.
        </p>

        <!-- Was als Nächstes -->
        <div class="hk-danke__next">
          <h2 class="hk-danke__next-h">WAS JETZT PASSIERT</h2>
          <ol class="hk-danke__next-list">
            <li>
              <span class="hk-danke__next-time">≤ 1 H</span>
              <span class="hk-danke__next-body">
                <strong>Bestätigungs-Mail</strong>
                <span>landet automatisch in Ihrer Inbox (auch SPAM checken).</span>
              </span>
            </li>
            <li>
              <span class="hk-danke__next-time">≤ 24 H</span>
              <span class="hk-danke__next-body">
                <strong>Persönlicher Rückruf oder Mail</strong>
                <span>mit ersten Fragen und Termin-Vorschlag fürs Erstgespräch.</span>
              </span>
            </li>
            <li>
              <span class="hk-danke__next-time">≤ 7 T</span>
              <span class="hk-danke__next-body">
                <strong>Erstgespräch vor Ort</strong>
                <span>kostenfrei für Privatkunden im Märkischen Kreis.</span>
              </span>
            </li>
            <li>
              <span class="hk-danke__next-time">≤ 14 T</span>
              <span class="hk-danke__next-body">
                <strong>Festpreis-Angebot</strong>
                <span>schriftlich mit Leistungs­verzeichnis — keine Überraschungen.</span>
              </span>
            </li>
          </ol>
        </div>

        <!-- Telemetrie-Footer -->
        <div class="hk-danke__telemetry">
          <div class="hk-danke__telemetry-cell">
            <span class="hk-danke__telemetry-k">DURCHSCHNITTLICHE ANTWORT</span>
            <span class="hk-danke__telemetry-v"><NumberCounter to={4.2} duration={1.6} decimals={1} /> H</span>
          </div>
          <div class="hk-danke__telemetry-cell">
            <span class="hk-danke__telemetry-k">ANFRAGEN Q2/2026</span>
            <span class="hk-danke__telemetry-v"><NumberCounter to={47} duration={1.4} /></span>
          </div>
          <div class="hk-danke__telemetry-cell">
            <span class="hk-danke__telemetry-k">ZUFRIEDENHEIT ⌀</span>
            <span class="hk-danke__telemetry-v">4,9<span>/5</span></span>
          </div>
        </div>

        <div class="hk-danke__actions">
          <MagneticButton href="/demos/elektro/" strength={0.4} variant="primary" class="hk-danke__btn" data-cursor-hover>
            <span>ZURÜCK ZUR STARTSEITE</span>
            <span aria-hidden="true">→</span>
          </MagneticButton>
          <a href="/demos/elektro/referenzen/" class="hk-danke__link" data-cursor-hover>
            <span>WÄHREND SIE WARTEN — UNSERE REFERENZEN</span>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</ElektroLayout>

<style>
  .hk-danke {
    min-height: calc(100svh - 80px);
    padding-block: clamp(3rem, 6vw, 5rem);
    display: flex;
    align-items: center;
  }

  .hk-danke__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
    width: 100%;
  }
  @media (min-width: 900px) {
    .hk-danke__inner { grid-template-columns: 0.85fr 1.15fr; }
  }

  .hk-danke__visual {
    color: var(--color-text);
    border: 1px solid var(--color-rule-strong);
    padding: 0.75rem;
    background: var(--color-surface);
    position: relative;
    aspect-ratio: 1;
    max-width: 420px;
    margin-inline: auto;
  }
  .hk-danke__visual::before,
  .hk-danke__visual::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--color-accent);
    border-style: solid;
  }
  .hk-danke__visual::before { top: -1px; left: -1px; border-width: 1.5px 0 0 1.5px; }
  .hk-danke__visual::after { bottom: -1px; right: -1px; border-width: 0 1.5px 1.5px 0; }

  .hk-danke__visual svg { width: 100%; height: 100%; display: block; }

  .hk-danke__copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hk-danke__h {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.88;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 0.4rem;
  }
  .hk-danke__h-line { display: block; overflow: hidden; padding-right: 0.04em; }
  .hk-danke__h-line--alt { color: var(--color-accent); }

  .hk-danke__lead {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
    max-width: 56ch;
    margin: 0;
  }
  .hk-danke__lead strong { color: var(--color-accent); font-weight: 600; }

  /* Was Jetzt Passiert */
  .hk-danke__next {
    border: 1px solid var(--color-rule-strong);
    background: var(--color-surface);
  }
  .hk-danke__next-h {
    margin: 0;
    padding: 0.7rem 1rem;
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
  }
  .hk-danke__next-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .hk-danke__next-list li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .hk-danke__next-list li:last-child { border-bottom: none; }

  .hk-danke__next-time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .hk-danke__next-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .hk-danke__next-body strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    font-weight: 400;
  }
  .hk-danke__next-body span {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
  }

  /* Telemetrie */
  .hk-danke__telemetry {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--color-rule-strong);
  }
  @media (max-width: 540px) {
    .hk-danke__telemetry { grid-template-columns: 1fr; }
  }

  .hk-danke__telemetry-cell {
    padding: 0.85rem 1rem;
    border-right: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .hk-danke__telemetry-cell:last-child { border-right: none; }
  @media (max-width: 540px) {
    .hk-danke__telemetry-cell { border-right: none; border-bottom: 1px solid var(--color-rule); }
    .hk-danke__telemetry-cell:last-child { border-bottom: none; }
  }

  .hk-danke__telemetry-k {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hk-danke__telemetry-v {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: 0.005em;
  }
  .hk-danke__telemetry-v span {
    font-size: 0.5em;
    color: var(--color-muted);
    margin-left: 0.1em;
  }

  /* Actions */
  .hk-danke__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 2rem;
    margin-top: 0.5rem;
  }

  .hk-danke__btn {
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 1.1rem 1.75rem;
  }
  .hk-danke__btn:hover { background: var(--color-text); color: var(--color-bg); }

  .hk-danke__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    text-transform: uppercase;
    transition: color 0.3s, gap 0.3s var(--ease-out-expo);
  }
  .hk-danke__link svg { width: 12px; height: 12px; }
  .hk-danke__link:hover { color: var(--color-accent); gap: 0.85rem; }
</style>
