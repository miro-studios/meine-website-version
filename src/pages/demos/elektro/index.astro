<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function init() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const hero = document.querySelector<HTMLElement>('[data-hk-hero]');
    const plate = document.querySelector<HTMLElement>('[data-hk-hero-plate]');
    if (hero && plate) {
      gsap.to(plate, {
        yPercent: -6,
        ease: 'none',
        scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.6 },
      });
    }

    // Pin-Section für Prozess (nur Desktop, sonst überlappt es mit den Karten)
    const proc = document.querySelector<HTMLElement>('[data-hk-proc]');
    const procHead = document.querySelector<HTMLElement>('[data-hk-proc-head]');
    if (proc && procHead && window.matchMedia('(min-width: 900px)').matches) {
      // Sticky-Behaviour ist über CSS bereits gesetzt — ScrollTrigger nur für
      // sanften Reveal der einzelnen Step-Karten.
      const steps = proc.querySelectorAll<HTMLElement>('.hk-proc__step');
      steps.forEach((step, i) => {
        gsap.from(step, {
          opacity: 0,
          y: 40,
          duration: 0.8,
          ease: 'expo.out',
          scrollTrigger: { trigger: step, start: 'top 85%', once: true },
          delay: i * 0.05,
        });
      });
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
