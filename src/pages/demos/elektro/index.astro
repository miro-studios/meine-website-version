---
/**
 * Holtkamp Elektrotechnik — Demo-Startseite
 *
 * Showcase für miro-studios "Business Multi-Page"-Paket (€ 2.799 + € 34,99/Mon).
 * Sitemap: Start · Betrieb · Leistungen · Referenzen · Journal · Kontakt
 *          + Impressum & Datenschutz.
 *
 * Industrial Brutalism mit Premium-Touch: tiefes Warm-Schwarz, warmer
 * Cream-Text, elektrisches Gelb als Akzent. Anton (Display) + Manrope (Body)
 * + JetBrains Mono (technische Labels).
 *
 * Dies ist eine Demo — kein realer Kunde.
 */
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://miro-studios.de/demos/elektro/#business',
  name: 'Holtkamp Elektrotechnik',
  description:
    'Elektro- und Heizungsbau-Meisterbetrieb in Lüdenscheid. Installationen, Photovoltaik, Wärmepumpen und Smart Home für Privat und Gewerbe seit 1989.',
  url: 'https://miro-studios.de/demos/elektro/',
  telephone: '+49 2351 608021',
  email: 'hallo@holtkamp-elektro.de',
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Volmestraße 47',
    postalCode: '58507',
    addressLocality: 'Lüdenscheid',
    addressRegion: 'NRW',
    addressCountry: 'DE',
  },
  areaServed: ['Lüdenscheid', 'Märkischer Kreis', 'Sauerland', 'Hagen', 'Iserlohn'],
  founder: 'Werner Holtkamp',
  foundingDate: '1989',
};

const services = [
  { n: '01', t: 'ELEKTRO­INSTALLATION', sub: 'Privat · Gewerbe · Industrie', text: 'Neuinstallationen, Sanierungen und Erweiterungen — von der Verteilung bis zur einzelnen Steckdose. VDE-konform, dokumentiert, mit Messprotokoll.' },
  { n: '02', t: 'HEIZUNG & WÄRME', sub: 'Wärmepumpe · Hybrid · Solar', text: 'Wir planen und bauen Wärmepumpen-Systeme, hybride Heizungen und Solarthermie. Mit Heizlastberechnung, hydraulischem Abgleich und BAFA-Antrag.' },
  { n: '03', t: 'PHOTOVOLTAIK', sub: 'Komplett-Anlagen mit Speicher', text: 'Auslegung, Montage, Anmeldung und Inbetriebnahme. Wir liefern wirtschaftliche Anlagen mit Wechselrichter, Speicher und Wallbox-Anbindung.' },
  { n: '04', t: 'SMART HOME', sub: 'KNX · Loxone · Matter', text: 'Eine Anlage, die zentral schaltet, dimmt, regelt und meldet. Wir planen herstellerunabhängig und übergeben dokumentiert mit Wartungsvertrag.' },
  { n: '05', t: 'E-MOBILITÄT', sub: 'Wallbox · Lastmanagement', text: 'Vom 11-kW-Heim­anschluss bis zur Firmen-Lade­infrastruktur mit dynamischem Lastmanagement und Abrechnungs-Backend.' },
  { n: '06', t: '24H NOTDIENST', sub: 'Strom & Wärme · MK-Gebiet', text: 'Wenn die Sicherung knallt oder die Heizung ausfällt, sind wir innerhalb von 90 Minuten beim Kunden — Tag, Nacht, Wochenende.' },
];

const process = [
  { n: '01', label: 'ANFRAGE', text: 'Sie rufen an oder schicken eine Mail. Wir reagieren innerhalb von 24 Stunden mit einem Termin-Vorschlag.' },
  { n: '02', label: 'ORTSTERMIN', text: 'Wir kommen vorbei, hören zu, messen und prüfen — kostenfrei für Privatkunden, klärt Machbarkeit und Förderfähigkeit.' },
  { n: '03', label: 'ANGEBOT', text: 'Sie bekommen ein schriftliches Festpreis-Angebot mit Leistungsverzeichnis. Keine Überraschungen auf der Rechnung.' },
  { n: '04', label: 'AUSFÜHRUNG', text: 'Termingebunden, sauber, mit täglichem Status-Update. Wir hinterlassen die Baustelle besenrein.' },
];
---

<ElektroLayout
  title="Holtkamp Elektrotechnik — Strom. Wärme. Zukunft. · Lüdenscheid"
  description="Holtkamp ist Elektro- und Heizungsbau-Meisterbetrieb in Lüdenscheid. Installationen, Photovoltaik, Wärmepumpen und Smart Home für Privat, Gewerbe und Industrie."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- ── HERO ──────────────────────────────────────────────────────── -->
  <section class="hk-hero" data-hk-hero>
    <div class="hk-hero__grid" aria-hidden="true"></div>

    <!-- Spec-Bar oben -->
    <div class="hk-hero__spec hk-container">
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">FILE</span>
        <span class="hk-hero__spec-v">HK-2026.HOME</span>
      </span>
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">MEISTER</span>
        <span class="hk-hero__spec-v">HWK MK · NR. 47 / 13</span>
      </span>
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">VDE</span>
        <span class="hk-hero__spec-v">0100 · 0105 · 0701</span>
      </span>
      <span class="hk-hero__spec-cell hk-hero__spec-cell--push">
        <span class="hk-hero__spec-dot" aria-hidden="true"></span>
        <span class="hk-hero__spec-v">24H NOTDIENST AKTIV</span>
      </span>
    </div>

    <!-- Hero-Inhalt -->
    <div class="hk-hero__inner hk-container">
      <div class="hk-hero__copy">
        <div class="hk-hero__index">
          <span class="hk-hero__index-n">N°</span>
          <span class="hk-hero__index-v">00</span>
          <span class="hk-hero__index-line" aria-hidden="true"></span>
          <span class="hk-hero__index-k">START / HOME</span>
        </div>

        <h1 class="hk-hero__h">
          <span class="hk-hero__line"><SplitText by="chars" stagger={0.025} delay={0.05} onScroll={false}>STROM.</SplitText></span>
          <span class="hk-hero__line hk-hero__line--y"><SplitText by="chars" stagger={0.025} delay={0.4} onScroll={false}>WÄRME.</SplitText></span>
          <span class="hk-hero__line"><SplitText by="chars" stagger={0.025} delay={0.75} onScroll={false}>ZUKUNFT.</SplitText></span>
        </h1>

        <div class="hk-hero__caption">
          <span class="hk-hero__caption-tag" aria-hidden="true"></span>
          <p>
            HOLTKAMP ELEKTROTECHNIK · MEISTERBETRIEB IN LÜDENSCHEID — SEIT 1989
            PLANEN UND BAUEN WIR ELEKTRO-, HEIZUNGS- UND ENERGIETECHNIK FÜR
            PRIVAT, GEWERBE UND INDUSTRIE IM SAUERLAND.
          </p>
        </div>

        <div class="hk-hero__actions">
          <MagneticButton href="/demos/elektro/kontakt/" strength={0.35} variant="primary" class="hk-hero__cta">
            <span>PROJEKT ANFRAGEN</span>
            <span aria-hidden="true">→</span>
          </MagneticButton>
          <a href="/demos/elektro/leistungen/" class="hk-hero__link">
            <span>Was wir bauen</span>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
          </a>
        </div>
      </div>

      <!-- Plakat-Stats -->
      <aside class="hk-hero__plate" data-hk-hero-plate>
        <div class="hk-hero__plate-head">
          <span>STAND · Q2/2026</span>
          <span class="hk-hero__plate-id">REV·08</span>
        </div>
        <dl class="hk-hero__plate-data">
          <div>
            <dt>JAHRE</dt>
            <dd><NumberCounter to={37} duration={1.6} /></dd>
            <span>BETRIEBSGESCHICHTE</span>
          </div>
          <div>
            <dt>PROJEKTE</dt>
            <dd><NumberCounter to={2400} duration={2.2} />+</dd>
            <span>ABGESCHLOSSEN</span>
          </div>
          <div>
            <dt>TEAM</dt>
            <dd><NumberCounter to={14} duration={1.4} /></dd>
            <span>GESELLEN & MEISTER</span>
          </div>
          <div>
            <dt>NOTRUF</dt>
            <dd>
              <span class="hk-hero__plate-num">90</span>
              <span class="hk-hero__plate-unit">MIN</span>
            </dd>
            <span>REAKTIONSZEIT MK</span>
          </div>
        </dl>
        <div class="hk-hero__plate-foot">
          INNUNG · E-CHECK · ZERTIFIZIERT
        </div>
      </aside>
    </div>

    <!-- Marquee unten -->
    <div class="hk-hero__strip" aria-hidden="true">
      <div class="hk-hero__strip-track">
        <span>ELEKTROINSTALLATION</span><span>+</span>
        <span>WÄRMEPUMPE</span><span>+</span>
        <span>PHOTOVOLTAIK</span><span>+</span>
        <span>KNX-SMART-HOME</span><span>+</span>
        <span>WALLBOX</span><span>+</span>
        <span>NOTSTROM</span><span>+</span>
        <span>BLITZSCHUTZ</span><span>+</span>
        <span>E-CHECK</span><span>+</span>
        <span>ELEKTROINSTALLATION</span><span>+</span>
        <span>WÄRMEPUMPE</span><span>+</span>
        <span>PHOTOVOLTAIK</span><span>+</span>
        <span>KNX-SMART-HOME</span><span>+</span>
        <span>WALLBOX</span><span>+</span>
        <span>NOTSTROM</span><span>+</span>
        <span>BLITZSCHUTZ</span><span>+</span>
        <span>E-CHECK</span><span>+</span>
      </div>
    </div>
  </section>

  <!-- ── MANIFEST ──────────────────────────────────────────────────── -->
  <section class="hk-manifest hk-section">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 01</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">MANIFEST / WAS UNS UNTERSCHEIDET</span>
      </div>

      <h2 class="hk-manifest__h">
        <SplitText by="words" stagger={0.05}>Wir verlegen keine Kabel — wir bauen Anlagen, die in 25&nbsp;Jahren noch sauber funktionieren.</SplitText>
      </h2>

      <div class="hk-manifest__cols">
        <RevealOnScroll y={40}>
          <p>
            Elektro und Heizung sind keine Bereiche, die man trennen sollte —
            wer Wärme plant, plant Strom mit. Wir haben deshalb beide
            Gewerke unter einem Dach. Eine Ansprechperson, ein Termin,
            eine Rechnung.
          </p>
        </RevealOnScroll>
        <RevealOnScroll y={40}>
          <p>
            Wir arbeiten ausschließlich mit Materialien, die wir auch im
            eigenen Haus verbauen würden. Markenkomponenten, dokumentierte
            Herkunft, Garantien, die Bestand haben. Das kostet mehr — und
            spart in Summe, weil nichts in zehn Jahren wieder raus muss.
          </p>
        </RevealOnScroll>
        <RevealOnScroll y={40}>
          <p>
            Familienbetrieb, dritte Generation. Werner Holtkamp hat den
            Betrieb 1989 gegründet, sein Sohn führt heute die Geschäfte,
            seine Enkelin ist seit 2024 Meisterin. Das heißt: Sie kennen
            uns, und wir verschwinden nicht.
          </p>
        </RevealOnScroll>
      </div>
    </div>
  </section>

  <!-- ── ÜBER UNS TEASER ───────────────────────────────────────────── -->
  <section class="hk-about hk-section">
    <div class="hk-container hk-about__grid">
      <div class="hk-about__visual" aria-hidden="true">
        <svg viewBox="0 0 360 480" class="hk-about__circuit">
          <defs>
            <pattern id="hk-grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M24 0H0V24" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.18"/>
            </pattern>
          </defs>
          <rect width="360" height="480" fill="url(#hk-grid)" />

          <!-- Schaltplan-Andeutung -->
          <g fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M40 80 L 130 80 L 130 180 L 220 180 L 220 280 L 320 280" />
            <path d="M40 200 L 90 200 L 90 380 L 240 380" />
            <path d="M260 40 L 260 120 L 320 120" />
          </g>

          <!-- Knoten -->
          <g fill="currentColor">
            <circle cx="40" cy="80" r="4" />
            <circle cx="130" cy="180" r="4" />
            <circle cx="220" cy="280" r="4" />
            <circle cx="320" cy="280" r="4" />
            <circle cx="90" cy="200" r="4" />
            <circle cx="240" cy="380" r="4" />
            <circle cx="260" cy="120" r="4" />
            <circle cx="320" cy="120" r="4" />
            <circle cx="40" cy="200" r="4" />
            <circle cx="260" cy="40" r="4" />
          </g>

          <!-- Sicherung-Symbol -->
          <g fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="155" y="225" width="34" height="14" />
            <line x1="148" y1="232" x2="155" y2="232" />
            <line x1="189" y1="232" x2="196" y2="232" />
          </g>

          <!-- Wärme-Symbol -->
          <g fill="none" stroke="var(--color-accent)" stroke-width="1.8">
            <path d="M275 350 q-5 -10 0 -20 q5 -10 0 -20" />
            <path d="M285 350 q-5 -10 0 -20 q5 -10 0 -20" />
            <path d="M295 350 q-5 -10 0 -20 q5 -10 0 -20" />
          </g>

          <!-- Labels -->
          <text x="44" y="74" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" opacity="0.6">+N</text>
          <text x="324" y="116" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-accent)" opacity="0.9">L1</text>
          <text x="324" y="284" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" opacity="0.6">PE</text>

          <!-- Footer-Label -->
          <text x="40" y="455" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="var(--color-accent)" letter-spacing="2">SCHALT­PLAN · BEISPIEL</text>
        </svg>
      </div>

      <div class="hk-about__copy">
        <p class="hk-eyebrow">Über Holtkamp · seit 1989</p>
        <h2 class="hk-about__h">
          DREI&nbsp;GENERATIONEN.<br />
          <span class="hk-about__h-alt">EIN HANDSCHLAG.</span>
        </h2>
        <p class="hk-about__text">
          Werner Holtkamp hat den Betrieb 1989 in Lüdenscheid gegründet.
          Heute leiten sein Sohn Daniel und seine Enkelin Karla Holtkamp die
          Firma. Wir sind ein 14-köpfiges Team aus Meistern, Gesellen und
          Auszubildenden — und wir haben in den letzten Jahren gezielt
          ausgebildet, weil der Beruf nur dann eine Zukunft hat, wenn man sie
          mitbaut.
        </p>
        <ul class="hk-about__list">
          <li><strong>3</strong> Meisterbriefe im Haus</li>
          <li><strong>11</strong> Gesellen mit langjähriger Erfahrung</li>
          <li><strong>4</strong> Auszubildende in laufender Ausbildung</li>
        </ul>
        <a href="/demos/elektro/ueber-uns/" class="hk-about__link">
          <span>BETRIEB ANSEHEN</span>
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── LEISTUNGEN TEASER ─────────────────────────────────────────── -->
  <section class="hk-svc hk-section">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 02</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">LEISTUNGEN / 6 GEWERKE</span>
      </div>

      <RevealOnScroll>
        <h2 class="hk-svc__h">
          WAS WIR<br />
          <span class="hk-svc__h-alt">FÜR SIE TUN.</span>
        </h2>
      </RevealOnScroll>

      <ul class="hk-svc__grid">
        {services.map(s => (
          <li class="hk-svc__cell">
            <div class="hk-svc__cell-n">{s.n}</div>
            <h3 class="hk-svc__cell-t" set:html={s.t} />
            <p class="hk-svc__cell-sub">{s.sub}</p>
            <p class="hk-svc__cell-text">{s.text}</p>
            <a href="/demos/elektro/leistungen/" class="hk-svc__cell-link">
              <span>Details</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── CASE-STUDY SHOWCASE ───────────────────────────────────────── -->
  <section class="hk-case hk-section">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 03</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">REFERENZ / AUSGEWÄHLT</span>
      </div>

      <RevealOnScroll y={40}>
        <div class="hk-case__inner">
          <div class="hk-case__visual">
            <div class="hk-case__visual-frame">
              <span class="hk-case__visual-label">REF · 0214</span>
              <svg viewBox="0 0 480 360" class="hk-case__svg" role="img" aria-label="Schematische Darstellung Wohnhaus mit PV-Anlage und Wärmepumpe">
                <!-- Boden -->
                <line x1="20" y1="280" x2="460" y2="280" stroke="currentColor" stroke-width="1.4" />
                <g stroke="currentColor" stroke-width="0.5" opacity="0.4">
                  <line x1="40" y1="280" x2="30" y2="295" />
                  <line x1="70" y1="280" x2="60" y2="295" />
                  <line x1="100" y1="280" x2="90" y2="295" />
                  <line x1="130" y1="280" x2="120" y2="295" />
                  <line x1="160" y1="280" x2="150" y2="295" />
                  <line x1="190" y1="280" x2="180" y2="295" />
                  <line x1="220" y1="280" x2="210" y2="295" />
                  <line x1="250" y1="280" x2="240" y2="295" />
                  <line x1="280" y1="280" x2="270" y2="295" />
                  <line x1="310" y1="280" x2="300" y2="295" />
                  <line x1="340" y1="280" x2="330" y2="295" />
                  <line x1="370" y1="280" x2="360" y2="295" />
                  <line x1="400" y1="280" x2="390" y2="295" />
                  <line x1="430" y1="280" x2="420" y2="295" />
                </g>
                <!-- Haus -->
                <path d="M 120 280 L 120 160 L 220 90 L 320 160 L 320 280 Z" fill="color-mix(in srgb, var(--color-accent) 6%, transparent)" stroke="currentColor" stroke-width="1.6" />
                <!-- Dach mit PV-Modulen -->
                <g fill="var(--color-accent)" opacity="0.85">
                  <polygon points="135,167 178,135 188,142 145,174" />
                  <polygon points="155,182 198,150 208,157 165,189" />
                  <polygon points="175,197 218,165 228,172 185,204" />
                  <polygon points="235,135 278,167 268,174 225,142" />
                  <polygon points="255,150 298,182 288,189 245,157" />
                  <polygon points="275,165 318,197 308,204 265,172" />
                </g>
                <!-- Fenster + Tür -->
                <rect x="145" y="210" width="35" height="40" fill="color-mix(in srgb, var(--color-text) 12%, transparent)" stroke="currentColor" stroke-width="1" />
                <rect x="200" y="200" width="40" height="80" fill="none" stroke="currentColor" stroke-width="1" />
                <rect x="260" y="210" width="35" height="40" fill="color-mix(in srgb, var(--color-text) 12%, transparent)" stroke="currentColor" stroke-width="1" />
                <!-- Wärmepumpe -->
                <rect x="350" y="240" width="55" height="40" fill="none" stroke="currentColor" stroke-width="1.4" />
                <circle cx="378" cy="260" r="11" fill="none" stroke="currentColor" stroke-width="1" />
                <path d="M373 260 L378 255 L383 260 L378 265 Z" fill="currentColor" />
                <text x="350" y="305" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="var(--color-accent)" letter-spacing="1">WP · 9 KW</text>
                <!-- Verbindung -->
                <path d="M 320 250 L 350 250" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="3 3" />
                <!-- Sonnen-Pfeil -->
                <g stroke="var(--color-accent)" fill="none" stroke-width="1.6">
                  <circle cx="80" cy="60" r="16" />
                  <line x1="80" y1="60" x2="160" y2="120" />
                  <polygon points="160,120 152,116 156,124" fill="var(--color-accent)" stroke="none" />
                </g>
                <text x="20" y="110" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="var(--color-accent)" letter-spacing="1">PV · 12,4 KWP</text>
                <!-- Spec rechts -->
                <g stroke="currentColor" stroke-width="0.6" opacity="0.6" fill="none">
                  <line x1="430" y1="90" x2="430" y2="280" />
                  <line x1="425" y1="90" x2="435" y2="90" />
                  <line x1="425" y1="280" x2="435" y2="280" />
                </g>
                <text x="443" y="195" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" letter-spacing="0.5" transform="rotate(90 443 195)">7,2 m</text>
              </svg>
            </div>
          </div>

          <div class="hk-case__copy">
            <p class="hk-eyebrow">Referenz · Hagen · 2024</p>
            <h2 class="hk-case__h">
              EINFAMILIENHAUS HAGEN —<br />
              VOM GASKESSEL ZUR<br />
              <span class="hk-case__h-alt">VOLLEN ELEKTRIFIZIERUNG.</span>
            </h2>
            <p class="hk-case__text">
              Familie M. wollte raus aus dem Gasvertrag — wir haben die
              Bestands­heizung durch eine Luft-Wasser-Wärmepumpe ersetzt,
              eine 12,4-kWp-Photovoltaik mit 10-kWh-Speicher aufs Dach gebaut
              und das Haus mit einer 11-kW-Wallbox auf E-Mobilität vorbereitet.
              Alles aus einer Hand, in sieben Wochen, mit BAFA-Antrag.
            </p>

            <dl class="hk-case__stats">
              <div>
                <dt>EINSPARUNG</dt>
                <dd><NumberCounter to={2840} duration={2} /></dd>
                <span>€ / JAHR</span>
              </div>
              <div>
                <dt>AUTARKIE</dt>
                <dd><NumberCounter to={74} duration={1.6} />%</dd>
                <span>EIGENVERBRAUCH</span>
              </div>
              <div>
                <dt>FÖRDERUNG</dt>
                <dd><NumberCounter to={17500} duration={2.2} /></dd>
                <span>€ BAFA + KfW</span>
              </div>
            </dl>

            <a href="/demos/elektro/referenzen/" class="hk-case__link">
