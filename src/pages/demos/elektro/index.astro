<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hk-hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-bg);
  }

  .hk-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--hk-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--hk-grid-line) 1px, transparent 1px);
    background-size: clamp(40px, 6vw, 72px) clamp(40px, 6vw, 72px);
    background-position: 50% 0%;
    mask-image: radial-gradient(ellipse 70% 80% at 50% 40%, black 30%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 40%, black 30%, transparent 90%);
    z-index: 0;
    pointer-events: none;
  }

  /* Lightning-Bolt SVG im Hintergrund — die "premium" Schicht */
  .hk-hero__bolt {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  [data-hk-bolt] {
    stroke-dasharray: 2400;
    stroke-dashoffset: 2400;
    animation: hk-bolt-draw 5s ease-out 0.6s forwards,
               hk-bolt-pulse 4s ease-in-out 5.6s infinite;
  }
  @keyframes hk-bolt-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes hk-bolt-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.95; }
  }

  /* Scan-Line die durch den Hero wandert */
  .hk-hero__scanline {
    transform: translateY(0);
    animation: hk-scanline 8s linear infinite;
    opacity: 0.0;
  }
  @keyframes hk-scanline {
    0% { transform: translateY(0); opacity: 0; }
    8% { opacity: 0.5; }
    50% { transform: translateY(900px); opacity: 0.5; }
    58% { opacity: 0; }
    100% { transform: translateY(900px); opacity: 0; }
  }

  .hk-hero__spec {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2rem;
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--color-rule);
    position: relative;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .hk-hero__spec-cell {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hk-hero__spec-cell--push { margin-left: auto; }

  .hk-hero__spec-k { color: var(--color-muted); font-weight: 500; }
  .hk-hero__spec-v { color: var(--color-text); font-weight: 700; }

  /* Live-Ticker — rotating Mini-Telemetrie */
  .hk-hero__spec-cell--ticker {
    min-width: 280px;
    overflow: hidden;
  }
  .hk-hero__spec-cell--ticker .hk-hero__spec-k { color: var(--color-accent); }
  .hk-hero__ticker {
    position: relative;
    display: inline-block;
    height: 1.2em;
    min-width: 240px;
    overflow: hidden;
    vertical-align: bottom;
  }
  .hk-hero__ticker-item {
    position: absolute;
    inset: 0;
    transform: translateY(120%);
    opacity: 0;
    transition: transform 0.6s var(--ease-out-expo), opacity 0.4s linear;
    white-space: nowrap;
  }
  .hk-hero__ticker-item.is-active {
    transform: translateY(0);
    opacity: 1;
  }
  .hk-hero__ticker-item.is-out {
    transform: translateY(-120%);
    opacity: 0;
  }

  .hk-hero__spec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent),
                0 0 12px color-mix(in srgb, var(--color-accent) 50%, transparent);
    animation: hk-pulse 2.4s ease-in-out infinite;
  }

  .hk-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(3rem, 6vw, 5rem);
  }

  @media (min-width: 900px) {
    .hk-hero__inner {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 0.85fr);
      gap: clamp(2rem, 4vw, 4rem);
    }
  }

  .hk-hero__copy {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2.5rem);
