  .hk-hero__h {
    font-family: var(--font-display);
    font-size: clamp(4rem, 16vw, 16rem);
    line-height: 0.83;
    letter-spacing: 0.005em;
    font-weight: 400;
    margin: 0;
    text-transform: uppercase;
  }

  .hk-hero__line {
    display: block;
    position: relative;
    overflow: hidden;
    padding-right: 0.04em;
  }

  .hk-hero__line--y { color: var(--color-accent); }

  /* "Outline-Echo" hinter der Glyph-Stack — 3D-Layer-Look */
  .hk-hero__line-shadow {
    position: absolute;
    inset: 0;
    padding-right: inherit;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--color-text) 14%, transparent);
    transform: translate(0.06em, 0.06em);
    pointer-events: none;
    z-index: -1;
    user-select: none;
  }
  .hk-hero__line--y .hk-hero__line-shadow {
    -webkit-text-stroke: 1px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  /* Caption */
  .hk-hero__caption {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 1rem;
    max-width: 60ch;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .hk-hero__caption-tag {
    width: 10px;
    height: 10px;
    margin-top: 6px;
    background: var(--color-accent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .hk-hero__caption p {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin: 0;
    font-weight: 500;
  }

  /* Actions */
  .hk-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 2rem;
  }

  .hk-hero__cta {
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 1.1rem 1.75rem;
  }
  .hk-hero__cta:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .hk-hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    transition: color 0.3s, gap 0.3s var(--ease-out-expo);
  }
  .hk-hero__link svg { width: 14px; height: 14px; }
  .hk-hero__link:hover { color: var(--color-accent); gap: 0.85rem; }

  /* Plate (Premium-Upgrade) */
  .hk-hero__plate {
    background: linear-gradient(180deg,
      var(--color-surface) 0%,
      color-mix(in srgb, var(--color-surface-2) 80%, var(--color-bg)) 100%);
    border: 1px solid var(--color-rule-strong);
    color: var(--color-text);
    position: relative;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Corner-Brackets — premium signal */
  .hk-hero__plate-bracket {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: var(--color-accent);
    border-style: solid;
    z-index: 2;
    pointer-events: none;
  }
  .hk-hero__plate-bracket--tl { top: -5px; left: -5px; border-width: 1.5px 0 0 1.5px; }
  .hk-hero__plate-bracket--tr { top: -5px; right: -5px; border-width: 1.5px 1.5px 0 0; }
  .hk-hero__plate-bracket--bl { bottom: -5px; left: -5px; border-width: 0 0 1.5px 1.5px; }
  .hk-hero__plate-bracket--br { bottom: -5px; right: -5px; border-width: 0 1.5px 1.5px 0; }

  .hk-hero__plate-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-content: flex-start;
    padding: 0.7rem 0.95rem;
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    font-weight: 700;
  }
  .hk-hero__plate-head > span:nth-child(2) { flex: 1; }
  .hk-hero__plate-head-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 35%, transparent),
                0 0 8px var(--color-accent);
    animation: hk-pulse 2.4s ease-in-out infinite;
  }
  .hk-hero__plate-id { color: var(--color-accent); }

  .hk-hero__plate-data {
    margin: 0;
    padding: 0.5rem 0.9rem 0.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .hk-hero__plate-data > div {
    padding: 1.1rem 0.7rem 1rem 0.7rem;
    border-bottom: 1px solid var(--color-rule);
    border-right: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    position: relative;
    overflow: hidden;
    transition: background-color 0.3s var(--ease-out-expo);
  }
  .hk-hero__plate-data > div:hover {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }
  .hk-hero__plate-data > div:nth-child(2n) { border-right: none; }
  .hk-hero__plate-data > div:nth-last-child(-n+2) { border-bottom: none; }

  /* Progress-Bar pro KPI */
  .hk-hero__plate-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: color-mix(in srgb, var(--color-text) 6%, transparent);
    overflow: hidden;
  }
  .hk-hero__plate-bar::after {
    content: '';
    display: block;
    width: var(--w);
    height: 100%;
    background: var(--color-accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-accent) 60%, transparent);
    transform-origin: left;
    animation: hk-bar-grow 1.6s var(--ease-out-expo) 0.6s both;
  }
  .hk-hero__plate-bar--inverse::after {
    background: linear-gradient(90deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 40%, var(--color-text)));
  }
  @keyframes hk-bar-grow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .hk-hero__plate-data dt {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hk-hero__plate-data dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }
  .hk-hero__plate-data span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hk-hero__plate-num { color: var(--color-accent); }
  .hk-hero__plate-unit {
    font-size: 0.4em !important;
    color: var(--color-muted) !important;
    margin-left: 0.2em;
    letter-spacing: 0.1em !important;
  }

  /* Power-Indikator (Audio-Style-Bars) */
  .hk-hero__plate-power {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 0.95rem;
    border-top: 1px solid var(--color-rule-strong);
    background: var(--color-bg);
  }
  .hk-hero__plate-power-k {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    font-weight: 700;
  }
  .hk-hero__plate-power-bars {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 18px;
  }
  .hk-hero__plate-power-bars span {
    flex: 1;
    background: var(--color-accent);
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-accent) 50%, transparent);
    animation: hk-power-bar 1.4s ease-in-out infinite;
    transform-origin: bottom;
  }
  .hk-hero__plate-power-bars span:nth-child(1)  { animation-delay: 0.00s; height: 40%; }
  .hk-hero__plate-power-bars span:nth-child(2)  { animation-delay: 0.07s; height: 65%; }
  .hk-hero__plate-power-bars span:nth-child(3)  { animation-delay: 0.14s; height: 90%; }
  .hk-hero__plate-power-bars span:nth-child(4)  { animation-delay: 0.21s; height: 55%; }
  .hk-hero__plate-power-bars span:nth-child(5)  { animation-delay: 0.28s; height: 70%; }
  .hk-hero__plate-power-bars span:nth-child(6)  { animation-delay: 0.35s; height: 100%; }
  .hk-hero__plate-power-bars span:nth-child(7)  { animation-delay: 0.42s; height: 45%; }
  .hk-hero__plate-power-bars span:nth-child(8)  { animation-delay: 0.49s; height: 85%; }
  .hk-hero__plate-power-bars span:nth-child(9)  { animation-delay: 0.56s; height: 75%; }
  .hk-hero__plate-power-bars span:nth-child(10) { animation-delay: 0.63s; height: 60%; }
  .hk-hero__plate-power-bars span:nth-child(11) { animation-delay: 0.70s; height: 95%; }
  .hk-hero__plate-power-bars span:nth-child(12) { animation-delay: 0.77s; height: 50%; }
  .hk-hero__plate-power-bars span:nth-child(13) { animation-delay: 0.84s; height: 80%; }
  .hk-hero__plate-power-bars span:nth-child(14) { animation-delay: 0.91s; height: 65%; }
  .hk-hero__plate-power-bars span:nth-child(15) { animation-delay: 0.98s; height: 90%; }
  .hk-hero__plate-power-bars span:nth-child(16) { animation-delay: 1.05s; height: 55%; }
  .hk-hero__plate-power-bars span:nth-child(17) { animation-delay: 1.12s; height: 75%; }
  .hk-hero__plate-power-bars span:nth-child(18) { animation-delay: 1.19s; height: 100%; }
  .hk-hero__plate-power-bars span:nth-child(19) { animation-delay: 1.26s; height: 45%; }
  .hk-hero__plate-power-bars span:nth-child(20) { animation-delay: 1.33s; height: 70%; }
  @keyframes hk-power-bar {
    0%, 100% { transform: scaleY(0.6); }
    50% { transform: scaleY(1); }
  }
  .hk-hero__plate-power-v {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: 0.005em;
  }
  .hk-hero__plate-power-v span {
    font-size: 0.5em;
    color: var(--color-muted);
    margin-left: 0.15em;
  }

  .hk-hero__plate-foot {
    padding: 0.7rem 0.9rem;
    border-top: 1px solid var(--color-rule);
    background: var(--color-surface-2);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    text-align: center;
    font-weight: 700;
  }

  /* Double-Row Marquee — gegenläufig */
  .hk-hero__strip-wrap {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--color-bg);
  }
  .hk-hero__strip {
    overflow: hidden;
    padding-block: 0.85rem;
  }
  .hk-hero__strip--y {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .hk-hero__strip--dark {
    background: var(--color-bg);
    color: var(--color-text);
    border-top: 1px solid var(--color-rule);
  }

  .hk-hero__strip-track {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: max-content;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    animation: hk-strip 38s linear infinite;
  }
  .hk-hero__strip-track--reverse {
    animation: hk-strip-reverse 44s linear infinite;
  }
  .hk-hero__strip--dark .hk-hero__strip-track span:not(.hk-hero__strip-dot) {
    color: var(--color-text);
  }
  .hk-hero__strip-dot {
    color: var(--color-accent);
    font-size: 0.55em;
    transform: translateY(-1px);
  }

  @keyframes hk-strip {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes hk-strip-reverse {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  /* ── MANIFEST ──────────────────────────────────────────────────── */
  .hk-manifest {
    border-top: 1px solid var(--color-rule);
  }

  .hk-manifest__h {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    max-width: 28ch;
  }

  .hk-manifest__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .hk-manifest__cols { grid-template-columns: repeat(3, 1fr); gap: clamp(2rem, 4vw, 3rem); }
  }

  .hk-manifest__cols p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    padding-top: 1.25rem;
    border-top: 2px solid var(--color-accent);
  }

  /* ── MEGA NUMBERS ─────────────────────────────────────────────── */
  .hk-numbers {
    border-top: 1px solid var(--color-rule);
    padding-block: clamp(4rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
  }
  .hk-numbers::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to bottom, var(--hk-grid-line) 1px, transparent 1px);
    background-size: 100% 80px;
    pointer-events: none;
    opacity: 0.5;
    mask-image: linear-gradient(to bottom, black, transparent 70%);
    -webkit-mask-image: linear-gradient(to bottom, black, transparent 70%);
  }

  .hk-numbers__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule-strong);
  }

  .hk-numbers__row {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1.4fr) minmax(0, 1fr);
    grid-template-areas:
      "idx num lbl"
      "idx num sub";
    column-gap: clamp(1rem, 2vw, 2.5rem);
    row-gap: 0.4rem;
    padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
    position: relative;
    transition: padding-left 0.6s var(--ease-out-expo);
  }
  .hk-numbers__row:hover { padding-left: clamp(0.5rem, 1.5vw, 1.25rem); }

  /* Yellow rail that slides in on hover */
  .hk-numbers__row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .hk-numbers__row:hover::before { transform: scaleY(1); }

  @media (max-width: 720px) {
    .hk-numbers__row {
      grid-template-columns: 2.5rem 1fr;
      grid-template-areas:
        "idx num"
        "idx lbl"
        ".   sub";
    }
  }

  .hk-numbers__idx {
    grid-area: idx;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    font-weight: 700;
    align-self: flex-start;
    padding-top: 0.4rem;
  }

  .hk-numbers__n {
    grid-area: num;
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.005em;
    font-weight: 400;
    color: var(--color-text);
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    text-transform: uppercase;
  }
  .hk-numbers__row:nth-child(2n) .hk-numbers__n { color: var(--color-accent); }

  .hk-numbers__unit {
    font-size: 0.32em;
    color: var(--color-muted);
    letter-spacing: 0.12em;
    margin-left: 0.05em;
    font-weight: 400;
  }

  .hk-numbers__lbl {
    grid-area: lbl;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
    line-height: 1.1;
    align-self: flex-end;
    padding-bottom: 0.3rem;
  }

  .hk-numbers__sub {
    grid-area: sub;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 38ch;
    letter-spacing: 0.02em;
  }

  /* ── ABOUT TEASER ──────────────────────────────────────────────── */
  .hk-about {
    border-top: 1px solid var(--color-rule);
    background: var(--color-surface);
  }

  .hk-about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hk-about__grid { grid-template-columns: 0.9fr 1.1fr; }
  }

  .hk-about__visual {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-rule-strong);
    aspect-ratio: 360 / 480;
    overflow: hidden;
  }

  .hk-about__circuit {
    width: 100%;
    height: 100%;
    color: var(--color-text);
  }

  .hk-about__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 1rem 0 1.5rem;
  }
  .hk-about__h-alt { color: var(--color-accent); }

  .hk-about__text {
    font-size: 1.05rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    max-width: 56ch;
    margin: 0 0 1.5rem;
  }

  .hk-about__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding-block: 1.25rem;
  }

  .hk-about__list li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .hk-about__list strong {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-accent);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .hk-about__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-text);
    transition: background-color 0.3s, color 0.3s, gap 0.3s var(--ease-out-expo);
  }
  .hk-about__link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    gap: 0.9rem;
    border-color: var(--color-accent);
  }
  .hk-about__link svg { width: 14px; height: 14px; }

  /* ── SERVICES TEASER ───────────────────────────────────────────── */
  .hk-svc {
    border-top: 1px solid var(--color-rule);
  }

  .hk-svc__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }
  .hk-svc__h-alt { color: var(--color-accent); }

  .hk-svc__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-rule-strong);
  }
  @media (min-width: 720px) {
    .hk-svc__grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Asymmetric: featured spans 2 columns, others span 1 (effective 4-col base) */
  @media (min-width: 1100px) {
    .hk-svc__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-flow: dense;
    }
    .hk-svc__cell--feature {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .hk-svc__cell {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    border-right: 1px solid var(--color-rule-strong);
    border-bottom: 1px solid var(--color-rule-strong);
    position: relative;
    transition: background-color 0.4s var(--ease-out-expo), color 0.4s var(--ease-out-expo);
    overflow: hidden;
    isolation: isolate;
  }

  /* Diagonal accent line that grows on hover */
  .hk-svc__cell::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-top: 14px solid var(--color-accent);
    border-left: 14px solid transparent;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
    z-index: 2;
  }
  .hk-svc__cell:hover::after { opacity: 1; }

  .hk-svc__cell--feature {
    background: var(--color-surface);
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
  }

  .hk-svc__cell:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .hk-svc__cell:last-child { border-right: none; }
  @media (min-width: 720px) and (max-width: 1099px) {
    .hk-svc__cell:nth-child(2n) { border-right: none; }
    .hk-svc__cell:nth-last-child(-n+2):nth-child(2n+1) { border-bottom: none; }
    .hk-svc__cell:last-child { border-bottom: none; }
  }
  @media (min-width: 1100px) {
    /* 4-col grid mit feature(2x2) + 5 single-cells:
       Row 1: [feature][feature][2][3]
       Row 2: [feature][feature][4][5]
       Row 3: [6][6 spanning rest of row?] — we have 6 cells total.
       Actually: feature(span 2x2), cells 2-5 fill the top-right 2x2 area,
       cell 6 spans the entire next row.
    */
    .hk-svc__cell:nth-child(2),
    .hk-svc__cell:nth-child(3),
    .hk-svc__cell:nth-child(4),
    .hk-svc__cell:nth-child(5) {
      grid-column: span 1;
    }
    .hk-svc__cell:nth-child(6) {
      grid-column: span 4;
    }
    /* Borders: feature bottom + right are inside, no need to strip.
       The cells in column 4 (i.e. nth(3) and nth(5)) lose right border. */
    .hk-svc__cell:nth-child(3),
    .hk-svc__cell:nth-child(5) { border-right: none; }
    /* Row-2 cells lose bottom border (above row 3) */
    .hk-svc__cell--feature,
    .hk-svc__cell:nth-child(4),
    .hk-svc__cell:nth-child(5) { border-bottom: 1px solid var(--color-rule-strong); }
    .hk-svc__cell:nth-child(6) { border-right: none; border-bottom: none; }
  }

