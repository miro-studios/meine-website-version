</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Cleanup-Registry — alles was beim astro:before-swap aufgeräumt werden
  // muss (Listener, rAF, Interval, IO) landet hier. Ohne sauberen Teardown
  // bauen sich Listener bei jeder View-Transition auf und die Seite wird
  // mit der Zeit zäh — auf Mobile noch schneller spürbar.
  let cleanups: Array<() => void> = [];
  let tickerInterval: number | undefined;

  // Mobile-Erkennung: Touch ohne präzisen Zeiger. Auf solchen Geräten
  // feuert mouseenter zwar manchmal (Hybrid-Browser), mouseleave aber
  // unzuverlässig — das hinterlässt hängende Transforms (3D-Tilt). Wir
  // schalten die Mouse-Effekte dort komplett ab.
  const isCoarse = () =>
    window.matchMedia('(hover: none), (pointer: coarse)').matches;
  const isMobile = () => window.matchMedia('(max-width: 720px)').matches;

  function startTicker() {
    const ticker = document.querySelector<HTMLElement>('[data-hk-ticker] .hk-hero__ticker');
    if (!ticker) return;
    const items = Array.from(ticker.querySelectorAll<HTMLElement>('.hk-hero__ticker-item'));
    if (items.length < 2) return;
    let i = 0;
    window.clearInterval(tickerInterval);
    tickerInterval = window.setInterval(() => {
      items[i].classList.remove('is-active');
      items[i].classList.add('is-out');
      i = (i + 1) % items.length;
      items.forEach(it => it.classList.remove('is-out'));
      // Ensure only the new one is active
      items.forEach(it => it.classList.remove('is-active'));
      items[i].classList.add('is-active');
    }, 2800);
  }

  // ── Spark-Canvas ────────────────────────────────────────────────
  // Lightweight gelbe Funken-Particles im Hero-Hintergrund. Steigen
  // langsam auf, faden aus. Pausiert wenn Hero unsichtbar (Battery-
  // schonend auf Mobile) und räumt resize-Listener beim Teardown auf.
  function startSparks() {
    const canvas = document.querySelector<HTMLCanvasElement>('[data-hk-sparks]');
    const hero = document.querySelector<HTMLElement>('[data-hk-hero]');
    if (!canvas || !hero) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      if (!canvas || !ctx || !hero) return;
      const r = hero.getBoundingClientRect();
      canvas.width = Math.max(1, Math.floor(r.width * dpr));
      canvas.height = Math.max(1, Math.floor(r.height * dpr));
      canvas.style.width = `${r.width}px`;
      canvas.style.height = `${r.height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    type Spark = { x: number; y: number; vy: number; r: number; life: number; max: number; hue: number };
    const sparks: Spark[] = [];
    const N = isMobile() ? 10 : 28;

    function spawn(): Spark {
      const w = canvas?.width ? canvas.width / dpr : window.innerWidth;
      const h = canvas?.height ? canvas.height / dpr : window.innerHeight;
      return {
        x: Math.random() * w,
        y: h + Math.random() * 40,
        vy: 0.25 + Math.random() * 0.55,
        r: 0.7 + Math.random() * 1.6,
        life: 0,
        max: 220 + Math.random() * 260,
        hue: Math.random() < 0.25 ? 0 : 50,
      };
    }
    for (let i = 0; i < N; i++) {
      const s = spawn();
      s.life = Math.random() * s.max;
      s.y = Math.random() * (canvas.height / dpr);
      sparks.push(s);
    }

    let raf = 0;
    let running = false;
    function frame() {
      if (!canvas || !ctx) return;
      const w = canvas.width / dpr;
      const h = canvas.height / dpr;
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < sparks.length; i++) {
        const s = sparks[i];
        s.life += 1;
        s.y -= s.vy;
        s.x += Math.sin(s.life * 0.04 + i) * 0.18;
        const t = s.life / s.max;
        const alpha = t < 0.1 ? t * 10 : 1 - Math.max(0, (t - 0.3) / 0.7);
        if (alpha <= 0 || s.y < -20) {
          sparks[i] = spawn();
          continue;
        }
        const c = s.hue === 0
          ? `rgba(240, 237, 228, ${alpha * 0.55})`
          : `rgba(255, 214, 10, ${alpha * 0.75})`;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = c;
        ctx.shadowBlur = 8;
        ctx.shadowColor = s.hue === 0
          ? 'rgba(240, 237, 228, 0.6)'
          : 'rgba(255, 214, 10, 0.9)';
        ctx.fill();
        ctx.shadowBlur = 0;
      }
      raf = requestAnimationFrame(frame);
    }
    const start = () => { if (!running) { running = true; raf = requestAnimationFrame(frame); } };
    const stop = () => { if (running) { running = false; cancelAnimationFrame(raf); } };

    // Sparks nur laufen lassen, solange Hero im Viewport ist — dem
    // Akku auf Mobile zuliebe, aber auch generell für Main-Thread.
    const io = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) start(); else stop();
    }, { threshold: 0.01 });
    io.observe(hero);

    cleanups.push(() => {
      stop();
      io.disconnect();
      window.removeEventListener('resize', resize);
    });
  }

  // ── Mouse-Move Parallax + 3D-Tilt im Hero ────────────────────────
  // Touch-Geräte: skip. Auf Hybrid-Browsern feuert mouseleave nicht
  // zuverlässig und der 3D-Tilt-Transform bleibt sonst hängen.
  function startHeroInteractions() {
    if (isCoarse()) return;
    const hero = document.querySelector<HTMLElement>('[data-hk-hero]');
    if (!hero) return;
    const parallaxNodes = Array.from(
      hero.querySelectorAll<HTMLElement>('[data-hk-hero-parallax]'),
    );
    const tiltNodes = Array.from(hero.querySelectorAll<HTMLElement>('[data-hk-tilt]'));

    const onMove = (e: MouseEvent) => {
      if (!hero) return;
      const r = hero.getBoundingClientRect();
      const cx = (e.clientX - r.left) / r.width - 0.5;  // -0.5 .. 0.5
      const cy = (e.clientY - r.top) / r.height - 0.5;
      // Parallax-Layer
      parallaxNodes.forEach((node) => {
        const k = parseFloat(node.dataset.hkHeroParallax || '0.15');
        const tx = -cx * 40 * k;
        const ty = -cy * 40 * k;
        node.style.transform = `translate3d(${tx.toFixed(2)}px, ${ty.toFixed(2)}px, 0)`;
      });
      // 3D-Tilt
      tiltNodes.forEach((node) => {
        const max = parseFloat(node.dataset.hkTilt || '6');
        const rx = -cy * max;
        const ry = cx * max;
        const r2 = node.getBoundingClientRect();
        const lx = ((e.clientX - r2.left) / r2.width) * 100;
        const ly = ((e.clientY - r2.top) / r2.height) * 100;
        node.style.transform = `perspective(900px) rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg)`;
        node.style.setProperty('--hk-tilt-x', `${lx}%`);
        node.style.setProperty('--hk-tilt-y', `${ly}%`);
      });
    };
    const onLeave = () => {
      parallaxNodes.forEach((n) => (n.style.transform = ''));
      tiltNodes.forEach((n) => (n.style.transform = ''));
    };
    hero.addEventListener('mousemove', onMove, { passive: true });
    hero.addEventListener('mouseleave', onLeave);

    cleanups.push(() => {
      hero.removeEventListener('mousemove', onMove);
      hero.removeEventListener('mouseleave', onLeave);
      parallaxNodes.forEach((n) => (n.style.transform = ''));
      tiltNodes.forEach((n) => (n.style.transform = ''));
    });
  }

  // ── Hover-Glitch auf Hero-Headline-Zeilen ───────────────────────
  function startHeadlineGlitch() {
    if (isCoarse()) return;
    const lines = Array.from(
      document.querySelectorAll<HTMLElement>('.hk-hero__h .hk-hero__line'),
    );
    const teardowns: Array<() => void> = [];
    lines.forEach((line) => {
      let raf = 0;
      const onEnter = () => {
        let t = 0;
        const max = 18;
        cancelAnimationFrame(raf);
        const tick = () => {
          t += 1;
          if (t > max) {
            line.style.transform = '';
            return;
          }
          const x = (Math.random() - 0.5) * 6;
          const y = (Math.random() - 0.5) * 3;
          line.style.transform = `translate3d(${x.toFixed(1)}px, ${y.toFixed(1)}px, 0)`;
          raf = requestAnimationFrame(tick);
        };
        raf = requestAnimationFrame(tick);
      };
      const onLeave = () => {
        cancelAnimationFrame(raf);
        line.style.transform = '';
      };
      line.addEventListener('mouseenter', onEnter);
      line.addEventListener('mouseleave', onLeave);
      teardowns.push(() => {
        cancelAnimationFrame(raf);
        line.removeEventListener('mouseenter', onEnter);
        line.removeEventListener('mouseleave', onLeave);
        line.style.transform = '';
      });
    });
    cleanups.push(() => teardowns.forEach((fn) => fn()));
  }

  // ── Service-Card Spotlight + Subtile Tilt ───────────────────────
  // Auf Touch komplett deaktiviert: ein Tap kann mouseenter feuern,
  // aber mouseleave nie — Folge wäre eine Card mit hängender
  // perspective-Rotation. Hover-Fill kommt sowieso vom :hover-CSS,
  // das auf Touch nicht zündet.
  function startSvcCards() {
    if (isCoarse()) return;
    const cells = Array.from(document.querySelectorAll<HTMLElement>('.hk-svc__cell'));
    const teardowns: Array<() => void> = [];
    cells.forEach((cell) => {
      const max = cell.classList.contains('hk-svc__cell--feature') ? 4 : 6;
      const onEnter = () => cell.classList.add('is-hot');
      const onMove = (e: MouseEvent) => {
        const r = cell.getBoundingClientRect();
        const px = ((e.clientX - r.left) / r.width) * 100;
        const py = ((e.clientY - r.top) / r.height) * 100;
        cell.style.setProperty('--hk-svc-x', `${px}%`);
        cell.style.setProperty('--hk-svc-y', `${py}%`);
        const rx = ((py / 100) - 0.5) * -max;
        const ry = ((px / 100) - 0.5) * max;
        cell.style.transform = `perspective(900px) rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg)`;
      };
      const onLeave = () => {
        cell.classList.remove('is-hot');
        cell.style.transform = '';
      };
      cell.addEventListener('mouseenter', onEnter);
      cell.addEventListener('mousemove', onMove);
      cell.addEventListener('mouseleave', onLeave);
      teardowns.push(() => {
        cell.removeEventListener('mouseenter', onEnter);
        cell.removeEventListener('mousemove', onMove);
        cell.removeEventListener('mouseleave', onLeave);
        cell.classList.remove('is-hot');
        cell.style.transform = '';
      });
    });
    cleanups.push(() => teardowns.forEach((fn) => fn()));
  }

  function init() {
    // Vorherige Listener/rAFs abräumen (z.B. nach View-Transition).
    cleanups.forEach((fn) => fn());
    cleanups = [];

    startTicker();
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    startSparks();
    startHeroInteractions();
    startHeadlineGlitch();
    startSvcCards();
    const hero = document.querySelector<HTMLElement>('[data-hk-hero]');
    const plate = document.querySelector<HTMLElement>('[data-hk-hero-plate]');
    if (hero && plate) {
      const tween = gsap.to(plate, {
        yPercent: -6,
        ease: 'none',
        scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.6 },
      });
      cleanups.push(() => {
        tween.scrollTrigger?.kill();
        tween.kill();
      });
    }

    // Pin-Section für Prozess — Step-Reveal via IntersectionObserver.
    // (gsap.from + ScrollTrigger hatte einen Race-Condition mit Lenis, der
    // dazu führte, dass die Steps unsichtbar blieben wenn man schnell
    // gescrollt hat. IO ist hier zuverlässiger und braucht keine GSAP-
    // Initialisierung.)
    const proc = document.querySelector<HTMLElement>('[data-hk-proc]');
    if (proc && window.matchMedia('(min-width: 900px)').matches) {
      const steps = Array.from(proc.querySelectorAll<HTMLElement>('.hk-proc__step'));
      steps.forEach((step, i) => {
        step.style.opacity = '0';
        step.style.transform = 'translateY(32px)';
        step.style.transition = `opacity 0.7s var(--ease-out-expo) ${i * 0.06}s, transform 0.7s var(--ease-out-expo) ${i * 0.06}s`;
      });
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            io.unobserve(el);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });
      steps.forEach((step) => io.observe(step));

      // Safety-Net: nach 1,5 s alle Steps zwingend sichtbar machen
      // (falls IO aus irgendeinem Grund nicht feuert)
      const safetyTimer = window.setTimeout(() => {
        steps.forEach((step) => {
          step.style.opacity = '1';
          step.style.transform = 'translateY(0)';
        });
      }, 1500);

      cleanups.push(() => {
        io.disconnect();
        window.clearTimeout(safetyTimer);
      });
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    window.clearInterval(tickerInterval);
    cleanups.forEach((fn) => fn());
    cleanups = [];
  });
</script>
