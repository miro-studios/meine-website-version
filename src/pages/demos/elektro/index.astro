<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hk-hero {
    position: relative;
    min-height: 100vh;        /* Fallback für ältere Browser */
    min-height: 100svh;        /* Mobile-Browser ohne URL-Bar */
    overflow: hidden;
    isolation: isolate;
    background: var(--color-bg);
  }

  .hk-hero__grid {
    position: absolute;
    inset: -4%;
    background-image:
      linear-gradient(to right, var(--hk-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--hk-grid-line) 1px, transparent 1px);
    background-size: clamp(40px, 6vw, 72px) clamp(40px, 6vw, 72px);
    background-position: 50% 0%;
    mask-image: radial-gradient(ellipse 70% 80% at 50% 40%, black 30%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 40%, black 30%, transparent 90%);
    z-index: 0;
    pointer-events: none;
    will-change: transform;
    transition: transform 0.7s var(--ease-out-expo);
  }

  /* Spark-Canvas — leichte gelbe Funken die im Hintergrund langsam aufsteigen */
  .hk-hero__sparks {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0.7;
  }

  /* Lightning-Bolt SVG im Hintergrund — die "premium" Schicht */
  .hk-hero__bolt {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  /* Auf schmalen Viewports zerschneidet preserveAspectRatio="slice"
     den 1440×900-viewBox so stark, dass der Blitz visuell verschwindet
     und nur ein gelber Streifen bleibt. Dort ausblenden — der Hero
     bleibt durch Grid + Sparks + Strom-Wellen trotzdem dynamisch. */
  @media (max-width: 720px) {
    .hk-hero__bolt { display: none; }
  }
  [data-hk-bolt] {
    stroke-dasharray: 2400;
    stroke-dashoffset: 2400;
    animation: hk-bolt-draw 5s ease-out 0.6s forwards,
               hk-bolt-pulse 4s ease-in-out 5.6s infinite;
  }
  @keyframes hk-bolt-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes hk-bolt-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.95; }
  }

  /* Scan-Line die durch den Hero wandert */
  .hk-hero__scanline {
    transform: translateY(0);
    animation: hk-scanline 8s linear infinite;
    opacity: 0.0;
  }
  @keyframes hk-scanline {
    0% { transform: translateY(0); opacity: 0; }
    8% { opacity: 0.5; }
    50% { transform: translateY(900px); opacity: 0.5; }
    58% { opacity: 0; }
    100% { transform: translateY(900px); opacity: 0; }
  }

  .hk-hero__spec {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2rem;
    padding-block: 0.85rem;
