---
/**
 * Holtkamp Elektrotechnik — Demo-Startseite
 *
 * Showcase für miro-studios "Business Multi-Page"-Paket (€ 2.799 + € 34,99/Mon).
 * Sitemap: Start · Betrieb · Leistungen · Referenzen · Journal · Kontakt
 *          + Impressum & Datenschutz.
 *
 * Industrial Brutalism mit Premium-Touch: tiefes Warm-Schwarz, warmer
 * Cream-Text, elektrisches Gelb als Akzent. Anton (Display) + Manrope (Body)
 * + JetBrains Mono (technische Labels).
 *
 * Dies ist eine Demo — kein realer Kunde.
 */
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';
import EnergyFlow from '@components/elektro/EnergyFlow.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://miro-studios.de/demos/elektro/#business',
  name: 'Holtkamp Elektrotechnik',
  description:
    'Elektro- und Heizungsbau-Meisterbetrieb in Lüdenscheid. Installationen, Photovoltaik, Wärmepumpen und Smart Home für Privat und Gewerbe seit 1989.',
  url: 'https://miro-studios.de/demos/elektro/',
  telephone: '+49 2351 608021',
  email: 'hallo@holtkamp-elektro.de',
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Volmestraße 47',
    postalCode: '58507',
    addressLocality: 'Lüdenscheid',
    addressRegion: 'NRW',
    addressCountry: 'DE',
  },
  areaServed: ['Lüdenscheid', 'Märkischer Kreis', 'Sauerland', 'Hagen', 'Iserlohn'],
  founder: 'Werner Holtkamp',
  foundingDate: '1989',
};

const services = [
  { n: '01', t: 'ELEKTRO­INSTALLATION', sub: 'Privat · Gewerbe · Industrie', text: 'Neuinstallationen, Sanierungen und Erweiterungen — von der Verteilung bis zur einzelnen Steckdose. VDE-konform, dokumentiert, mit Messprotokoll.' },
  { n: '02', t: 'HEIZUNG & WÄRME', sub: 'Wärmepumpe · Hybrid · Solar', text: 'Wir planen und bauen Wärmepumpen-Systeme, hybride Heizungen und Solarthermie. Mit Heizlastberechnung, hydraulischem Abgleich und BAFA-Antrag.' },
  { n: '03', t: 'PHOTOVOLTAIK', sub: 'Komplett-Anlagen mit Speicher', text: 'Auslegung, Montage, Anmeldung und Inbetriebnahme. Wir liefern wirtschaftliche Anlagen mit Wechselrichter, Speicher und Wallbox-Anbindung.' },
  { n: '04', t: 'SMART HOME', sub: 'KNX · Loxone · Matter', text: 'Eine Anlage, die zentral schaltet, dimmt, regelt und meldet. Wir planen herstellerunabhängig und übergeben dokumentiert mit Wartungsvertrag.' },
  { n: '05', t: 'E-MOBILITÄT', sub: 'Wallbox · Lastmanagement', text: 'Vom 11-kW-Heim­anschluss bis zur Firmen-Lade­infrastruktur mit dynamischem Lastmanagement und Abrechnungs-Backend.' },
  { n: '06', t: '24H NOTDIENST', sub: 'Strom & Wärme · MK-Gebiet', text: 'Wenn die Sicherung knallt oder die Heizung ausfällt, sind wir innerhalb von 90 Minuten beim Kunden — Tag, Nacht, Wochenende.' },
];

type ServiceIcon = 'panel' | 'pump' | 'pv' | 'knx' | 'wallbox' | 'siren';
const serviceIcons: ServiceIcon[] = ['panel', 'pump', 'pv', 'knx', 'wallbox', 'siren'];

const process = [
  { n: '01', label: 'ANFRAGE', text: 'Sie rufen an oder schicken eine Mail. Wir reagieren innerhalb von 24 Stunden mit einem Termin-Vorschlag.' },
  { n: '02', label: 'ORTSTERMIN', text: 'Wir kommen vorbei, hören zu, messen und prüfen — kostenfrei für Privatkunden, klärt Machbarkeit und Förderfähigkeit.' },
  { n: '03', label: 'ANGEBOT', text: 'Sie bekommen ein schriftliches Festpreis-Angebot mit Leistungsverzeichnis. Keine Überraschungen auf der Rechnung.' },
  { n: '04', label: 'AUSFÜHRUNG', text: 'Termingebunden, sauber, mit täglichem Status-Update. Wir hinterlassen die Baustelle besenrein.' },
];
---

<ElektroLayout
  title="Holtkamp Elektrotechnik — Strom. Wärme. Zukunft. · Lüdenscheid"
  description="Holtkamp ist Elektro- und Heizungsbau-Meisterbetrieb in Lüdenscheid. Installationen, Photovoltaik, Wärmepumpen und Smart Home für Privat, Gewerbe und Industrie."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- ── HERO (Premium-Upgrade) ───────────────────────────────────── -->
  <section class="hk-hero" data-hk-hero data-hk-section data-hk-name="Start">
    <div class="hk-hero__grid" data-hk-hero-parallax="0.12" aria-hidden="true"></div>

    <!-- Spark-Canvas (lightweight gelbe Funken die langsam aufsteigen) -->
    <canvas class="hk-hero__sparks" data-hk-sparks aria-hidden="true"></canvas>

    <!-- Animated Circuit-Bolt SVG im Hintergrund -->
    <svg class="hk-hero__bolt" data-hk-hero-parallax="0.22" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="hk-bolt-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.55"/>
          <stop offset="55%" stop-color="var(--color-accent)" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/>
        </linearGradient>
        <filter id="hk-bolt-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="8" />
        </filter>
      </defs>

      <!-- Diagonal lightning path (premium accent) -->
      <path
        d="M 1340 -40 L 980 280 L 1110 280 L 720 700 L 880 700 L 540 980"
        fill="none"
        stroke="url(#hk-bolt-grad)"
        stroke-width="60"
        stroke-linecap="square"
        stroke-linejoin="miter"
        filter="url(#hk-bolt-glow)"
        opacity="0.8"
        data-hk-bolt
      />
      <path
        d="M 1340 -40 L 980 280 L 1110 280 L 720 700 L 880 700 L 540 980"
        fill="none"
        stroke="var(--color-accent)"
        stroke-width="1.2"
        stroke-linecap="square"
        stroke-linejoin="miter"
        opacity="0.65"
      />

      <!-- Scan-Line die langsam vertical durchläuft -->
      <line
        class="hk-hero__scanline"
        x1="0" y1="0" x2="1440" y2="0"
        stroke="var(--color-accent)"
        stroke-width="1"
        opacity="0.35"
      />
    </svg>

    <!-- Spec-Bar oben (mit Live-Ticker) -->
    <div class="hk-hero__spec hk-container">
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">FILE</span>
        <span class="hk-hero__spec-v">HK-2026.HOME</span>
      </span>
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">MEISTER</span>
        <span class="hk-hero__spec-v">HWK MK · NR. 47 / 13</span>
      </span>
      <span class="hk-hero__spec-cell">
        <span class="hk-hero__spec-k">VDE</span>
        <span class="hk-hero__spec-v">0100 · 0105 · 0701</span>
      </span>
      <span class="hk-hero__spec-cell hk-hero__spec-cell--ticker" data-hk-ticker>
        <span class="hk-hero__spec-k">LIVE</span>
        <span class="hk-hero__spec-v hk-hero__ticker">
          <span class="hk-hero__ticker-item is-active">PV-INSTALLATION · ISERLOHN</span>
          <span class="hk-hero__ticker-item">WALLBOX-MONTAGE · LÜDENSCHEID</span>
          <span class="hk-hero__ticker-item">WÄRMEPUMPE · HALVER</span>
          <span class="hk-hero__ticker-item">SMART-HOME · MEINERZHAGEN</span>
          <span class="hk-hero__ticker-item">E-CHECK · KIERSPE</span>
        </span>
      </span>
      <span class="hk-hero__spec-cell hk-hero__spec-cell--push">
        <span class="hk-hero__spec-dot" aria-hidden="true"></span>
        <span class="hk-hero__spec-v">24H NOTDIENST AKTIV</span>
      </span>
    </div>

    <!-- Hero-Inhalt -->
    <div class="hk-hero__inner hk-container">
      <div class="hk-hero__copy">
        <div class="hk-hero__index">
          <span class="hk-hero__index-n">N°</span>
          <span class="hk-hero__index-v">00</span>
          <span class="hk-hero__index-line" aria-hidden="true"></span>
          <span class="hk-hero__index-k">START / HOME · MAY · 2026</span>
        </div>

        <h1 class="hk-hero__h">
          <span class="hk-hero__line">
            <span class="hk-hero__line-shadow" aria-hidden="true">STROM.</span>
            <SplitText by="chars" stagger={0.025} delay={0.05} onScroll={false}>STROM.</SplitText>
          </span>
          <span class="hk-hero__line hk-hero__line--y">
            <span class="hk-hero__line-shadow" aria-hidden="true">WÄRME.</span>
            <SplitText by="chars" stagger={0.025} delay={0.4} onScroll={false}>WÄRME.</SplitText>
          </span>
          <span class="hk-hero__line">
            <span class="hk-hero__line-shadow" aria-hidden="true">ZUKUNFT.</span>
            <SplitText by="chars" stagger={0.025} delay={0.75} onScroll={false}>ZUKUNFT.</SplitText>
          </span>
        </h1>

        <div class="hk-hero__caption">
          <span class="hk-hero__caption-tag" aria-hidden="true"></span>
          <p>
            HOLTKAMP ELEKTROTECHNIK · MEISTERBETRIEB IN LÜDENSCHEID — SEIT 1989
            PLANEN UND BAUEN WIR ELEKTRO-, HEIZUNGS- UND ENERGIETECHNIK FÜR
            PRIVAT, GEWERBE UND INDUSTRIE IM SAUERLAND.
          </p>
        </div>

        <div class="hk-hero__actions">
          <MagneticButton href="/demos/elektro/kontakt/" strength={0.35} variant="primary" class="hk-hero__cta" data-cursor-hover>
            <span>PROJEKT ANFRAGEN</span>
            <span aria-hidden="true">→</span>
          </MagneticButton>
          <a href="/demos/elektro/leistungen/" class="hk-hero__link" data-cursor-hover>
            <span>Was wir bauen</span>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"/></svg>
          </a>
        </div>
      </div>

      <!-- Premium-Stats-Panel mit Corner-Brackets + Live-Bar -->
      <aside class="hk-hero__plate" data-hk-hero-plate data-hk-tilt="6">
        <span class="hk-hero__plate-bracket hk-hero__plate-bracket--tl" aria-hidden="true"></span>
        <span class="hk-hero__plate-bracket hk-hero__plate-bracket--tr" aria-hidden="true"></span>
        <span class="hk-hero__plate-bracket hk-hero__plate-bracket--bl" aria-hidden="true"></span>
        <span class="hk-hero__plate-bracket hk-hero__plate-bracket--br" aria-hidden="true"></span>

        <div class="hk-hero__plate-head">
          <span class="hk-hero__plate-head-dot" aria-hidden="true"></span>
          <span>BETRIEBSTELEMETRIE · Q2/2026</span>
          <span class="hk-hero__plate-id">REV·08</span>
        </div>

        <dl class="hk-hero__plate-data">
          <div>
            <dt>JAHRE</dt>
            <dd><NumberCounter to={37} duration={1.6} /></dd>
            <span>BETRIEBSGESCHICHTE</span>
            <span class="hk-hero__plate-bar" style="--w: 92%" aria-hidden="true"></span>
          </div>
          <div>
            <dt>PROJEKTE</dt>
            <dd><NumberCounter to={2400} duration={2.2} />+</dd>
            <span>ABGESCHLOSSEN</span>
            <span class="hk-hero__plate-bar" style="--w: 88%" aria-hidden="true"></span>
          </div>
          <div>
            <dt>TEAM</dt>
            <dd><NumberCounter to={14} duration={1.4} /></dd>
            <span>GESELLEN & MEISTER</span>
            <span class="hk-hero__plate-bar" style="--w: 64%" aria-hidden="true"></span>
          </div>
          <div>
            <dt>NOTRUF</dt>
            <dd>
              <span class="hk-hero__plate-num">90</span>
              <span class="hk-hero__plate-unit">MIN</span>
            </dd>
            <span>REAKTIONSZEIT MK</span>
            <span class="hk-hero__plate-bar hk-hero__plate-bar--inverse" style="--w: 18%" aria-hidden="true"></span>
          </div>
        </dl>

        <!-- Power-Indikator unten -->
        <div class="hk-hero__plate-power">
          <span class="hk-hero__plate-power-k">POWER</span>
          <div class="hk-hero__plate-power-bars" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
          <span class="hk-hero__plate-power-v">100<span>%</span></span>
        </div>

        <div class="hk-hero__plate-foot">
          INNUNG · E-CHECK · ZERTIFIZIERT
        </div>
      </aside>
    </div>

    <!-- Doppel-Marquee (gegenläufig) — Top in Gelb, Bottom mit gelben Punkten -->
    <div class="hk-hero__strip-wrap" aria-hidden="true">
      <div class="hk-hero__strip hk-hero__strip--y">
        <div class="hk-hero__strip-track">
          <span>ELEKTROINSTALLATION</span><span>·</span>
          <span>WÄRMEPUMPE</span><span>·</span>
          <span>PHOTOVOLTAIK</span><span>·</span>
          <span>KNX-SMART-HOME</span><span>·</span>
          <span>WALLBOX</span><span>·</span>
          <span>NOTSTROM</span><span>·</span>
          <span>BLITZSCHUTZ</span><span>·</span>
          <span>E-CHECK</span><span>·</span>
          <span>ELEKTROINSTALLATION</span><span>·</span>
          <span>WÄRMEPUMPE</span><span>·</span>
          <span>PHOTOVOLTAIK</span><span>·</span>
          <span>KNX-SMART-HOME</span><span>·</span>
          <span>WALLBOX</span><span>·</span>
          <span>NOTSTROM</span><span>·</span>
          <span>BLITZSCHUTZ</span><span>·</span>
          <span>E-CHECK</span><span>·</span>
        </div>
      </div>
      <div class="hk-hero__strip hk-hero__strip--dark">
        <div class="hk-hero__strip-track hk-hero__strip-track--reverse">
          <span>SEIT 1989</span><span class="hk-hero__strip-dot">●</span>
          <span>LÜDENSCHEID</span><span class="hk-hero__strip-dot">●</span>
          <span>HWK MK 47/13</span><span class="hk-hero__strip-dot">●</span>
          <span>3 MEISTER · 4 AZUBI</span><span class="hk-hero__strip-dot">●</span>
          <span>184 BEWERTUNGEN · 4,9★</span><span class="hk-hero__strip-dot">●</span>
          <span>VDE-FACHBETRIEB</span><span class="hk-hero__strip-dot">●</span>
          <span>SEIT 1989</span><span class="hk-hero__strip-dot">●</span>
          <span>LÜDENSCHEID</span><span class="hk-hero__strip-dot">●</span>
          <span>HWK MK 47/13</span><span class="hk-hero__strip-dot">●</span>
          <span>3 MEISTER · 4 AZUBI</span><span class="hk-hero__strip-dot">●</span>
          <span>184 BEWERTUNGEN · 4,9★</span><span class="hk-hero__strip-dot">●</span>
          <span>VDE-FACHBETRIEB</span><span class="hk-hero__strip-dot">●</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section-Divider-Tag -->
  <div class="hk-tag" aria-hidden="true">
    <span class="hk-tag__inner">
      <span class="hk-tag__dot"></span>
      <span class="hk-tag__k">STEP</span>
      <span class="hk-tag__v">01 · MANIFEST</span>
    </span>
  </div>

  <!-- ── MANIFEST (Editorial-Treatment) ───────────────────────────── -->
  <section class="hk-manifest hk-section" data-hk-section data-hk-name="Manifest">
    <!-- Marginalia: Rotated Side-Label links -->
    <span class="hk-manifest__margin" aria-hidden="true">
      <span class="hk-manifest__margin-line"></span>
      MANIFEST · MAI 2026 · FOLIO 01
      <span class="hk-manifest__margin-line"></span>
    </span>

    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 01</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">MANIFEST / WAS UNS UNTERSCHEIDET</span>
      </div>

      <h2 class="hk-manifest__h">
        <SplitText by="words" stagger={0.05}>Wir verlegen keine Kabel — wir bauen Anlagen, die in 25&nbsp;Jahren noch sauber funktionieren.</SplitText>
      </h2>

      <!-- Pull-Quote im Editorial-Stil -->
      <RevealOnScroll y={30}>
        <blockquote class="hk-manifest__quote">
          <span class="hk-manifest__quote-mark" aria-hidden="true">„</span>
          <p>
            Wenn du sauber arbeitest und pünktlich bist, kommen die
            nächsten zwölf Kunden von allein.
          </p>
          <footer>
            <span class="hk-manifest__quote-cite">WERNER HOLTKAMP</span>
            <span class="hk-manifest__quote-role">Gründer · 1989</span>
          </footer>
        </blockquote>
      </RevealOnScroll>

      <div class="hk-manifest__cols">
        <RevealOnScroll y={40}>
          <div class="hk-manifest__col">
            <span class="hk-manifest__col-n">01</span>
            <p class="hk-manifest__col-text hk-dropcap">
              Elektro und Heizung sind keine Bereiche, die man trennen sollte —
              wer Wärme plant, plant Strom mit. Wir haben deshalb beide
              Gewerke unter einem Dach. Eine Ansprechperson, ein Termin,
              eine Rechnung.
            </p>
          </div>
        </RevealOnScroll>
        <RevealOnScroll y={40}>
          <div class="hk-manifest__col">
            <span class="hk-manifest__col-n">02</span>
            <p class="hk-manifest__col-text">
              Wir arbeiten ausschließlich mit Materialien, die wir auch im
              eigenen Haus verbauen würden. Markenkomponenten, dokumentierte
              Herkunft, Garantien, die Bestand haben. <em>Das kostet mehr —
              und spart in Summe</em>, weil nichts in zehn Jahren wieder
              raus muss.
            </p>
          </div>
        </RevealOnScroll>
        <RevealOnScroll y={40}>
          <div class="hk-manifest__col">
            <span class="hk-manifest__col-n">03</span>
            <p class="hk-manifest__col-text">
              Familienbetrieb, dritte Generation. Werner Holtkamp hat den
              Betrieb 1989 gegründet, sein Sohn führt heute die Geschäfte,
              seine Enkelin ist seit 2024 Meisterin. Das heißt: <em>Sie
              kennen uns, und wir verschwinden nicht.</em>
            </p>
          </div>
        </RevealOnScroll>
      </div>
    </div>
  </section>

  <!-- Section-Divider-Tag -->
  <div class="hk-tag" aria-hidden="true">
    <span class="hk-tag__inner">
      <span class="hk-tag__dot"></span>
      <span class="hk-tag__k">STEP</span>
      <span class="hk-tag__v">02 · IN ZAHLEN</span>
    </span>
  </div>

  <!-- ── MEGA NUMBERS ──────────────────────────────────────────────── -->
  <section class="hk-numbers" data-hk-numbers data-hk-section data-hk-name="In Zahlen">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 02</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">DATEN / IM SCHNITT</span>
      </div>

      <ol class="hk-numbers__list">
        <li class="hk-numbers__row">
          <span class="hk-numbers__idx">01</span>
          <span class="hk-numbers__n" data-hk-mega>
            <NumberCounter to={37} duration={2} />
          </span>
          <span class="hk-numbers__lbl">JAHRE BETRIEB</span>
          <span class="hk-numbers__sub">Familiengeführt. Eigentümergeführt geblieben. Werner Holtkamp ist heute noch beratend dabei.</span>
        </li>
        <li class="hk-numbers__row">
          <span class="hk-numbers__idx">02</span>
          <span class="hk-numbers__n" data-hk-mega>
            <NumberCounter to={2400} duration={2.4} />+
          </span>
          <span class="hk-numbers__lbl">PROJEKTE FERTIG</span>
          <span class="hk-numbers__sub">Vom Einfamilienhaus mit 12-kWp-Anlage bis zur 1.200-m²-Industriehalle mit 800-A-Verteilung.</span>
        </li>
        <li class="hk-numbers__row">
          <span class="hk-numbers__idx">03</span>
          <span class="hk-numbers__n" data-hk-mega>
            <NumberCounter to={90} duration={1.6} /><span class="hk-numbers__unit">MIN</span>
          </span>
          <span class="hk-numbers__lbl">REAKTIONSZEIT NOTDIENST</span>
          <span class="hk-numbers__sub">Im Märkischen Kreis. Tag, Nacht, Wochenende, Feiertag. 0&nbsp;23&nbsp;51 / 60&nbsp;80&nbsp;21.</span>
        </li>
        <li class="hk-numbers__row">
          <span class="hk-numbers__idx">04</span>
          <span class="hk-numbers__n" data-hk-mega>
            <NumberCounter to={4.9} duration={1.6} decimals={1} /><span class="hk-numbers__unit">/5</span>
          </span>
          <span class="hk-numbers__lbl">KUNDEN-SCHNITT</span>
          <span class="hk-numbers__sub">Aus 184 öffentlichen Bewertungen über Google, ProvenExpert und MyHammer. Stand Mai 2026.</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- Section-Divider-Tag -->
  <div class="hk-tag" aria-hidden="true">
    <span class="hk-tag__inner">
      <span class="hk-tag__dot"></span>
      <span class="hk-tag__k">STEP</span>
      <span class="hk-tag__v">03 · ENERGIEFLUSS</span>
    </span>
  </div>

  <!-- ── ENERGY-FLOW DIAGRAMM (Wow-Section) ───────────────────────── -->
  <EnergyFlow />

  <!-- ── ÜBER UNS TEASER ───────────────────────────────────────────── -->
  <section class="hk-about hk-section" data-hk-section data-hk-name="Betrieb">
    <div class="hk-container hk-about__grid">
      <div class="hk-about__visual" aria-hidden="true">
        <svg viewBox="0 0 360 480" class="hk-about__circuit">
          <defs>
            <pattern id="hk-grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M24 0H0V24" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.18"/>
            </pattern>
          </defs>
          <rect width="360" height="480" fill="url(#hk-grid)" />

          <!-- Schaltplan-Andeutung -->
          <g fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M40 80 L 130 80 L 130 180 L 220 180 L 220 280 L 320 280" />
            <path d="M40 200 L 90 200 L 90 380 L 240 380" />
            <path d="M260 40 L 260 120 L 320 120" />
          </g>

          <!-- Knoten -->
          <g fill="currentColor">
            <circle cx="40" cy="80" r="4" />
            <circle cx="130" cy="180" r="4" />
            <circle cx="220" cy="280" r="4" />
            <circle cx="320" cy="280" r="4" />
