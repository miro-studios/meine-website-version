  .hk-hero__plate-power-bars span:nth-child(4)  { animation-delay: 0.21s; height: 55%; }
  .hk-hero__plate-power-bars span:nth-child(5)  { animation-delay: 0.28s; height: 70%; }
  .hk-hero__plate-power-bars span:nth-child(6)  { animation-delay: 0.35s; height: 100%; }
  .hk-hero__plate-power-bars span:nth-child(7)  { animation-delay: 0.42s; height: 45%; }
  .hk-hero__plate-power-bars span:nth-child(8)  { animation-delay: 0.49s; height: 85%; }
  .hk-hero__plate-power-bars span:nth-child(9)  { animation-delay: 0.56s; height: 75%; }
  .hk-hero__plate-power-bars span:nth-child(10) { animation-delay: 0.63s; height: 60%; }
  .hk-hero__plate-power-bars span:nth-child(11) { animation-delay: 0.70s; height: 95%; }
  .hk-hero__plate-power-bars span:nth-child(12) { animation-delay: 0.77s; height: 50%; }
  .hk-hero__plate-power-bars span:nth-child(13) { animation-delay: 0.84s; height: 80%; }
  .hk-hero__plate-power-bars span:nth-child(14) { animation-delay: 0.91s; height: 65%; }
  .hk-hero__plate-power-bars span:nth-child(15) { animation-delay: 0.98s; height: 90%; }
  .hk-hero__plate-power-bars span:nth-child(16) { animation-delay: 1.05s; height: 55%; }
  .hk-hero__plate-power-bars span:nth-child(17) { animation-delay: 1.12s; height: 75%; }
  .hk-hero__plate-power-bars span:nth-child(18) { animation-delay: 1.19s; height: 100%; }
  .hk-hero__plate-power-bars span:nth-child(19) { animation-delay: 1.26s; height: 45%; }
  .hk-hero__plate-power-bars span:nth-child(20) { animation-delay: 1.33s; height: 70%; }
  @keyframes hk-power-bar {
    0%, 100% { transform: scaleY(0.6); }
    50% { transform: scaleY(1); }
  }
  .hk-hero__plate-power-v {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: 0.005em;
  }
  .hk-hero__plate-power-v span {
    font-size: 0.5em;
    color: var(--color-muted);
    margin-left: 0.15em;
  }

  .hk-hero__plate-foot {
    padding: 0.7rem 0.9rem;
    border-top: 1px solid var(--color-rule);
    background: var(--color-surface-2);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    text-align: center;
    font-weight: 700;
  }

  /* Double-Row Marquee — gegenläufig */
  .hk-hero__strip-wrap {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--color-bg);
  }
  .hk-hero__strip {
    overflow: hidden;
    padding-block: 0.85rem;
  }
  .hk-hero__strip--y {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .hk-hero__strip--dark {
    background: var(--color-bg);
    color: var(--color-text);
    border-top: 1px solid var(--color-rule);
  }

  .hk-hero__strip-track {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: max-content;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    animation: hk-strip 38s linear infinite;
  }
  .hk-hero__strip-track--reverse {
    animation: hk-strip-reverse 44s linear infinite;
  }
  .hk-hero__strip--dark .hk-hero__strip-track span:not(.hk-hero__strip-dot) {
    color: var(--color-text);
  }
  .hk-hero__strip-dot {
    color: var(--color-accent);
    font-size: 0.55em;
    transform: translateY(-1px);
  }

  @keyframes hk-strip {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes hk-strip-reverse {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  /* ── MANIFEST (Editorial-Treatment) ───────────────────────────── */
  .hk-manifest {
    border-top: 1px solid var(--color-rule);
    position: relative;
  }

  /* Marginalia — rotierte Side-Label nur Desktop */
  .hk-manifest__margin {
    display: none;
  }
  @media (min-width: 1280px) {
    .hk-manifest__margin {
      display: inline-flex;
      align-items: center;
      gap: 0.85rem;
      position: absolute;
      left: clamp(0.5rem, 1.5vw, 1.25rem);
      top: 50%;
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: left center;
      white-space: nowrap;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.28em;
      color: var(--color-muted);
      font-weight: 700;
      text-transform: uppercase;
      pointer-events: none;
    }
    .hk-manifest__margin-line {
      width: 32px;
      height: 1px;
      background: var(--color-accent);
    }
  }

  .hk-manifest__h {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    max-width: 28ch;
  }

  /* Pull-Quote */
  .hk-manifest__quote {
    position: relative;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.5rem, 3vw, 2.5rem);
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--color-accent) 6%, transparent),
      transparent);
    border-left: 2px solid var(--color-accent);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hk-manifest__quote-mark {
    position: absolute;
    top: -0.4rem;
    left: 0.6rem;
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 6.5rem);
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.6;
    pointer-events: none;
  }

  .hk-manifest__quote p {
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: 0.005em;
    color: var(--color-text);
    text-transform: uppercase;
    font-weight: 400;
  }

  .hk-manifest__quote footer {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    border-top: 1px solid var(--color-rule);
    padding-top: 0.85rem;
  }
  .hk-manifest__quote-cite {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
  }
  .hk-manifest__quote-role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }

  /* Drei Spalten */
  .hk-manifest__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .hk-manifest__cols { grid-template-columns: repeat(3, 1fr); gap: clamp(2rem, 4vw, 3rem); }
  }

  .hk-manifest__col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--color-accent);
    position: relative;
  }

  .hk-manifest__col-n {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
  }

  .hk-manifest__col-text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    margin: 0;
  }
  .hk-manifest__col-text em {
    color: var(--color-text);
    font-style: normal;
    background-image: linear-gradient(transparent 55%, color-mix(in srgb, var(--color-accent) 30%, transparent) 55%, color-mix(in srgb, var(--color-accent) 30%, transparent) 90%, transparent 90%);
    padding: 0 0.05em;
  }

  /* Drop-Cap auf der ersten Spalte */
  .hk-dropcap::first-letter {
    font-family: var(--font-display);
    font-size: 3.4em;
    line-height: 0.8;
    float: left;
    margin: 0.06em 0.18em 0 -0.04em;
    color: var(--color-accent);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  /* ── MEGA NUMBERS ─────────────────────────────────────────────── */
  .hk-numbers {
    border-top: 1px solid var(--color-rule);
    padding-block: clamp(4rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
  }
  .hk-numbers::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to bottom, var(--hk-grid-line) 1px, transparent 1px);
    background-size: 100% 80px;
    pointer-events: none;
    opacity: 0.5;
    mask-image: linear-gradient(to bottom, black, transparent 70%);
    -webkit-mask-image: linear-gradient(to bottom, black, transparent 70%);
  }

  .hk-numbers__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule-strong);
  }

  .hk-numbers__row {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1.4fr) minmax(0, 1fr);
    grid-template-areas:
      "idx num lbl"
      "idx num sub";
    column-gap: clamp(1rem, 2vw, 2.5rem);
    row-gap: 0.4rem;
    padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
    position: relative;
    transition: padding-left 0.6s var(--ease-out-expo);
  }
  .hk-numbers__row:hover { padding-left: clamp(0.5rem, 1.5vw, 1.25rem); }

  /* Yellow rail that slides in on hover */
  .hk-numbers__row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .hk-numbers__row:hover::before { transform: scaleY(1); }

  @media (max-width: 720px) {
    .hk-numbers__row {
      grid-template-columns: 2.5rem 1fr;
      grid-template-areas:
        "idx num"
        "idx lbl"
        ".   sub";
    }
  }

  .hk-numbers__idx {
    grid-area: idx;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    font-weight: 700;
    align-self: flex-start;
    padding-top: 0.4rem;
  }

  .hk-numbers__n {
    grid-area: num;
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.005em;
    font-weight: 400;
    color: var(--color-text);
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    text-transform: uppercase;
  }
  .hk-numbers__row:nth-child(2n) .hk-numbers__n { color: var(--color-accent); }

  .hk-numbers__unit {
    font-size: 0.32em;
    color: var(--color-muted);
    letter-spacing: 0.12em;
    margin-left: 0.05em;
    font-weight: 400;
  }

  .hk-numbers__lbl {
    grid-area: lbl;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
    line-height: 1.1;
    align-self: flex-end;
    padding-bottom: 0.3rem;
  }

  .hk-numbers__sub {
    grid-area: sub;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 38ch;
    letter-spacing: 0.02em;
  }

  /* ── ABOUT TEASER ──────────────────────────────────────────────── */
  .hk-about {
    border-top: 1px solid var(--color-rule);
    background: var(--color-surface);
  }

  .hk-about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hk-about__grid { grid-template-columns: 0.9fr 1.1fr; }
  }

  .hk-about__visual {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-rule-strong);
    aspect-ratio: 360 / 480;
    overflow: hidden;
  }

  .hk-about__circuit {
    width: 100%;
    height: 100%;
    color: var(--color-text);
  }

  .hk-about__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 1rem 0 1.5rem;
  }
  .hk-about__h-alt { color: var(--color-accent); }

  .hk-about__text {
    font-size: 1.05rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    max-width: 56ch;
    margin: 0 0 1.5rem;
  }

  .hk-about__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding-block: 1.25rem;
  }

  .hk-about__list li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .hk-about__list strong {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-accent);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .hk-about__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-text);
    transition: background-color 0.3s, color 0.3s, gap 0.3s var(--ease-out-expo);
  }
  .hk-about__link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    gap: 0.9rem;
    border-color: var(--color-accent);
  }
  .hk-about__link svg { width: 14px; height: 14px; }

  /* ── SERVICES TEASER ───────────────────────────────────────────── */
  .hk-svc {
    border-top: 1px solid var(--color-rule);
  }

  .hk-svc__h {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }
  .hk-svc__h-alt { color: var(--color-accent); }

  .hk-svc__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-rule-strong);
  }
  @media (min-width: 720px) {
    .hk-svc__grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Asymmetric: featured spans 2 columns, others span 1 (effective 4-col base) */
  @media (min-width: 1100px) {
    .hk-svc__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-flow: dense;
    }
    .hk-svc__cell--feature {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .hk-svc__cell {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    border-right: 1px solid var(--color-rule-strong);
    border-bottom: 1px solid var(--color-rule-strong);
    position: relative;
    transition: background-color 0.4s var(--ease-out-expo),
                color 0.4s var(--ease-out-expo),
                transform 0.35s var(--ease-out-expo);
    overflow: hidden;
    isolation: isolate;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Spotlight-Glow der dem Cursor folgt (eingeblendet bei :hover) */
  .hk-svc__cell::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 220px at var(--hk-svc-x, 50%) var(--hk-svc-y, 50%),
      color-mix(in srgb, var(--color-accent) 18%, transparent),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
  }
  .hk-svc__cell:hover::before { opacity: 0; }
  .hk-svc__cell.is-hot::before { opacity: 1; }

  /* Diagonal accent line that grows on hover */
  .hk-svc__cell::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-top: 14px solid var(--color-accent);
    border-left: 14px solid transparent;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
    z-index: 2;
  }
  .hk-svc__cell:hover::after { opacity: 1; }

  .hk-svc__cell--feature {
    background: var(--color-surface);
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
  }

  .hk-svc__cell:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .hk-svc__cell:last-child { border-right: none; }
  @media (min-width: 720px) and (max-width: 1099px) {
    .hk-svc__cell:nth-child(2n) { border-right: none; }
    .hk-svc__cell:nth-last-child(-n+2):nth-child(2n+1) { border-bottom: none; }
    .hk-svc__cell:last-child { border-bottom: none; }
  }
  @media (min-width: 1100px) {
    /* 4-col grid mit feature(2x2) + 5 single-cells:
       Row 1: [feature][feature][2][3]
       Row 2: [feature][feature][4][5]
       Row 3: [6][6 spanning rest of row?] — we have 6 cells total.
       Actually: feature(span 2x2), cells 2-5 fill the top-right 2x2 area,
       cell 6 spans the entire next row.
    */
    .hk-svc__cell:nth-child(2),
    .hk-svc__cell:nth-child(3),
    .hk-svc__cell:nth-child(4),
    .hk-svc__cell:nth-child(5) {
      grid-column: span 1;
    }
    .hk-svc__cell:nth-child(6) {
      grid-column: span 4;
    }
    /* Borders: feature bottom + right are inside, no need to strip.
       The cells in column 4 (i.e. nth(3) and nth(5)) lose right border. */
    .hk-svc__cell:nth-child(3),
    .hk-svc__cell:nth-child(5) { border-right: none; }
    /* Row-2 cells lose bottom border (above row 3) */
    .hk-svc__cell--feature,
    .hk-svc__cell:nth-child(4),
    .hk-svc__cell:nth-child(5) { border-bottom: 1px solid var(--color-rule-strong); }
    .hk-svc__cell:nth-child(6) { border-right: none; border-bottom: none; }
  }

  .hk-svc__cell-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
  }

  .hk-svc__cell-n {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    transition: color 0.4s var(--ease-out-expo);
  }
  .hk-svc__cell:hover .hk-svc__cell-n { color: var(--color-bg); }

  .hk-svc__cell-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 0.3rem 0.55rem;
    letter-spacing: 0.16em;
    font-weight: 700;
  }
  .hk-svc__cell:hover .hk-svc__cell-tag {
    background: var(--color-bg);
    color: var(--color-accent);
  }

  /* Feature-Cell Visual */
  .hk-svc__cell-visual {
    margin-block: 0.5rem 0.4rem;
    color: var(--color-text);
    border: 1px solid var(--color-rule);
    padding: 0.6rem;
    background: var(--color-bg);
    transition: background 0.4s var(--ease-out-expo), border-color 0.4s var(--ease-out-expo);
  }
  .hk-svc__cell-visual svg { width: 100%; height: auto; display: block; }
  .hk-svc__cell:hover .hk-svc__cell-visual {
    background: var(--color-bg);
    border-color: var(--color-bg);
  }

  /* Mini-Variante für die kleinen Cells */
  .hk-svc__cell-visual--mini {
    max-width: 110px;
    align-self: flex-start;
    padding: 0.45rem;
    margin-block: 0.2rem 0.2rem;
  }
  .hk-svc__cell-visual--mini svg { aspect-ratio: 96 / 64; }

  .hk-svc__cell-t {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    margin: 0.3rem 0 0;
    font-weight: 400;
  }
  .hk-svc__cell--feature .hk-svc__cell-t {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    margin-top: 0.5rem;
  }

  .hk-svc__cell-sub {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin: 0;
    transition: color 0.4s var(--ease-out-expo);
  }
