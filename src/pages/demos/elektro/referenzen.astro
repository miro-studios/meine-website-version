---
import ElektroLayout from '@layouts/ElektroLayout.astro';
import SplitText from '@components/shared/SplitText.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';
import MagneticButton from '@components/shared/MagneticButton.astro';
import BeforeAfter from '@components/elektro/BeforeAfter.astro';

interface Case {
  id: string;
  year: string;
  cat: 'PV + WP' | 'INDUSTRIE' | 'SMART HOME' | 'SANIERUNG' | 'NOTDIENST';
  title: string;
  location: string;
  problem: string;
  solution: string;
  result: string;
  stats: { k: string; v: string; sub: string }[];
  featured?: boolean;
}

const cases: Case[] = [
  {
    id: '0214',
    year: '2024',
    cat: 'PV + WP',
    title: 'EFH HAGEN — VOLL-ELEKTRIFIZIERUNG MIT 12,4-KWP-PV',
    location: 'Einfamilienhaus · Hagen-Hohenlimburg',
    problem: 'Familie M. zahlte 2023 rund 3.800 € für Gas und Strom — der Vertrag lief aus, der alte Gaskessel war 22 Jahre alt. Wir wurden für eine Beratung angefragt.',
    solution: 'Komplettpaket: Demontage Gaskessel, neue Luft-Wasser-Wärmepumpe (Stiebel Eltron HPA-O 9 kW), 12,4-kWp-PV-Anlage auf Süd-Dach mit 10-kWh-Speicher, 11-kW-Wallbox vorbereitet für E-Mobilität.',
    result: 'Jahreskosten 2025 für Strom + Wärme: 960 €. Eigenverbrauchs­quote liegt bei 74 %. BAFA + KfW-Förderung in Summe 17.500 €.',
    stats: [
      { k: 'EINSPARUNG', v: '2.840 €', sub: 'pro Jahr' },
      { k: 'AUTARKIE', v: '74 %', sub: 'Eigenverbrauch' },
      { k: 'FÖRDERUNG', v: '17.500 €', sub: 'BAFA + KfW' },
      { k: 'AMORTISATION', v: '8,2 J', sub: 'kalkuliert' },
    ],
    featured: true,
  },
  {
    id: '0207',
    year: '2024',
    cat: 'INDUSTRIE',
    title: 'SÄNGER METALL — ELEKTRO-INSTALLATION PRODUKTIONSHALLE',
    location: 'Produktionserweiterung · Plettenberg',
    problem: 'Erweiterung einer Metallverarbeitungs-Halle um 1.200 m² Produktionsfläche mit drei CNC-Zentren. Bestehende Verteilung war für die neuen Lasten unterdimensioniert.',
    solution: 'Komplette neue Unterverteilung 800 A, Kabeltrassen über Decke, dreiphasige CEE-Anschlüsse für CNC, Hallenbeleuchtung in LED mit DALI-Steuerung, Brandmelde-Erweiterung VdS-konform.',
    result: 'Inbetriebnahme termingerecht, Strom­last­messung 6 Monate später bestätigt sauberen Betrieb. Sänger Metall ist seitdem auf Wartungsvertrag mit uns.',
    stats: [
      { k: 'FLÄCHE', v: '1.200 m²', sub: 'erweitert' },
      { k: 'LAST', v: '800 A', sub: 'neue Verteilung' },
      { k: 'BAUZEIT', v: '11 W', sub: 'inkl. Inbetrieb' },
    ],
  },
  {
    id: '0198',
    year: '2023',
    cat: 'SMART HOME',
    title: 'VILLA SAUERLAND — KNX-SMART-HOME 480 M²',
    location: 'Neubau-Villa · Iserlohn',
    problem: 'Neubau einer 480-m²-Villa mit Vollausstattung Smart Home — Heizung, Licht, Beschattung, Sicherheit, Multiroom — vom Bauherrn ausdrücklich keine Cloud-Abhängigkeit gewünscht.',
    solution: 'Komplette KNX-Anlage mit 320 Aktoren, lokale Visualisierung über Gira-X1, redundante Stromversorgung, Sicherheitssensorik mit Anbindung an Wachdienst. Programmierung in 4 Wochen ETS5.',
    result: 'Bauherr nutzt die Anlage seit zwei Jahren komplett autark, ohne Cloud-Service. Wartungsvertrag inkl. Soft-Updates läuft jährlich.',
    stats: [
      { k: 'AKTOREN', v: '320', sub: 'KNX' },
      { k: 'FLÄCHE', v: '480 m²', sub: 'Vollausbau' },
      { k: 'CLOUD', v: '0', sub: 'lokale Logik' },
    ],
  },
  {
    id: '0184',
    year: '2023',
    cat: 'SANIERUNG',
    title: 'ALTBAU LÜDENSCHEID — KOMPLETT-SANIERUNG ELEKTRO',
    location: 'Wohnhaus Bj. 1908 · Lüdenscheid',
    problem: 'Komplette Neu-Elektrifizierung eines bewohnten Wohnhauses aus 1908, alte Leitungen mit Aluminium und ohne Schutzleiter. Bewohner sollten während der Sanierung im Haus bleiben.',
    solution: 'Etagenweise Vorgehensweise über 6 Wochen, neuer Hausanschluss, Smart-Meter-Vorbereitung, Cat6-Verkabelung in allen Räumen, neue Sicherungs­verteilung mit FI-Schutzschaltern.',
    result: 'Nullschaden während der Bauzeit, keine vermeidbaren Bohrungen in Erhaltenswertes. Heute lebt eine fünfköpfige Familie ohne Sicherheitsdefizite im Haus.',
    stats: [
      { k: 'BAUJAHR', v: '1908', sub: 'Bestand' },
      { k: 'STECKDOSEN', v: '148', sub: 'erneuert' },
      { k: 'BAUZEIT', v: '6 W', sub: 'bewohnt' },
    ],
  },
  {
    id: '0176',
    year: '2023',
    cat: 'PV + WP',
    title: 'HOFGUT WALDHAUS — ENERGIE-AUTARKIE 92%',
    location: 'Landwirtschaft + Wohnhaus · Halver',
    problem: 'Großes Hofgut mit Wohnhaus, Stall, Werkstatt — bisher Heizöl + Netzstrom. Eigentümer wollte maximal mögliche Energie-Autarkie ohne Komfort­verlust.',
    solution: '24-kWp-PV-Anlage auf Scheunendach (Süd + Ost), 30-kWh-Speicher, Erd-Sole-Wärmepumpe 16 kW mit Tiefenbohrung, 22-kW-Wallbox für Trecker und Hybrid-PKW.',
    result: '92 % Eigenverbrauchsquote über das Jahr, im Sommer komplette Autarkie, Heizöl-Tank wurde demontiert. Investition 89.500 €, Förderung 32.000 €.',
    stats: [
      { k: 'PV', v: '24 kWp', sub: 'Süd + Ost' },
      { k: 'SPEICHER', v: '30 kWh', sub: 'BYD' },
      { k: 'AUTARKIE', v: '92 %', sub: 'p.a.' },
    ],
  },
  {
    id: '0161',
    year: '2022',
    cat: 'NOTDIENST',
    title: 'KÄLTEAUSFALL — REHA-KLINIK WERDOHL',
    location: '24h-Notdienst · Werdohl',
    problem: 'Sonntag Nachmittag, Klinik mit 80 Betten, Kälte-Maschine für Server-Raum ausgefallen, Temperaturen kletterten auf 38 °C. Standby-Notdienst von zwei Lieferanten antwortete nicht.',
    solution: 'Karla Holtkamp in 65 Minuten vor Ort, Schaltschrank-Diagnose, defekter Magnetschütz lokalisiert, Ersatzteil aus Werkstatt geholt, in 3 Stunden wieder im Betrieb.',
    result: 'Server­raum erreichte nie 42 °C-Notabschaltung, keine Daten­auswirkung. Klinik hat seitdem Service-Level-Vertrag mit uns.',
    stats: [
      { k: 'ANFAHRT', v: '65 MIN', sub: 'Sonntag' },
      { k: 'REPARATUR', v: '3 H', sub: 'inkl. Anfahrt' },
      { k: 'AUSFALL', v: '0 H', sub: 'IT-Systeme' },
    ],
  },
];

const featured = cases.find(c => c.featured)!;
const others = cases.filter(c => !c.featured);
---

<ElektroLayout
  title="Holtkamp Elektrotechnik — Referenzen · Ausgewählte Projekte"
  description="Sechs ausgewählte Projekte aus 37 Jahren Holtkamp: Photovoltaik, Wärmepumpe, Industrie-Installation, KNX-Smart-Home, Altbau-Sanierung und 24h-Notdienst — mit echten Zahlen."
>
  <!-- ── Page Hero ────────────────────────────────────────────────── -->
  <section class="hk-pg-hero" data-hk-section data-hk-name="Übersicht">
    <div class="hk-pg-hero__spec" aria-hidden="true">
      <span class="hk-pg-hero__spec-k">PAGE</span>
      <span class="hk-pg-hero__spec-v">03 / REFERENZEN</span>
      <span class="hk-pg-hero__spec-dot"></span>
      <span class="hk-pg-hero__spec-k">SEL</span>
      <span class="hk-pg-hero__spec-v">06 / 2.400+</span>
      <span class="hk-pg-hero__spec-line"></span>
      <span class="hk-pg-hero__spec-k">CAT</span>
      <span class="hk-pg-hero__spec-v">PV+WP · IND · KNX · SAN · NOT</span>
      <span class="hk-pg-hero__spec-pulse"></span>
      <span class="hk-pg-hero__spec-v">DRAG · KLICK · VERGLEICH</span>
    </div>

    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 03</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">PAGE / REFERENZEN</span>
      </div>

      <h1 class="hk-pg-hero__h">
        <span class="hk-pg-hero__line"><SplitText by="words" stagger={0.05}>WAS WIR</SplitText></span>
        <span class="hk-pg-hero__line hk-pg-hero__line--alt"><SplitText by="words" stagger={0.05} delay={0.2}>SCHON GEMACHT HABEN.</SplitText></span>
      </h1>

      <p class="hk-pg-hero__lead">
        Sechs ausgewählte Projekte aus den letzten Jahren — vom Einfamilien­haus
        mit Voll-Elektrifizierung bis zum Sonntag-Nacht-Notdienst in einer
        Reha-Klinik. Alle Zahlen sind echt, alle Kunden­zitate freigegeben.
      </p>

      <ul class="hk-pg-hero__stats">
        <li><strong><NumberCounter to={2400} duration={2.2} />+</strong> Projekte gesamt</li>
        <li><strong><NumberCounter to={184} duration={1.8} /></strong> Bewertungen</li>
        <li><strong>4,9</strong> / 5 Sterne ⌀</li>
      </ul>
    </div>
  </section>

  <!-- ── Featured Case ────────────────────────────────────────────── -->
  <section class="hk-feat hk-section" data-hk-section data-hk-name="Featured">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">FEATURED</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">REF · {featured.id} · {featured.year}</span>
      </div>

      <RevealOnScroll y={40}>
        <article class="hk-feat__art">
          <BeforeAfter
            beforeLabel="VORHER · GAS 2023"
            afterLabel="NACHHER · WP+PV 2024"
            caption="Drag · Klick & ziehen, um die Zustände zu vergleichen"
            initial={50}
          >
            <!-- BEFORE: Haus mit Gas-Kessel-Anschluss, kein PV -->
            <svg slot="before" viewBox="0 0 560 360" preserveAspectRatio="xMidYMid slice">
              <defs>
                <pattern id="hk-ba-grid-b" width="28" height="28" patternUnits="userSpaceOnUse">
                  <path d="M28 0H0V28" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                </pattern>
              </defs>
              <rect width="560" height="360" fill="var(--color-bg)" />
              <rect width="560" height="360" fill="url(#hk-ba-grid-b)" />
              <line x1="20" y1="280" x2="540" y2="280" stroke="currentColor" stroke-width="1.4" />
              <g stroke="currentColor" stroke-width="0.5" opacity="0.4">
                {Array.from({length: 17}).map((_, i) => (
                  <line x1={40 + i*30} y1="280" x2={30 + i*30} y2="298" />
                ))}
              </g>
              <!-- Haus (graues Dach, keine Module) -->
              <path d="M 130 280 L 130 160 L 250 90 L 370 160 L 370 280 Z" fill="color-mix(in srgb, var(--color-text) 4%, transparent)" stroke="currentColor" stroke-width="1.6" />
              <!-- Dachziegel-Andeutung -->
              <g stroke="currentColor" stroke-width="0.5" opacity="0.35">
                <line x1="140" y1="172" x2="245" y2="105" />
                <line x1="155" y1="188" x2="255" y2="120" />
                <line x1="170" y1="204" x2="265" y2="135" />
                <line x1="245" y1="105" x2="355" y2="172" />
                <line x1="255" y1="120" x2="345" y2="188" />
                <line x1="265" y1="135" x2="335" y2="204" />
              </g>
              <rect x="160" y="210" width="40" height="44" fill="color-mix(in srgb, var(--color-text) 8%, transparent)" stroke="currentColor" stroke-width="1" />
              <rect x="230" y="200" width="40" height="80" fill="none" stroke="currentColor" stroke-width="1" />
              <rect x="300" y="210" width="40" height="44" fill="color-mix(in srgb, var(--color-text) 8%, transparent)" stroke="currentColor" stroke-width="1" />
              <!-- Schornstein mit Rauch (Gasheizung) -->
              <rect x="295" y="115" width="14" height="38" fill="color-mix(in srgb, var(--color-text) 20%, transparent)" stroke="currentColor" stroke-width="1" />
              <g stroke="currentColor" stroke-width="1" fill="none" opacity="0.45">
                <path d="M302 110 q-4 -8 0 -14 q4 -6 0 -12" />
                <path d="M308 108 q-4 -10 0 -16 q4 -6 0 -14" />
              </g>
              <!-- Gas-Symbol unten rechts -->
              <rect x="395" y="232" width="60" height="48" fill="color-mix(in srgb, var(--color-text) 8%, transparent)" stroke="currentColor" stroke-width="1.2" />
              <text x="425" y="262" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="currentColor" text-anchor="middle">GAS</text>
              <text x="395" y="308" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="currentColor" opacity="0.6" letter-spacing="1">22-J-KESSEL · BJ 2002</text>
              <!-- Stromkosten-Text -->
              <text x="20" y="50" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="currentColor" opacity="0.7" letter-spacing="1.5">JAHRESKOSTEN</text>
              <text x="20" y="80" font-family="Anton, sans-serif" font-size="38" font-weight="400" fill="currentColor" letter-spacing="0.5">3.800 €</text>
              <text x="20" y="100" font-family="JetBrains Mono, monospace" font-size="9" font-weight="500" fill="currentColor" opacity="0.5" letter-spacing="1.5">STROM + GAS</text>
            </svg>

            <!-- AFTER: PV-Module auf Dach + Wärmepumpe + bessere Auslastung -->
            <svg slot="after" viewBox="0 0 560 360" preserveAspectRatio="xMidYMid slice">
              <defs>
                <pattern id="hk-ba-grid-a" width="28" height="28" patternUnits="userSpaceOnUse">
                  <path d="M28 0H0V28" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                </pattern>
              </defs>
              <rect width="560" height="360" fill="var(--color-bg)" />
              <rect width="560" height="360" fill="url(#hk-ba-grid-a)" />
              <line x1="20" y1="280" x2="540" y2="280" stroke="currentColor" stroke-width="1.4" />
              <g stroke="currentColor" stroke-width="0.5" opacity="0.4">
                {Array.from({length: 17}).map((_, i) => (
                  <line x1={40 + i*30} y1="280" x2={30 + i*30} y2="298" />
                ))}
              </g>
              <path d="M 130 280 L 130 160 L 250 90 L 370 160 L 370 280 Z" fill="color-mix(in srgb, var(--color-accent) 6%, transparent)" stroke="currentColor" stroke-width="1.6" />
              <!-- PV-Module -->
              <g fill="var(--color-accent)" opacity="0.9">
                <polygon points="148,170 200,135 212,142 160,177" />
                <polygon points="170,185 222,150 234,157 182,192" />
                <polygon points="192,200 244,165 256,172 204,207" />
                <polygon points="262,135 314,170 302,177 250,142" />
                <polygon points="284,150 336,185 324,192 272,157" />
                <polygon points="306,165 358,200 346,207 294,172" />
              </g>
              <!-- Module-Rasterlinien für Detail -->
              <g stroke="var(--color-bg)" stroke-width="0.5" opacity="0.5">
                <line x1="170" y1="155" x2="172" y2="158" />
              </g>
              <rect x="160" y="210" width="40" height="44" fill="color-mix(in srgb, var(--color-text) 12%, transparent)" stroke="currentColor" stroke-width="1" />
              <rect x="230" y="200" width="40" height="80" fill="none" stroke="currentColor" stroke-width="1" />
              <rect x="300" y="210" width="40" height="44" fill="color-mix(in srgb, var(--color-text) 12%, transparent)" stroke="currentColor" stroke-width="1" />
              <!-- Wärmepumpe rechts -->
              <rect x="395" y="232" width="60" height="48" fill="none" stroke="currentColor" stroke-width="1.4" />
              <circle cx="425" cy="256" r="13" fill="none" stroke="currentColor" stroke-width="1" />
              <path d="M419 256 L425 250 L431 256 L425 262 Z" fill="currentColor" />
              <text x="395" y="308" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="var(--color-accent)" letter-spacing="1">WP · 9 KW · COP 4,3</text>
              <!-- Verbindung Haus → WP -->
              <path d="M 370 250 L 395 250" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="3 3">
                <animate attributeName="stroke-dashoffset" values="0;-12" dur="1.2s" repeatCount="indefinite" />
              </path>
              <!-- Sonne mit Pfeil -->
              <g stroke="var(--color-accent)" fill="none" stroke-width="1.6">
                <circle cx="495" cy="55" r="14" />
                <line x1="495" y1="55" x2="495" y2="35" />
                <line x1="495" y1="55" x2="495" y2="75" />
                <line x1="495" y1="55" x2="475" y2="55" />
                <line x1="495" y1="55" x2="515" y2="55" />
                <line x1="481" y1="41" x2="471" y2="31" />
                <line x1="509" y1="41" x2="519" y2="31" />
                <line x1="481" y1="69" x2="471" y2="79" />
                <line x1="509" y1="69" x2="519" y2="79" />
              </g>
              <!-- Stromkosten neu -->
              <text x="20" y="50" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="var(--color-accent)" letter-spacing="1.5">JAHRESKOSTEN</text>
              <text x="20" y="80" font-family="Anton, sans-serif" font-size="38" font-weight="400" fill="var(--color-accent)" letter-spacing="0.5">960 €</text>
              <text x="20" y="100" font-family="JetBrains Mono, monospace" font-size="9" font-weight="500" fill="var(--color-accent)" opacity="0.7" letter-spacing="1.5">STROM-EIGENVERBRAUCH 74%</text>
              <!-- Einsparung-Tag -->
              <g transform="translate(20 130)">
                <rect x="0" y="0" width="180" height="32" fill="var(--color-accent)" />
                <text x="10" y="22" font-family="JetBrains Mono, monospace" font-size="13" font-weight="700" fill="var(--color-bg)" letter-spacing="1">– 2.840 € / JAHR</text>
              </g>
            </svg>
          </BeforeAfter>

          <div class="hk-feat__copy">
            <span class="hk-feat__cat">{featured.cat}</span>
            <h2 class="hk-feat__h">{featured.title}</h2>
            <p class="hk-feat__loc">{featured.location}</p>

            <dl class="hk-feat__story">
              <dt>AUSGANGSLAGE</dt>
              <dd>{featured.problem}</dd>
              <dt>UNSERE LÖSUNG</dt>
              <dd>{featured.solution}</dd>
              <dt>ERGEBNIS</dt>
              <dd>{featured.result}</dd>
            </dl>

            <ul class="hk-feat__stats">
              {featured.stats.map(s => (
                <li>
                  <span class="hk-feat__stats-k">{s.k}</span>
                  <span class="hk-feat__stats-v">{s.v}</span>
                  <span class="hk-feat__stats-s">{s.sub}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      </RevealOnScroll>
    </div>
  </section>

  <!-- ── Weitere Cases ────────────────────────────────────────────── -->
  <section class="hk-other hk-section" data-hk-section data-hk-name="Weitere">
    <div class="hk-container">
      <div class="hk-bar">
        <span class="hk-bar-n">N° 04</span>
        <span class="hk-bar-line" aria-hidden="true"></span>
        <span class="hk-bar-k">WEITERE PROJEKTE / 5</span>
      </div>

      <h2 class="hk-other__h">
        FÜNF<br />
        <span class="hk-other__h-alt">WEITERE PROJEKTE.</span>
      </h2>

      <ul class="hk-other__grid">
        {others.map(c => (
          <li class="hk-other__cell">
            <!-- Mini-Visual oben -->
            <div class="hk-other__visual" aria-hidden="true">
              {c.cat === 'INDUSTRIE' && (
                <svg viewBox="0 0 320 130" preserveAspectRatio="xMidYMid meet">
                  <defs>
                    <pattern id={`oi-grid-${c.id}`} width="16" height="16" patternUnits="userSpaceOnUse">
                      <path d="M16 0H0V16" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                    </pattern>
                  </defs>
                  <rect width="320" height="130" fill={`url(#oi-grid-${c.id})`}/>
                  <!-- Halle -->
                  <path d="M 20 110 L 20 50 L 90 30 L 90 110 Z M 90 30 L 160 50 L 160 110 L 90 110 M 160 50 L 230 30 L 230 110 L 160 110 M 230 30 L 300 50 L 300 110 L 230 110" fill="color-mix(in srgb, var(--color-text) 5%, transparent)" stroke="currentColor" stroke-width="1.2"/>
                  <line x1="20" y1="110" x2="300" y2="110" stroke="currentColor" stroke-width="1.4"/>
                  <!-- Maschinen -->
                  <g stroke="currentColor" stroke-width="1" fill="var(--color-bg)">
                    <rect x="35" y="78" width="22" height="32"/>
                    <rect x="105" y="78" width="22" height="32"/>
                    <rect x="175" y="78" width="22" height="32"/>
                  </g>
                  <!-- CNC-Indikatoren -->
                  <circle cx="46" cy="86" r="2" fill="var(--color-accent)"/>
                  <circle cx="116" cy="86" r="2" fill="var(--color-accent)"/>
                  <circle cx="186" cy="86" r="2" fill="var(--color-accent)">
                    <animate attributeName="opacity" values="1;0.3;1" dur="1.8s" repeatCount="indefinite"/>
                  </circle>
                  <!-- Hochspannungs-Trasse -->
                  <line x1="20" y1="20" x2="300" y2="20" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="3 6">
                    <animate attributeName="stroke-dashoffset" values="0;-18" dur="1.4s" repeatCount="indefinite"/>
                  </line>
                  <text x="260" y="44" font-family="JetBrains Mono, monospace" font-size="7" fill="var(--color-accent)" letter-spacing="1" font-weight="700">800 A</text>
                </svg>
              )}
              {c.cat === 'SMART HOME' && (
                <svg viewBox="0 0 320 130" preserveAspectRatio="xMidYMid meet">
                  <defs>
                    <pattern id={`os-grid-${c.id}`} width="16" height="16" patternUnits="userSpaceOnUse">
                      <path d="M16 0H0V16" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18"/>
                    </pattern>
                  </defs>
                  <rect width="320" height="130" fill={`url(#os-grid-${c.id})`}/>
                  <!-- Hub Mitte -->
                  <rect x="140" y="50" width="40" height="30" fill="var(--color-bg)" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="160" cy="65" r="3" fill="var(--color-accent)">
                    <animate attributeName="opacity" values="0.4;1;0.4" dur="1.8s" repeatCount="indefinite"/>
                  </circle>
