---
import ArchitektLayout from '@layouts/ArchitektLayout.astro';
import RevealOnScroll from '@components/shared/RevealOnScroll.astro';
import SplitText from '@components/shared/SplitText.astro';
import NumberCounter from '@components/shared/NumberCounter.astro';

const team = [
  { name: 'Mareike Vossen', role: 'Gründerin · Dipl.-Ing. Arch.', since: '1998' },
  { name: 'Tilo Brand', role: 'Partner · Bauleitung', since: '2007' },
  { name: 'Jana Holtermann', role: 'Projektarchitektin', since: '2014' },
  { name: 'Lukas Vossen', role: 'Innenarchitektur', since: '2018' },
  { name: 'Pia Reinkemeier', role: 'Visualisierung / BIM', since: '2021' },
  { name: 'Daniel Köhne', role: 'Bauzeichnung', since: '2022' },
  { name: 'Sara Adigüzel', role: 'Büroleitung', since: '2019' },
];

const values = [
  { n: '01', title: 'MASS STATT STIL', text: 'Wir folgen keinem Look. Jedes Projekt bekommt die Form, die zu Ort, Programm und Budget passt — auch wenn das uns selber überrascht.' },
  { n: '02', title: 'MATERIAL DAS ALTERT', text: 'Wir bevorzugen Materialien, die mit der Zeit besser aussehen: Holz, Putz, Sichtbeton, gewachstes Metall. Keine Folie, die nach zwei Jahren reißt.' },
  { n: '03', title: 'EINE STIMME PRO PROJEKT', text: 'Bei uns hat jedes Projekt eine feste Architektin und einen festen Bauleiter — von Tag eins bis zur Übergabe. Keine Stafetten.' },
];
---

<ArchitektLayout
  title="Atelier Vossen — Büro & Team"
  description="Sieben Personen, ein Atelier in Lüdenscheid. Wie wir denken, wer wir sind und warum wir lieber langsam planen als schnell bauen."
>
  <!-- Page Hero -->
  <section class="av-pg-hero av-section">
    <div class="av-container">
      <div class="av-bar">
        <span class="av-bar-n">N° 01</span>
        <span class="av-bar-line" aria-hidden="true"></span>
        <span class="av-bar-k">PAGE / BUERO.MD</span>
      </div>
      <h1 class="av-pg-hero__h">
        <span class="av-pg-hero__line"><SplitText by="words" stagger={0.05}>SIEBEN PERSONEN.</SplitText></span>
        <span class="av-pg-hero__line av-pg-hero__line--alt"><SplitText by="words" stagger={0.05} delay={0.2}>EINE WERKSTATT.</SplitText></span>
      </h1>
      <div class="av-pg-hero__intro">
        <p class="av-pg-hero__lead">
          Wir sitzen in einer ehemaligen Schmiede am Knapper Bach in Lüdenscheid.
          Hohe Decken, viel Licht, ein langer Holztisch in der Mitte — alle
          Entwürfe entstehen hier gemeinsam und werden hier gemeinsam zerlegt.
        </p>
        <p class="av-pg-hero__lead">
          Was uns verbindet, ist nicht ein Stil, sondern eine Arbeitsweise:
          langsam denken, schnell zeichnen, dann wieder langsam denken.
        </p>
      </div>
    </div>
  </section>

  <!-- Werte -->
  <section class="av-values av-section">
    <div class="av-container">
      <div class="av-bar">
        <span class="av-bar-n">N° 02</span>
        <span class="av-bar-line" aria-hidden="true"></span>
        <span class="av-bar-k">PRINZIPIEN / 3 SAETZE</span>
      </div>
      <RevealOnScroll>
        <h2 class="av-values__h">DREI SÄTZE, DIE WIR BEI JEDEM ENTWURF EINHALTEN.</h2>
      </RevealOnScroll>

      <ol class="av-values__list">
        {values.map(v => (
          <li class="av-values__item">
            <span class="av-values__n">[{v.n}]</span>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Stats -->
  <section class="av-stats">
    <div class="av-container">
      <div class="av-stats__grid">
        <div class="av-stats__cell">
          <span class="av-stats__num"><NumberCounter to={27} duration={2.2} /></span>
          <span class="av-stats__label">JAHRE ATELIER</span>
        </div>
        <div class="av-stats__cell">
          <span class="av-stats__num"><NumberCounter to={184} duration={2.4} /></span>
          <span class="av-stats__label">PROJEKTE</span>
        </div>
        <div class="av-stats__cell">
          <span class="av-stats__num"><NumberCounter to={7} duration={1.6} /></span>
          <span class="av-stats__label">TEAM</span>
        </div>
        <div class="av-stats__cell">
          <span class="av-stats__num">
            <NumberCounter to={94} duration={2.2} />
            <span class="av-stats__unit">%</span>
          </span>
          <span class="av-stats__label">EMPFEHLUNGSQUOTE</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="av-team av-section">
    <div class="av-container">
      <div class="av-bar">
        <span class="av-bar-n">N° 03</span>
        <span class="av-bar-line" aria-hidden="true"></span>
        <span class="av-bar-k">TEAM / N=7</span>
      </div>
      <RevealOnScroll>
        <h2 class="av-team__h">WER HINTER DEM ATELIER STEHT.</h2>
      </RevealOnScroll>

      <table class="av-team__table">
        <thead>
          <tr>
            <th>N°</th>
            <th>NAME</th>
            <th>FUNKTION</th>
            <th>SEIT</th>
          </tr>
        </thead>
        <tbody>
          {team.map((p, i) => (
            <tr class="av-team__row">
              <td class="av-team__index">{String(i + 1).padStart(2, '0')}</td>
              <td class="av-team__name">{p.name}</td>
              <td class="av-team__role">{p.role}</td>
              <td class="av-team__since">{p.since}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Manifest -->
  <section class="av-manifest av-section">
    <div class="av-container">
      <div class="av-bar">
        <span class="av-bar-n">N° 04</span>
        <span class="av-bar-line" aria-hidden="true"></span>
        <span class="av-bar-k">ZITAT / WERKSTATTGESPRAECH</span>
      </div>
      <RevealOnScroll>
        <blockquote class="av-manifest__q">
          „EIN HAUS IST NICHT DA, UM ANGESCHAUT ZU WERDEN.
          ES IST DA, UM DRIN ZU KOCHEN, ZU STREITEN, KRANK ZU SEIN
          UND ALT ZU WERDEN. ALLES ANDERE IST WERBUNG."
        </blockquote>
        <p class="av-manifest__by">— MAREIKE VOSSEN · WERKSTATTGESPRÄCH 2022</p>
      </RevealOnScroll>
    </div>
  </section>
</ArchitektLayout>

<style>
  /* Shared bar */
  .av-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    margin-bottom: 2.5rem;
  }
  .av-bar-n { color: var(--color-accent); font-weight: 700; }
  .av-bar-line { flex: 1; height: 1px; background: var(--color-rule-strong); }
  .av-bar-k { color: var(--color-muted); font-weight: 500; }

  /* Page Hero */
  .av-pg-hero {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(3rem, 6vw, 5rem);
  }
  .av-pg-hero__h {
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 10rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin: 0 0 3rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-pg-hero__line { display: block; overflow: hidden; }
  .av-pg-hero__line--alt { color: var(--color-primary); }

  .av-pg-hero__intro {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    max-width: 900px;
    margin-left: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }
  @media (min-width: 720px) {
    .av-pg-hero__intro { grid-template-columns: 1fr 1fr; }
  }
  .av-pg-hero__lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    margin: 0;
  }

  /* Values */
  .av-values {
    border-top: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-surface) 50%, transparent);
  }
  .av-values__h {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    max-width: 28ch;
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-values__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-rule-strong);
  }
  @media (min-width: 800px) {
    .av-values__list { grid-template-columns: repeat(3, 1fr); }
  }
  .av-values__item {
    background: var(--color-bg);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    border-right: 1px solid var(--color-rule-strong);
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .av-values__item:last-child { border-right: none; }
  @media (min-width: 800px) {
    .av-values__item { border-bottom: none; }
  }
  .av-values__n {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }
  .av-values__item h3 {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.8vw, 1.6rem);
    margin: 0;
    letter-spacing: -0.015em;
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-values__item p {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
  }

  /* Stats */
  .av-stats {
    background: var(--color-primary);
    color: var(--color-bg);
    padding-block: clamp(3.5rem, 6vw, 5rem);
  }
  .av-stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 1rem;
  }
  @media (min-width: 720px) {
    .av-stats__grid { grid-template-columns: repeat(4, 1fr); }
  }
  .av-stats__cell {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--color-bg) 25%, transparent);
  }
  .av-stats__num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 700;
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
  }
  .av-stats__unit {
    font-size: 0.5em;
    color: var(--color-accent);
    font-weight: 700;
  }
  .av-stats__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-bg) 65%, transparent);
  }

  /* Team */
  .av-team {
    border-top: 1px solid var(--color-rule);
  }
  .av-team__h {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-team__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
  }
  .av-team__table thead th {
    text-align: left;
    padding: 0.85rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-rule-strong);
  }
  .av-team__row {
    border-bottom: 1px solid var(--color-rule);
    transition: background-color 0.3s;
  }
  .av-team__row td {
    padding: 1.1rem 0.5rem;
    vertical-align: baseline;
  }
  .av-team__row:hover {
    background: color-mix(in srgb, var(--color-text) 5%, transparent);
  }
  .av-team__index {
    width: 3rem;
    font-size: 0.78rem;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .av-team__name {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    letter-spacing: -0.015em;
    color: var(--color-text);
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-team__role {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-text) 75%, transparent);
  }
  .av-team__since {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    font-weight: 500;
    text-align: right;
  }

  /* Manifest */
  .av-manifest {
    border-top: 1px solid var(--color-rule);
    background: var(--color-text);
    color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }
  .av-manifest::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--color-bg) 8%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-bg) 8%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
    z-index: 0;
  }
  .av-manifest .av-container { position: relative; z-index: 1; }
  .av-manifest .av-bar-line { background: color-mix(in srgb, var(--color-bg) 20%, transparent); }
  .av-manifest .av-bar-k { color: color-mix(in srgb, var(--color-bg) 65%, transparent); }
  .av-manifest__q {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4.5vw, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    max-width: 28ch;
    margin: 0 0 2rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .av-manifest__by {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin: 0;
    font-weight: 700;
  }
</style>
