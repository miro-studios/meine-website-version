{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			],
			"@components/*": [
				"src/components/*"
			],
			"@layouts/*": [
				"src/layouts/*"
			],
			"@lib/*": [
				"src/lib/*"
			],
			"@styles/*": [
				"src/styles/*"
			]
		},
		"jsx": "preserve"
	},
	"include": [
		"src/**/*",
		".astro/**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}